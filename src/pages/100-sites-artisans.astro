---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionTitle from '../components/SectionTitle.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

// 🔧 MISE À JOUR ICI : changer le nombre de sites réalisés
const sitesRealises = 0;
const sitesTotal = 100;
const progressPercent = Math.round((sitesRealises / sitesTotal) * 100);

const checkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
---

<BaseLayout
  title="100 Vitrines — Sites web gratuits pour artisans | Marc Muller"
  description="Je crée gratuitement 100 sites web professionnels pour des artisans sans présence en ligne. Création, hébergement et nom de domaine offerts la première année."
>
  <SchemaOrg type="localBusiness" />

  <!-- HERO -->
  <section class="relative w-full min-h-[70vh] flex items-center overflow-hidden bg-[#0D0D0D]">
    <!-- Animated gradient blobs -->
    <div class="absolute top-[20%] left-[15%] w-[500px] h-[500px] rounded-full bg-[var(--color-accent)] opacity-[0.08] blur-[150px] hero-blob-1"></div>
    <div class="absolute bottom-[10%] right-[10%] w-[400px] h-[400px] rounded-full bg-emerald-500 opacity-[0.06] blur-[130px] hero-blob-2"></div>

    <!-- Dot grid pattern -->
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="relative mx-auto max-w-4xl px-6 py-20 md:px-8 text-center">
      <!-- Badge -->
      <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/[0.08] px-5 py-2.5 text-sm hero-fade hero-fade-1">
        <span class="relative flex h-2.5 w-2.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-accent)] opacity-75"></span>
          <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-[var(--color-accent)]"></span>
        </span>
        <span style="color: rgba(255,255,255,0.8);">Défi en cours — {sitesTotal - sitesRealises} places disponibles</span>
      </div>

      <h1 class="mb-8 text-[2.75rem] md:text-6xl lg:text-[4.25rem] font-bold leading-[1.08] tracking-[-0.03em] text-white hero-fade hero-fade-2">
        100 Vitrines pour
        <span class="hero-accent-text">100 Artisans.</span>
      </h1>

      <p class="mb-10 text-lg md:text-xl leading-relaxed text-gray-400 max-w-2xl mx-auto hero-fade hero-fade-3">
        Vous êtes artisan et vous n'avez pas de site web ? Je vous en crée un gratuitement. Un vrai site pro, rapide, bien référencé — pas un template.
      </p>

      <div class="flex flex-col gap-4 sm:flex-row justify-center hero-fade hero-fade-4">
        <a href="#candidater" class="group inline-flex items-center justify-center rounded-xl bg-accent px-8 py-4 text-base font-semibold text-white shadow-[0_4px_20px_rgba(232,108,71,0.25)] transition-all duration-300 hover:bg-accent-hover hover:shadow-[0_8px_30px_rgba(232,108,71,0.35)] hover:-translate-y-0.5" style="background: linear-gradient(135deg, #E86C47, #D4572F);">
          Je candidate
          <svg class="ml-2 h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
        <a href="#comment-ca-marche" class="group inline-flex items-center justify-center rounded-xl border border-white/20 bg-white/5 px-8 py-4 text-base font-semibold text-white/85 transition-all duration-300 backdrop-blur-sm hover:bg-white/10 hover:border-white/30 hover:text-white">
          Comment ça marche ?
        </a>
      </div>

      <!-- Counter -->
      <div class="mt-14 hero-fade hero-fade-5">
        <div class="inline-flex flex-col items-center gap-4 rounded-2xl px-8 py-5" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
          <div class="flex items-baseline gap-3">
            <span class="text-5xl font-extrabold text-[var(--color-accent)]">{sitesRealises}</span>
            <span class="text-2xl text-gray-500 font-light">/</span>
            <span class="text-5xl font-extrabold text-white">{sitesTotal}</span>
          </div>
          <p class="text-sm text-gray-400 uppercase tracking-widest">sites réalisés</p>
          <div class="w-64 bg-white/10 rounded-full h-2.5">
            <div
              class="bg-gradient-to-r from-[var(--color-accent)] to-orange-400 h-2.5 rounded-full transition-all duration-1000"
              style={`width: ${progressPercent === 0 ? 1 : progressPercent}%;`}
            ></div>
          </div>
          <p class="text-xs text-gray-500">{sitesTotal - sitesRealises} places encore disponibles</p>
        </div>
      </div>
    </div>
  </section>

  <!-- POURQUOI CETTE INITIATIVE -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <SectionTitle title="Pourquoi je fais ça" align="center" badge="Win-Win" />
      <div class="mt-16 grid gap-8 md:grid-cols-2">
        <!-- Pour vous -->
        <div class="rounded-xl bg-white p-8 border border-[var(--color-border)] hover:shadow-lg transition-all duration-300">
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-emerald-50">
            <svg class="w-7 h-7 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="mb-4 text-xl font-bold text-[var(--color-text)]">Pour vous, artisan</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">
            Vous exercez un métier que vous maîtrisez, mais être visible en ligne, c'est un autre métier. Vous savez que vous devriez avoir un site, mais le budget, le temps, la complexité — tout ça freine.
          </p>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            Avec cette initiative, vous recevez un site web professionnel sans rien débourser. Un site qui vous ressemble, qui est trouvable sur Google, et qui vous ramène des clients.
          </p>
        </div>

        <!-- Pour moi -->
        <div class="rounded-xl bg-white p-8 border border-[var(--color-border)] hover:shadow-lg transition-all duration-300">
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-accent-light)]">
            <svg class="w-7 h-7 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
            </svg>
          </div>
          <h3 class="mb-4 text-xl font-bold text-[var(--color-text)]">Pour moi, créateur</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed mb-4">
            Je suis transparent : cette initiative me sert aussi. En créant 100 sites, j'affine mon processus de création, je gagne en rapidité, et je construis un portfolio diversifié de projets réels.
          </p>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            C'est un échange honnête. Vous apportez votre métier, vos photos, votre histoire — je les transforme en un site web qui travaille pour vous. On y gagne tous les deux.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CE QUE VOUS RECEVEZ -->
  <section class="w-full bg-white px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <SectionTitle title="Ce que vous recevez" align="center" subtitle="Exactement la même qualité que mes sites payants. Pas de version au rabais." />

      <div class="mt-16 grid gap-6 md:grid-cols-3">
        <!-- Card 1: Site -->
        <div class="rounded-xl bg-[var(--color-bg)] p-8 border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.2);">
            <svg class="w-6 h-6 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-[var(--color-text)]">Un site one page complet</h3>
          <div class="space-y-2">
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Design sur mesure à votre image</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Responsive mobile & tablette</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Formulaire de contact</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Mentions légales & RGPD</span>
            </div>
          </div>
        </div>

        <!-- Card 2: SEO -->
        <div class="rounded-xl bg-[var(--color-bg)] p-8 border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.2);">
            <svg class="w-6 h-6 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-[var(--color-text)]">Référencement SEO & GEO</h3>
          <div class="space-y-2">
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Optimisé pour Google</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Visible dans les IA (ChatGPT, etc.)</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Données structurées Schema.org</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Score Lighthouse 95+</span>
            </div>
          </div>
        </div>

        <!-- Card 3: Hébergement -->
        <div class="rounded-xl bg-[var(--color-bg)] p-8 border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-xl" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.2);">
            <svg class="w-6 h-6 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-[var(--color-text)]">Hébergement & domaine</h3>
          <div class="space-y-2">
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Hébergement Cloudflare offert</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Nom de domaine offert 1 an</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">Certificat SSL inclus</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text-muted)]">CDN mondial ultra-rapide</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Prix comparatif -->
      <div class="mt-12 text-center">
        <div class="inline-flex items-center gap-3 rounded-full px-6 py-3" style="background: rgba(232, 108, 71, 0.06); border: 1px solid rgba(232, 108, 71, 0.15);">
          <span class="text-sm text-[var(--color-text-muted)]">Valeur réelle de ce site :</span>
          <span class="text-lg font-bold text-[var(--color-text)] line-through decoration-[var(--color-accent)]">490€ HT</span>
          <span class="text-lg font-extrabold text-[var(--color-accent)]">0€</span>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMENT ÇA MARCHE -->
  <section id="comment-ca-marche" class="w-full bg-[var(--color-bg-alt)] px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <SectionTitle title="Comment ça marche" align="center" subtitle="3 étapes simples. Vous vous occupez de votre métier, je m'occupe du site." />
      <div class="mt-16 grid gap-8 md:grid-cols-3">
        <!-- Étape 1 -->
        <div class="relative text-center">
          <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-accent)] text-3xl font-bold text-white mx-auto shadow-lg">
            1
          </div>
          <h3 class="mb-4 text-lg font-bold text-[var(--color-text)]">Vous candidatez</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            Remplissez le formulaire ci-dessous. Parlez-moi de votre métier, de votre activité, de ce que vous aimeriez montrer sur votre site.
          </p>
          <p class="mt-3 text-sm font-medium text-[var(--color-accent)]">2 minutes</p>
        </div>

        <!-- Étape 2 -->
        <div class="relative text-center">
          <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-accent)] text-3xl font-bold text-white mx-auto shadow-lg">
            2
          </div>
          <h3 class="mb-4 text-lg font-bold text-[var(--color-text)]">On échange</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            Je vous recontacte rapidement. On fait un point rapide par téléphone ou visio pour que je comprenne bien votre activité et vos besoins.
          </p>
          <p class="mt-3 text-sm font-medium text-[var(--color-accent)]">15-30 minutes</p>
        </div>

        <!-- Étape 3 -->
        <div class="relative text-center">
          <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-[var(--color-accent)] text-3xl font-bold text-white mx-auto shadow-lg">
            3
          </div>
          <h3 class="mb-4 text-lg font-bold text-[var(--color-text)]">Votre site est en ligne</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            Je crée votre site, vous validez, et il est publié. Vous commencez à recevoir des appels et des demandes de devis.
          </p>
          <p class="mt-3 text-sm font-medium text-[var(--color-accent)]">5-7 jours</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="w-full bg-white px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-3xl">
      <SectionTitle title="Questions fréquentes" align="center" />

      <div class="mt-12 space-y-3">
        <details class="group rounded-xl bg-[var(--color-bg)] p-6 border border-[var(--color-border)] hover:shadow-sm transition-all" open>
          <summary class="flex cursor-pointer items-center justify-between gap-3 font-bold text-[var(--color-text)]">
            <span>C'est vraiment gratuit ? Où est le piège ?</span>
            <svg class="h-5 w-5 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            Pas de piège. La création du site est gratuite. L'hébergement est gratuit (Cloudflare). Le nom de domaine est offert la première année. Au bout d'un an, vous ne payez que le renouvellement du domaine — environ 10-15€/an pour un .fr. C'est tout. Pas d'abonnement caché, pas de frais de maintenance obligatoire.
          </p>
        </details>

        <details class="group rounded-xl bg-[var(--color-bg)] p-6 border border-[var(--color-border)] hover:shadow-sm transition-all">
          <summary class="flex cursor-pointer items-center justify-between gap-3 font-bold text-[var(--color-text)]">
            <span>Pourquoi vous faites ça gratuitement ?</span>
            <svg class="h-5 w-5 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            C'est un échange gagnant-gagnant, et je suis transparent là-dessus. En créant 100 sites pour des artisans, j'améliore mon processus de création, je construis un portfolio diversifié, et j'aide des professionnels qui le méritent à être visibles en ligne. Vous y gagnez un site pro, j'y gagne en expérience et en vitesse.
          </p>
        </details>

        <details class="group rounded-xl bg-[var(--color-bg)] p-6 border border-[var(--color-border)] hover:shadow-sm transition-all">
          <summary class="flex cursor-pointer items-center justify-between gap-3 font-bold text-[var(--color-text)]">
            <span>C'est un template ou un vrai site sur mesure ?</span>
            <svg class="h-5 w-5 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            Un vrai site sur mesure. Couleurs, textes, photos, structure — tout est adapté à votre activité. C'est exactement le même site que je vends habituellement à 490€. La seule différence, c'est le prix.
          </p>
        </details>

        <details class="group rounded-xl bg-[var(--color-bg)] p-6 border border-[var(--color-border)] hover:shadow-sm transition-all">
          <summary class="flex cursor-pointer items-center justify-between gap-3 font-bold text-[var(--color-text)]">
            <span>Qui peut candidater ?</span>
            <svg class="h-5 w-5 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            Tout artisan ou professionnel indépendant en France qui n'a pas encore de site web (ou dont le site actuel est vraiment obsolète). Plombier, coiffeur, boulanger, menuisier, photographe, coach sportif — tous les métiers sont bienvenus. La seule condition : exercer réellement votre activité.
          </p>
        </details>

        <details class="group rounded-xl bg-[var(--color-bg)] p-6 border border-[var(--color-border)] hover:shadow-sm transition-all">
          <summary class="flex cursor-pointer items-center justify-between gap-3 font-bold text-[var(--color-text)]">
            <span>Qu'est-ce que je dois fournir ?</span>
            <svg class="h-5 w-5 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            Votre temps pour un appel de 15-30 minutes, des photos de votre travail (même prises au téléphone), votre logo si vous en avez un, et les informations de base sur votre activité (services, zone géographique, coordonnées). Je m'occupe du reste : rédaction des textes, design, développement, mise en ligne.
          </p>
        </details>

        <details class="group rounded-xl bg-[var(--color-bg)] p-6 border border-[var(--color-border)] hover:shadow-sm transition-all">
          <summary class="flex cursor-pointer items-center justify-between gap-3 font-bold text-[var(--color-text)]">
            <span>Et après la première année ?</span>
            <svg class="h-5 w-5 transition-transform group-open:rotate-180 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </summary>
          <p class="mt-4 text-[var(--color-text-muted)]">
            L'hébergement reste gratuit (Cloudflare est gratuit par nature pour les sites statiques). Le seul coût sera le renouvellement de votre nom de domaine — environ 10-15€/an pour un .fr. Si vous souhaitez des modifications ou une évolution du site, on en discutera à ce moment-là, mais rien d'obligatoire.
          </p>
        </details>

        <details class="group rounded-xl bg-[var(--color-bg)] p-6 border border-[var(--color-border)] hover:shadow-sm transition-all">
          <summary class="flex cursor-pointer items-center justify-between gap-3 font-bold text-[var(--color-text)]">
            <span>Le site m'appartient ?</span>
