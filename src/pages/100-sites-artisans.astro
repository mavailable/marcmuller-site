---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

// 🔧 MISE À JOUR ICI : changer le nombre de sites réalisés
const sitesRealises = 5;
const sitesTotal = 100;
const progressPercent = Math.round((sitesRealises / sitesTotal) * 100);
---

<BaseLayout
  title="100 Vitrines — Sites web gratuits pour artisans | Marc Muller"
  description="Je crée gratuitement 100 sites web professionnels pour des artisans sans présence en ligne. Création, hébergement et nom de domaine offerts la première année."
  noHeader={true}
>
  <SchemaOrg type="localBusiness" />

  <!-- ═══════════════════════════════════════
       HERO — Dark, centré, compteur scoreboard
       ═══════════════════════════════════════ -->
  <section class="relative w-full min-h-[80vh] flex items-center justify-center overflow-hidden bg-[#0A0A0A]">
    <!-- Gradient ambient -->
    <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(232,108,71,0.10) 0%, transparent 70%);"></div>
    <!-- Subtle grid -->
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: linear-gradient(rgba(255,255,255,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.3) 1px, transparent 1px); background-size: 64px 64px;"></div>

    <div class="relative mx-auto max-w-3xl px-6 py-24 text-center">

      <!-- Pill badge -->
      <div class="mb-10 inline-flex items-center gap-2.5 rounded-full px-4 py-1.5 text-xs font-medium tracking-widest uppercase hero-fade hero-fade-1" style="background: rgba(232,108,71,0.08); border: 1px solid rgba(232,108,71,0.2); color: #E86C47;">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute h-full w-full animate-ping rounded-full opacity-60" style="background:#E86C47;"></span>
          <span class="relative h-1.5 w-1.5 rounded-full" style="background:#E86C47;"></span>
        </span>
        Initiative en cours · {sitesTotal - sitesRealises} places disponibles
      </div>

      <!-- Titre -->
      <h1 class="mb-6 font-bold leading-none tracking-tight text-white hero-fade hero-fade-2" style="font-size: clamp(2.8rem, 8vw, 5.5rem); letter-spacing: -0.04em;">
        100&nbsp;Vitrines<br/>
        <span class="hero-accent">pour 100 Artisans</span>
      </h1>

      <p class="mb-10 text-lg leading-relaxed hero-fade hero-fade-3" style="color: rgba(255,255,255,0.5); max-width: 34rem; margin-left: auto; margin-right: auto;">
        Vous exercez un métier. Moi, je construis des sites. Vous n'avez pas de site — je vous en offre un. Vrai. Pro. Gratuit.
      </p>

      <!-- CTA -->
      <div class="flex flex-col sm:flex-row gap-3 justify-center hero-fade hero-fade-4">
        <a href="#candidater" class="inline-flex items-center justify-center gap-2 rounded-lg px-8 py-3.5 text-sm font-semibold text-white transition-all hover:-translate-y-0.5" style="background: #E86C47; box-shadow: 0 0 30px rgba(232,108,71,0.3);">
          Je candidate
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="#comment-ca-marche" class="inline-flex items-center justify-center gap-2 rounded-lg px-8 py-3.5 text-sm font-medium transition-all" style="color: rgba(255,255,255,0.5); border: 1px solid rgba(255,255,255,0.1);">
          Comment ça marche ?
        </a>
      </div>

      <!-- Scoreboard compteur -->
      <div class="mt-14 hero-fade hero-fade-5">
        <div class="inline-block">
          <!-- Scoreboard card -->
          <div class="scoreboard rounded-2xl px-10 py-6" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07);">
            <div class="flex items-end justify-center gap-2 mb-3">
              <!-- Sites réalisés -->
              <div class="text-center">
                <div class="score-number font-extrabold tabular-nums" style="font-size:4rem; line-height:1; color: #E86C47;">{sitesRealises}</div>
                <div class="text-xs mt-1" style="color:rgba(255,255,255,0.3); letter-spacing:0.12em;">RÉALISÉS</div>
              </div>
              <div class="text-4xl font-light mb-4" style="color:rgba(255,255,255,0.15);">/</div>
              <!-- Total -->
              <div class="text-center">
                <div class="font-extrabold tabular-nums" style="font-size:4rem; line-height:1; color:rgba(255,255,255,0.15);">{sitesTotal}</div>
                <div class="text-xs mt-1" style="color:rgba(255,255,255,0.2); letter-spacing:0.12em;">OBJECTIF</div>
              </div>
            </div>
            <!-- Progress track -->
            <div class="mt-2 w-full rounded-full overflow-hidden" style="height:3px; background:rgba(255,255,255,0.07);">
              <div class="h-full rounded-full transition-all duration-1000" style={`width:${progressPercent === 0 ? 0.5 : progressPercent}%; background: linear-gradient(90deg,#E86C47,#FF8A65);`}></div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════
       WIN-WIN — Deux panneaux pleine-largeur
       ═══════════════════════════════════════ -->
  <section class="w-full grid md:grid-cols-2">

    <!-- Panneau gauche : Pour l'artisan -->
    <div class="px-10 py-16 md:py-20 lg:px-16 flex flex-col justify-center" style="background:#111111;">
      <span class="text-xs font-semibold uppercase tracking-widest mb-6" style="color:#E86C47;">Pour vous, artisan</span>
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-3 leading-snug" style="letter-spacing:-0.02em;">
        Vous exercez votre métier.<br/>Moi, je vous rends visible.
      </h2>
      <p class="text-sm mb-8" style="color:rgba(255,255,255,0.35);">
        Sans site, vos futurs clients ne vous trouvent pas — et vont chez quelqu'un d'autre.
      </p>

      <div class="space-y-5">
        <div class="flex items-start gap-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(232,108,71,0.12);">
            <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-white mb-0.5">Création 100% gratuite</p>
            <p class="text-sm" style="color:rgba(255,255,255,0.4);">Design sur mesure, textes rédigés, mise en ligne incluse.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(232,108,71,0.12);">
            <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-white mb-0.5">Hébergement gratuit à vie</p>
            <p class="text-sm" style="color:rgba(255,255,255,0.4);">Sur Cloudflare — rapide, fiable, sans abonnement mensuel.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(232,108,71,0.12);">
            <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-white mb-0.5">Domaine offert la 1ère année</p>
            <p class="text-sm" style="color:rgba(255,255,255,0.4);">Votre <span style="color:rgba(255,255,255,0.6);">votre-metier.fr</span> à votre nom. Ensuite ~10€/an, c'est tout.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:rgba(232,108,71,0.12);">
            <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-white mb-0.5">Visible sur Google dès le départ</p>
            <p class="text-sm" style="color:rgba(255,255,255,0.4);">SEO technique intégré — vos clients vous trouvent localement.</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Panneau droit : Pour Marc -->
    <div class="px-10 py-16 md:py-20 lg:px-16 flex flex-col justify-center relative" style="background:#F7F5F2; border-left:1px solid #E8E4E0;">
      <span class="text-xs font-semibold uppercase tracking-widest mb-6" style="color:#999;">Pour moi, créateur</span>
      <h2 class="text-2xl md:text-3xl font-bold mb-3 leading-snug" style="color:#1A1A1A; letter-spacing:-0.02em;">
        Je suis honnête —<br/>cette initiative me sert aussi.
      </h2>
      <p class="text-sm mb-8" style="color:#AAA;">
        Ce n'est pas de la charité. C'est un échange gagnant-gagnant, et j'y tiens à la transparence.
      </p>

      <div class="space-y-5">
        <div class="flex items-start gap-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:#EDEBE8;">
            <svg class="w-4 h-4" style="color:#888;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold mb-0.5" style="color:#1A1A1A;">J'affine mon processus</p>
            <p class="text-sm" style="color:#888;">100 sites = 100 occasions de tester, d'améliorer, d'aller plus vite.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:#EDEBE8;">
            <svg class="w-4 h-4" style="color:#888;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold mb-0.5" style="color:#1A1A1A;">Je construis un portfolio réel</p>
            <p class="text-sm" style="color:#888;">Chaque métier est différent — c'est du vrai travail, pas des projets fictifs.</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 mt-0.5" style="background:#EDEBE8;">
            <svg class="w-4 h-4" style="color:#888;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold mb-0.5" style="color:#1A1A1A;">Je rencontre de vrais artisans</p>
            <p class="text-sm" style="color:#888;">Des gens qui font, qui créent — j'aime ça, et ça nourrit mon travail.</p>
          </div>
        </div>
      </div>

      <div class="mt-10 pt-6 flex items-center gap-3" style="border-top:1px solid #E8E4E0;">
        <div class="w-8 h-8 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0" style="background:#E86C47;">M</div>
        <div>
          <p class="text-sm font-semibold" style="color:#1A1A1A;">Marc Muller</p>
          <p class="text-xs" style="color:#AAA;">Créateur de sites web indépendant</p>
        </div>
      </div>
    </div>

  </section>

  <!-- ═══════════════════════════════════════
       CE QUE VOUS RECEVEZ — Style spec sheet
       ═══════════════════════════════════════ -->
  <section class="w-full bg-white px-6 py-20 md:px-8 md:py-28">
    <div class="mx-auto max-w-4xl">

      <div class="mb-12">
        <p class="text-xs uppercase tracking-widest font-semibold mb-3" style="color:#E86C47;">Livraison</p>
        <h2 class="text-3xl md:text-4xl font-bold" style="color:#1A1A1A; letter-spacing:-0.02em;">Ce que je m'engage à livrer.</h2>
        <p class="mt-3 text-base" style="color:#888;">Exactement la même qualité que mes sites à 490€. Pas de version au rabais.</p>
      </div>

      <!-- Spec table -->
      <div class="rounded-2xl overflow-hidden" style="border: 1px solid #E8E4E0;">

        <!-- Header -->
        <div class="grid grid-cols-12 px-6 py-3 text-xs uppercase font-semibold tracking-widest" style="background:#F7F5F2; color:#999; border-bottom:1px solid #E8E4E0;">
          <span class="col-span-5">Livrable</span>
          <span class="col-span-5 hidden md:block">Détails</span>
          <span class="col-span-7 md:col-span-2 text-right">Inclus</span>
        </div>

        <!-- Row 1 -->
        <div class="grid grid-cols-12 items-center px-6 py-5" style="border-bottom:1px solid #F0EDEA;">
          <div class="col-span-5">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(232,108,71,0.08);">
                <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <span class="font-semibold text-sm" style="color:#1A1A1A;">Site one page</span>
            </div>
          </div>
          <div class="col-span-5 hidden md:block">
            <p class="text-sm" style="color:#888;">Design sur mesure, responsive mobile, formulaire contact, mentions légales</p>
          </div>
          <div class="col-span-7 md:col-span-2 flex justify-end">
            <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold" style="background:#ECFDF5; color:#059669;">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Inclus
            </span>
          </div>
        </div>

        <!-- Row 2 -->
        <div class="grid grid-cols-12 items-center px-6 py-5" style="border-bottom:1px solid #F0EDEA;">
          <div class="col-span-5">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(232,108,71,0.08);">
                <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
              </div>
              <span class="font-semibold text-sm" style="color:#1A1A1A;">SEO & GEO</span>
            </div>
          </div>
          <div class="col-span-5 hidden md:block">
            <p class="text-sm" style="color:#888;">Optimisé Google + IA (ChatGPT, etc.), Schema.org, balises meta, score Lighthouse 95+</p>
          </div>
          <div class="col-span-7 md:col-span-2 flex justify-end">
            <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold" style="background:#ECFDF5; color:#059669;">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Inclus
            </span>
          </div>
        </div>

        <!-- Row 3 -->
        <div class="grid grid-cols-12 items-center px-6 py-5" style="border-bottom:1px solid #F0EDEA;">
          <div class="col-span-5">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(232,108,71,0.08);">
                <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>
              </div>
              <span class="font-semibold text-sm" style="color:#1A1A1A;">Hébergement</span>
            </div>
          </div>
          <div class="col-span-5 hidden md:block">
            <p class="text-sm" style="color:#888;">Cloudflare Pages — CDN mondial, SSL, ultra-rapide — <span class="font-semibold">gratuit à vie</span></p>
          </div>
          <div class="col-span-7 md:col-span-2 flex justify-end">
            <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold" style="background:#ECFDF5; color:#059669;">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              Inclus
            </span>
          </div>
        </div>

        <!-- Row 4 -->
        <div class="grid grid-cols-12 items-center px-6 py-5" style="border-bottom:1px solid #F0EDEA;">
          <div class="col-span-5">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(232,108,71,0.08);">
                <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
              </div>
              <span class="font-semibold text-sm" style="color:#1A1A1A;">Nom de domaine</span>
            </div>
          </div>
          <div class="col-span-5 hidden md:block">
            <p class="text-sm" style="color:#888;">Votre <span class="font-medium">votre-metier.fr</span> — offert la 1ère année, puis ~10€/an (coût réel)</p>
          </div>
          <div class="col-span-7 md:col-span-2 flex justify-end">
            <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold" style="background:#FFF7ED; color:#EA580C;">
              An 1 gratuit
            </span>
          </div>
        </div>

        <!-- Row 5 -->
        <div class="grid grid-cols-12 items-center px-6 py-5" style="border-bottom:1px solid #F0EDEA;">
          <div class="col-span-5">
            <div class="flex items-center gap-3">
              <div class="w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0" style="background:rgba(232,108,71,0.08);">
                <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </div>
              <span class="font-semibold text-sm" style="color:#1A1A1A;">Rédaction & contenu</span>
            </div>
          </div>
          <div class="col-span-5 hidden md:block">
            <p class="text-sm" style="color:#888;">Textes rédigés par moi à partir de notre échange — vous relisez et validez</p>
          </div>
          <div class="col-span-7 md:col-span-2 flex justify-end">
            <span class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-xs font-semibold" style="background:#ECFDF5; color:#059669;">
