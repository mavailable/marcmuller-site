  {
    id: 'occivolt',
    title: "Occi'Volt",
    sector: 'Artisanat',
    sectorColor: 'border-yellow-400/30 bg-yellow-400/10 text-yellow-400',
    type: 'Site vitrine',
    offer: 'Multi-pages',
    description: 'Électricien indépendant à Castelnaudary et dans tout le Lauragais. Un site pensé pour le SEO local avec galerie de réalisations, avis Google intégrés et demande de devis — pour un artisan qui veut des chantiers sans prospecter.',
    url: 'https://occivolt.pages.dev/',
    gradient: 'from-[#1A1A1A] to-[#D4A017]',
    screenshot: '/images/projects/occivolt.webp',
    features: ['Galerie réalisations', 'Avis Google intégrés', 'Demande de devis', 'SEO local', 'FAQ', 'Appel direct'],
    stack: ['Astro', 'Tailwind', 'Cloudflare'],
    highlights: [
      { label: 'Lighthouse', value: '100' },
      { label: 'Livré en', value: '5 jours' },
      { label: 'Coût hébergement', value: '0€/mois' },
    ],
  },
  {
    id: 'roma-laudarium',
    title: 'Roma Laudarium',
    sector: 'Art & Culture',
    sectorColor: 'border-emerald-400/30 bg-emerald-400/10 text-emerald-400',
    type: 'Site vitrine',
    offer: 'Essentiel',
    description: 'Écrivaine, conteuse et metteuse en scène. Le site présente son spectacle de contes pour jeune public, son univers poétique et permet aux programmateurs de salles et écoles de la contacter — pour une artiste qui tournait sans vitrine web.',
    url: 'https://roma-laudarium.pages.dev/',
    gradient: 'from-[#1B3A2A] to-[#C9942A]',
    screenshot: '/images/projects/roma-laudarium.webp',
    features: ['Présentation spectacle', 'Univers artistique', 'Contact programmateurs', 'Design poétique', 'SEO local', 'Conforme RGPD'],
    stack: ['Astro', 'Tailwind', 'Cloudflare'],
    highlights: [
      { label: 'Lighthouse', value: '100' },
