    highlights: [
      { label: 'Lighthouse', value: '100' },
      { label: 'Paiement', value: 'Stripe' },
      { label: 'Coût hébergement', value: '0€/mois' },
    ],
  },
  {
    id: 'pacor-piano',
    title: "P'Accord Piano",
    sector: 'Artisanat',
    sectorColor: 'border-yellow-400/30 bg-yellow-400/10 text-yellow-400',
    type: 'Site vitrine',
    offer: 'Multi-pages',
    description: 'Accordeur de piano indépendant à Chartres. Le site génère des demandes grâce à un calculateur de tarif géolocalisé et un design soigné qui inspire confiance dès la première visite.',
    url: 'https://pacor-piano.vercel.app/',
