    url: 'https://mm-securite.fr',
    gradient: 'from-[#2D5A7B] to-[#4A7C9E]',
    screenshot: '/images/projects/mm-securite.webp',
    features: ['SEO local avancé', 'Demande de devis', 'Conformité ERP', 'Pages services', 'Blog', 'FAQ'],
    stack: ['Astro', 'Tailwind', 'Cloudflare'],
    highlights: [
      { label: 'Lighthouse', value: '100' },
      { label: 'Cible', value: 'Commerces' },
