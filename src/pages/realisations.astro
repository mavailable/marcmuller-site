---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Réalisations — MM Agency';
const description = 'Découvrez les sites web que j\'ai créés pour mes clients. Design sur mesure, performance maximale et SEO local au rendez-vous.';

interface Project {
  id: string;
  title: string;
  sector: string;
  sectorColor: string;
  type: string;
  offer: 'Essentiel' | 'Multi-pages' | 'Sur mesure';
  description: string;
  url: string;
  gradient: string;
  screenshot: string;
  features: string[];
  stack: string[];
  highlights: { label: string; value: string }[];
}

const offerColors: Record<string, { bg: string; text: string; border: string }> = {
  'Essentiel': { bg: 'bg-blue-500/10', text: 'text-blue-500', border: 'border-blue-500/20' },
  'Multi-pages': { bg: 'bg-[var(--color-accent)]/10', text: 'text-[var(--color-accent)]', border: 'border-[var(--color-accent)]/20' },
  'Sur mesure': { bg: 'bg-purple-500/10', text: 'text-purple-500', border: 'border-purple-500/20' },
};

const offers = ['Essentiel', 'Multi-pages', 'Sur mesure'] as const;

const projects: Project[] = [
  {
    id: 'la-grange-aux-fees',
    title: 'La Grange aux Fées',
    sector: 'Tourisme',
    sectorColor: 'border-amber-400/30 bg-amber-400/10 text-amber-400',
    type: 'Site de réservation',
    offer: 'Sur mesure',
    description: 'Complexe de 6 gîtes de charme à Amnéville-les-Thermes. Le site permet aux visiteurs de choisir leur gîte via un sélecteur visuel, consulter les avis Airbnb et réserver directement — sans passer par une plateforme.',
    url: 'https://dev.la-grange-aux-fees.pages.dev/',
    gradient: 'from-[#C97152] to-[#E8A87C]',
    screenshot: '/images/projects/la-grange-aux-fees.webp',
    features: ['Réservation directe', 'Sélecteur de gîtes', 'Avis Airbnb intégrés', 'Galerie immersive', 'SEO local', 'Contact WhatsApp'],
    stack: ['Astro', 'Tailwind', 'Cloudflare'],
    highlights: [
      { label: 'Lighthouse', value: '100' },
      { label: 'Livré en', value: '5 jours' },
      { label: 'Coût hébergement', value: '0€/mois' },
    ],
  },
  {
    id: 'vergers-galine',
    title: 'Les Vergers de la Galine',
    sector: 'Agriculture',
    sectorColor: 'border-lime-400/30 bg-lime-400/10 text-lime-400',
    type: 'Site e-commerce',
