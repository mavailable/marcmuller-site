    ],
  },
  {
    id: 'kor',
    title: 'Kor',
    sector: 'SaaS',
    sectorColor: 'border-purple-400/30 bg-purple-400/10 text-purple-400',
    type: 'Landing page',
    offer: 'Essentiel',
    description: 'Copilote business IA pour entrepreneurs. Une landing page dark mode avec animations fluides, présentation des intégrations et formulaire d\'inscription à la bêta — conçue pour convertir les early adopters.',
    url: 'https://kor-landing.pages.dev/',
    gradient: 'from-[#6B5B95] to-[#A78BFA]',
    screenshot: '/images/projects/kor.webp',
    features: ['Design dark mode', 'Animations au scroll', 'Inscription bêta', 'Présentation produit', '10+ intégrations', 'Conforme RGPD'],
