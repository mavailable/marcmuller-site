    url: 'https://main.site-levain-kohtao.pages.dev/',
    gradient: 'from-[#1B2F33] to-[#C97152]',
    screenshot: '/images/projects/levain-kohtao.webp',
    features: ['Design immersif', 'Menu interactif', 'Carte & itinéraire', 'Contact WhatsApp', 'SEO local', 'FAQ'],
