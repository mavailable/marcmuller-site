---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getClientProjects, getSampleProjects, type Project } from '../data/projects';

const title = 'Réalisations — Marc M';
const description = 'Découvrez les sites web que j\'ai créés pour mes clients. Design sur mesure, performance maximale et SEO local au rendez-vous.';

const clientProjects = getClientProjects();
const sampleProjects = getSampleProjects();
const totalProjects = clientProjects.length + sampleProjects.length;
---

<BaseLayout title={title} description={description} ogImage="/og-realisations.png" lang="fr" frPath="/realisations" enPath="/en/portfolio">
  <!-- HERO — compact, stats intégrées -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-10 md:px-8 md:py-14 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative mx-auto max-w-6xl z-10">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <!-- Left: title -->
        <div>
          <h1 class="text-3xl font-bold text-white md:text-4xl">Mes réalisations</h1>
          <p class="mt-2 text-neutral-400 text-sm max-w-lg">Sites sur mesure, Astro + Tailwind. Rapide, bien référencé, pensé pour convertir.</p>
        </div>
        <!-- Right: mini stats -->
        <div class="flex items-center gap-5 md:gap-6">
          <div class="text-center">
            <p class="text-xl font-bold text-white">{totalProjects}</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">Projets</p>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div class="text-center">
            <p class="text-xl font-bold text-white">100</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">Score vitesse</p>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div class="text-center">
            <p class="text-xl font-bold text-[var(--color-accent)]">0€</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">/mois</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJETS CLIENTS -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-12 md:px-8 md:py-16">
    <div class="mx-auto max-w-6xl">
      <div class="mb-10 flex items-center gap-3">
        <h2 class="text-2xl font-bold text-[var(--color-text)]">Projets clients</h2>
        <span class="inline-flex items-center justify-center rounded-full bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-semibold text-[var(--color-accent)]">
          {clientProjects.length}
        </span>
      </div>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {clientProjects.map((project) => (
          <article class="group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            {/* Screenshot */}
            <div class="relative overflow-hidden">
              <div class="aspect-video overflow-hidden bg-neutral-100">
                <img
                  src={project.screenshot}
                  alt={`Capture d'écran de ${project.title}`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              {/* Sector badge overlay */}
              <span class={`absolute top-3 left-3 inline-block rounded-full border px-3 py-1 text-xs font-semibold backdrop-blur-sm ${project.sectorColor}`}>
                {project.sector}
              </span>
              {/* WIP badge */}
              {project.wip && (
                <span class="absolute top-3 right-3 inline-block rounded-full border border-amber-500/30 bg-amber-500/20 px-3 py-1 text-xs font-semibold text-amber-200 backdrop-blur-sm">
                  En cours
                </span>
              )}
            </div>

            {/* Content */}
            <div class="flex flex-1 flex-col p-5">
              <h3 class="mb-2 text-lg font-bold text-[var(--color-text)]">{project.title}</h3>
              <p class="mb-4 line-clamp-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
                {project.description}
              </p>

              {/* Features pills */}
              <div class="mb-5 flex flex-wrap gap-1.5">
                {project.features.slice(0, 4).map((f) => (
                  <span class="rounded-md bg-[var(--color-bg-alt)] px-2 py-0.5 text-[11px] font-medium text-[var(--color-text)]">
                    {f}
                  </span>
                ))}
              </div>

              {/* Review */}
              {'review' in project && project.review && (
                <div class="mb-5 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-3">
                  <div class="mb-1.5 flex items-center gap-2">
                    <div class="flex gap-0.5">
                      {[1,2,3,4,5].map(() => (
                        <svg class="h-3 w-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                      ))}
                    </div>
                    <span class="text-xs font-semibold text-[var(--color-text)]">{project.review.author}</span>
                  </div>
                  <p class="text-xs italic leading-relaxed text-[var(--color-text-muted)]">
                    "{project.review.text.slice(0, 100)}..."
                  </p>
                </div>
              )}

              {/* Spacer to push CTA to bottom */}
              <div class="mt-auto">
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex w-full items-center justify-center gap-2 rounded-xl bg-[var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-lg"
                  style="box-shadow: 0 4px 15px rgba(232, 108, 71, 0.2);"
                  data-umami-event={`portfolio-visit-${project.id}`}
                >
                  Voir le site
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- EXEMPLES PAR SECTEUR -->
  <section class="w-full border-t border-[var(--color-border)] bg-[var(--color-bg-alt)] px-6 py-12 md:px-8 md:py-16">
    <div class="mx-auto max-w-6xl">
      <div class="mb-3">
        <h2 class="text-2xl font-bold text-[var(--color-text)]">Exemples de ce que je peux créer pour votre secteur</h2>
      </div>
      <p class="mb-10 max-w-2xl text-sm text-[var(--color-text-muted)]">
        20 sites de démonstration couvrant des secteurs variés. Chacun est un site fonctionnel, avec un design adapté au métier.
      </p>

      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sampleProjects.map((project) => (
          <article class="group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--color-border)] bg-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:shadow-xl">
            {/* Screenshot */}
            <div class="relative overflow-hidden">
              <div class="aspect-video overflow-hidden bg-neutral-100">
                <img
                  src={project.screenshot}
                  alt={`Capture d'écran de ${project.title}`}
                  class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </div>
              {/* Sector badge overlay */}
              <span class={`absolute top-3 left-3 inline-block rounded-full border px-3 py-1 text-xs font-semibold backdrop-blur-sm ${project.sectorColor}`}>
                {project.sector}
              </span>
              {/* Exemple badge */}
              <span class="absolute top-3 right-3 inline-block rounded-full border border-emerald-400/30 bg-emerald-500/20 px-3 py-1 text-xs font-semibold text-emerald-300 backdrop-blur-sm">
                Exemple
              </span>
            </div>

            {/* Content */}
            <div class="flex flex-1 flex-col p-5">
              <h3 class="mb-2 text-lg font-bold text-[var(--color-text)]">{project.title}</h3>
              <p class="mb-4 line-clamp-2 text-sm leading-relaxed text-[var(--color-text-muted)]">
                {project.description}
              </p>

              {/* Features pills */}
              <div class="mb-5 flex flex-wrap gap-1.5">
                {project.features.slice(0, 4).map((f) => (
                  <span class="rounded-md bg-[var(--color-bg-alt)] px-2 py-0.5 text-[11px] font-medium text-[var(--color-text)]">
                    {f}
                  </span>
                ))}
              </div>

              {/* Spacer to push CTA to bottom */}
              <div class="mt-auto">
                <a
                  href={project.url}
                  class="inline-flex w-full items-center justify-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-2.5 text-sm font-medium text-[var(--color-text-muted)] transition-all hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                  data-umami-event={`portfolio-visit-${project.id}`}
                >
                  Voir le site
                  <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TECH SECTION -->
  <section class="w-full border-t border-[var(--color-border)] bg-white px-6 py-16 md:px-8 md:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-[var(--color-text)]">La stack derrière chaque projet</h2>
      <p class="mb-10 text-[var(--color-text-muted)]">Pas de WordPress, pas de templates. Du code custom, optimisé, déployé sur le edge.</p>
      <div class="flex flex-wrap items-center justify-center gap-6">
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Astro</span>
          <span class="text-xs text-[var(--color-text-muted)]">Framework</span>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Tailwind</span>
          <span class="text-xs text-[var(--color-text-muted)]">CSS</span>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Cloudflare</span>
          <span class="text-xs text-[var(--color-text-muted)]">Hosting</span>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Stripe</span>
          <span class="text-xs text-[var(--color-text-muted)]">Paiement</span>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Web3Forms</span>
          <span class="text-xs text-[var(--color-text-muted)]">Formulaires</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-gradient-to-b from-[#1A1A1A] to-[#111111] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-white">Votre projet mérite la même attention</h2>
      <p class="mb-8 text-neutral-300">
        Site Vitrine à 490€, Projets Sur Mesure sur devis. Livré en 7 jours.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/commander"
          class="inline-block rounded-xl bg-white px-8 py-3 font-semibold text-[var(--color-accent)] transition-all hover:bg-neutral-100 hover:shadow-xl"
          style="box-shadow: 0 10px 25px rgba(255, 255, 255, 0.1);"
          data-umami-event="realisations-cta-commander"
        >
          Commander — 490€
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 py-3 font-medium text-white/85 transition-all hover:bg-white/10"
        >
          Projet sur mesure ? Parlons-en
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
