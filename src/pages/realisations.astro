---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getProjectsForCarousel, type Project } from '../data/projects';

const title = 'Réalisations — Marc M';
const description = 'Découvrez les sites web que j\'ai créés pour mes clients. Design sur mesure, performance maximale et SEO local au rendez-vous.';

const offerColors: Record<string, { bg: string; text: string; border: string }> = {
  'Essentiel': { bg: 'bg-blue-500/10', text: 'text-blue-500', border: 'border-blue-500/20' },
  'Multi-pages': { bg: 'bg-[var(--color-accent)]/10', text: 'text-[var(--color-accent)]', border: 'border-[var(--color-accent)]/20' },
  'Sur mesure': { bg: 'bg-purple-500/10', text: 'text-purple-500', border: 'border-purple-500/20' },
};

const offers = ['Essentiel', 'Multi-pages', 'Sur mesure'] as const;

const visibleProjects = getProjectsForCarousel('realisations');
const sectors = [...new Set(visibleProjects.map(p => p.sector))];
const types = [...new Set(visibleProjects.map(p => p.type))];
---

<BaseLayout title={title} description={description} ogImage="/og-realisations.png" lang="fr" frPath="/realisations" enPath="/en/portfolio">
  <!-- HERO — compact, stats intégrées -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-10 md:px-8 md:py-14 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative mx-auto max-w-5xl z-10">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <!-- Left: title -->
        <div>
          <h1 class="text-3xl font-bold text-white md:text-4xl">Mes réalisations</h1>
          <p class="mt-2 text-neutral-400 text-sm max-w-lg">Sites sur mesure, Astro + Tailwind. Rapide, bien référencé, pensé pour convertir.</p>
        </div>
        <!-- Right: mini stats -->
        <div class="flex items-center gap-5 md:gap-6">
          <div class="text-center">
            <p class="text-xl font-bold text-white">{visibleProjects.length}</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">Projets</p>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div class="text-center">
            <p class="text-xl font-bold text-white">100</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">Lighthouse</p>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div class="text-center">
            <p class="text-xl font-bold text-[var(--color-accent)]">0€</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">/mois</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-8 md:px-8 md:py-12">
    <div class="mx-auto max-w-5xl">

      <!-- FILTER BAR -->
      <div class="mb-8 space-y-3" id="filter-bar">
        <!-- Row 1: Offre -->
        <div class="flex flex-wrap items-center justify-center gap-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mr-2">Offre</span>
          <button data-filter-type="offer" data-filter-value="all" class="filter-btn filter-btn--active px-4 py-1.5 rounded-full text-xs font-medium transition-all duration-200 cursor-pointer bg-[var(--color-text)] text-white shadow-sm">
            Toutes <span class="ml-1 opacity-60">{visibleProjects.length}</span>
          </button>
          {offers.map((offer) => (
            <button data-filter-type="offer" data-filter-value={offer} class="filter-btn px-4 py-1.5 rounded-full text-xs font-medium transition-all duration-200 cursor-pointer bg-white text-[var(--color-text-muted)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/40 hover:text-[var(--color-text)]">
              {offer} <span class="ml-1 opacity-60">{visibleProjects.filter(p => p.offer === offer).length}</span>
            </button>
          ))}
        </div>
        <!-- Row 2: Secteur -->
        <div class="flex flex-wrap items-center justify-center gap-2">
          <span class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mr-2">Secteur</span>
          <button data-filter-type="sector" data-filter-value="all" class="filter-btn filter-btn--active px-4 py-1.5 rounded-full text-xs font-medium transition-all duration-200 cursor-pointer bg-[var(--color-text)] text-white shadow-sm">
            Tous
          </button>
          {sectors.map((sector) => (
            <button data-filter-type="sector" data-filter-value={sector} class="filter-btn px-4 py-1.5 rounded-full text-xs font-medium transition-all duration-200 cursor-pointer bg-white text-[var(--color-text-muted)] border border-[var(--color-border)] hover:border-[var(--color-accent)]/40 hover:text-[var(--color-text)]">
              {sector}
            </button>
          ))}
        </div>
        <!-- Empty state -->
        <p id="no-results" class="hidden text-center text-[var(--color-text-muted)] py-12">Aucun projet ne correspond à ces filtres.</p>
      </div>

    <div class="space-y-12" id="projects-list">
      {visibleProjects.map((project, index) => (
        <article id={project.id} data-offer={project.offer} data-sector={project.sector} class="project-card group overflow-hidden rounded-2xl border border-[var(--color-border)] bg-white shadow-sm transition-all hover:shadow-xl">
          <div class={`grid ${index % 2 === 0 ? 'lg:grid-cols-[1.1fr_1fr]' : 'lg:grid-cols-[1fr_1.1fr]'}`}>

            {/* Screenshot area */}
            <div class={`relative overflow-hidden bg-gradient-to-br ${project.gradient} ${index % 2 !== 0 ? 'lg:order-2' : ''} flex flex-col items-center justify-center p-6 lg:p-8`}>
              {/* Screenshot — full image, no crop */}
              <div class="relative w-full rounded-lg overflow-hidden shadow-2xl ring-1 ring-black/10">
                <img
                  src={project.screenshot}
                  alt={`Capture d'écran de ${project.title}`}
                  class="w-full h-auto block"
                  loading="lazy"
                />
              </div>
              {/* Highlights pills — masqués si wip */}
              <div class="flex flex-wrap justify-center gap-2 mt-5">
                {project.wip ? (
                  <span class="rounded-full bg-amber-500/30 px-3 py-1 text-[11px] font-medium text-amber-200 backdrop-blur-sm border border-amber-400/20">
                    En cours de création
                  </span>
                ) : project.highlights.map((h) => (
                  <span class="rounded-full bg-black/25 px-3 py-1 text-[11px] font-medium text-white backdrop-blur-sm">
                    {h.label} : <span class="font-bold">{h.value}</span>
                  </span>
                ))}
              </div>
            </div>

            {/* Content side */}
            <div class={`flex flex-col justify-center p-8 lg:p-10 ${index % 2 !== 0 ? 'lg:order-1' : ''}`}>
              {/* Sector + Type + Offer */}
              <div class="mb-4 flex flex-wrap items-center gap-2">
                <span class={`inline-block rounded-full border px-3 py-1 text-xs font-semibold ${project.sectorColor}`}>
                  {project.sector}
                </span>
                <span class={`inline-block rounded-full border px-3 py-1 text-xs font-semibold ${offerColors[project.offer].bg} ${offerColors[project.offer].text} ${offerColors[project.offer].border}`}>
                  Offre {project.offer}
                </span>
                <span class="text-xs text-[var(--color-text-muted)]">{project.type}</span>
                {project.wip && (
                  <span class="inline-block rounded-full border border-amber-500/30 bg-amber-500/10 px-3 py-1 text-xs font-semibold text-amber-600">
                    En cours de création
                  </span>
                )}
              </div>

              <h2 class="mb-3 text-2xl font-bold text-[var(--color-text)] lg:text-3xl">
                {project.title}
              </h2>

              <p class="mb-6 text-[var(--color-text-muted)] leading-relaxed">
                {project.description}
              </p>

              {/* Features */}
              <div class="mb-6 flex flex-wrap gap-2">
                {project.features.map((f) => (
                  <span class="rounded-md bg-[var(--color-bg-alt)] px-2.5 py-1 text-xs font-medium text-[var(--color-text)]">
                    {f}
                  </span>
                ))}
              </div>

              {/* Avis client lié (optionnel) */}
              {'review' in project && project.review && (
                <details class="mb-6 group/review rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] overflow-hidden">
                  <summary class="flex cursor-pointer list-none items-start gap-3 p-4 select-none">
                    <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-xs font-bold text-white">
                      {project.review.author.charAt(0)}
                    </div>
                    <div class="min-w-0 flex-1">
                      <div class="mb-1.5 flex flex-wrap items-center gap-2">
                        <div class="flex gap-0.5">
                          {[1,2,3,4,5].map(() => (
                            <svg class="h-3 w-3 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                          ))}
                        </div>
                        <span class="text-xs font-semibold text-[var(--color-text)]">{project.review.author}</span>
                        <span class="text-xs text-[var(--color-text-muted)]">· {project.review.role}</span>
                      </div>
                      <p class="text-xs text-[var(--color-text-muted)] italic leading-relaxed">
                        "{project.review.text.slice(0, 80)}…"
                        <span class="ml-1 not-italic font-medium text-[var(--color-accent)] group-open/review:hidden">Lire l'avis</span>
                      </p>
                    </div>
                    <svg class="mt-1 h-4 w-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open/review:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="border-t border-[var(--color-border)] px-4 pb-4 pt-3">
                    <p class="text-xs text-[var(--color-text-muted)] italic leading-relaxed">"{project.review.text}"</p>
                    <a
                      href={project.review.googleUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="mt-3 inline-flex items-center gap-1.5 text-xs text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
                    >
                      <svg class="h-3.5 w-3.5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                      Voir sur Google
                    </a>
                  </div>
                </details>
              )}

              {/* CTA */}
              <div class="flex flex-wrap gap-3">
                {project.wip ? (
                  <span class="inline-flex items-center gap-2 rounded-xl border border-amber-500/30 bg-amber-50 px-5 py-2.5 text-sm font-medium text-amber-700">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                    Site en cours de création
                  </span>
                ) : (
                <>
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-lg"
                  style="box-shadow: 0 4px 15px rgba(232, 108, 71, 0.2);"
                >
                  Voir le site
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                </a>
                <a
                  href={`https://pagespeed.web.dev/analysis?url=${encodeURIComponent(project.url)}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-2.5 text-sm font-medium text-[var(--color-text-muted)] transition-all hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                >
                  Score Lighthouse
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                </a>
                </>
                )}
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>
    </div>
  </section>

  <!-- TECH SECTION -->
  <section class="w-full border-t border-[var(--color-border)] bg-white px-6 py-16 md:px-8 md:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-[var(--color-text)]">La stack derrière chaque projet</h2>
      <p class="mb-10 text-[var(--color-text-muted)]">Pas de WordPress, pas de templates. Du code custom, optimisé, déployé sur le edge.</p>
      <div class="flex flex-wrap items-center justify-center gap-6">
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Astro</span>
          <span class="text-xs text-[var(--color-text-muted)]">Framework</span>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Tailwind</span>
          <span class="text-xs text-[var(--color-text-muted)]">CSS</span>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Cloudflare</span>
          <span class="text-xs text-[var(--color-text-muted)]">Hosting</span>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Stripe</span>
          <span class="text-xs text-[var(--color-text-muted)]">Paiement</span>
        </div>
        <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
          <span class="text-lg font-bold text-[var(--color-accent)]">Web3Forms</span>
          <span class="text-xs text-[var(--color-text-muted)]">Formulaires</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-gradient-to-b from-[#1A1A1A] to-[#111111] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-white">Votre projet mérite la même attention</h2>
      <p class="mb-8 text-neutral-300">
        Essentiel à 490€, Multi-pages à 1 290€, Sur mesure à partir de 1 990€. Livré en 7 jours.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-block rounded-xl bg-[var(--color-accent)] px-8 py-3 font-medium text-white transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-xl"
          style="box-shadow: 0 10px 25px rgba(232, 108, 71, 0.3);"
        >
          Parlons de votre projet
        </a>
        <a
          href="/offre"
          class="inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 py-3 font-medium text-white/85 transition-all hover:bg-white/10"
        >
          Voir les formules
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const cards = document.querySelectorAll<HTMLElement>('.project-card');
    const noResults = document.getElementById('no-results');

    const activeClass = ['bg-[var(--color-text)]', 'text-white', 'shadow-sm'];
    const inactiveClass = ['bg-white', 'text-[var(--color-text-muted)]', 'border', 'border-[var(--color-border)]'];

    // Current filter state
    const state: Record<string, string> = { offer: 'all', sector: 'all' };

    function applyFilters() {
      let visibleCount = 0;
      cards.forEach(card => {
        const matchOffer = state.offer === 'all' || card.dataset.offer === state.offer;
        const matchSector = state.sector === 'all' || card.dataset.sector === state.sector;
        const show = matchOffer && matchSector;

        if (show) {
          visibleCount++;
          card.style.display = '';
          card.style.opacity = '0';
          card.style.transform = 'translateY(12px)';
          requestAnimationFrame(() => {
            card.style.transition = 'opacity 0.35s ease, transform 0.35s ease';
            card.style.opacity = '1';
            card.style.transform = 'translateY(0)';
          });
        } else {
          card.style.transition = 'opacity 0.15s ease';
          card.style.opacity = '0';
          setTimeout(() => { card.style.display = 'none'; }, 150);
        }
      });

      if (noResults) {
        noResults.classList.toggle('hidden', visibleCount > 0);
      }
    }

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const type = btn.dataset.filterType as string;
        const value = btn.dataset.filterValue as string;

        state[type] = value;

        // Update button styles within same group
        buttons.forEach(b => {
          if (b.dataset.filterType === type) {
            b.classList.remove(...activeClass);
            b.classList.add(...inactiveClass);
            b.classList.remove('filter-btn--active');
          }
        });
        btn.classList.remove(...inactiveClass);
        btn.classList.add(...activeClass);
        btn.classList.add('filter-btn--active');

        applyFilters();
      });
    });
  });
</script>
