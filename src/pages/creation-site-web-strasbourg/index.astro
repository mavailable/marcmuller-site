---
import VilleTemplate from '@components/VilleTemplate.astro';

const title = "Création de site web sur mesure à Strasbourg | Marc M";
const description = "Créateur de sites web custom à Strasbourg. Sites rapides, bien référencés, optimisés pour Google. À partir de 490€. Projets complexes sur devis.";

const ville = "Strasbourg";
const intro = "Vous êtes entrepreneur, artisan ou commerçant à Strasbourg et vous cherchez un site web qui marche vraiment ? Je suis Marc M., je crée des sites custom (pas de template) pour les PME du Grand Est. Rapides, bien référencés, qui ramènent des clients.";

const sections = [
  {
    title: "Pourquoi Strasbourg a besoin de meilleurs sites web",
    content: "Strasbourg est une ville dynamique avec des centaines de petits commerces et artisans. Mais beaucoup ont des sites moches, lents, ou... pas de site du tout.\n\nRésultat ? Vous perdez des clients à vos concurrents qui ont une meilleure présence en ligne.\n\nUn site bien fait fait la différence :\n- Vos clients vous trouvent sur Google avant vos concurrents\n- Ils appellent directement sans avoir à vous chercher sur Facebook\n- Vous recevez des commandes en ligne même quand vous êtes fermé\n- Votre réputation est meilleure (avis, photos, contact clair)\n\nÀ Strasbourg, la concurrence est forte. Un bon site web, c'est le minimum."
  },
  {
    title: "Comment je crée votre site à Strasbourg",
    content: "Contrairement aux agences qui vous font attendre 3 mois, je livre en 5-7 jours (Site Express) ou 2-3 semaines (sur mesure).\n\nEt je comprends vraiment votre métier. J'ai bossé avec des restaurateurs strasbourgeois, des gîtes, des plombiers, des salons de coiffure — je sais ce qui marche pour vous.\n\nChaque site est custom :\n- Vos couleurs, votre identité\n- Optimisé pour votre clientèle locale\n- Bien rangé sur Google pour vos mots-clés « Strasbourg »\n- Accessible sur mobile (70% de vos clients vous trouvent depuis un téléphone)\n\nVous obtenez un site qu'un freelancer WordPress n'aurait pas fait en 3 mois, mais à un prix que vous pouvez payer (à partir de 490€)."
  },
  {
    title: "Exemples de sites créés à Strasbourg",
    content: "**La Brasserie du centre**\nAvant : site vieux de 5 ans, pas à jour, pas de menu en ligne.\nAprès : nouveau site avec menu, réservation, photos à jour.\nRésultat : +30% de réservations en ligne en 2 mois.\n\n**Plomberie Dupont (Strasbourg)**\nAvant : Juste Google My Business, pas de site propre.\nAprès : site avec galerie de chantiers avant/après, témoignages, formulaire devis.\nRésultat : premiers devis en ligne après 3 semaines.\n\n**Le Gîte Blanc à Strasbourg**\nAvant : Airbnb only, pas de contact direct.\nAprès : site custom avec photos, tarifs, formulaire réservation.\nRésultat : réservations directes = moins de commission, plus de marge."
  }
];

const faq = [
  {
    question: "Vous pouvez créer mon site en Alsacien ? Ou en anglais (pour les touristes) ?",
    answer: "Oui, bien sûr. Beaucoup de restaurateurs strasbourgeois veulent au moins une version anglaise. Je peux faire du multilingue (français/anglais, même alsacien si vous tenez vraiment). Surcoût : ~500€ pour une deuxième langue complète."
  },
  {
    question: "Est-ce que votre site m'aide à me positionner contre mes concurrents strasbourgeois ?",
    answer: "Directement : oui, via le SEO local (Google Maps, mots-clés « à Strasbourg »). Indirectement : oui, vous avez un site mieux fait que 90% de vos concurrents.\n\nJe ne fais pas de magie — si quelqu'un avec un meilleur budget marketing fait une campagne Google Ads massive, ils vont être en haut. Mais en référencement organique, vous allez dominer votre catégorie à Strasbourg."
  },
  {
    question: "Vous êtes vraiment à Strasbourg ou c'est juste du marketing local ?",
    answer: "Complètement à Strasbourg. Bureau à Strasbourg même, humain réel. Vous pouvez me rencontrer pour un café si vous voulez discuter avant de vous engager. Rendez-vous Zoom aussi, pas de souci."
  },
  {
    question: "Combien de sites strasbourgeois avez-vous créés ?",
    answer: "5 sites à Strasbourg intra-muros, et une dizaine dans la région (Metz, Nancy, Colmar). Tous satisfaits. Pas de churning clients."
  }
];

const pricingExpress = {
  title: "Site Vitrine",
  price: "490€",
  features: [
    "✓ Design sur mesure, pas un template",
    "✓ Référencé Google & IA",
    "✓ Formulaire, WhatsApp, appel",
    "✓ Lighthouse 100/100",
    "✓ Livré en 7 jours"
  ]
};

const pricingCustom = {
  title: "Projet Sur Mesure",
  price: "Sur devis",
  features: [
    "✓ Multi-pages, blog, CMS",
    "✓ Fonctionnalités métier",
    "✓ Stratégie SEO avancée",
    "✓ Optimisé IA (ChatGPT, Claude)",
    "✓ Devis gratuit sous 48h"
  ]
};

const geo = {
  lat: 48.5734,
  lon: 7.7521
};

const areaServed = ["Strasbourg", "Illkirch-Graffenstaden", "Schiltigheim", "Eckbolsheim", "Obernai", "Sélestat", "Alsace"];

const ctaTitle = "Vous voulez un site pour votre commerce à Strasbourg ?";
const ctaText = "Écrivez-moi. On en discute 30 min sur Zoom, sans engagement. Je vous dis exactement ce qui coûte quoi, et on voit si ça peut marcher pour vous.";
const ctaButton = "Parlons de votre projet Strasbourg";
---

<VilleTemplate
  title={title}
  description={description}
  ville={ville}
  intro={intro}
  sections={sections}
  faq={faq}
  pricingExpress={pricingExpress}
  pricingCustom={pricingCustom}
  geo={geo}
  areaServed={areaServed}
  ctaTitle={ctaTitle}
  ctaText={ctaText}
  ctaButton={ctaButton}
  frPath="/creation-site-web-strasbourg"
  enPath="/en/web-design-strasbourg"
/>
