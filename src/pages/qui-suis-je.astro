---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionTitle from '../components/SectionTitle.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

const localIcon = `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /></svg>`;
const qualityIcon = `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
const techIcon = `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4m-4-4l-4 4m4-4l4-4" /></svg>`;
const transparencyIcon = `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>`;
---

<BaseLayout
  title="Qui suis-je - Marc Muller"
  description="Marc Muller, créateur de sites web sur mesure pour entrepreneurs du Grand Est. 8 ans en agence, indépendant depuis 2020."
>
  <SchemaOrg type="person" />
  <!-- HERO -->
  <section class="w-full relative overflow-hidden px-6 py-16 md:px-8 md:py-24" style="background-color: #0D0D0D;">
    <!-- Dot grid overlay -->
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, #fff 1px, transparent 1px); background-size: 20px 20px;"></div>

    <div class="mx-auto max-w-4xl relative z-10">
      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Marc Muller — créateur de sites web sur mesure
      </h1>
      <p class="mb-8 text-lg leading-relaxed text-gray-300 md:text-xl">
        Basé à Strasbourg, je crée des sites web avec Astro et Tailwind pour artisans et entrepreneurs. Depuis 2020, pas de templates, pas de WordPress — juste du custom.
      </p>

      <!-- Photo placeholder -->
      <div class="w-full h-64 md:h-96 bg-gradient-to-b from-white/10 to-white/5 rounded-xl border border-white/20 flex items-center justify-center mb-8 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-white/5 via-transparent to-transparent"></div>
        <p class="text-gray-400 relative z-10">Photo à venir</p>
      </div>
    </div>
  </section>

  <!-- PARCOURS -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">
      <SectionTitle title="D'où je viens" />
      <div class="mt-8 space-y-6 text-[var(--color-text)]">
        <p>
          <strong>2012-2020 : 8 ans en agence web</strong> à Strasbourg. Designer, développeur, référenceur. Vous savez, ce genre de boîte où tu dois faire un peu de tout en même temps. J'ai aimé apprendre, moins aimé les procédures bizarres et les sites faits pour montrer à des clients qu'on était "créatif" sans vraiment les aider.
        </p>
        <p>
          <strong>2020 : le départ.</strong> Un jour, je me suis dit que j'avais mieux à faire que suivre un process de validation à 5 niveaux pour un simple bouton. J'ai quitté et j'ai lancé en indépendant. Best decision ever.
        </p>
        <p>
          <strong>2020-Aujourd'hui :</strong> 12+ projets livrés, 100% de clients heureux. Restaurants, artisans BTP, boutiques en ligne, freelances. J'ai plongé dans les technos modernes : Astro (révélation), Tailwind, intégrations API. Je dis non aux projets qui ne m'intéressent pas. Je ne fais que du qualitatif.
        </p>
      </div>

      <!-- Timeline with vertical line and cards -->
      <div class="mt-12 relative">
        <!-- Vertical line -->
        <div class="absolute left-3 top-6 bottom-6 w-0.5 bg-[var(--color-accent)]"></div>

        <div class="space-y-8">
          <!-- Item 1 -->
          <div class="flex gap-6 relative">
            <div class="w-7 h-7 rounded-full bg-[var(--color-accent)] flex items-center justify-center flex-shrink-0 z-10 mt-0.5">
              <div class="w-3 h-3 rounded-full bg-[var(--color-bg)]"></div>
            </div>
            <div class="bg-white rounded-xl p-5 border border-[var(--color-border)] shadow-sm hover:shadow-md transition-shadow">
              <p class="font-bold text-[var(--color-text)] text-lg">2012-2020</p>
              <p class="text-[var(--color-text-muted)] text-sm mt-1">Agence web, polyvalence forcée</p>
            </div>
          </div>

          <!-- Item 2 -->
          <div class="flex gap-6 relative">
            <div class="w-7 h-7 rounded-full bg-[var(--color-accent)] flex items-center justify-center flex-shrink-0 z-10 mt-0.5">
              <div class="w-3 h-3 rounded-full bg-[var(--color-bg)]"></div>
            </div>
            <div class="bg-white rounded-xl p-5 border border-[var(--color-border)] shadow-sm hover:shadow-md transition-shadow">
              <p class="font-bold text-[var(--color-text)] text-lg">2020</p>
              <p class="text-[var(--color-text-muted)] text-sm mt-1">Indépendant, premiers clients</p>
            </div>
          </div>

          <!-- Item 3 -->
          <div class="flex gap-6 relative">
            <div class="w-7 h-7 rounded-full bg-[var(--color-accent)] flex items-center justify-center flex-shrink-0 z-10 mt-0.5">
              <div class="w-3 h-3 rounded-full bg-[var(--color-bg)]"></div>
            </div>
            <div class="bg-white rounded-xl p-5 border border-[var(--color-border)] shadow-sm hover:shadow-md transition-shadow">
              <p class="font-bold text-[var(--color-text)] text-lg">2024-2026</p>
              <p class="text-[var(--color-text-muted)] text-sm mt-1">MM Agency, Astro & Tailwind</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERTISE / TECH STACK -->
  <section class="w-full bg-white px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">
      <SectionTitle title="Ce que je maîtrise" />
      <div class="mt-8 grid grid-cols-2 gap-3 md:grid-cols-4">
        <div class="px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-full text-center text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 hover:scale-105 transition-all">
          Astro 5
        </div>
        <div class="px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-full text-center text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 hover:scale-105 transition-all">
          Tailwind CSS
        </div>
        <div class="px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-full text-center text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 hover:scale-105 transition-all">
          Cloudflare
        </div>
        <div class="px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-full text-center text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 hover:scale-105 transition-all">
          Web3Forms
        </div>
        <div class="px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-full text-center text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 hover:scale-105 transition-all">
          Decap CMS
        </div>
        <div class="px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-full text-center text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 hover:scale-105 transition-all">
          SEO
        </div>
        <div class="px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-full text-center text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 hover:scale-105 transition-all">
          Analytics
        </div>
        <div class="px-4 py-2 bg-[var(--color-bg)] border border-[var(--color-border)] rounded-full text-center text-sm font-medium text-[var(--color-text)] hover:border-[var(--color-accent)] hover:bg-[var(--color-accent)]/5 hover:scale-105 transition-all">
          Git
        </div>
      </div>

      <p class="mt-8 text-[var(--color-text-muted)]">
        Stack technique : Astro 5, Tailwind CSS v4, TypeScript, Cloudflare Pages, Web3Forms, Decap CMS, SEO local, Core Web Vitals.
      </p>
    </div>
  </section>

  <!-- CONVICTIONS -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">
      <SectionTitle title="Ce en quoi je crois" align="center" />
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        <!-- Local -->
        <div class="bg-white rounded-xl p-6 border border-[var(--color-border)] border-t-4 border-t-[var(--color-accent)] shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
          <div class="flex items-start gap-3 mb-3">
            <span class="text-[var(--color-accent)] flex-shrink-0" set:html={localIcon} />
            <h3 class="text-lg font-bold text-[var(--color-text)]">Local, pas corporate</h3>
          </div>
          <p class="text-[var(--color-text-muted)]">
            Je bosse avec les entrepreneurs du Grand Est, les gens qui créent vraiment. Pas les multinationales qui veulent 15 révisions inutiles.
          </p>
        </div>

        <!-- Qualité -->
        <div class="bg-white rounded-xl p-6 border border-[var(--color-border)] border-t-4 border-t-[var(--color-accent)] shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
          <div class="flex items-start gap-3 mb-3">
            <span class="text-[var(--color-accent)] flex-shrink-0" set:html={qualityIcon} />
            <h3 class="text-lg font-bold text-[var(--color-text)]">Qualité sans compromis</h3>
          </div>
          <p class="text-[var(--color-text-muted)]">
            Même pour un site Essentiel. Code propre, performance optimisée, sécurité de base. Pas de dette technique dès le départ.
          </p>
        </div>

        <!-- Tech -->
        <div class="bg-white rounded-xl p-6 border border-[var(--color-border)] border-t-4 border-t-[var(--color-accent)] shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
          <div class="flex items-start gap-3 mb-3">
            <span class="text-[var(--color-accent)] flex-shrink-0" set:html={techIcon} />
            <h3 class="text-lg font-bold text-[var(--color-text)]">Technologie moderne</h3>
          </div>
          <p class="text-[var(--color-text-muted)]">
            Astro, pas WordPress. Tailwind, pas CSS à la main. Tooling moderne. Ça va plus vite, c'est plus sûr, c'est plus maintenable.
          </p>
        </div>

        <!-- Transparence -->
        <div class="bg-white rounded-xl p-6 border border-[var(--color-border)] border-t-4 border-t-[var(--color-accent)] shadow-sm hover:shadow-lg hover:-translate-y-1 transition-all">
          <div class="flex items-start gap-3 mb-3">
            <span class="text-[var(--color-accent)] flex-shrink-0" set:html={transparencyIcon} />
            <h3 class="text-lg font-bold text-[var(--color-text)]">Transparence totale</h3>
          </div>
          <p class="text-[var(--color-text-muted)]">
            Pas de caché, pas de upsell surprise. Je te dis les prix, les délais, ce qu'il y a dedans. Point.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CÔTÉ HUMAIN -->
  <section class="w-full bg-white px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">
      <SectionTitle title="Côté humain" />
      <div class="mt-8 space-y-4">
        <p class="text-[var(--color-text-muted)] border-l-4 border-[var(--color-accent)] pl-4">
          Randos dans les Vosges (et Alsace en général). J'aime les restaurants qui font bien manger pour pas trop cher. Je lis — code, entrepreneuriat, IA. Je regarde quels modèles marchent vraiment, comment les gens créent sans lever 10M$.
        </p>
        <p class="text-[var(--color-text-muted)] border-l-4 border-[var(--color-accent)] pl-4">
          Je n'aime pas : les réunions inutiles, les PowerPoint sans queue ni tête, les templates dégueulasses, Internet Explorer.
        </p>
        <p class="text-[var(--color-text-muted)] border-l-4 border-[var(--color-accent)] pl-4">
          Vous m'écrivez un samedi ? Réponse le lundi. Vous avez une question « con » ? Aucune question n'est con. Je ne suis pas un mec d'agence qui vous traite de haut.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="w-full px-6 py-16 md:px-8 md:py-24" style="background: linear-gradient(135deg, #1A1A1A 0%, #111111 100%);">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-3xl font-bold text-white">Discutons de votre projet</h2>
      <p class="mb-8 text-lg text-gray-300">
        Vous avez un site à créer, une idée à explorer, ou vous voulez juste discuter web ? Écrivez-moi.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <Button href="/contact" variant="primary" size="lg">Me contacter</Button>
        <a
          href="https://wa.me/33688766648?text=Bonjour%20Marc%2C%20je%20souhaite%20discuter%20d'un%20projet%20de%20site%20web."
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-base font-semibold text-white transition-all hover:-translate-y-0.5 hover:shadow-lg"
          style="background:#25D366;"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
