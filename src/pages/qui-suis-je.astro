---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';

const whatsappNumber = business.whatsapp;
const whatsappMessage = encodeURIComponent("Bonjour Marc, j'ai vu ton parcours et j'aimerais qu'on discute d'un projet.");
---

<BaseLayout
  title="Qui suis-je — Marc M"
  description="Marc, 40 ans, Messin. Entrepreneur depuis toujours, je crée des sites web performants pour ceux qui fabriquent des choses avec leurs mains."
  lang="fr"
  frPath="/qui-suis-je"
  enPath="/en/about"
>
  <SchemaOrg type="person" />

  <!-- HERO — Nom + photo -->
  <section class="w-full relative overflow-hidden" style="background-color: #0D0D0D;">
    <!-- Gradient glow derrière la photo -->
    <div class="absolute top-[20%] left-[50%] -translate-x-1/2 w-[500px] h-[500px] rounded-full opacity-[0.08] blur-[120px]" style="background: var(--color-accent);"></div>
    <!-- Dot grid -->
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="mx-auto max-w-4xl relative z-10 px-6 pt-20 md:pt-28">
      <div class="flex flex-col md:flex-row items-center gap-0 md:gap-12">
        <!-- Photo buste — fond transparent, fondu en bas -->
        <div class="flex-shrink-0 w-64 md:w-80 mx-auto md:mx-0 relative">
          <picture>
            <source srcset="/images/marc-muller.webp" type="image/webp" />
            <img
              src="/images/marc-muller.png"
              alt="Marc Muller"
              class="w-full h-auto relative z-10"
              width="500"
              height="500"
              loading="eager"
            />
          </picture>
          <!-- Fondu bas pour fondre dans la section -->
          <div class="absolute bottom-0 left-0 right-0 h-24 z-20" style="background: linear-gradient(to top, #0D0D0D, transparent);"></div>
        </div>
        <!-- Texte — centré verticalement avec la photo -->
        <div class="text-center md:text-left pb-8 md:pb-0 pt-4 md:pt-0">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] mb-4" style="color: var(--color-accent);">Qui suis-je</p>
          <h1 class="text-4xl md:text-5xl font-bold leading-[1.1] text-white mb-4">
            Marc Muller
          </h1>
          <p class="text-xl md:text-2xl leading-relaxed font-light" style="color: rgba(255,255,255,0.7);">
            40 ans, Messin. Entrepreneur depuis toujours, développeur par la force des choses.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- HISTOIRE — Prose éditoriale -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-2xl">

      <!-- Bloc 1 : Les origines -->
      <p class="text-xl md:text-2xl leading-relaxed text-[var(--color-text)] font-medium mb-10">
        J'ai grandi dans des boulangeries, entouré d'entrepreneurs qui se lèvent tôt et qui fabriquent des choses avec leurs mains.
      </p>
      <p class="text-base md:text-lg leading-relaxed text-[var(--color-text-muted)] mb-6">
        Ça m'a marqué. Depuis, j'ai fait dix ans dans le bâtiment et l'immobilier, puis dix ans dans l'escape game — d'abord en physique, puis en ligne. À chaque fois, le même réflexe : fabriquer mes propres outils. Des mécanismes physiques, du code, des systèmes entiers bricolés pour que le truc tourne comme je veux.
      </p>
      <p class="text-base md:text-lg leading-relaxed text-[var(--color-text-muted)] mb-16">
        Je ne suis pas développeur de formation, mais j'ai toujours eu les mains dans la tech, poussé par des proches passionnés qui baignent dedans depuis toujours.
      </p>

      <!-- Accent visuel — la galère -->
      <div class="border-l-3 pl-6 md:pl-8 mb-16" style="border-color: var(--color-accent);">
        <p class="text-lg md:text-xl leading-relaxed text-[var(--color-text)] italic">
          Des sites web, j'en ai fait pour chacun de mes business. Ou plutôt : j'ai galéré à en faire. Pendant des années, c'était le truc frustrant — avoir la vision mais pas les bons outils pour sortir un résultat propre.
        </p>
      </div>

      <!-- Bloc 2 : Aujourd'hui -->
      <p class="text-base md:text-lg leading-relaxed text-[var(--color-text-muted)] mb-6">
        Aujourd'hui, les outils ont rattrapé les gens comme moi. Je crée des sites performants, bien référencés, aux standards de 2026 — pour mes projets et pour ceux des autres.
      </p>

    </div>
  </section>

  <!-- CHIFFRES — Bande sobre -->
  <section class="w-full bg-white px-6 py-10 md:py-14 border-y" style="border-color: var(--color-border);">
    <div class="mx-auto max-w-3xl">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 text-center">
        <div>
          <p class="text-3xl md:text-4xl font-bold text-[var(--color-text)]">20</p>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">ans d'entrepreneuriat</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold text-[var(--color-text)]">4</p>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">secteurs différents</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold" style="color: var(--color-accent);">100</p>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">sites offerts aux artisans</p>
        </div>
        <div>
          <p class="text-3xl md:text-4xl font-bold" style="color: var(--color-accent);">100<span class="text-lg">/100</span></p>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">score Lighthouse</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CE QUI ME FAIT VIBRER -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-2xl">
      <h2 class="text-2xl md:text-3xl font-bold text-[var(--color-text)] mb-6">Ce que je préfère dans ce métier</h2>
      <p class="text-base md:text-lg leading-relaxed text-[var(--color-text-muted)] mb-6">
        Rencontrer des gens. Chaque client, c'est un métier différent, une histoire différente, un problème différent à résoudre. Après vingt ans à monter des boîtes dans des univers très variés, c'est ce qui me fait vibrer : comprendre ce que tu fais et le rendre visible.
      </p>
      <p class="text-base md:text-lg leading-relaxed text-[var(--color-text-muted)]">
        Et apprendre. Tout le temps. Nouveaux outils, nouvelles techniques, nouvelles façons de faire. Le web bouge vite, les gens qui s'y arrêtent prennent du retard. Moi je préfère rester curieux — c'est comme ça que je fais de meilleurs sites chaque mois.
      </p>
    </div>
  </section>

  <!-- NOTE PERSO — Plongée (touch) -->
  <section class="w-full px-6 py-10 md:px-8 md:py-14" style="background: var(--color-bg-alt);">
    <div class="mx-auto max-w-2xl flex items-start gap-4">
      <span class="text-2xl flex-shrink-0 mt-0.5">🤿</span>
      <p class="text-[var(--color-text-muted)] leading-relaxed">
        Quand je ne suis pas derrière un écran, je suis probablement sous l'eau. Divemaster certifié, il m'arrive de bosser depuis la Thaïlande entre deux plongées. Remote, pas déconnecté.
      </p>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="w-full px-6 py-16 md:px-8 md:py-24" style="background: linear-gradient(135deg, #1A1A1A 0%, #111111 100%);">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="mb-4 text-3xl font-bold text-white">On discute ?</h2>
      <p class="mb-8 text-lg" style="color: rgba(255,255,255,0.6);">
        Un projet, une question, ou juste envie de dire bonjour — écris-moi.
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <Button href="/contact" variant="primary" size="lg">Me contacter</Button>
        <a
          href={`https://wa.me/${whatsappNumber}?text=${whatsappMessage}`}
          target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 rounded-xl px-7 py-3.5 text-base font-semibold text-white transition-all hover:-translate-y-0.5 hover:shadow-lg"
          style="background:#25D366;"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          WhatsApp
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
