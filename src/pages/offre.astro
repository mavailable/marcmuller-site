---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionTitle from '../components/SectionTitle.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';

const whatsappMessage = encodeURIComponent(business.whatsappMessage);

const checkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;

const faqItems = [
  {
    question: "490€, c'est un template ?",
    answer: "Non. Chaque site est construit de zéro, à votre image. Pas de WordPress, pas de template. Le prix reflète l'efficacité de mon processus — un site unique prêt en 7 jours."
  },
  {
    question: "Paiement en plusieurs fois ?",
    answer: "Oui. Site Vitrine : 2× 245€. Projet Sur Mesure : 50% à la signature, le reste à la livraison. On s'adapte."
  },
  {
    question: "Et après la première année ?",
    answer: "Votre site continue de fonctionner, gratuitement. L'hébergement est offert à vie. Seul le nom de domaine (~10€/an) est à renouveler. Si vous voulez un accompagnement (modifs, support, contenu), des formules existent dès 39€/mois."
  },
  {
    question: "C'est quoi le référencement GEO ?",
    answer: "GEO = Generative Engine Optimization. En plus du SEO classique (Google), j'optimise votre site pour qu'il apparaisse dans les réponses des IA — ChatGPT, Perplexity, Claude. C'est le référencement de demain, inclus dès aujourd'hui."
  },
  {
    question: "Vous faites du WordPress ?",
    answer: "Non, je travaille avec Astro. C'est plus rapide (meilleur ranking Google), plus sûr (zéro plugin = zéro faille), et plus léger. Résultat : un site qui charge en moins d'1 seconde."
  },
  {
    question: "Comment ça se passe concrètement ?",
    answer: "Vous commandez en ligne, vous remplissez un questionnaire guidé (activité, textes, photos), on fait un appel de 15 min pour cadrer, et je livre en 7 jours. Un aller-retour de corrections est inclus."
  },
  {
    question: "Et si j'ai des besoins plus complexes ?",
    answer: "Multi-pages, blog, réservation en ligne, boutique, fonctionnalités métier — on en parle ensemble. Je fais un devis gratuit sous 48h, sans engagement."
  },
  {
    question: "Je ne sais pas quoi mettre sur mon site, vous m'aidez ?",
    answer: "Oui, c'est inclus. Je rédige tous vos textes à partir d'un échange de 15 minutes sur votre activité. Vous validez le résultat, c'est tout. Aucune compétence rédactionnelle requise."
  },
  {
    question: "Je peux modifier le site moi-même ensuite ?",
    answer: "Oui. Votre site inclut un espace d'édition simple (Keystatic) : vous changez vos textes, photos et horaires comme dans un document Word. Pas besoin de toucher au code."
  }
];
---

<BaseLayout
  title="Offre & Tarifs — Marc M | Création de sites web"
  description="Site professionnel sur mesure à 490€, achat en ligne. Livré en 7 jours. Lighthouse 100. Référencé Google & IA. Projets complexes sur devis."
  lang="fr"
  frPath="/offre"
  enPath="/en/services"
>
  <SchemaOrg type="localBusiness" />
  <SchemaOrg type="faqPage" data={faqItems} />

  <!-- HERO -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="mx-auto max-w-4xl text-center relative z-10">
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white">Achat en ligne — livré en 7 jours</span>
      </div>

      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Un site pro qui vous amène des clients
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto">
        Design sur mesure. Visible sur Google et les IA. Ultra-rapide. Je m'occupe de tout — même les textes. Vous commandez, je livre.
      </p>
    </div>
  </section>

  <!-- SITE VITRINE — LE PRODUIT -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-12 md:px-8 md:py-16">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-10 lg:grid-cols-2 items-start">

        <!-- CARD PRODUIT -->
        <div class="relative rounded-2xl p-8 lg:p-10 flex flex-col" style="background-color: #111; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(232, 108, 71, 0.3);">
          <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl" style="background: linear-gradient(90deg, #E86C47, #F5C8B3);"></div>

          <div class="mb-2">
            <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider text-neutral-300" style="letter-spacing: 0.15em;">Site Vitrine</span>
          </div>
          <h2 class="text-2xl font-bold text-white mb-2">Votre site professionnel</h2>
          <p class="text-sm text-neutral-400 mb-6 leading-relaxed">Construit de zéro, à votre image. Pas un template.</p>

          <div class="mb-8">
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-extrabold text-white">490</span>
              <span class="text-2xl font-bold text-white">€</span>
              <span class="text-sm text-neutral-400 ml-2">HT · ou 2× 245€</span>
            </div>
          </div>

          <div class="space-y-3 flex-grow mb-8">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Design unique</strong> à votre image — pas de template</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Visible sur Google et les IA</strong> — SEO & GEO optimisé</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Pensé pour convertir</strong> — appel, WhatsApp, formulaire</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Ultra-rapide</strong> — votre site charge en moins d'une seconde</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Prêt en 7 jours</strong> — 1 aller-retour de corrections inclus</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Textes rédigés pour vous</strong> — vous n'avez rien à écrire</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>C'est votre site</strong> — vous êtes propriétaire, zéro lock-in</span>
            </div>
          </div>

          <div class="space-y-3">
            <a href="/commander" class="block w-full py-4 px-6 text-center rounded-xl text-base font-semibold text-white transition-all duration-200" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.4);">
              Commander mon site — 490€
            </a>
            <a href="/contact" class="block w-full py-3 px-6 text-center rounded-xl text-sm font-semibold text-neutral-300 border border-neutral-700 transition-all duration-200 hover:border-neutral-500 hover:text-white">
              Juste poser une question
            </a>
            <p class="text-center text-xs text-neutral-500 mt-1">Hébergement & domaine offerts la 1ère année</p>
          </div>
        </div>

        <!-- CE QUI EST INCLUS -->
        <div class="flex flex-col gap-6">
          <h3 class="text-lg font-bold text-[var(--color-text)]">Comment ça marche</h3>

          <div class="space-y-5">
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white text-sm" style="background: linear-gradient(135deg, #E86C47, #D4572F);">1</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">Vous commandez en ligne</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">Paiement sécurisé. Vous remplissez un questionnaire guidé : activité, textes, photos, préférences.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white text-sm" style="background: linear-gradient(135deg, #E86C47, #D4572F);">2</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">On fait le point ensemble</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">Appel de 15 minutes pour cadrer le projet. Si vos besoins dépassent le Site Vitrine, je vous oriente sans surcoût.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white text-sm" style="background: linear-gradient(135deg, #E86C47, #D4572F);">3</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">Je construis votre site</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">Design, développement, contenu, SEO — tout est fait sur mesure en 7 jours.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white text-sm" style="background: linear-gradient(135deg, #E86C47, #D4572F);">4</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">Votre site est en ligne</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">Un aller-retour de corrections, puis mise en ligne. Vous recevez les accès à tout.</p>
              </div>
            </div>
          </div>

          <!-- SOCIAL PROOF -->
          <div class="mt-4 flex items-center gap-4 px-5 py-4 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)]">
            <div class="text-3xl font-extrabold" style="color: #E86C47;">{business.sitesRealises}</div>
            <div>
              <p class="text-sm font-semibold text-[var(--color-text)]">sites livrés</p>
              <p class="text-xs text-[var(--color-text-muted)]">Tous à Lighthouse 100 — <a href="/realisations" class="underline hover:text-[var(--color-accent)]">voir les réalisations</a></p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ADD-ONS -->
  <section class="w-full px-6 py-12 md:px-8 md:py-16" style="background: linear-gradient(180deg, #FAFAFA 0%, #FFFFFF 100%);">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-3" style="letter-spacing: 0.2em;">À la carte</p>
        <h2 class="text-3xl font-bold text-[var(--color-text)]">Ajoutez ce dont vous avez besoin</h2>
        <p class="mt-3 text-[var(--color-text-muted)]">Disponibles avec le Site Vitrine ou en complément d'un Projet Sur Mesure.</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Page supplémentaire</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Une page dédiée en plus (À propos, tarifs, galerie...)</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+120€</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Fiche Google Business</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Création et optimisation de votre fiche Google Maps</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+90€</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 4V2m0 2a2 2 0 100 4m0-4a2 2 0 110 4m10-4V2m0 2a2 2 0 100 4m0-4a2 2 0 110 4M5 20a7 7 0 0114 0M12 14a3 3 0 100-6 3 3 0 000 6z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Pack réseaux sociaux</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Visuels optimisés Facebook, LinkedIn et Google Business</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+150€</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Blog SEO</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">5 articles optimisés + CMS pour écrire vous-même</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+390€</p>
        </div>
      </div>

      <!-- Ligne 2 — add-ons complémentaires -->
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 mt-4">
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Galerie photos avancée</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Lightbox, filtrage par catégorie, chargement optimisé</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+90€</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Boutique en ligne</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Catalogue produits, paiement Stripe, gestion des commandes</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+250€</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Prise de RDV en ligne</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Calendrier intégré, réservation automatique</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+180€</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Animations au scroll</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Effets visuels élégants au défilement de la page</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+90€</p>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJET SUR MESURE -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="mx-auto max-w-5xl relative z-10">
      <div class="grid gap-10 lg:grid-cols-2 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-4" style="letter-spacing: 0.2em;">Sur devis</p>
          <h2 class="text-3xl font-bold text-white mb-4">Un projet qui dépasse le site vitrine ?</h2>
          <p class="text-neutral-300 mb-6 leading-relaxed">
            Multi-pages, blog, réservation en ligne, calculateur de prix, fonctionnalités métier — je construis exactement ce qu'il vous faut. Devis gratuit sous 48h.
          </p>

          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Architecture sur mesure</strong> — autant de pages qu'il en faut</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Fonctionnalités métier</strong> — booking, paiement, catalogue, calculateur</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Blog + CMS</strong> — écrivez vos articles en autonomie</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Stratégie SEO</strong> — pages par ville, par service, contenu ciblé</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Analytics</strong> — suivi des visites et des conversions</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/contact" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-[var(--color-accent)] px-8 py-3 text-sm font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-all duration-200">
              Discuter de mon projet
            </a>
