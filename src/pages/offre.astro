---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionTitle from '../components/SectionTitle.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';

const whatsappMessage = encodeURIComponent(business.whatsappMessage);

const checkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
const xIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>`;

const faqItems = [
  {
    question: "490€, c'est un template ?",
    answer: "Non. Chaque site est construit de zéro, à votre image. Le prix reflète l'efficacité de mon processus, pas un manque de qualité."
  },
  {
    question: "Paiement en plusieurs fois ?",
    answer: "Oui. Essentiel : 50/50. Multi-pages et Sur mesure : paiement en 2 ou 3 fois, 50% à la signature et le reste à la livraison. On s'adapte."
  },
  {
    question: "Qu'est-ce qui est inclus dans l'hébergement 1 an ?",
    answer: "Hébergement sur Cloudflare (CDN mondial, ultra-rapide), nom de domaine .fr ou .com, certificat SSL, maintenance technique et mises à jour pendant 12 mois. Au bout d'un an, renouvellement à 120€/an."
  },
  {
    question: "C'est quoi le référencement GEO ?",
    answer: "GEO = Generative Engine Optimization. En plus du SEO classique (Google), j'optimise votre site pour qu'il soit bien référencé dans les réponses des IA — ChatGPT, Perplexity, Claude. C'est le référencement de demain, inclus dès aujourd'hui."
  },
  {
    question: "Vous faites du WordPress ?",
    answer: "Non, je travaille avec Astro. C'est plus rapide (meilleur ranking Google), plus sûr (zéro plugin = zéro faille), et plus léger. Résultat : un site qui charge en moins d'1 seconde et qui plaît à Google."
  },
  {
    question: "Quelle formule choisir ?",
    answer: "Essentiel si vous démarrez ou si une page suffit (freelance, artisan local). Multi-pages si vous avez besoin de présenter plusieurs services, une galerie, des avis (c'est le plus demandé). Sur mesure si vous avez des besoins spécifiques : paiement, réservation, e-commerce, blog. Pas sûr ? On en parle au téléphone."
  }
];
---

<BaseLayout
  title="Offre & Tarifs — Marc M | Création de sites web"
  description="3 formules claires : Essentiel 490€, Multi-pages 1 290€, Sur mesure dès 1 990€. Tout inclus : hébergement 1 an, nom de domaine, SEO, maintenance."
  lang="fr"
  frPath="/offre"
  enPath="/en/services"
>
  <SchemaOrg type="localBusiness" />
  <SchemaOrg type="faqPage" data={faqItems} />
  <!-- HERO -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="mx-auto max-w-4xl text-center relative z-10">
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white">3 formules, 0 mauvaise surprise</span>
      </div>

      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Un site pro, au juste prix
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto">
        Toutes les formules incluent 1 an d'hébergement, le nom de domaine, la maintenance et le référencement SEO & GEO.
      </p>
    </div>
  </section>

  <!-- PRICING CARDS -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-12 md:px-8 md:py-16">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-0 lg:grid-cols-3 items-stretch">

        <!-- ESSENTIEL -->
        <div class="pricing-card rounded-xl lg:rounded-r-none border border-[var(--color-border)] bg-white p-6 lg:p-7 flex flex-col">
          <div class="mb-3">
            <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider text-[var(--color-text-muted)]" style="letter-spacing: 0.15em;">Essentiel</span>
          </div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-1">Site One Page</h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-5 leading-relaxed">Une page unique qui dit l'essentiel. Parfait pour démarrer.</p>

          <div class="mb-5">
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-[var(--color-text)]">490</span>
              <span class="text-xl font-bold text-[var(--color-text)]">€</span>
              <span class="text-sm text-[var(--color-text-muted)] ml-1">HT</span>
            </div>
          </div>

          <div class="mb-5 space-y-2.5 flex-grow">
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]"><strong>1 page</strong> complète et structurée</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Design custom à votre image</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Responsive mobile & tablette</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Formulaire de contact</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">SEO & GEO optimisé</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Lighthouse 95+</span>
            </div>
          </div>

          <div class="mt-auto pt-4">
            <a href="/contact" class="block w-full py-3 px-5 text-center rounded-lg text-sm font-semibold border-2 border-[var(--color-border)] text-[var(--color-text)] hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all duration-200">
              Demander un devis
            </a>
            <p class="text-center text-xs text-[var(--color-text-muted)] mt-2">Livré en 5 jours</p>
            <a href="/100-sites-artisans" target="_blank" rel="noopener" class="block text-center text-xs mt-3 font-medium transition-colors" style="color: var(--color-accent);">
              Artisan ? Ce site peut être <strong>gratuit</strong> pour vous →
            </a>
          </div>
        </div>

        <!-- MULTI-PAGES (RECOMMANDÉ) -->
        <div class="pricing-card pricing-card--featured relative rounded-xl p-6 lg:p-7 flex flex-col z-10" style="background-color: #111; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(232, 108, 71, 0.3);">
          <div class="absolute top-0 left-0 right-0 h-1 rounded-t-xl" style="background: linear-gradient(90deg, #E86C47, #F5C8B3);"></div>

          <div class="mb-3 flex items-center justify-between">
            <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider text-neutral-300" style="letter-spacing: 0.15em;">Multi-pages</span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-[var(--color-accent)] text-white text-xs font-bold rounded-full">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              Populaire
            </span>
          </div>
          <h2 class="text-xl font-bold text-white mb-1">Site Vitrine</h2>
          <p class="text-sm text-neutral-300 mb-5 leading-relaxed">Le choix de la plupart des pros et artisans.</p>

          <div class="mb-5">
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-white">1 290</span>
              <span class="text-xl font-bold text-white">€</span>
              <span class="text-sm text-neutral-300 ml-1">HT</span>
            </div>
          </div>

          <p class="text-xs font-semibold uppercase tracking-wider text-neutral-400 mb-3">Tout de Essentiel, plus :</p>
          <div class="mb-5 space-y-2.5 flex-grow">
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>5 à 7 pages</strong> personnalisées</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-white">Formulaire contact + devis</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-white">Animations au scroll</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-white">Galerie photos / réalisations</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-white">Blog SEO intégré</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-white">Lighthouse 95+ <strong>garanti</strong></span>
            </div>
          </div>

          <div class="mt-auto pt-4">
            <a href="/contact" class="block w-full py-3 px-5 text-center rounded-lg text-sm font-semibold text-white transition-all duration-200" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 15px rgba(232, 108, 71, 0.4);">
              Démarrer mon projet
            </a>
            <p class="text-center text-xs text-neutral-400 mt-2">Livré en 7-10 jours</p>
          </div>
        </div>

        <!-- SUR MESURE -->
        <div class="pricing-card rounded-xl lg:rounded-l-none border border-[var(--color-border)] bg-white p-6 lg:p-7 flex flex-col">
          <div class="mb-3">
            <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider text-[var(--color-text-muted)]" style="letter-spacing: 0.15em;">Sur mesure</span>
          </div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-1">Site Avancé</h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-5 leading-relaxed">Paiement, réservation, e-commerce — sans limites.</p>

          <div class="mb-5">
            <p class="text-xs text-[var(--color-text-muted)] mb-0.5">À partir de</p>
            <div class="flex items-baseline gap-1">
              <span class="text-4xl font-extrabold text-[var(--color-text)]">1 990</span>
              <span class="text-xl font-bold text-[var(--color-text)]">€</span>
              <span class="text-sm text-[var(--color-text-muted)] ml-1">HT</span>
            </div>
          </div>

          <p class="text-xs font-semibold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Tout de Multi-pages, plus :</p>
          <div class="mb-5 space-y-2.5 flex-grow">
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]"><strong>Pages illimitées</strong></span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Paiement en ligne (Stripe)</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Réservation / Booking intégré</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Animations & interactions avancées</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Analytics & suivi conversions</span>
            </div>
            <div class="flex items-center gap-2.5">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-4 h-4" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Multi-langues possible</span>
            </div>
          </div>

          <div class="mt-auto pt-4">
            <a href="/contact" class="block w-full py-3 px-5 text-center rounded-lg text-sm font-semibold border-2 border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-all duration-200">
              Discuter de mon projet
            </a>
            <p class="text-center text-xs text-[var(--color-text-muted)] mt-2">Livré en 2-4 semaines</p>
          </div>
        </div>

      </div>

      <!-- INCLUS DANS TOUTES LES FORMULES — PRO BANNER -->
      <div class="mt-10 relative overflow-hidden rounded-2xl" style="background: linear-gradient(135deg, #0D0D0D 0%, #1A1A1A 100%);">
        <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;"></div>
        <div class="relative z-10 px-8 py-8 md:px-12 md:py-10">
          <div class="flex items-center justify-center gap-3 mb-8">
            <div class="h-px flex-1 max-w-16" style="background: linear-gradient(90deg, transparent, rgba(232, 108, 71, 0.5));"></div>
            <h3 class="text-center text-sm font-bold uppercase tracking-widest text-white/90" style="letter-spacing: 0.2em;">Inclus dans chaque formule</h3>
            <div class="h-px flex-1 max-w-16" style="background: linear-gradient(270deg, transparent, rgba(232, 108, 71, 0.5));"></div>
          </div>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
            <div class="text-center group">
              <div class="w-11 h-11 mx-auto mb-3 rounded-xl flex items-center justify-center" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.2);">
                <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 15a4 4 0 004 4h9a5 5 0 10-.1-9.999 5.002 5.002 0 10-9.78 2.096A4.001 4.001 0 003 15z" /></svg>
              </div>
              <p class="text-sm font-semibold text-white">Hébergement 1 an</p>
              <p class="text-xs text-neutral-400 mt-0.5">Cloudflare CDN mondial</p>
            </div>
            <div class="text-center group">
              <div class="w-11 h-11 mx-auto mb-3 rounded-xl flex items-center justify-center" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.2);">
                <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>
              </div>
              <p class="text-sm font-semibold text-white">Nom de domaine</p>
              <p class="text-xs text-neutral-400 mt-0.5">Inclus la 1ère année</p>
            </div>
            <div class="text-center group">
              <div class="w-11 h-11 mx-auto mb-3 rounded-xl flex items-center justify-center" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.2);">
                <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              </div>
              <p class="text-sm font-semibold text-white">SEO & GEO</p>
              <p class="text-xs text-neutral-400 mt-0.5">Google + moteurs IA</p>
            </div>
            <div class="text-center group">
              <div class="w-11 h-11 mx-auto mb-3 rounded-xl flex items-center justify-center" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.2);">
                <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              </div>
              <p class="text-sm font-semibold text-white">Maintenance 1 an</p>
              <p class="text-xs text-neutral-400 mt-0.5">Mises à jour & support</p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-5">
        <p class="text-xs text-[var(--color-text-muted)]">
          Paiement en 2 ou 3 fois possible · Tous les prix sont HT · Devis précis après appel
        </p>
      </div>
    </div>
  </section>

  <!-- COMPARISON TABLE -->
  <section class="w-full px-6 py-16 md:px-8 md:py-24" style="background: linear-gradient(180deg, #FAFAFA 0%, #FFFFFF 100%);">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-3" style="letter-spacing: 0.2em;">Comparatif</p>
        <h2 class="text-3xl font-bold text-[var(--color-text)]">Ce qui est inclus dans chaque formule</h2>
      </div>

      <div class="overflow-x-auto rounded-2xl" style="box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04);">
        <table class="w-full text-sm" style="border-collapse: separate; border-spacing: 0;">
          <!-- HEADER -->
          <thead>
            <tr>
              <th class="px-6 py-5 text-left text-xs font-bold uppercase tracking-wider text-[var(--color-text-muted)] bg-white rounded-tl-2xl" style="letter-spacing: 0.1em; width: 30%;">Fonctionnalité</th>
              <th class="px-4 py-5 text-center bg-white" style="width: 23%;">
                <span class="block text-sm font-bold text-[var(--color-text)]">Essentiel</span>
                <span class="block text-lg font-extrabold text-[var(--color-text)] mt-0.5">490<span class="text-xs font-normal text-[var(--color-text-muted)] ml-0.5">€ HT</span></span>
              </th>
              <th class="px-4 py-5 text-center relative" style="width: 23%; background-color: #111;">
                <div class="absolute top-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, #E86C47, #F5C8B3);"></div>
                <span class="inline-flex items-center gap-1 px-2.5 py-0.5 bg-[var(--color-accent)] text-white text-[10px] font-bold rounded-full mb-1.5">
                  <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  Populaire
