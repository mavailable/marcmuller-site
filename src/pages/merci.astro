---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import { business } from '../data/business';

const checkIcon = `<svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>`;
---

<BaseLayout
  title="Message reçu — Marc M"
  description="Merci pour votre message. Je lis tout personnellement et je reviens vers vous sous 48h."
  noindex={true}
  lang="fr"
  frPath="/merci"
  enPath="/en/thank-you"
>
  <!-- MAIN SECTION -->
  <section class="w-full bg-white px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <!-- Checkmark Icon -->
      <div class="flex justify-center mb-8">
        <div class="text-[var(--color-accent)]" set:html={checkIcon} />
      </div>

      <!-- Main Message -->
      <h1 class="mb-6 text-4xl font-bold leading-tight text-[var(--color-text)] md:text-5xl">
        Message reçu !
      </h1>

      <p class="mb-8 text-lg text-[var(--color-text-muted)] md:text-xl leading-relaxed">
        Merci pour votre message. Je lis tout personnellement et je reviens vers vous sous 48h max.
      </p>

      <!-- Confirmation Email -->
      <div class="bg-[var(--color-bg-alt)] rounded-lg p-8 mb-12 border border-[var(--color-border)]">
        <p class="text-sm text-[var(--color-text-muted)] mb-2">Vérifiez votre email (y compris les spams) pour une confirmation.</p>
        <p class="text-sm text-[var(--color-text-muted)]">
          Si vous ne recevez rien dans 5 minutes, cliquez le bouton ci-dessous.
        </p>
      </div>

      <!-- What's Next -->
      <div class="mb-12">
        <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">En attendant :</h2>
        <div class="grid gap-4 md:grid-cols-3">
          <a
            href="/commander"
            class="block p-6 border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-bg)] transition-colors text-left"
          >
            <p class="font-bold text-[var(--color-text)] mb-2">Commander un site</p>
            <p class="text-sm text-[var(--color-text-muted)]">Site Vitrine à 490€ — commandez en ligne</p>
          </a>
          <a
            href="/qui-suis-je"
            class="block p-6 border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-bg)] transition-colors text-left"
          >
            <p class="font-bold text-[var(--color-text)] mb-2">Me connaître</p>
            <p class="text-sm text-[var(--color-text-muted)]">Mon parcours et mes convictions</p>
          </a>
          <a
            href="/"
            class="block p-6 border border-[var(--color-border)] rounded-lg hover:bg-[var(--color-bg)] transition-colors text-left"
          >
            <p class="font-bold text-[var(--color-text)] mb-2">Retour à l'accueil</p>
            <p class="text-sm text-[var(--color-text-muted)]">Découvrir mes réalisations</p>
          </a>
        </div>
      </div>

      <!-- Direct Contact Info -->
      <div class="bg-[var(--color-bg)] rounded-lg p-8 mb-12">
        <p class="text-sm text-[var(--color-text-muted)] mb-5">
          Vous préférez ne pas attendre ? Contactez-moi directement :
        </p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center items-center">
          <a
            href={`https://wa.me/${business.whatsapp}?text=${encodeURIComponent("Bonjour Marc, je viens d'envoyer mon formulaire et je voulais juste vous dire bonjour !")}`}
            target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg px-5 py-2.5 text-sm font-semibold text-white transition-all hover:shadow-md"
            style="background:#25D366;"
            data-umami-event="merci-whatsapp-click"
          >
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            WhatsApp
          </a>
          <a href="mailto:marc@muller.im" class="text-sm font-medium text-[var(--color-accent)] hover:underline" data-umami-event="email-click">
            marc@muller.im
          </a>
        </div>
      </div>

      <!-- Back Home Button -->
      <Button href="/" variant="primary" size="lg">
        Retour à l'accueil
      </Button>
    </div>
  </section>
</BaseLayout>
