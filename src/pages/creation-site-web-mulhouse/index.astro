---
import VilleTemplate from '@components/VilleTemplate.astro';

const title = "Création de site web sur mesure à Mulhouse | Marc M";
const description = "Créateur de sites web custom à Mulhouse. Sites rapides, bien référencés Google & IA, optimisés pour les indépendants et commerçants du Haut-Rhin. À partir de 490€.";

const ville = "Mulhouse";
const intro = "Vous êtes indépendant, commerçant ou thérapeute à Mulhouse et vous avez besoin d'un site web qui vous ramène des clients ? Je suis Marc M., je crée des sites sur mesure pour les pros du Haut-Rhin. Rapides, bien référencés, livrés en 7 jours. Pas de WordPress, pas de template.";

const sections = [
  {
    title: "La situation à Mulhouse : des pros invisibles en ligne",
    content: "Mulhouse est une ville d'artisans, de commerçants et de créateurs. Mais côté web, beaucoup sont invisibles.\n\nLe constat :\n- Des sites WordPress datés ou pas de site du tout\n- Des fiches Google Business incomplètes\n- Des concurrents mieux référencés qui captent les clients\n- Des visiteurs mobile qui partent après 3 secondes de chargement\n\nQuand quelqu'un tape « coiffeur Mulhouse » ou « plombier Mulhouse » sur Google, êtes-vous dans les résultats ? Si non, vous perdez des clients chaque jour.\n\nUn site moderne et bien référencé change la donne."
  },
  {
    title: "Mon approche pour les pros de Mulhouse",
    content: "Je travaille à distance depuis Metz, mais j'ai déjà accompagné des clients dans tout le Grand Est — y compris en Alsace.\n\nPour chaque site, je fais :\n- Un design unique qui reflète votre activité (pas de template)\n- Référencement Google local optimisé (mots-clés Mulhouse, Haut-Rhin, carte Google)\n- Référencement IA inclus (ChatGPT, Perplexity, Claude vous citent)\n- Responsive parfait (80% de vos clients cherchent sur mobile)\n- Performance maximale (Lighthouse 100, chargement < 1 seconde)\n- Rédaction de tous vos textes incluse\n\nLivraison en 7 jours. Un échange de cadrage de 15 minutes pour démarrer — par téléphone, visio ou écrit."
  },
  {
    title: "Exemples de sites pour Mulhouse et le Haut-Rhin",
    content: "**Salon Emma (Coiffure)**\nSite vitrine avec galerie avant/après, prestations, tarifs et prise de rendez-vous. Design chaleureux, SEO local « coiffeur + ville ».\n\n**Ostéo Reinhardt (Santé)**\nSite multi-pages pour un cabinet d'ostéopathie : approche, pathologies traitées, tarifs, prise de RDV en ligne. Sobre et professionnel.\n\n**Boulangerie Pétrin (Artisanat)**\nSite vitrine avec horaires, gamme de pains et viennoiseries, commande en ligne pour le week-end. Photos appétissantes, chargement instantané."
  }
];

const faq = [
  {
    question: "Vous êtes basé à Metz, vous travaillez vraiment sur Mulhouse ?",
    answer: "Oui. Tout se fait à distance — échange de cadrage par téléphone ou visio, allers-retours par email et WhatsApp. J'ai des clients dans tout le Grand Est et au-delà. La distance ne change rien à la qualité ni au délai."
  },
  {
    question: "Combien de temps pour apparaître sur Google à Mulhouse ?",
    answer: "Votre site est en ligne en 7 jours. Le référencement local (Google Maps, résultats organiques) prend 2 à 8 semaines pour être visible, selon la concurrence sur vos mots-clés. Le SEO technique est inclus dès la livraison."
  },
  {
    question: "Vous pouvez faire un site bilingue français/allemand ?",
    answer: "Oui. C'est pertinent pour Mulhouse et la zone frontalière. Je propose des sites bilingues FR/DE ou FR/EN. Le surcoût dépend du volume de contenu — on en discute lors de l'échange de cadrage."
  },
  {
    question: "C'est quoi la différence avec une agence web à Mulhouse ?",
    answer: "Le prix (490€ vs 2000-5000€), le délai (7 jours vs 4-8 semaines), et l'interlocuteur unique (moi, du début à la fin). Même qualité technique — scores Lighthouse 100/100, SEO inclus, design sur mesure. Pas de commercial, pas de chef de projet intermédiaire."
  }
];

const pricingExpress = {
  title: "Site Vitrine",
  price: "490€",
  features: [
    "✓ Design sur mesure, pas un template",
    "✓ Référencé Google & IA",
    "✓ Formulaire, WhatsApp, appel",
    "✓ Lighthouse 100/100",
    "✓ Livré en 7 jours"
  ]
};

const pricingCustom = {
  title: "Projet Sur Mesure",
  price: "Sur devis",
  features: [
    "✓ Multi-pages, blog, CMS",
    "✓ Fonctionnalités métier",
    "✓ Stratégie SEO avancée",
    "✓ Optimisé IA (ChatGPT, Claude)",
    "✓ Devis gratuit sous 48h"
  ]
};

const geo = {
  lat: 47.7508,
  lon: 7.3359
};

const areaServed = ["Mulhouse", "Haut-Rhin", "Colmar", "Guebwiller", "Altkirch", "Saint-Louis", "Wittenheim"];

const ctaTitle = "Prêt à lancer votre site web à Mulhouse ?";
const ctaText = "Écrivez-moi ou appelez. Échange gratuit de 15 minutes, sans engagement. On regarde ensemble ce qu'il vous faut.";
const ctaButton = "Commander mon site — 490€";
---

<VilleTemplate
  title={title}
  description={description}
  ville={ville}
  intro={intro}
  sections={sections}
  faq={faq}
  pricingExpress={pricingExpress}
  pricingCustom={pricingCustom}
  geo={geo}
  areaServed={areaServed}
  ctaTitle={ctaTitle}
  ctaText={ctaText}
  ctaButton={ctaButton}
  frPath="/creation-site-web-mulhouse"
/>
