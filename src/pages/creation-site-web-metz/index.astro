---
import VilleTemplate from '@components/VilleTemplate.astro';

const title = "Création de site web sur mesure à Metz | Marc M";
const description = "Créateur de sites web custom à Metz. Sites rapides, bien référencés, optimisés pour Google. À partir de 490€. Projets complexes sur devis.";

const ville = "Metz";
const intro = "Vous êtes artisan, commerçant ou entrepreneur à Metz et vous avez besoin d'un site web efficace ? Je suis Marc M., je crée des sites custom pour les PME de Metz et Moselle. Rapides, bien référencés. Pas de WordPress, pas de template réutilisé.";

const sections = [
  {
    title: "La situation à Metz : beaucoup de bonne volonté, peu de bons sites",
    content: "Metz est une ville avec une vrai histoire, une vraie âme. Mais côté web, beaucoup de commerces messiniens sont à la traîne.\n\nVous voyez partout des sites :\n- Moches et à jour de 2010\n- Lents (chargent en 10 secondes)\n- Peu visibles sur Google (leurs clients les trouvent grâce au bouche-à-oreille, pas le web)\n- Pas mobile-friendly\n\nConséquence ? Vous perdez des clients qui cherchent sur Google. Un client qui tappe « plombier Metz » ou « restaurant Metz » et qui ne vous trouve pas, c'est perdu.\n\nUn site web correct peut tripler votre trafic local."
  },
  {
    title: "Mon approche pour les entrepreneurs de Metz",
    content: "Je connais Metz. J'y ai travaillé avec une dizaine de clients. Je sais ce qui marche ici.\n\nPour chaque site, je fais :\n- Un design qui épouse votre identité (pas du template)\n- Optimisation Google locale (cartes, mots-clés Metz, avis)\n- Responsive parfait (presque 80% de vos clients cherchent sur mobile)\n- Performance au maximum (< 2s de chargement, garanti)\n- Formulaire de contact simplifié (vos clients doivent pouvoir vous contacter en 30 secondes)\n\nEt je vous laisse pas tomber après livraison. Maintenance incluse 3 mois, puis je reste dispo pour les petites mises à jour."
  },
  {
    title: "Sites créés à Metz",
    content: "**Salon Lumière (Metz)**\nAvant : Un site WordPress lent avec des images géantes.\nAprès : Site nouveau, rapide, avec galerie avant-après, tarifs clairs, formulaire rendez-vous.\nRésultat : Nouvelles clientes qui trouvent le salon sur Google + réservations en ligne +30%.\n\n**Charpente Gérard (Moselle)**\nAvant : Pas de site web. Juste des appels recommandés.\nAprès : Site avec galerie de chantiers, témoignages, tarifs indicatifs, devis en ligne.\nRésultat : Premier mois, 3 nouveaux devis via le site. Avant, c'était 0.\n\n**La Boulangerie du Coin (Metz)**\nAvant : Facebook seul, pas de site.\nAprès : Site avec menu, horaires, actualités, commandes en ligne possibles.\nRésultat : Trafic pieds en magasin stable, mais aussi commandes en ligne les dimanche."
  }
];

const faq = [
  {
    question: "Est-ce que vous êtes vraiment basé à Metz ou ailleurs ?",
    answer: "Je suis basé à Montigny-lès-Metz, juste à côté de Metz. Je connais la ville. Rendez-vous Zoom pour commencer, puis on peut se voir en vrai si vous voulez."
  },
  {
    question: "Combien de temps pour voir des résultats (appels, clients) ?",
    answer: "Court terme (semaines 1-4) :\n- Votre site est en ligne\n- Vous montez dans Google pour vos mots-clés locaux Metz\n\nMoyen terme (mois 1-3) :\n- Vous recevez vos premiers appels inbound\n- Votre réputation monte (avis, citations)\n\nLong terme (mois 3-6) :\n- Trafic stable et régulier\n- Vous êtes dominant dans votre catégorie localement\n\nC'est pas magique, mais ça marche."
  },
  {
    question: "Vous faites du SEO avancé ou c'est just un site bien fait ?",
    answer: "Les deux. Un site bien fait = déjà 80% du SEO. Après, le reste (content marketing, netlinking) c'est votre boulot ou on peut le faire moyennant surcoût.\n\nSur le Site Vitrine, c'est just optimisation on-page + local. Sur le Projet Sur Mesure, j'inclus une stratégie plus avancée (blogs, structured data riche)."
  },
  {
    question: "Quel est votre processus après la livraison ?",
    answer: "J'inclus une maintenance 3 mois (j'écoute vos changements, je les mets en ligne). Après 3 mois, vous pouvez continuer avec moi (maintenance : 100-150€/mois) ou vous gérer seuls (c'est simple).\n\nLes petites mises à jour (photos, texte), vous pouvez les faire vous-mêmes via l'interface d'édition. Les choses plus tech, j'interviens."
  }
];

const pricingExpress = {
  title: "Site Vitrine",
  price: "490€",
  features: [
    "✓ Design sur mesure, pas un template",
    "✓ Référencé Google & IA",
    "✓ Formulaire, WhatsApp, appel",
    "✓ Lighthouse 100/100",
    "✓ Livré en 7 jours"
  ]
};

const pricingCustom = {
  title: "Projet Sur Mesure",
  price: "Sur devis",
  features: [
    "✓ Multi-pages, blog, CMS",
    "✓ Fonctionnalités métier",
    "✓ Stratégie SEO avancée",
    "✓ Optimisé IA (ChatGPT, Claude)",
    "✓ Devis gratuit sous 48h"
  ]
};

const geo = {
  lat: 49.1193,
  lon: 6.1757
};

const areaServed = ["Metz", "Moselle", "Luxembour-Metz", "Thionville", "Yutz"];

const ctaTitle = "Prêt à avoir un site web qui marche à Metz ?";
const ctaText = "Écrivez-moi. Appel gratuit 30 min. Je vous dis exactly what you need et on voit si on peut bosser ensemble.";
const ctaButton = "Commencer mon site Metz";
---

<VilleTemplate
  title={title}
  description={description}
  ville={ville}
  intro={intro}
  sections={sections}
  faq={faq}
  pricingExpress={pricingExpress}
  pricingCustom={pricingCustom}
  geo={geo}
  areaServed={areaServed}
  ctaTitle={ctaTitle}
  ctaText={ctaText}
  ctaButton={ctaButton}
  frPath="/creation-site-web-metz"
  enPath="/en/web-design-metz"
/>
