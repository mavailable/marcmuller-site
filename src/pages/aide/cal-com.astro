---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const title = 'Configurer votre agenda Cal.com — Guide pas-à-pas · Marc M';
const description = 'Créez votre agenda en ligne gratuit avec Cal.com pour que vos clients réservent directement un créneau. Guide complet en 10 minutes.';

const breadcrumbs = [
  { name: 'Accueil', url: `${business.url}/` },
  { name: 'Aide', url: `${business.url}/aide/` },
  { name: 'Cal.com', url: `${business.url}/aide/cal-com/` },
];

const howToSteps = [
  { name: 'Créez votre compte', text: 'Rendez-vous sur cal.com et cliquez sur "Get started". Inscrivez-vous avec votre email professionnel. Le plan gratuit suffit.' },
  { name: 'Configurez votre profil', text: 'Entrez votre nom, votre activité et votre fuseau horaire (Europe/Paris). Ajoutez une photo si vous le souhaitez.' },
  { name: 'Définissez vos disponibilités', text: 'Dans "Availability", indiquez vos jours et créneaux horaires de travail. Par exemple : lundi-vendredi, 9h-12h et 14h-18h. Cal.com n\'affichera que ces créneaux à vos clients.' },
  { name: 'Créez un type de rendez-vous', text: 'Dans "Event Types", modifiez l\'événement par défaut ou créez-en un nouveau. Donnez-lui un nom clair : "Rendez-vous téléphonique — 30 min" ou "Visite atelier — 1h". Choisissez la durée.' },
  { name: 'Choisissez le mode de rendez-vous', text: 'Pour un appel téléphonique : sélectionnez "Phone call" et entrez votre numéro. Pour une visio : connectez Google Meet ou Zoom. Pour un rendez-vous physique : indiquez votre adresse dans "Location".' },
  { name: 'Testez et copiez votre lien', text: 'Votre lien de réservation ressemble à cal.com/votre-nom. Testez-le vous-même pour vérifier que tout fonctionne, puis envoyez-moi le lien.' },
];

const faq = [
  {
    question: 'L\'interface Cal.com est en anglais, c\'est normal ?',
    answer: 'Oui, l\'interface d\'administration est en anglais. Mais la page de réservation vue par vos clients peut être en français. Les termes utilisés dans ce guide ("Availability", "Event Types", "Location") correspondent aux menus que vous verrez.',
  },
  {
    question: 'Pourquoi Cal.com plutôt que Calendly ?',
    answer: 'Cal.com est open-source et son plan gratuit est plus généreux que Calendly : pas de limite d\'événements, notifications email incluses, synchronisation Google Agenda.',
  },
  {
    question: 'Mes clients verront quoi exactement ?',
    answer: 'Une page simple avec un calendrier et vos créneaux disponibles. Ils choisissent un jour, un horaire, remplissent leur nom et email, et c\'est réservé. Vous recevez un email de confirmation automatique.',
  },
];
---

<BaseLayout title={title} description={description} lang="fr" frPath="/aide/cal-com">

  <SchemaOrg type="breadcrumb" data={breadcrumbs} />
  <SchemaOrg type="howTo" data={{
    name: 'Configurer un agenda en ligne Cal.com',
    description: 'Guide pour créer et configurer votre agenda Cal.com gratuit, définir vos disponibilités et obtenir votre lien de réservation.',
    totalTime: 'PT10M',
    steps: howToSteps,
  }} />
  <SchemaOrg type="faqPage" data={faq} />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/aide" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour aux guides
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-violet-400/30 bg-violet-400/10 px-3 py-1 text-xs font-semibold text-violet-300">
          Agenda
        </span>
        <span class="text-sm text-neutral-400">~10 minutes</span>
        <span class="text-sm text-neutral-400">•</span>
        <span class="text-sm text-neutral-400">100% gratuit</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        Configurer votre agenda Cal.com
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        Cal.com permet à vos clients de réserver un créneau directement depuis votre site. Plus besoin d'échanger 5 messages pour trouver un horaire.
      </p>
    </div>
  </section>

  <!-- GUIDE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">

        <!-- Intro -->
        <div class="mb-10 rounded-lg bg-violet-50 border border-violet-200 p-5">
          <p class="text-sm font-semibold text-violet-800 mb-1">Bon à savoir</p>
          <p class="text-sm text-violet-700 leading-relaxed">
            L'interface Cal.com est en anglais, mais pas de panique — ce guide traduit chaque étape. La page de réservation vue par vos clients sera, elle, en français.
          </p>
        </div>

        <!-- Steps -->
        <div class="space-y-8">
          {howToSteps.map((step, i) => (
            <div class="flex gap-5">
              <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-[var(--color-accent)] text-white font-bold text-sm shadow-md">
                {i + 1}
              </div>
              <div class="flex-1 pt-1.5">
                <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">{step.name}</h2>
                <p class="text-[var(--color-text-muted)] leading-relaxed">{step.text}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Tips -->
        <div class="mt-10 rounded-lg bg-amber-50 border border-amber-200 p-5">
          <p class="text-sm font-semibold text-amber-800 mb-2">Conseils</p>
          <ul class="list-disc pl-4 text-sm text-amber-700 leading-relaxed space-y-1.5">
            <li>Connectez votre Google Agenda pour éviter les doubles réservations.</li>
            <li>Activez les rappels par email — ça réduit les rendez-vous oubliés.</li>
            <li>Ajoutez un délai de 15 min entre les rendez-vous pour souffler.</li>
            <li>Limitez la prise de RDV à 7 jours à l'avance si votre planning change souvent.</li>
          </ul>
        </div>

        <!-- Link format -->
        <div class="mt-10 rounded-lg bg-neutral-50 border border-neutral-200 p-5">
          <p class="text-sm font-semibold text-neutral-700 mb-2">À quoi ressemble votre lien ?</p>
          <code class="block bg-neutral-100 rounded-lg px-4 py-3 text-sm font-mono text-neutral-600">
            cal.com/votre-nom/rendez-vous-30min
          </code>
          <p class="mt-2 text-xs text-neutral-500">C'est ce lien que j'intégrerai sur votre site, dans un bouton "Prendre rendez-vous".</p>
        </div>

        <!-- FAQ -->
        <div class="mt-10 space-y-4">
          <p class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Questions fréquentes</p>
          {faq.map((item) => (
            <details class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)] overflow-hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-4 p-4 text-sm font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors [&::-webkit-details-marker]:hidden">
                {item.question}
                <svg class="w-4 h-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-4 pb-4">
                <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">{item.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-10 rounded-xl bg-[#0D0D0D] p-6 text-center">
          <p class="text-white font-semibold mb-2">Une fois votre agenda configuré</p>
          <p class="text-neutral-300 text-sm mb-5">Envoyez-moi votre lien Cal.com — je l'intègre sur votre site.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={`mailto:${business.email}?subject=Lien Cal.com&body=Bonjour Marc,%0A%0AVoici mon lien Cal.com : %0A%0AMerci !`}
              class="inline-block px-6 py-2.5 bg-[var(--color-accent)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--color-accent-hover)] transition-all"
              data-umami-event="aide-calcom-email">
              Envoyer par email
            </a>
            <a href={`https://wa.me/${business.whatsapp}?text=Bonjour Marc, voici mon lien Cal.com : `}
              target="_blank" rel="noopener noreferrer"
              class="inline-block px-6 py-2.5 bg-white/10 text-white text-sm font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all"
              data-umami-event="aide-calcom-whatsapp">
              Envoyer par WhatsApp
            </a>
          </div>
        </div>

        <!-- Nav between guides -->
        <div class="mt-8 flex items-center justify-between rounded-lg border border-[var(--color-border)] p-4">
          <a href="/aide/web3forms" class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-all">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            Web3Forms
          </a>
          <a href="/aide/acces-techniques" class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] hover:gap-3 transition-all">
            Accès techniques
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>
