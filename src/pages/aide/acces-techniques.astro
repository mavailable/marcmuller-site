---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const title = 'Préparer vos accès techniques — Guide · Marc M';
const description = 'Checklist des informations techniques à rassembler pour que je puisse mettre votre site en ligne : domaine, email, identifiants.';

const breadcrumbs = [
  { name: 'Accueil', url: 'https://marcm.fr/' },
  { name: 'Aide', url: 'https://marcm.fr/aide/' },
  { name: 'Accès techniques', url: 'https://marcm.fr/aide/acces-techniques/' },
];

const howToSteps = [
  { name: 'Identifiant OVH (si domaine chez OVH)', text: 'Votre identifiant client OVH (format: ab12345-ovh) et le nom de domaine acheté. Pas besoin du mot de passe — juste l\'identifiant, je vous guiderai pour la suite.' },
  { name: 'Clé Web3Forms', text: 'La clé d\'accès de votre compte Web3Forms (format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx). Voir le guide dédié si ce n\'est pas encore fait.' },
  { name: 'Lien Cal.com (si agenda)', text: 'Votre lien de réservation Cal.com (format: cal.com/votre-nom). Applicable uniquement si vous avez choisi l\'option agenda en ligne.' },
  { name: 'Logo en haute qualité', text: 'Votre logo au format PNG ou SVG, en haute résolution. Si vous n\'avez pas de logo, indiquez-le — je peux créer une identité visuelle simple.' },
  { name: 'Photos de votre activité', text: 'Entre 5 et 15 photos de votre travail, atelier, équipe ou produits. Des photos prises au téléphone suffisent — l\'important c\'est qu\'elles soient authentiques, pas des photos stock.' },
  { name: 'Textes et informations spécifiques', text: 'Horaires d\'ouverture, adresse complète, numéro de téléphone à afficher, email de contact, liens vers vos réseaux sociaux et fiche Google Business.' },
];
---

<BaseLayout title={title} description={description} ogType="article" lang="fr" frPath="/aide/acces-techniques">

  <SchemaOrg type="breadcrumb" data={breadcrumbs} />
  <SchemaOrg type="howTo" data={{
    name: 'Préparer les accès techniques pour la mise en ligne d\'un site',
    description: 'Checklist complète des informations et accès à rassembler pour permettre la mise en ligne de votre site web.',
    totalTime: 'PT5M',
    steps: howToSteps,
  }} />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/aide" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour aux guides
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-orange-400/30 bg-orange-400/10 px-3 py-1 text-xs font-semibold text-orange-300">
          Technique
        </span>
        <span class="text-sm text-neutral-400">~5 minutes</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        Préparer vos accès techniques
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        Tout ce dont j'ai besoin pour mettre votre site en ligne, rassemblé en une seule checklist.
      </p>
    </div>
  </section>

  <!-- GUIDE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">

        <!-- Intro -->
        <div class="mb-10 rounded-lg bg-orange-50 border border-orange-200 p-5">
          <p class="text-sm font-semibold text-orange-800 mb-1">Pas de panique</p>
          <p class="text-sm text-orange-700 leading-relaxed">
            Vous n'avez pas besoin de tout avoir en même temps. Envoyez-moi ce que vous avez, on avance étape par étape. Chaque élément a son propre guide si vous avez besoin d'aide.
          </p>
        </div>

        <!-- Checklist -->
        <div class="space-y-6">
          {howToSteps.map((step, i) => (
            <div class="flex gap-5 p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)]">
              <div class="flex-shrink-0 flex items-start pt-0.5">
                <div class="w-6 h-6 rounded border-2 border-[var(--color-accent)]/40 flex items-center justify-center">
                  <span class="text-xs font-bold text-[var(--color-accent)]">{i + 1}</span>
                </div>
              </div>
              <div class="flex-1">
                <h2 class="text-base font-bold text-[var(--color-text)] mb-1">{step.name}</h2>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{step.text}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Cross-links -->
        <div class="mt-10 rounded-lg bg-neutral-50 border border-neutral-200 p-5">
          <p class="text-sm font-semibold text-neutral-700 mb-3">Guides liés</p>
          <ul class="space-y-2">
            <li>
              <a href="/aide/domaine-ovh" class="text-sm text-[var(--color-accent)] hover:underline font-medium">
                Acheter votre nom de domaine chez OVH
              </a>
            </li>
            <li>
              <a href="/aide/web3forms" class="text-sm text-[var(--color-accent)] hover:underline font-medium">
                Créer votre compte Web3Forms
              </a>
            </li>
            <li>
              <a href="/aide/cal-com" class="text-sm text-[var(--color-accent)] hover:underline font-medium">
                Configurer votre agenda Cal.com
              </a>
            </li>
          </ul>
        </div>

        <!-- CTA -->
        <div class="mt-10 rounded-xl bg-[#0D0D0D] p-6 text-center">
          <p class="text-white font-semibold mb-2">Prêt ? Envoyez-moi tout d'un coup</p>
          <p class="text-neutral-300 text-sm mb-5">Un seul message avec tout ce que vous avez — je fais le tri.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={`mailto:${business.email}?subject=Accès techniques — Mon site&body=Bonjour Marc,%0A%0AVoici mes accès :%0A%0A- Identifiant OVH : %0A- Domaine : %0A- Clé Web3Forms : %0A- Lien Cal.com : %0A%0AMerci !`}
              class="inline-block px-6 py-2.5 bg-[var(--color-accent)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--color-accent-hover)] transition-all"
              data-umami-event="aide-acces-email">
              Envoyer par email
            </a>
            <a href={`https://wa.me/${business.whatsapp}?text=Bonjour Marc, voici mes accès techniques :%0A%0AIdentifiant OVH : %0ADomaine : %0AClé Web3Forms : %0ALien Cal.com : `}
              target="_blank" rel="noopener noreferrer"
              class="inline-block px-6 py-2.5 bg-white/10 text-white text-sm font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all"
              data-umami-event="aide-acces-whatsapp">
              Envoyer par WhatsApp
            </a>
          </div>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>
