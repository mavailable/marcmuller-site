---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const title = 'Préparer vos accès techniques — Checklist · Marc M';
const description = 'Checklist des informations techniques à rassembler pour la mise en ligne de votre site : domaine, clé Web3Forms, photos, logo.';

const breadcrumbs = [
  { name: 'Accueil', url: `${business.url}/` },
  { name: 'Aide', url: `${business.url}/aide/` },
  { name: 'Accès techniques', url: `${business.url}/aide/acces-techniques/` },
];

const checklist = [
  {
    name: 'Contact technique OVH (si domaine chez OVH)',
    text: 'Désignez-moi comme contact technique de votre domaine (identifiant : mm130337-ovh). Vous restez propriétaire — ça me permet uniquement de configurer les DNS.',
    guide: { href: '/aide/domaine-ovh', label: 'Guide domaine OVH' },
  },
  {
    name: 'Clé Web3Forms',
    text: 'La clé d\'accès de votre compte Web3Forms (format: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx). Indispensable pour activer votre formulaire de contact.',
    guide: { href: '/aide/web3forms', label: 'Guide Web3Forms' },
  },
  {
    name: 'Lien Cal.com (si agenda)',
    text: 'Votre lien de réservation Cal.com (format: cal.com/votre-nom). Applicable uniquement si vous avez choisi l\'option agenda en ligne.',
    guide: { href: '/aide/cal-com', label: 'Guide Cal.com' },
  },
  {
    name: 'Logo en haute qualité',
    text: 'Votre logo au format PNG ou SVG, en haute résolution. Si vous n\'avez pas de logo, indiquez-le — je peux créer une identité visuelle simple.',
    guide: null,
  },
  {
    name: 'Photos de votre activité',
    text: 'Entre 5 et 15 photos de votre travail, atelier, équipe ou produits. Des photos prises au téléphone suffisent — l\'important c\'est qu\'elles soient authentiques, pas des photos stock.',
    guide: null,
  },
  {
    name: 'Textes et informations spécifiques',
    text: 'Horaires d\'ouverture, adresse complète, numéro de téléphone à afficher, email de contact, liens vers vos réseaux sociaux et fiche Google Business.',
    guide: null,
  },
];

const faq = [
  {
    question: 'Dois-je tout avoir avant que vous commenciez ?',
    answer: 'Non. Je peux démarrer la création dès le brief validé. Les accès techniques ne sont nécessaires qu\'au moment de la mise en ligne. Envoyez-moi ce que vous avez, on complète au fur et à mesure.',
  },
  {
    question: 'Comment vous envoyer les photos ?',
    answer: 'Par email, WeTransfer, Google Drive ou WhatsApp — comme vous préférez. L\'important c\'est qu\'elles soient en bonne résolution (pas de captures d\'écran ou de miniatures).',
  },
  {
    question: 'Mes identifiants sont-ils en sécurité ?',
    answer: 'Je n\'ai pas besoin de votre mot de passe OVH — le rôle de contact technique me donne uniquement accès aux DNS du domaine. Pour la clé Web3Forms et le lien Cal.com, ce sont des informations qui ne donnent accès à rien de sensible.',
  },
];
---

<BaseLayout title={title} description={description} lang="fr" frPath="/aide/acces-techniques">

  <SchemaOrg type="breadcrumb" data={breadcrumbs} />
  <SchemaOrg type="faqPage" data={faq} />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/aide" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour aux guides
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-orange-400/30 bg-orange-400/10 px-3 py-1 text-xs font-semibold text-orange-300">
          Technique
        </span>
        <span class="text-sm text-neutral-400">~5 minutes</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        Préparer vos accès techniques
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        Tout ce dont j'ai besoin pour mettre votre site en ligne, rassemblé en une seule checklist.
      </p>
    </div>
  </section>

  <!-- GUIDE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">

        <!-- Intro -->
        <div class="mb-10 rounded-lg bg-orange-50 border border-orange-200 p-5">
          <p class="text-sm font-semibold text-orange-800 mb-1">Pas de panique</p>
          <p class="text-sm text-orange-700 leading-relaxed">
            Vous n'avez pas besoin de tout avoir en même temps. Envoyez-moi ce que vous avez, on avance étape par étape. Les trois premiers éléments ont chacun leur propre guide détaillé.
          </p>
        </div>

        <!-- Checklist -->
        <div class="space-y-6">
          {checklist.map((item, i) => (
            <div class="flex gap-5 p-4 rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)]">
              <div class="flex-shrink-0 flex items-start pt-0.5">
                <div class="w-6 h-6 rounded border-2 border-[var(--color-accent)]/40 flex items-center justify-center">
                  <span class="text-xs font-bold text-[var(--color-accent)]">{i + 1}</span>
                </div>
              </div>
              <div class="flex-1">
                <h2 class="text-base font-bold text-[var(--color-text)] mb-1">{item.name}</h2>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{item.text}</p>
                {item.guide && (
                  <a href={item.guide.href} class="mt-2 inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-accent)] hover:underline">
                    {item.guide.label}
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                    </svg>
                  </a>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- FAQ -->
        <div class="mt-10 space-y-4">
          <p class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Questions fréquentes</p>
          {faq.map((item) => (
            <details class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)] overflow-hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-4 p-4 text-sm font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors [&::-webkit-details-marker]:hidden">
                {item.question}
                <svg class="w-4 h-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-4 pb-4">
                <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">{item.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-10 rounded-xl bg-[#0D0D0D] p-6 text-center">
          <p class="text-white font-semibold mb-2">Prêt ? Envoyez-moi tout d'un coup</p>
          <p class="text-neutral-300 text-sm mb-5">Un seul message avec tout ce que vous avez — je fais le tri.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={`mailto:${business.email}?subject=Accès techniques — Mon site&body=Bonjour Marc,%0A%0AVoici mes accès :%0A%0A- Domaine : %0A- Contact technique OVH ajouté : oui / non%0A- Clé Web3Forms : %0A- Lien Cal.com : %0A%0AMerci !`}
              class="inline-block px-6 py-2.5 bg-[var(--color-accent)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--color-accent-hover)] transition-all"
              data-umami-event="aide-acces-email">
              Envoyer par email
            </a>
            <a href={`https://wa.me/${business.whatsapp}?text=Bonjour Marc, voici mes accès techniques :%0A%0ADomaine : %0AContact technique OVH ajouté : oui/non%0AClé Web3Forms : %0ALien Cal.com : `}
              target="_blank" rel="noopener noreferrer"
              class="inline-block px-6 py-2.5 bg-white/10 text-white text-sm font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all"
              data-umami-event="aide-acces-whatsapp">
              Envoyer par WhatsApp
            </a>
          </div>
        </div>

        <!-- Nav back -->
        <div class="mt-8 flex items-center justify-between rounded-lg border border-[var(--color-border)] p-4">
          <a href="/aide/cal-com" class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-all">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            Agenda Cal.com
          </a>
          <a href="/aide" class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] hover:gap-3 transition-all">
            Tous les guides
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>
