---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const title = 'Aide — Guides pour bien démarrer · Marc M';
const description = 'Guides pas-à-pas pour configurer votre domaine, formulaire de contact, agenda en ligne et autres outils liés à votre site web.';

interface Guide {
  title: string;
  slug: string;
  icon: string;
  duration: string;
  excerpt: string;
  tag: string;
}

const guides: Guide[] = [
  {
    title: 'Acheter votre nom de domaine chez OVH',
    slug: 'domaine-ovh',
    icon: '🌐',
    duration: '10 min',
    excerpt: 'Réservez votre .fr ou .com sur OVH et préparez-le pour la mise en ligne de votre site.',
    tag: 'Domaine',
  },
  {
    title: 'Créer votre compte Web3Forms',
    slug: 'web3forms',
    icon: '📬',
    duration: '3 min',
    excerpt: 'Créez un compte gratuit et récupérez votre clé d\'accès pour activer le formulaire de contact de votre site.',
    tag: 'Formulaire',
  },
  {
    title: 'Configurer votre agenda Cal.com',
    slug: 'cal-com',
    icon: '📅',
    duration: '10 min',
    excerpt: 'Créez votre agenda en ligne gratuit pour que vos clients réservent directement un créneau.',
    tag: 'Agenda',
  },
  {
    title: 'Préparer vos accès techniques',
    slug: 'acces-techniques',
    icon: '🔑',
    duration: '5 min',
    excerpt: 'Rassemblez les informations dont j\'ai besoin pour mettre votre site en ligne : domaine, email, identifiants.',
    tag: 'Technique',
  },
];

const breadcrumbs = [
  { name: 'Accueil', url: 'https://marcm.fr/' },
  { name: 'Aide', url: 'https://marcm.fr/aide/' },
];

const tagColors: Record<string, { badge: string; bar: string; heroBadge: string }> = {
  'Domaine':    { badge: 'bg-sky-100 text-sky-700',       bar: 'bg-sky-400',       heroBadge: 'border-sky-400/40 bg-sky-400/15 text-sky-300' },
  'Formulaire': { badge: 'bg-emerald-100 text-emerald-700', bar: 'bg-emerald-400', heroBadge: 'border-emerald-400/40 bg-emerald-400/15 text-emerald-300' },
  'Agenda':     { badge: 'bg-violet-100 text-violet-700', bar: 'bg-violet-400',    heroBadge: 'border-violet-400/40 bg-violet-400/15 text-violet-300' },
  'Technique':  { badge: 'bg-orange-100 text-orange-700', bar: 'bg-orange-400',    heroBadge: 'border-orange-400/40 bg-orange-400/15 text-orange-300' },
};
---

<BaseLayout title={title} description={description} lang="fr" frPath="/aide">

  <SchemaOrg type="breadcrumb" data={breadcrumbs} />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-4xl z-10">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-neutral-300">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></span>
        Centre d'aide
      </div>

      <h1 class="mb-5 text-4xl font-bold leading-tight text-white md:text-5xl">
        Guides de démarrage
      </h1>
      <p class="max-w-2xl text-lg text-neutral-300 md:text-xl leading-relaxed">
        Tout ce qu'il faut configurer pour votre site, expliqué pas-à-pas. Chaque guide prend moins de 10 minutes.
      </p>

      <!-- Tags -->
      <div class="mt-8 flex flex-wrap gap-2">
        {Object.entries(tagColors).map(([tag, colors]) => (
          <span class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-medium ${colors.heroBadge}`}>
            <span class={`w-1.5 h-1.5 rounded-full ${colors.bar}`}></span>
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- GUIDES GRID -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">
      <div class="grid gap-5 sm:grid-cols-2">
        {guides.map((guide) => (
          <a href={`/aide/${guide.slug}`} class="group block" data-umami-event="aide-guide-click" data-umami-event-guide={guide.slug}>
            <article class="flex h-full flex-col overflow-hidden rounded-xl border border-[var(--color-border)] bg-white shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
              <div class={`h-1 w-full shrink-0 ${tagColors[guide.tag]?.bar ?? 'bg-[var(--color-accent)]'}`}></div>

              <div class="flex flex-1 flex-col p-6">
                <!-- Icon + Meta -->
                <div class="mb-3 flex items-center gap-3">
                  <span class="text-2xl" aria-hidden="true">{guide.icon}</span>
                  <div class="flex flex-wrap items-center gap-2">
                    <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${tagColors[guide.tag]?.badge ?? 'bg-neutral-100 text-neutral-600'}`}>
                      {guide.tag}
                    </span>
                    <span class="flex items-center gap-1 text-xs text-[var(--color-text-muted)]">
                      <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                      </svg>
                      {guide.duration}
                    </span>
                  </div>
                </div>

                <!-- Title -->
                <h2 class="mb-3 text-base font-bold leading-snug text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent)] md:text-lg">
                  {guide.title}
                </h2>

                <!-- Excerpt -->
                <p class="mb-5 flex-1 text-sm leading-relaxed text-[var(--color-text-muted)]">
                  {guide.excerpt}
                </p>

                <!-- CTA -->
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-accent)] transition-all group-hover:gap-2.5">
                  Voir le guide
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </article>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-gradient-to-b from-[#1A1A1A] to-[#111111] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-white">Besoin d'un coup de main ?</h2>
      <p class="mb-8 text-neutral-300 leading-relaxed">
        Si vous bloquez sur une étape, envoyez-moi un message — je vous guide en direct.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-3 bg-[var(--color-accent)] text-white font-semibold rounded-xl hover:bg-[var(--color-accent-hover)] transition-all shadow-lg hover:shadow-xl"
        style="box-shadow: 0 10px 25px rgba(232, 108, 71, 0.3);"
        data-umami-event="aide-cta-contact"
      >
        Me contacter
      </a>
    </div>
  </section>
</BaseLayout>
