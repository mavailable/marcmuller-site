---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const title = 'Créer votre compte Web3Forms et récupérer la clé — Guide · Marc M';
const description = 'Créez un compte Web3Forms gratuit en 3 minutes et récupérez votre clé d\'accès pour activer le formulaire de contact de votre site.';

const breadcrumbs = [
  { name: 'Accueil', url: `${business.url}/` },
  { name: 'Aide', url: `${business.url}/aide/` },
  { name: 'Web3Forms', url: `${business.url}/aide/web3forms/` },
];

const howToSteps = [
  { name: 'Allez sur Web3Forms', text: 'Rendez-vous sur web3forms.com. C\'est un service gratuit — pas de carte bancaire demandée.' },
  { name: 'Entrez votre email professionnel', text: 'Dans la section "Create your Access Key", entrez l\'email sur lequel vous souhaitez recevoir les messages du formulaire de contact. C\'est l\'email que vos clients utiliseront pour vous joindre.' },
  { name: 'Vérifiez votre boîte mail', text: 'Web3Forms vous envoie un email de confirmation. Cliquez sur le lien dans l\'email. Vérifiez vos spams si vous ne le voyez pas.' },
  { name: 'Copiez votre clé d\'accès (Access Key)', text: 'Une fois confirmé, Web3Forms affiche votre Access Key — un code qui ressemble à "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx". Copiez-le.' },
  { name: 'Envoyez-moi la clé', text: 'Envoyez-moi cette clé par email ou WhatsApp. Je l\'intégrerai dans le formulaire de contact de votre site. Vos messages arriveront directement dans votre boîte mail.' },
];

const faq = [
  {
    question: 'À quoi sert cette clé exactement ?',
    answer: 'La clé fait le lien entre le formulaire de votre site et votre boîte mail. Quand un visiteur remplit le formulaire, Web3Forms utilise cette clé pour savoir à qui envoyer le message. Il n\'y a aucun risque à me la transmettre — elle ne donne accès à rien d\'autre.',
  },
  {
    question: 'Est-ce que Web3Forms est vraiment gratuit ?',
    answer: 'Oui. Le plan gratuit permet de recevoir 250 messages par mois, ce qui est largement suffisant pour un site vitrine. Pas de carte bancaire requise.',
  },
  {
    question: 'Je peux changer l\'email de réception plus tard ?',
    answer: 'Oui, vous pouvez modifier l\'email associé depuis votre tableau de bord Web3Forms à tout moment. Je n\'ai rien à changer de mon côté, la clé reste la même.',
  },
];
---

<BaseLayout title={title} description={description} lang="fr" frPath="/aide/web3forms">

  <SchemaOrg type="breadcrumb" data={breadcrumbs} />
  <SchemaOrg type="howTo" data={{
    name: 'Créer un compte Web3Forms et récupérer la clé d\'accès',
    description: 'Guide pour créer un compte Web3Forms gratuit et récupérer la clé d\'accès nécessaire au formulaire de contact de votre site.',
    totalTime: 'PT3M',
    steps: howToSteps,
  }} />
  <SchemaOrg type="faqPage" data={faq} />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/aide" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour aux guides
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-emerald-400/30 bg-emerald-400/10 px-3 py-1 text-xs font-semibold text-emerald-300">
          Formulaire
        </span>
        <span class="text-sm text-neutral-400">~3 minutes</span>
        <span class="text-sm text-neutral-400">•</span>
        <span class="text-sm text-neutral-400">100% gratuit</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        Créer votre compte Web3Forms
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        Web3Forms permet à vos visiteurs de vous envoyer un message depuis votre site. L'opération prend 3 minutes.
      </p>
    </div>
  </section>

  <!-- GUIDE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">

        <!-- Intro -->
        <div class="mb-10 rounded-lg bg-emerald-50 border border-emerald-200 p-5">
          <p class="text-sm font-semibold text-emerald-800 mb-1">Comment ca marche ?</p>
          <p class="text-sm text-emerald-700 leading-relaxed">
            Quand un visiteur remplit le formulaire de contact sur votre site, Web3Forms vous envoie son message directement par email. Pas d'interface compliquée — tout arrive dans votre boîte mail habituelle.
          </p>
        </div>

        <!-- Steps -->
        <div class="space-y-8">
          {howToSteps.map((step, i) => (
            <div class="flex gap-5">
              <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-[var(--color-accent)] text-white font-bold text-sm shadow-md">
                {i + 1}
              </div>
              <div class="flex-1 pt-1.5">
                <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">{step.name}</h2>
                <p class="text-[var(--color-text-muted)] leading-relaxed">{step.text}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Key format -->
        <div class="mt-10 rounded-lg bg-neutral-50 border border-neutral-200 p-5">
          <p class="text-sm font-semibold text-neutral-700 mb-2">À quoi ressemble la clé ?</p>
          <code class="block bg-neutral-100 rounded-lg px-4 py-3 text-sm font-mono text-neutral-600 break-all">
            a1b2c3d4-e5f6-7890-abcd-ef1234567890
          </code>
        </div>

        <!-- FAQ -->
        <div class="mt-10 space-y-4">
          <p class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Questions fréquentes</p>
          {faq.map((item) => (
            <details class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)] overflow-hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-4 p-4 text-sm font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors [&::-webkit-details-marker]:hidden">
                {item.question}
                <svg class="w-4 h-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-4 pb-4">
                <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">{item.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-10 rounded-xl bg-[#0D0D0D] p-6 text-center">
          <p class="text-white font-semibold mb-2">Une fois la clé copiée</p>
          <p class="text-neutral-300 text-sm mb-5">Envoyez-la moi par email ou WhatsApp — j'active votre formulaire dans la journée.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={`mailto:${business.email}?subject=Clé Web3Forms&body=Bonjour Marc,%0A%0AVoici ma clé Web3Forms : %0A%0AMerci !`}
              class="inline-block px-6 py-2.5 bg-[var(--color-accent)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--color-accent-hover)] transition-all"
              data-umami-event="aide-web3forms-email">
              Envoyer par email
            </a>
            <a href={`https://wa.me/${business.whatsapp}?text=Bonjour Marc, voici ma clé Web3Forms : `}
              target="_blank" rel="noopener noreferrer"
              class="inline-block px-6 py-2.5 bg-white/10 text-white text-sm font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all"
              data-umami-event="aide-web3forms-whatsapp">
              Envoyer par WhatsApp
            </a>
          </div>
        </div>

        <!-- Nav between guides -->
        <div class="mt-8 flex items-center justify-between rounded-lg border border-[var(--color-border)] p-4">
          <a href="/aide/domaine-ovh" class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-all">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" />
            </svg>
            Nom de domaine
          </a>
          <a href="/aide/cal-com" class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] hover:gap-3 transition-all">
            Agenda Cal.com
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>
