---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const title = 'Acheter votre nom de domaine chez OVH — Guide pas-à-pas · Marc M';
const description = 'Guide complet pour réserver votre nom de domaine .fr ou .com chez OVH. 10 minutes, tout est expliqué étape par étape.';

const breadcrumbs = [
  { name: 'Accueil', url: `${business.url}/` },
  { name: 'Aide', url: `${business.url}/aide/` },
  { name: 'Nom de domaine OVH', url: `${business.url}/aide/domaine-ovh/` },
];

const steps = [
  {
    name: 'Allez sur la page Noms de domaine d\'OVH',
    text: 'Cliquez sur le lien ci-dessous pour accéder directement à la page de recherche de noms de domaine.',
    link: { href: 'https://www.ovhcloud.com/fr/domains/', label: 'Ouvrir OVH — Noms de domaine' },
    image: '/images/aide/ovh-recherche-domaine.webp',
    imageAlt: 'Page de recherche de noms de domaine sur OVH — barre de recherche et extensions disponibles',
  },
  {
    name: 'Cherchez votre domaine',
    text: 'Tapez le nom souhaité (ex. mon-entreprise.fr) dans la barre de recherche en haut de page. OVH vous indique immédiatement s\'il est disponible et propose des alternatives.',
  },
  {
    name: 'Choisissez l\'extension',
    text: 'Privilégiez le .fr si votre clientèle est en France. Le .com est un bon complément. Comptez environ 7 €/an pour un .fr.',
  },
  {
    name: 'Créez votre compte OVH',
    text: 'Si c\'est votre première commande, cliquez sur "Créer un compte" sur la page de connexion. Utilisez votre email professionnel et notez bien vos identifiants.',
    link: { href: 'https://www.ovh.com/auth/?onsuccess=https%3A%2F%2Fwww.ovh.com%2Fmanager&ovhSubsidiary=FR', label: 'Ouvrir la page de connexion OVH' },
    image: '/images/aide/ovh-connexion.webp',
    imageAlt: 'Page de connexion OVH — formulaire pour se connecter ou créer un compte',
  },
  {
    name: 'Passez commande',
    text: 'Ajoutez le domaine au panier. Décochez les options inutiles (hébergement, email OVH — on n\'en a pas besoin). Validez et payez.',
    tip: 'Seul le nom de domaine est nécessaire. Votre site sera hébergé ailleurs — c\'est inclus dans ma prestation.',
  },
  {
    name: 'Désignez-moi comme contact technique',
    text: 'Connectez-vous à votre espace client OVH, puis accédez à la gestion des contacts de votre domaine. Remplacez le contact technique par mon identifiant :',
    code: 'uo9730-ovh',
    detail: 'Vous restez propriétaire du domaine. Le contact technique me permet uniquement de configurer les DNS pour pointer vers votre site.',
    link: { href: 'https://help.ovhcloud.com/csm/fr-dns-domain-contact-management?id=kb_article_view&sysparm_article=KB0058104', label: 'Voir le guide OVH "Gérer les contacts"' },
    path: 'Espace client > Noms de domaine > votre-domaine.fr > Contacts',
  },
  {
    name: 'Confirmez-moi que c\'est fait',
    text: 'Envoyez-moi un message par email ou WhatsApp avec le nom de domaine acheté. Je recevrai la demande de contact technique de mon côté et je pourrai lancer la configuration DNS.',
  },
];

const howToSteps = steps.map(s => ({ name: s.name, text: s.text }));

const faq = [
  {
    question: 'Pourquoi OVH et pas un autre registrar ?',
    answer: 'OVH est le premier registrar français (bureau d\'enregistrement de noms de domaine). Le support est en français, les prix sont parmi les plus bas du marché, et la gestion est simple. C\'est ce que je recommande à tous mes clients.',
  },
  {
    question: 'Faut-il aussi prendre l\'hébergement chez OVH ?',
    answer: 'Non. Votre site sera hébergé sur Cloudflare Pages, c\'est inclus dans ma prestation. Chez OVH, vous n\'avez besoin que du nom de domaine.',
  },
  {
    question: 'Comment choisir un bon nom de domaine ?',
    answer: 'Choisissez un nom court, facile à épeler au téléphone, sans tirets si possible. L\'idéal : le nom de votre entreprise suivi de .fr.',
  },
  {
    question: 'Le contact technique a-t-il accès à mon compte OVH ?',
    answer: 'Non. Le contact technique peut uniquement gérer les DNS du domaine (les réglages qui pointent vers votre site). Il ne peut pas accéder à votre compte, vos moyens de paiement ou transférer le domaine. Vous restez seul propriétaire.',
  },
];
---

<BaseLayout title={title} description={description} lang="fr" frPath="/aide/domaine-ovh">

  <SchemaOrg type="breadcrumb" data={breadcrumbs} />
  <SchemaOrg type="howTo" data={{
    name: 'Acheter un nom de domaine chez OVH',
    description: 'Guide pour réserver votre nom de domaine .fr ou .com sur OVH et le préparer pour votre site web.',
    totalTime: 'PT10M',
    steps: howToSteps,
  }} />
  <SchemaOrg type="faqPage" data={faq} />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/aide" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour aux guides
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-sky-400/30 bg-sky-400/10 px-3 py-1 text-xs font-semibold text-sky-300">
          Domaine
        </span>
        <span class="text-sm text-neutral-400">~10 minutes</span>
        <span class="text-sm text-neutral-400">•</span>
        <span class="text-sm text-neutral-400">Domaine ~7 €/an</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        Acheter votre nom de domaine chez OVH
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        Votre nom de domaine, c'est l'adresse de votre site sur internet. Voici comment le réserver en quelques minutes.
      </p>
    </div>
  </section>

  <!-- GUIDE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">

        <!-- Steps -->
        <div class="space-y-10">
          {steps.map((step, i) => (
            <div class="flex gap-5">
              <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-[var(--color-accent)] text-white font-bold text-sm shadow-md">
                {i + 1}
              </div>
              <div class="flex-1 pt-1.5">
                <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">{step.name}</h2>
                <p class="text-[var(--color-text-muted)] leading-relaxed">{step.text}</p>

                {/* Code block (identifiant OVH) */}
                {step.code && (
                  <div class="mt-3 rounded-lg bg-[#0D0D0D] px-5 py-3 inline-flex items-center gap-3">
                    <code class="text-lg font-mono font-bold text-white tracking-wide">{step.code}</code>
                    <span class="text-xs text-neutral-400">(mon identifiant OVH)</span>
                  </div>
                )}

                {/* Additional detail */}
                {step.detail && (
                  <p class="mt-2 text-sm text-[var(--color-text-muted)] leading-relaxed">{step.detail}</p>
                )}

                {/* Navigation path */}
                {step.path && (
                  <div class="mt-3 rounded-lg bg-neutral-50 border border-neutral-200 px-4 py-2.5">
                    <p class="text-xs font-semibold text-neutral-500 mb-1">Chemin dans l'espace client</p>
                    <p class="text-sm font-mono text-neutral-700">{step.path}</p>
                  </div>
                )}

                {/* Tip */}
                {step.tip && (
                  <div class="mt-3 rounded-lg bg-amber-50 border border-amber-200 px-4 py-2.5">
                    <p class="text-sm text-amber-700">{step.tip}</p>
                  </div>
                )}

                {/* External link */}
                {step.link && (
                  <a href={step.link.href} target="_blank" rel="noopener noreferrer"
                    class="mt-3 inline-flex items-center gap-2 rounded-lg border border-[var(--color-accent)]/20 bg-[var(--color-accent)]/5 px-4 py-2.5 text-sm font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent)]/10 transition-colors"
                    data-umami-event="aide-domaine-lien-externe" data-umami-event-url={step.link.href}>
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                    {step.link.label}
                  </a>
                )}

                {/* Screenshot */}
                {step.image && (
                  <div class="mt-4 rounded-lg border border-[var(--color-border)] overflow-hidden shadow-sm">
                    <img src={step.image} alt={step.imageAlt} width="1280" height="900" loading="lazy" decoding="async" class="w-full h-auto" />
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Tips -->
        <div class="mt-10 rounded-lg bg-amber-50 border border-amber-200 p-5">
          <p class="text-sm font-semibold text-amber-800 mb-2">Conseils</p>
          <ul class="list-disc pl-4 text-sm text-amber-700 leading-relaxed space-y-1.5">
            <li>Ne touchez à aucun réglage DNS — je m'en charge.</li>
            <li>Pensez à renouveler le domaine chaque année (OVH envoie un rappel par email).</li>
            <li>Si le .fr est pris, essayez le .com ou une variante avec votre ville.</li>
          </ul>
        </div>

        <!-- FAQ -->
        <div class="mt-10 space-y-4">
          <p class="text-sm font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Questions fréquentes</p>
          {faq.map((item) => (
            <details class="group rounded-lg border border-[var(--color-border)] bg-[var(--color-bg-alt)] overflow-hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-4 p-4 text-sm font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors [&::-webkit-details-marker]:hidden">
                {item.question}
                <svg class="w-4 h-4 shrink-0 text-[var(--color-text-muted)] transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-4 pb-4">
                <p class="text-sm leading-relaxed text-[var(--color-text-muted)]">{item.answer}</p>
              </div>
            </details>
          ))}
        </div>

        <!-- CTA -->
        <div class="mt-10 rounded-xl bg-[#0D0D0D] p-6 text-center">
          <p class="text-white font-semibold mb-2">Une fois le contact technique ajouté</p>
          <p class="text-neutral-300 text-sm mb-5">Envoyez-moi le nom de votre domaine par email ou WhatsApp.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={`mailto:${business.email}?subject=Domaine OVH — Contact technique ajouté&body=Bonjour Marc,%0A%0AJ'ai acheté mon domaine et je vous ai désigné comme contact technique.%0A%0AMon domaine : %0A%0AMerci !`}
              class="inline-block px-6 py-2.5 bg-[var(--color-accent)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--color-accent-hover)] transition-all"
              data-umami-event="aide-domaine-email">
              Envoyer par email
            </a>
            <a href={`https://wa.me/${business.whatsapp}?text=Bonjour Marc, j'ai acheté mon domaine et je vous ai désigné comme contact technique. Mon domaine : `}
              target="_blank" rel="noopener noreferrer"
              class="inline-block px-6 py-2.5 bg-white/10 text-white text-sm font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all"
              data-umami-event="aide-domaine-whatsapp">
              Envoyer par WhatsApp
            </a>
          </div>
        </div>

        <!-- Next guide -->
        <div class="mt-8 flex items-center justify-between rounded-lg border border-[var(--color-border)] p-4">
          <span class="text-xs font-semibold uppercase tracking-widest text-[var(--color-text-muted)]">Guide suivant</span>
          <a href="/aide/web3forms" class="inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)] hover:gap-3 transition-all">
            Créer votre compte Web3Forms
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>
