---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const title = 'Acheter votre nom de domaine chez OVH — Guide pas-à-pas · Marc M';
const description = 'Guide complet pour réserver votre nom de domaine .fr ou .com chez OVH. 10 minutes, tout est expliqué étape par étape.';

const breadcrumbs = [
  { name: 'Accueil', url: 'https://marcm.fr/' },
  { name: 'Aide', url: 'https://marcm.fr/aide/' },
  { name: 'Nom de domaine OVH', url: 'https://marcm.fr/aide/domaine-ovh/' },
];

const howToSteps = [
  { name: 'Allez sur OVH', text: 'Rendez-vous sur ovh.com et cliquez sur "Noms de domaine" dans le menu principal.' },
  { name: 'Cherchez votre domaine', text: 'Tapez le nom souhaité (ex. mon-entreprise.fr) dans la barre de recherche. OVH vous indique s\'il est disponible et propose des alternatives.' },
  { name: 'Choisissez l\'extension', text: 'Privilégiez le .fr si votre clientèle est en France. Le .com est un bon complément. Comptez environ 7€/an pour un .fr.' },
  { name: 'Créez votre compte OVH', text: 'Si c\'est votre première commande, créez un compte OVH avec votre email professionnel. Gardez bien vos identifiants.' },
  { name: 'Passez commande', text: 'Ajoutez le domaine au panier. Décochez les options inutiles (hébergement, email OVH — on n\'en a pas besoin). Validez et payez.' },
  { name: 'Envoyez-moi vos identifiants OVH', text: 'Une fois la commande confirmée, envoyez-moi votre identifiant client OVH (ex: ab12345-ovh) par email ou WhatsApp. Je configurerai les DNS pour pointer vers votre site.' },
];
---

<BaseLayout title={title} description={description} ogType="article" lang="fr" frPath="/aide/domaine-ovh">

  <SchemaOrg type="breadcrumb" data={breadcrumbs} />
  <SchemaOrg type="howTo" data={{
    name: 'Acheter un nom de domaine chez OVH',
    description: 'Guide pour réserver votre nom de domaine .fr ou .com sur OVH et le préparer pour votre site web.',
    totalTime: 'PT10M',
    steps: howToSteps,
  }} />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/aide" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour aux guides
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-sky-400/30 bg-sky-400/10 px-3 py-1 text-xs font-semibold text-sky-300">
          Domaine
        </span>
        <span class="text-sm text-neutral-400">~10 minutes</span>
        <span class="text-sm text-neutral-400">•</span>
        <span class="text-sm text-neutral-400">Gratuit (domaine ~7€/an)</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        Acheter votre nom de domaine chez OVH
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        Votre nom de domaine, c'est l'adresse de votre site sur internet. Voici comment le réserver en quelques minutes.
      </p>
    </div>
  </section>

  <!-- GUIDE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">

        <!-- Intro -->
        <div class="mb-10 rounded-lg bg-sky-50 border border-sky-200 p-5">
          <p class="text-sm font-semibold text-sky-800 mb-1">Pourquoi OVH ?</p>
          <p class="text-sm text-sky-700 leading-relaxed">
            OVH est le premier hébergeur français. Vos données restent en France, le support est en français, et les prix sont parmi les plus bas du marché. C'est ce que je recommande à tous mes clients.
          </p>
        </div>

        <!-- Steps -->
        <div class="space-y-8">
          {howToSteps.map((step, i) => (
            <div class="flex gap-5">
              <div class="flex-shrink-0 flex items-center justify-center w-10 h-10 rounded-full bg-[var(--color-accent)] text-white font-bold text-sm shadow-md">
                {i + 1}
              </div>
              <div class="flex-1 pt-1.5">
                <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">{step.name}</h2>
                <p class="text-[var(--color-text-muted)] leading-relaxed">{step.text}</p>
              </div>
            </div>
          ))}
        </div>

        <!-- Tips -->
        <div class="mt-10 rounded-lg bg-amber-50 border border-amber-200 p-5">
          <p class="text-sm font-semibold text-amber-800 mb-2">Conseils</p>
          <ul class="text-sm text-amber-700 leading-relaxed space-y-1.5">
            <li>Choisissez un nom court, facile à épeler au téléphone, sans tirets si possible.</li>
            <li>Pas besoin de prendre l'hébergement OVH — votre site sera sur Cloudflare Pages, c'est inclus dans ma prestation.</li>
            <li>Ne touchez à aucun réglage DNS — je m'en charge.</li>
          </ul>
        </div>

        <!-- CTA -->
        <div class="mt-10 rounded-xl bg-[#0D0D0D] p-6 text-center">
          <p class="text-white font-semibold mb-2">Une fois le domaine acheté</p>
          <p class="text-neutral-300 text-sm mb-5">Envoyez-moi votre identifiant client OVH par email ou WhatsApp.</p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href={`mailto:${business.email}?subject=Identifiant OVH — Mon domaine&body=Bonjour Marc,%0A%0AVoici mon identifiant OVH : %0AMon domaine : %0A%0AMerci !`}
              class="inline-block px-6 py-2.5 bg-[var(--color-accent)] text-white text-sm font-semibold rounded-lg hover:bg-[var(--color-accent-hover)] transition-all"
              data-umami-event="aide-domaine-email">
              Envoyer par email
            </a>
            <a href={`https://wa.me/${business.whatsapp}?text=Bonjour Marc, j'ai acheté mon domaine. Mon identifiant OVH est : `}
              target="_blank" rel="noopener noreferrer"
              class="inline-block px-6 py-2.5 bg-white/10 text-white text-sm font-semibold rounded-lg border border-white/20 hover:bg-white/20 transition-all"
              data-umami-event="aide-domaine-whatsapp">
              Envoyer par WhatsApp
            </a>
          </div>
        </div>

      </article>
    </div>
  </section>
</BaseLayout>
