---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Journal — Marc Muller';
const description = 'Réflexions sur le web, les prix, le SEO et comment les artisans et commerçants peuvent tirer le meilleur de leur présence en ligne.';

interface BlogPost {
  title: string;
  slug: string;
  date: string;
  dateISO: string;
  readTime: string;
  excerpt: string;
  tag: string;
}

const posts: BlogPost[] = [
  {
    title: 'Combien coûte un site web en 2026 ?',
    slug: 'combien-coute-un-site-web',
    date: '15 mars 2026',
    dateISO: '2026-03-15',
    readTime: '9 min',
    excerpt: 'Comparatif honnête : DIY vs template vs freelance vs agence. Ce qui change vraiment le prix — et ce qui n\'est qu\'un mythe.',
    tag: 'Business',
  },
  {
    title: 'Les 5 erreurs qui font fuir les clients de votre site web',
    slug: '5-erreurs-site-web-artisan',
    date: '8 mars 2026',
    dateISO: '2026-03-08',
    readTime: '7 min',
    excerpt: 'Vitesse, numéro invisible, photos stock, aucune preuve sociale… Ces erreurs coûtent des clients chaque jour. Diagnostic et corrections.',
    tag: 'Conseils',
  },
  {
    title: 'SEO local : comment apparaître en première position sur Google',
    slug: 'seo-local-artisans',
    date: '1er mars 2026',
    dateISO: '2026-03-01',
    readTime: '10 min',
    excerpt: 'Google Maps, fiches établissement, avis, Schema.org LocalBusiness : le guide complet pour les artisans et commerçants qui veulent être trouvés dans leur ville.',
    tag: 'SEO',
  },
  {
    title: 'Pourquoi votre site WordPress est lent — et ce que ça vous coûte',
    slug: 'pourquoi-votre-site-est-lent',
    date: '22 févr. 2026',
    dateISO: '2026-02-22',
    readTime: '7 min',
    excerpt: 'Un site lent perd 53 % de ses visiteurs mobiles. Voici pourquoi WordPress ralentit inévitablement, combien ça vous coûte en clients, et quelle solution tient vraiment.',
    tag: 'Performance',
  },
  {
    title: 'Faut-il un blog pour son site vitrine ? (Réponse honnête)',
    slug: 'faut-il-un-blog',
    date: '15 févr. 2026',
    dateISO: '2026-02-15',
    readTime: '6 min',
    excerpt: 'Le blog est souvent vendu comme une solution miracle pour le SEO. La réalité est plus nuancée. Voici quand c\'est une bonne idée — et quand c\'est une perte de temps.',
    tag: 'Stratégie',
  },
];

// Tag color system (complete class strings for Tailwind purge safety)
const tagConfig: Record<string, { badge: string; bar: string; heroBadge: string }> = {
  'Business':    { badge: 'bg-orange-100 text-orange-700',   bar: 'bg-orange-400',   heroBadge: 'border-orange-400/40 bg-orange-400/15 text-orange-300' },
  'Conseils':    { badge: 'bg-sky-100 text-sky-700',         bar: 'bg-sky-400',       heroBadge: 'border-sky-400/40 bg-sky-400/15 text-sky-300' },
  'SEO':         { badge: 'bg-emerald-100 text-emerald-700', bar: 'bg-emerald-400',   heroBadge: 'border-emerald-400/40 bg-emerald-400/15 text-emerald-300' },
  'Performance': { badge: 'bg-rose-100 text-rose-700',       bar: 'bg-rose-400',      heroBadge: 'border-rose-400/40 bg-rose-400/15 text-rose-300' },
  'Stratégie':   { badge: 'bg-violet-100 text-violet-700',   bar: 'bg-violet-400',    heroBadge: 'border-violet-400/40 bg-violet-400/15 text-violet-300' },
};

const allTags = [...new Set(posts.map(p => p.tag))];
const [featured, ...rest] = posts;
---

<BaseLayout title={title} description={description} lang="fr" frPath="/journal" enPath="/en/blog">

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-4xl z-10">
      <div class="mb-5 inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-neutral-300">
        <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-accent)]"></span>
        {posts.length} article{posts.length > 1 ? 's' : ''}
      </div>

      <h1 class="mb-5 text-4xl font-bold leading-tight text-white md:text-5xl">
        Journal
      </h1>
      <p class="max-w-2xl text-lg text-neutral-300 md:text-xl leading-relaxed">
        Réflexions pratiques sur le web : prix, SEO, performance et tout ce qu'on ne vous dit pas quand on vous vend un site.
      </p>

      <!-- Tags -->
      <div class="mt-8 flex flex-wrap gap-2">
        {allTags.map((tag) => (
          <span class={`inline-flex items-center gap-1.5 rounded-full border px-3 py-1 text-xs font-medium ${tagConfig[tag]?.heroBadge ?? 'border-white/10 bg-white/5 text-neutral-300'}`}>
            <span class={`w-1.5 h-1.5 rounded-full ${tagConfig[tag]?.bar ?? 'bg-white/40'}`}></span>
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">

      <!-- Article à la une -->
      <a href={`/journal/${featured.slug}`} class="group mb-8 block">
        <article class="relative rounded-2xl bg-[#0D0D0D] overflow-hidden shadow-xl transition-all duration-300 hover:shadow-2xl hover:-translate-y-1">
          <!-- Dot grid -->
          <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;"></div>
          <!-- Top accent bar -->
          <div class={`h-1 w-full ${tagConfig[featured.tag]?.bar ?? 'bg-[var(--color-accent)]'}`}></div>

          <div class="relative px-8 py-9 md:px-10 md:py-10">
            <!-- Meta row -->
            <div class="mb-5 flex flex-wrap items-center gap-3">
              <span class="rounded-full bg-white/10 px-2.5 py-0.5 text-xs font-bold uppercase tracking-widest text-white/70">
                À la une
              </span>
              <span class={`rounded-full border px-3 py-0.5 text-xs font-semibold ${tagConfig[featured.tag]?.heroBadge ?? 'border-white/10 bg-white/5 text-neutral-300'}`}>
                {featured.tag}
              </span>
              <time datetime={featured.dateISO} class="text-sm text-neutral-400">{featured.date}</time>
              <span class="text-neutral-600" aria-hidden="true">•</span>
              <span class="flex items-center gap-1.5 text-sm text-neutral-400">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {featured.readTime} de lecture
              </span>
            </div>

            <!-- Title -->
            <h2 class="mb-4 text-2xl font-bold leading-tight text-white transition-colors group-hover:text-[var(--color-accent)] md:text-3xl">
              {featured.title}
            </h2>

            <!-- Excerpt -->
            <p class="mb-7 max-w-2xl text-base text-neutral-300 leading-relaxed">
              {featured.excerpt}
            </p>

            <!-- CTA -->
            <span class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-5 py-2.5 text-sm font-semibold text-white transition-all group-hover:bg-[var(--color-accent)] group-hover:border-[var(--color-accent)] group-hover:gap-3">
              Lire l'article
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </span>
          </div>
        </article>
      </a>

      <!-- Grille des autres articles -->
      <div class="grid gap-5 sm:grid-cols-2">
        {rest.map((post, i) => (
          <a href={`/journal/${post.slug}`} class="group block">
            <article class="flex h-full flex-col overflow-hidden rounded-xl border border-[var(--color-border)] bg-white shadow-sm transition-all duration-300 hover:shadow-lg hover:-translate-y-1">
              <!-- Top color bar -->
              <div class={`h-1 w-full shrink-0 ${tagConfig[post.tag]?.bar ?? 'bg-[var(--color-accent)]'}`}></div>

              <div class="flex flex-1 flex-col p-6">
                <!-- Meta -->
                <div class="mb-3 flex flex-wrap items-center gap-2">
                  <span class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${tagConfig[post.tag]?.badge ?? 'bg-[var(--color-accent)]/10 text-[var(--color-accent)]'}`}>
                    {post.tag}
                  </span>
                  <time datetime={post.dateISO} class="text-xs text-[var(--color-text-muted)]">{post.date}</time>
                  <span class="flex items-center gap-1 text-xs text-[var(--color-text-muted)]">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    {post.readTime}
                  </span>
                </div>

                <!-- Title -->
                <h2 class="mb-3 text-base font-bold leading-snug text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent)] md:text-lg">
                  {post.title}
                </h2>

                <!-- Excerpt -->
                <p class="mb-5 flex-1 text-sm leading-relaxed text-[var(--color-text-muted)]">
                  {post.excerpt}
                </p>

                <!-- CTA -->
                <span class="inline-flex items-center gap-1.5 text-xs font-semibold text-[var(--color-accent)] transition-all group-hover:gap-2.5">
                  Lire l'article
                  <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                  </svg>
                </span>
              </div>
            </article>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-gradient-to-b from-[#1A1A1A] to-[#111111] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-white">Un projet en tête ?</h2>
      <p class="mb-8 text-neutral-300 leading-relaxed">
        Chaque article reflète ma façon de travailler : directe, transparente, sans jargon. Si ça vous parle, parlons de votre projet.
      </p>
      <a
        href="/contact"
        class="inline-block px-8 py-3 bg-[var(--color-accent)] text-white font-semibold rounded-xl hover:bg-[var(--color-accent-hover)] transition-all shadow-lg hover:shadow-xl"
        style="box-shadow: 0 10px 25px rgba(232, 108, 71, 0.3);"
      >
        Me contacter
      </a>
    </div>
  </section>
</BaseLayout>
