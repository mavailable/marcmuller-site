---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = '3 actions gratuites pour être plus visible cette semaine';
const description = 'Pas besoin de budget pub ni de site web pour commencer. Voici 3 actions concrètes, gratuites, faisables aujourd\'hui — qui peuvent changer votre visibilité locale.';

const publishDate = '2026-05-15';
const readTime = 5;
---

<BaseLayout title={title} description={description} ogType="article" ogImage="/og-default.png" lang="fr" frPath="/journal/3-actions-gratuites-visibilite" enPath="/en/blog/3-free-actions-visibility">
  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/journal" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour au journal
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-violet-400/40 bg-violet-400/15 px-3 py-1 text-xs font-semibold text-violet-300">
          Stratégie
        </span>
        <span class="text-sm text-neutral-400">15 mai 2026</span>
        <span class="text-sm text-neutral-400">•</span>
        <span class="text-sm text-neutral-400">{readTime} min de lecture</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        {title}
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">
        <div class="prose max-w-none">

          <!-- Table des matières -->
          <nav class="mb-12 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6 not-prose">
            <p class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Au programme</p>
            <ol class="space-y-2 text-sm">
              <li><a href="#action-1" class="text-[var(--color-accent)] hover:underline font-medium">1. Créez (ou complétez) votre fiche Google Business</a></li>
              <li><a href="#action-2" class="text-[var(--color-accent)] hover:underline font-medium">2. Demandez 5 avis Google aujourd'hui</a></li>
              <li><a href="#action-3" class="text-[var(--color-accent)] hover:underline font-medium">3. Publiez un avant/après sur vos réseaux</a></li>
              <li><a href="#bonus" class="text-[var(--color-accent)] hover:underline font-medium">Bonus : 10 minutes de plus</a></li>
              <li><a href="#pourquoi-ca-marche" class="text-[var(--color-accent)] hover:underline font-medium">Pourquoi ça marche</a></li>
              <li><a href="#faq" class="text-[var(--color-accent)] hover:underline font-medium">Questions fréquentes</a></li>
            </ol>
          </nav>

          <!-- Intro -->
          <section class="mb-12">
            <p class="mb-4 text-lg text-[var(--color-text)]">
              Vous n'avez pas de site. Pas de budget marketing. Pas le temps de « faire du digital ».
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Bonne nouvelle : ces 3 actions ne coûtent rien, prennent moins de 2 heures au total, et peuvent générer des appels dès cette semaine.
            </p>
            <p class="text-[var(--color-text)]">
              Pas de théorie. Juste trois choses à faire, dans l'ordre, avec le temps estimé pour chacune.
            </p>
          </section>

          <!-- Action 1 -->
          <section id="action-1" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              1. Créez (ou complétez) votre fiche Google Business
            </h2>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <div class="flex items-center gap-3 mb-0">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">30</span>
                <span class="text-sm font-semibold text-[var(--color-text)]">minutes — c'est tout ce qu'il faut</span>
              </div>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Rendez-vous sur <strong>business.google.com</strong>. Créez votre fiche si elle n'existe pas, ou revendiquez-la si Google l'a générée automatiquement.
            </p>

            <p class="mb-3 text-[var(--color-text)]">
              Remplissez <strong>tout</strong> :
            </p>
            <ul class="mb-6 text-[var(--color-text)]">
              <li>Nom exact de votre entreprise</li>
              <li>Adresse complète, téléphone, horaires</li>
              <li>La catégorie la plus précise possible — pas « Artisan » mais « Plombier », « Électricien », « Coiffeuse »</li>
              <li>Minimum <strong>5 photos</strong> : votre visage, vos réalisations, votre véhicule ou vos outils</li>
              <li>Une description de 750 caractères avec votre métier + ville intégrés naturellement</li>
            </ul>

            <p class="mb-4 text-[var(--color-text)]">
              <strong>Résultat :</strong> vous apparaissez sur Google Maps quand quelqu'un cherche « [votre métier] + [votre ville] ». 46 % des recherches Google ont une intention locale — près de la moitié. Si vous n'avez pas de fiche, vous êtes invisible pour ces personnes.
            </p>

            <div class="mb-4 rounded-xl bg-[var(--color-accent)]/5 border border-[var(--color-accent)]/20 px-6 py-4 not-prose">
              <p class="text-sm text-[var(--color-text)] leading-relaxed italic">
                « Un électricien à Épinal m'a dit qu'il a reçu 3 appels dans la semaine suivant la création de sa fiche — alors qu'il n'avait même pas de site web. »
              </p>
            </div>
          </section>

          <!-- Action 2 -->
          <section id="action-2" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              2. Demandez 5 avis Google aujourd'hui
            </h2>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <div class="flex items-center gap-3 mb-0">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">15</span>
                <span class="text-sm font-semibold text-[var(--color-text)]">minutes — 5 SMS, c'est réglé</span>
              </div>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Ouvrez votre fiche Google Business Profile. Copiez le lien direct pour laisser un avis (section « Partager le formulaire d'avis »).
            </p>

            <p class="mb-3 text-[var(--color-text)]">
              Envoyez ce SMS à vos <strong>5 derniers clients satisfaits</strong> :
            </p>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <p class="text-sm text-[var(--color-text)] leading-relaxed italic">
                « Bonjour [Prénom], c'est [Votre nom]. Merci encore pour votre confiance ! Si vous avez 2 minutes, un petit avis Google m'aiderait beaucoup : [lien]. Merci ! »
              </p>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Pourquoi 5 ? Parce que 5 avis récents changent tout. Google favorise les entreprises avec de l'activité récente. Une fiche avec 5 avis frais de la semaine passe devant une fiche avec 20 avis vieux d'un an. 88 % des consommateurs font autant confiance aux avis en ligne qu'à une recommandation personnelle.
            </p>

            <p class="text-[var(--color-text)]">
              Pour aller plus loin sur les avis : <a href="/journal/seo-local-artisans#avis" class="text-[var(--color-accent)] hover:underline font-medium">le guide complet dans notre article SEO local</a>.
            </p>
          </section>

          <!-- Action 3 -->
          <section id="action-3" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              3. Publiez un avant/après sur vos réseaux
            </h2>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <div class="flex items-center gap-3 mb-0">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">20</span>
                <span class="text-sm font-semibold text-[var(--color-text)]">minutes — une photo, un texte, c'est publié</span>
              </div>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Prenez votre téléphone. Trouvez une photo récente de chantier, de réalisation, de plat, de coupe — ce que vous faites au quotidien. Si vous n'en avez pas, allez en prendre une maintenant.
            </p>

            <p class="mb-3 text-[var(--color-text)]">
              Publiez sur Facebook, Instagram, ou les deux. Voici un modèle de légende :
            </p>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <p class="text-sm text-[var(--color-text)] leading-relaxed italic">
                « [Métier] à [Ville] — [description courte du chantier]. Avant / Après. Besoin d'un devis ? Appelez-moi au [numéro]. »
              </p>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Pas de tempête de hashtags. Pas de jargon marketing. Montrez votre travail, point.
            </p>

            <p class="mb-4 text-[var(--color-text)]">
              Pourquoi ça fonctionne : votre réseau existant voit la publication, la partage, en parle. Une coiffeuse à Nancy a gagné 4 nouvelles clientes en un mois avec un seul post avant/après par semaine. La portée organique sur du contenu local reste forte — Facebook et Instagram favorisent les publications de proximité.
            </p>

            <p class="text-[var(--color-text)]">
              L'erreur la plus courante : ne pas publier du tout par peur de « mal faire ». Un post imparfait vaut infiniment mieux que pas de post. Vos clients veulent voir votre travail, pas une pub léchée.
            </p>
          </section>

          <!-- Bonus -->
          <section id="bonus" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Bonus : et si vous avez 10 minutes de plus
            </h2>

            <div class="rounded-xl bg-[var(--color-accent)]/5 border border-[var(--color-accent)]/20 p-6 not-prose">
              <ul class="space-y-3 text-sm text-[var(--color-text)]">
                <li class="flex items-start gap-3">
                  <span class="text-[var(--color-accent)] font-bold shrink-0">+3 min</span>
                  <span>Répondez à chaque avis Google existant — même un simple « Merci [Prénom] ! » montre que vous êtes actif</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--color-accent)] font-bold shrink-0">+2 min</span>
                  <span>Ajoutez votre numéro de téléphone à votre bio Facebook</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--color-accent)] font-bold shrink-0">+5 min</span>
                  <span>Mettez à jour votre profil WhatsApp Business avec votre métier + ville (ex : « Plombier à Metz — Dépannage & installation »)</span>
                </li>
              </ul>
            </div>
          </section>

          <!-- Pourquoi ça marche -->
          <section id="pourquoi-ca-marche" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Pourquoi ça marche
            </h2>

            <p class="mb-6 text-[var(--color-text)]">
              Ces 3 actions couvrent les 3 piliers de la visibilité locale :
            </p>

            <div class="space-y-4 mb-6 not-prose">
              <div class="flex items-start gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] px-5 py-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">1</span>
                <div>
                  <p class="font-bold text-[var(--color-text)] mb-1">Google Business = être trouvé</p>
                  <p class="text-sm text-[var(--color-text-muted)]">Vous existez sur Google Maps. Les gens qui cherchent votre métier dans votre ville vous trouvent.</p>
                </div>
              </div>
              <div class="flex items-start gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] px-5 py-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">2</span>
                <div>
                  <p class="font-bold text-[var(--color-text)] mb-1">Avis = être choisi</p>
                  <p class="text-sm text-[var(--color-text-muted)]">Entre deux résultats, le client appelle celui qui a des avis récents et positifs. La confiance se joue là.</p>
                </div>
              </div>
              <div class="flex items-start gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] px-5 py-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">3</span>
                <div>
                  <p class="font-bold text-[var(--color-text)] mb-1">Réseaux = être recommandé</p>
                  <p class="text-sm text-[var(--color-text-muted)]">Le bouche-à-oreille numérique. Vos contacts partagent, commentent, taguent. Le cercle s'élargit.</p>
                </div>
              </div>
            </div>

            <p class="text-[var(--color-text)]">
              Ensemble, ces trois leviers créent une boucle : on vous trouve, on vous fait confiance, on parle de vous. Total : 65 minutes de travail. Zéro euro dépensé.
            </p>
          </section>

          <!-- FAQ -->
          <section id="faq" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Questions fréquentes
            </h2>

            <div class="space-y-4 not-prose">
              {[
                {
                  q: "Je fais déjà tout ça et ça ne marche pas",
                  a: "Vérifiez trois choses : votre fiche Google Business est-elle complète à 100 % (photos, description, catégorie précise) ? Avez-vous 10 avis récents ou plus ? Publiez-vous au moins une fois par mois sur vos réseaux ? Si l'une de ces réponses est non, vous avez votre point de départ."
                },
                {
                  q: "Les réseaux sociaux suffisent-ils sans site web ?",
                  a: "Pour démarrer, oui. Fiche Google + réseaux + avis, ça suffit pour recevoir des appels. Mais à terme, un site vous donne le contrôle total. Facebook peut changer ses règles demain — votre site, lui, est à vous. C'est la prochaine étape logique, pas la première."
                },
                {
                  q: "Combien de temps avant de voir des résultats ?",
                  a: "Google Business Profile : quelques jours à quelques semaines pour apparaître sur Maps. Avis : effet immédiat sur la confiance — un client qui voit 5 étoiles récentes appelle plus facilement. Réseaux : variable, mais chaque post est un grain planté. Un boulanger à Strasbourg a vu ses commandes augmenter de 20 % en 3 mois avec un post par semaine."
                },
              ].map((item) => (
                <details class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] overflow-hidden">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-semibold text-[var(--color-text)] text-sm list-none hover:text-[var(--color-accent)] transition-colors">
                    {item.q}
                    <svg class="w-4 h-4 shrink-0 ml-3 transition-transform group-open:rotate-180 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <p class="px-6 pb-5 pt-1 text-sm text-[var(--color-text-muted)] leading-relaxed border-t border-[var(--color-border)]">{item.a}</p>
                </details>
              ))}
            </div>
          </section>

          <!-- Pour aller plus loin -->
          <div class="mt-12 mb-4 not-prose">
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-4">Pour aller plus loin</p>
            <div class="grid gap-4 sm:grid-cols-2">
              <a href="/journal/seo-local-artisans" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700 mb-3">SEO</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">SEO local : comment apparaître en première position sur Google</p>
              </a>
              <a href="/journal/5-erreurs-site-web-artisan" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-sky-100 px-2 py-0.5 text-xs font-semibold text-sky-700 mb-3">Conseils</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">Les 5 erreurs qui font fuir les clients de votre site web</p>
              </a>
            </div>
          </div>

          <!-- Bio auteur -->
          <div class="my-10 flex items-center gap-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-6 not-prose">
            <img
              src="/images/marc-muller.webp"
              alt="Marc Muller — développeur web freelance"
              class="w-16 h-16 rounded-full object-cover shrink-0 border-2 border-white shadow-sm"
            />
            <div>
              <p class="font-bold text-[var(--color-text)] mb-1">Marc Muller</p>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Développeur web freelance. Je crée des sites ultra-rapides pour artisans et commerçants du Grand Est,
                livrés en 5–10 jours, sans WordPress ni maintenance lourde.
              </p>
            </div>
          </div>

          <!-- CTA -->
          <section class="rounded-xl bg-[var(--color-accent)] p-8 text-center text-white not-prose">
            <h2 class="mb-4 text-2xl font-bold">Prêt pour l'étape suivante ?</h2>
            <p class="mb-3 text-lg opacity-95">Ces 3 actions posent les bases. Un site professionnel les transforme en machine à clients. Je peux vous le construire en 7 jours.</p>
            <p class="mb-8 opacity-80 text-sm">Site Vitrine dès 490€. Livré en 7 jours.</p>
            <a
              href="/offre"
              class="inline-block rounded-xl bg-white px-8 py-3 font-semibold text-[var(--color-accent)] transition-all hover:bg-neutral-100 hover:shadow-lg"
            >
              Voir les formules — dès 490€
            </a>
            <p class="mt-4">
              <a href="/contact" class="text-sm text-white/90 underline underline-offset-4 hover:text-white transition-colors">
                Une question ? Parlons de votre projet →
              </a>
            </p>
          </section>
        </div>
      </article>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "3 actions gratuites pour être plus visible cette semaine",
      "description": "Pas besoin de budget pub ni de site web pour commencer. Voici 3 actions concrètes, gratuites, faisables aujourd'hui — qui peuvent changer votre visibilité locale.",
      "image": "https://marcm.fr/og-default.png",
      "datePublished": "2026-05-15",
      "dateModified": "2026-05-15",
      "author": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr/qui-suis-je" },
      "publisher": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": "https://marcm.fr/journal/3-actions-gratuites-visibilite" },
      "articleSection": "Stratégie",
      "inLanguage": "fr-FR"
    }
  </script>
</BaseLayout>
