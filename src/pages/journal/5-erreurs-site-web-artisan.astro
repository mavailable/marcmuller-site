---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Les 5 erreurs qui font fuir les clients de votre site web';
const description = 'Un site web peut faire fuir des clients sans même que vous le sachiez. Voici les 5 erreurs les plus fréquentes chez les artisans — et comment les corriger.';

const publishDate = '2026-03-08';
const readTime = 7;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage="/og-default.png"
  lang="fr"
  frPath="/journal/5-erreurs-site-web-artisan"
  enPath="/en/blog/5-website-mistakes-craftspeople"
>
  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/journal" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour au journal
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-semibold text-[var(--color-accent)]">
          Conseils
        </span>
        <span class="text-sm text-neutral-400">8 mars 2026</span>
        <span class="text-sm text-neutral-400">•</span>
        <span class="text-sm text-neutral-400">{readTime} min de lecture</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        {title}
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">
        <div class="prose max-w-none">

          <!-- Table des matières -->
          <nav class="mb-12 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6 not-prose">
            <p class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Les 5 erreurs</p>
            <ol class="space-y-2 text-sm">
              <li><a href="#erreur-1" class="text-[var(--color-accent)] hover:underline font-medium">Erreur #1 — Votre site est trop lent</a></li>
              <li><a href="#erreur-2" class="text-[var(--color-accent)] hover:underline font-medium">Erreur #2 — Aucun numéro de téléphone visible</a></li>
              <li><a href="#erreur-3" class="text-[var(--color-accent)] hover:underline font-medium">Erreur #3 — Des photos génériques</a></li>
              <li><a href="#erreur-4" class="text-[var(--color-accent)] hover:underline font-medium">Erreur #4 — Pas de preuves sociales</a></li>
              <li><a href="#erreur-5" class="text-[var(--color-accent)] hover:underline font-medium">Erreur #5 — Un message trop flou</a></li>
              <li><a href="#bonus" class="text-[var(--color-accent)] hover:underline font-medium">Bonus — La 6ème erreur (la plus silencieuse)</a></li>
            </ol>
          </nav>

          <!-- Intro -->
          <section class="mb-12">
            <p class="mb-4 text-lg text-[var(--color-text)]">
              Votre site web existe. Vous avez payé pour le faire créer. Il est en ligne.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Et pourtant, les appels ne viennent pas.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Ce n'est pas forcément votre secteur qui est saturé. Ce n'est pas que « les gens ne cherchent pas sur internet ». C'est souvent — très souvent — votre site lui-même qui pose problème.
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              J'ai analysé des dizaines de sites d'artisans et de commerçants. Les mêmes erreurs reviennent systématiquement. Voici les cinq plus destructrices — et comment les corriger.
            </p>
          </section>

          <!-- Erreur 1 -->
          <section id="erreur-1" class="mb-12">
            <div class="mb-6 flex items-center gap-4">
              <span class="flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-600 font-bold text-lg shrink-0">1</span>
              <h2 class="text-2xl font-bold text-[var(--color-text)]">Votre site est trop lent</h2>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              C'est l'erreur la plus fréquente — et la plus coûteuse.
            </p>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6 not-prose">
              <p class="text-sm font-bold text-[var(--color-text)] mb-3">Ce que dit la recherche :</p>
              <ul class="space-y-2 text-sm text-[var(--color-text)] list-none ml-0">
                <li class="flex items-start gap-2"><span class="text-red-500 shrink-0 mt-0.5">→</span><span>53 % des visiteurs mobiles quittent un site qui met plus de 3 secondes à charger (Google, 2024)</span></li>
                <li class="flex items-start gap-2"><span class="text-red-500 shrink-0 mt-0.5">→</span><span>Chaque seconde de délai supplémentaire réduit le taux de conversion de 7 %</span></li>
                <li class="flex items-start gap-2"><span class="text-red-500 shrink-0 mt-0.5">→</span><span>Google pénalise les sites lents dans ses résultats de recherche</span></li>
              </ul>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Un site WordPress avec 15 plugins met souvent 5 à 8 secondes à charger sur mobile. Pendant ce temps, votre visiteur a déjà cliqué sur le site du concurrent.
            </p>

            <p class="mb-4 text-[var(--color-text)] text-sm">
              → Si votre site tourne sur WordPress, l'article <a href="/journal/pourquoi-votre-site-est-lent" class="text-[var(--color-accent)] hover:underline font-medium">Pourquoi votre site WordPress est lent</a> détaille les causes exactes et les solutions qui tiennent vraiment.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Comment vérifier</h3>
            <p class="mb-4 text-[var(--color-text)]">
              Testez votre site sur <strong>PageSpeed Insights</strong> (pagespeed.web.dev) depuis un mobile. Un score en dessous de 70 est un problème sérieux. En dessous de 50, c'est urgent.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Comment corriger</h3>
            <ul class="mb-4 text-[var(--color-text)]">
              <li>Passez vos images en format WebP (gain de 40–70 % sur le poids)</li>
              <li>Supprimez les plugins non utilisés sur WordPress</li>
              <li>Activez un cache (WP Rocket, LiteSpeed)</li>
              <li>Ou — solution radicale — changez de stack pour du statique (Astro, Next.js)</li>
            </ul>
          </section>

          <!-- Erreur 2 -->
          <section id="erreur-2" class="mb-12">
            <div class="mb-6 flex items-center gap-4">
              <span class="flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-600 font-bold text-lg shrink-0">2</span>
              <h2 class="text-2xl font-bold text-[var(--color-text)]">Aucun numéro de téléphone visible</h2>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Le visiteur qui atterrit sur votre site a une question. Il veut vous appeler. Il cherche votre numéro.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Il ne le trouve pas en 3 secondes. Il ferme l'onglet.
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              Pourtant, c'est la correction la plus simple au monde.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">La règle des 3 secondes</h3>
            <p class="mb-4 text-[var(--color-text)]">
              Votre numéro de téléphone doit être visible <strong>en moins de 3 secondes</strong>, sans scroll, sur mobile comme sur desktop. Idéalement :
            </p>
            <ul class="mb-4 text-[var(--color-text)]">
              <li>Dans le header, sur chaque page</li>
              <li>Cliquable sur mobile (lien <code>tel:</code>)</li>
              <li>Répété dans le footer et sur la page de contact</li>
            </ul>

            <p class="rounded-xl bg-[var(--color-accent)] p-5 font-semibold text-white">
              Pour les artisans, le téléphone reste le premier canal de conversion. Ne le cachez pas.
            </p>
          </section>

          <!-- Erreur 3 -->
          <section id="erreur-3" class="mb-12">
            <div class="mb-6 flex items-center gap-4">
              <span class="flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-600 font-bold text-lg shrink-0">3</span>
              <h2 class="text-2xl font-bold text-[var(--color-text)]">Des photos génériques à la place de vraies photos</h2>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Les photos stock sont l'équivalent d'un costume loué pour un entretien d'embauche. Ça trompe personne.
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              Quand un client voit une photo de chantier parfaitement éclairée avec un plombier souriant en costume blanc, il sait que ce n'est pas vous. Ça crée de la méfiance, pas de la confiance.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Ce qui marche vraiment</h3>
            <ul class="mb-6 text-[var(--color-text)]">
              <li>Votre vrai visage — une bonne photo de vous sur le chantier ou en atelier</li>
              <li>Vos vrais travaux — des photos avant/après de vos réalisations</li>
              <li>Votre environnement réel — boutique, atelier, véhicule, outils</li>
            </ul>

            <p class="mb-4 text-[var(--color-text)]">
              Pas besoin d'un photographe professionnel. Un iPhone récent en plein jour fait des merveilles. Ce qui compte, c'est l'authenticité, pas la perfection technique.
            </p>

            <div class="rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <p class="text-sm text-[var(--color-text)]">
                <strong>Astuce :</strong> demandez à votre conjoint(e) ou un ami de vous photographier sur un chantier un matin bien éclairé. Même 5 bonnes photos font toute la différence.
              </p>
            </div>
          </section>

          <!-- Erreur 4 -->
          <section id="erreur-4" class="mb-12">
            <div class="mb-6 flex items-center gap-4">
              <span class="flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-600 font-bold text-lg shrink-0">4</span>
              <h2 class="text-2xl font-bold text-[var(--color-text)]">Aucune preuve sociale visible</h2>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Vous avez des clients satisfaits. Vous avez des avis Google. Mais ils ne sont nulle part sur votre site.
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              Un client potentiel qui vous découvre ne vous connaît pas. La seule chose qui peut le rassurer, c'est l'expérience des autres. S'il ne voit rien, il hésite. S'il hésite, il cherche ailleurs.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Les preuves sociales qui convertissent</h3>
            <ul class="mb-6 text-[var(--color-text)]">
              <li><strong>Témoignages clients</strong> — avec prénom, ville et photo si possible</li>
              <li><strong>Note Google</strong> — intégrez votre étoile et le nombre d'avis directement sur la page d'accueil</li>
              <li><strong>Chiffres</strong> — "150 clients satisfaits", "12 ans d'expérience", "intervient sous 24h"</li>
              <li><strong>Réalisations</strong> — une galerie de vrais projets récents</li>
            </ul>

            <p class="mb-4 text-[var(--color-text)]">
              Vous n'avez pas encore d'avis Google ? C'est l'urgence numéro 1 hors site web. Envoyez le lien de dépôt d'avis à vos 10 derniers clients dès aujourd'hui.
            </p>
          </section>

          <!-- Erreur 5 -->
          <section id="erreur-5" class="mb-12">
            <div class="mb-6 flex items-center gap-4">
              <span class="flex items-center justify-center w-10 h-10 rounded-full bg-red-100 text-red-600 font-bold text-lg shrink-0">5</span>
              <h2 class="text-2xl font-bold text-[var(--color-text)]">Un message principal trop flou</h2>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              C'est l'erreur la plus subtile et la plus répandue.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Le visiteur arrive sur votre site. Il doit comprendre en 5 secondes : <em>qui vous êtes, ce que vous faites, pour qui, et pourquoi vous choisir vous plutôt qu'un autre.</em>
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              Trop souvent, on lit des titres du type :
            </p>

            <div class="mb-6 space-y-3 not-prose">
              <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                ✗ &nbsp;« Bienvenue sur le site de la maçonnerie Dupont »
              </div>
              <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                ✗ &nbsp;« Expert en solutions de bâtiment depuis 1998 »
              </div>
              <div class="rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
                ✗ &nbsp;« Qualité, savoir-faire, proximité »
              </div>
            </div>

            <p class="mb-6 text-[var(--color-text)]">
              Ces phrases ne disent rien à votre client. Comparez avec :
            </p>

            <div class="mb-6 space-y-3 not-prose">
              <div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
                ✓ &nbsp;« Maçon à Metz — Terrasses, extensions et rénovation de façades, devis en 48h »
              </div>
              <div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">
                ✓ &nbsp;« Plombier disponible 7j/7 à Nancy — Dépannage en moins de 2h »
              </div>
            </div>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">La formule en 3 éléments</h3>
            <ul class="mb-4 text-[var(--color-text)]">
              <li><strong>Métier + zone géographique</strong> — pour le SEO local</li>
              <li><strong>Service principal ou spécialité</strong> — pour la clarté</li>
              <li><strong>Différenciateur concret</strong> — délai, disponibilité, garantie, tarif</li>
            </ul>
          </section>

          <!-- Bonus -->
          <section id="bonus" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Bonus : la 6ème erreur (la plus silencieuse)
            </h2>

            <p class="mb-4 text-[var(--color-text)]">
              Vous n'apparaissez pas sur Google quand quelqu'un cherche votre métier dans votre ville.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              C'est le pire des scénarios : votre site est beau, rapide, convaincant — mais personne ne le voit jamais.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Le SEO local (apparaître sur Google Maps et en 1ère page de résultats pour une recherche géolocalisée) est une compétence à part entière. Il ne s'improvise pas, mais il n'est pas non plus hors de portée.
            </p>
            <p class="text-[var(--color-text)]">
              J'en parle en détail dans l'article dédié : <a href="/journal/seo-local-artisans" class="text-[var(--color-accent)] hover:underline font-medium">SEO local : comment apparaître en première position sur Google quand on est artisan →</a>
            </p>
          </section>

          <!-- Conclusion -->
          <section class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Conclusion
            </h2>

            <p class="mb-4 text-[var(--color-text)]">
              Ces cinq erreurs ont un point commun : elles se corrigent toutes, souvent en moins d'une journée de travail.
            </p>

            <p class="mb-6 text-[var(--color-text)]">
              Si votre site coche 3 de ces erreurs ou plus, il vaut la peine de le refaire plutôt que de le rapiécer. Un site qui fait fuir des clients coûte bien plus cher que le <a href="/journal/combien-coute-un-site-web" class="text-[var(--color-accent)] hover:underline font-medium">devis de refonte</a>.
            </p>

            <ol class="mb-6 text-[var(--color-text)]">
              <li><strong>Testez votre vitesse</strong> sur PageSpeed Insights dès aujourd'hui.</li>
              <li><strong>Vérifiez que votre numéro est visible</strong> sur mobile sans scroll.</li>
              <li><strong>Remplacez au moins une photo stock</strong> par une vraie photo de votre activité.</li>
              <li><strong>Ajoutez 2–3 témoignages clients</strong> sur la page d'accueil.</li>
              <li><strong>Relisez votre titre principal</strong> : est-ce qu'il dit clairement ce que vous faites et où ?</li>
            </ol>
          </section>

          <!-- Pour aller plus loin -->
          <div class="mt-12 mb-4 not-prose">
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-4">Pour aller plus loin</p>
            <div class="grid gap-4 sm:grid-cols-2">
              <a href="/journal/pourquoi-votre-site-est-lent" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-[var(--color-accent)]/10 px-2 py-0.5 text-xs font-semibold text-[var(--color-accent)] mb-3">Performance</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">Pourquoi votre site WordPress est lent — et ce que ça vous coûte</p>
              </a>
              <a href="/journal/faut-il-un-blog" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-[var(--color-accent)]/10 px-2 py-0.5 text-xs font-semibold text-[var(--color-accent)] mb-3">Stratégie</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">Faut-il un blog pour son site vitrine ? (Réponse honnête)</p>
              </a>
            </div>
          </div>

          <!-- Bio auteur -->
          <div class="my-10 flex items-center gap-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-6 not-prose">
            <img
              src="/images/marc-muller.webp"
              alt="Marc Muller — développeur web freelance"
              class="w-16 h-16 rounded-full object-cover shrink-0 border-2 border-white shadow-sm"
            />
            <div>
              <p class="font-bold text-[var(--color-text)] mb-1">Marc Muller</p>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Développeur web freelance. Je crée des sites ultra-rapides pour artisans et commerçants,
                livrés en 5–7 jours, sans WordPress ni contrats de maintenance.
              </p>
            </div>
          </div>

          <!-- CTA -->
          <section class="rounded-xl bg-[var(--color-accent)] p-8 text-center text-white not-prose">
            <h2 class="mb-4 text-2xl font-bold">Votre site fait-il ces erreurs ?</h2>
            <p class="mb-3 text-lg opacity-95">Je peux auditer votre site en 24h et vous dire exactement ce qui freine vos conversions.</p>
            <p class="mb-8 opacity-80 text-sm">Audit gratuit, sans engagement.</p>
            <a
              href="/commander"
              class="inline-block rounded-xl bg-white px-8 py-3 font-semibold text-[var(--color-accent)] transition-all hover:bg-neutral-100 hover:shadow-lg"
            >
              Commander mon site — 490€
            </a>
            <p class="mt-4">
              <a href="/contact" class="text-sm text-white/90 underline underline-offset-4 hover:text-white transition-colors">
                Besoin de plus ? Projet sur mesure →
              </a>
            </p>
          </section>
        </div>
      </article>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Les 5 erreurs qui font fuir les clients de votre site web",
      "description": "Un site web peut faire fuir des clients sans même que vous le sachiez. Voici les 5 erreurs les plus fréquentes chez les artisans — et comment les corriger.",
      "image": "https://marcm.fr/og-default.png",
      "datePublished": "2026-03-08",
      "dateModified": "2026-03-08",
      "author": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr/qui-suis-je" },
      "publisher": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": "https://marcm.fr/journal/5-erreurs-site-web-artisan" },
      "articleSection": "Conseils",
      "inLanguage": "fr-FR"
    }
  </script>
</BaseLayout>
