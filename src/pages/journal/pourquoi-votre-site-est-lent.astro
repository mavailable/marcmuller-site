---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Pourquoi votre site WordPress est lent — et ce que ça vous coûte vraiment';
const description = 'Un site lent perd 53 % de ses visiteurs mobiles. Voici pourquoi WordPress ralentit inévitablement avec le temps, ce que ça vous coûte en clients, et quelles solutions marchent vraiment.';

const publishDate = '2026-01-15';
const readTime = 7;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage="/og-default.png"
  lang="fr"
  frPath="/journal/pourquoi-votre-site-est-lent"
  enPath="/en/blog/why-your-website-is-slow"
>
  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/journal" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour au journal
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-semibold text-[var(--color-accent)]">
          Performance
        </span>
        <span class="text-sm text-neutral-400">15 janvier 2026</span>
        <span class="text-sm text-neutral-400">•</span>
        <span class="text-sm text-neutral-400">{readTime} min de lecture</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        {title}
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">
        <div class="prose max-w-none">

          <!-- Table des matières -->
          <nav class="mb-12 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6 not-prose">
            <p class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Au programme</p>
            <ol class="space-y-2 text-sm">
              <li><a href="#chiffres" class="text-[var(--color-accent)] hover:underline font-medium">1. Les chiffres qui font mal</a></li>
              <li><a href="#pourquoi-lent" class="text-[var(--color-accent)] hover:underline font-medium">2. Pourquoi WordPress ralentit avec le temps</a></li>
              <li><a href="#cout-reel" class="text-[var(--color-accent)] hover:underline font-medium">3. Ce que la lenteur vous coûte concrètement</a></li>
              <li><a href="#solutions-qui-marchent-pas" class="text-[var(--color-accent)] hover:underline font-medium">4. Les solutions qui ne marchent pas vraiment</a></li>
              <li><a href="#vraie-solution" class="text-[var(--color-accent)] hover:underline font-medium">5. La vraie solution : changer de stack</a></li>
              <li><a href="#faq" class="text-[var(--color-accent)] hover:underline font-medium">6. FAQ</a></li>
            </ol>
          </nav>

          <!-- Intro -->
          <section class="mb-12">
            <p class="mb-4 text-lg text-[var(--color-text)]">
              Vous avez un site WordPress. Il était rapide à sa création.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Puis vous avez ajouté des plugins. Votre hébergeur a mis à jour PHP. Un plugin a cassé quelque chose. Un autre a gonflé la taille des pages. Le thème s'est alourdi avec les mises à jour.
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              Résultat : votre site charge en 6 secondes sur mobile. Et vous perdez des clients sans même le savoir.
            </p>
          </section>

          <!-- Section 1 -->
          <section id="chiffres" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              1. Les chiffres qui font mal
            </h2>

            <div class="space-y-4 mb-8 not-prose">
              <div class="rounded-xl border-l-4 border-red-500 bg-red-50 pl-5 py-4 pr-4">
                <p class="text-2xl font-bold text-red-600 mb-1">53 %</p>
                <p class="text-sm text-red-700">des visiteurs mobiles quittent un site qui met plus de <strong>3 secondes</strong> à charger (Google, 2024)</p>
              </div>
              <div class="rounded-xl border-l-4 border-orange-500 bg-orange-50 pl-5 py-4 pr-4">
                <p class="text-2xl font-bold text-orange-600 mb-1">7 %</p>
                <p class="text-sm text-orange-700">de perte de conversion pour chaque seconde de délai supplémentaire</p>
              </div>
              <div class="rounded-xl border-l-4 border-yellow-500 bg-yellow-50 pl-5 py-4 pr-4">
                <p class="text-2xl font-bold text-yellow-600 mb-1">Top 3</p>
                <p class="text-sm text-yellow-700">La vitesse (Core Web Vitals) est un critère de classement officiel dans les résultats Google</p>
              </div>
            </div>

            <p class="text-[var(--color-text)]">
              Concrètement : si votre site génère 200 visites par mois et que la moitié part à cause de la lenteur, vous perdez 100 occasions de contact chaque mois.
            </p>
          </section>

          <!-- Section 2 -->
          <section id="pourquoi-lent" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              2. Pourquoi WordPress ralentit avec le temps
            </h2>

            <p class="mb-6 text-[var(--color-text)]">
              WordPress n'est pas lent par nature. C'est son architecture dynamique qui crée le problème à l'échelle.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Le problème des requêtes en cascade</h3>
            <p class="mb-6 text-[var(--color-text)]">
              À chaque fois qu'un visiteur charge votre page WordPress, le serveur exécute 30 à 80 requêtes SQL, charge 10 à 25 fichiers PHP, assemble les contenus, génère le HTML… le tout en temps réel. Chaque plugin ajoute ses propres requêtes. La note s'accumule.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Le poids des scripts</h3>
            <p class="mb-6 text-[var(--color-text)]">
              Un WordPress standard avec un thème Elementor et 15 plugins charge souvent entre 3 et 8 Mo de données par page. Un site Astro statique équivalent charge 200 à 600 Ko. Soit 5 à 15 fois plus léger.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Les plugins bloatware</h3>
            <p class="mb-4 text-[var(--color-text)]">
              Les plugins les plus gourmands :
            </p>
            <ul class="mb-6 text-[var(--color-text)]">
              <li><strong>Constructeurs de pages</strong> (Elementor, Divi, WPBakery) — injectent des tonnes de CSS/JS inutilisé</li>
              <li><strong>Sliders</strong> — chargent des librairies JavaScript lourdes pour peu d'effet</li>
              <li><strong>Plugins SEO mal configurés</strong> — doublonnent parfois des balises</li>
              <li><strong>Chat en direct, popups, trackers</strong> — chargent des scripts tiers bloquants</li>
            </ul>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Un site non optimisé pour mobile</h3>
            <p class="text-[var(--color-text)]">
              WordPress charge le même volume de données sur mobile que sur desktop. Pourtant, 65 à 75 % des visiteurs d'un artisan arrivent depuis un smartphone, souvent en 4G ou en zone intermédiaire.
            </p>
          </section>

          <!-- Section 3 -->
          <section id="cout-reel" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              3. Ce que la lenteur vous coûte concrètement
            </h2>

            <p class="mb-6 text-[var(--color-text)]">
              Passons aux chiffres réels. Prenons un artisan avec un site qui génère 150 visites par mois et perd 50 % des visiteurs mobiles à cause de la vitesse.
            </p>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6 font-mono text-sm text-[var(--color-text)] not-prose">
              <p class="font-bold mb-3 not-italic">Simulation mensuelle :</p>
              <p>Visites totales : 150</p>
              <p>Visites mobiles (70 %) : 105</p>
              <p>Bounce rate lenteur (53 %) : ~55 visiteurs perdus</p>
              <p>Taux de contact habituel : 5 %</p>
              <p class="mt-3 font-bold">Contacts perdus/mois : ~3</p>
              <p>Valeur moyenne d'un client : 400–1 500€</p>
              <p class="mt-3 font-bold text-red-600">Manque à gagner estimé : 1 200–4 500€/mois</p>
            </div>

            <p class="text-[var(--color-text)]">
              Contre ce manque à gagner, une refonte de site (dès 490€) est rentabilisée en quelques jours.
            </p>
          </section>

          <!-- Section 4 -->
          <section id="solutions-qui-marchent-pas" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              4. Les solutions qui ne marchent pas vraiment
            </h2>

            <p class="mb-6 text-[var(--color-text)]">
              On vous vendra souvent des pansements sur une jambe de bois. Les voici :
            </p>

            <div class="space-y-4 not-prose">
              <div class="rounded-xl border border-[var(--color-border)] p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">❌ &nbsp;Changer d'hébergeur</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Un hébergeur plus puissant aide un peu — mais la lenteur vient du code, pas du serveur. Vous payez plus cher pour masquer le problème.</p>
              </div>
              <div class="rounded-xl border border-[var(--color-border)] p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">❌ &nbsp;Installer WP Rocket ou LiteSpeed</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Ces plugins de cache améliorent les scores, mais ils ne corrigent pas le fond. Un site mal structuré reste lourd, même mis en cache. Et ça rajoute un plugin de plus à maintenir.</p>
              </div>
              <div class="rounded-xl border border-[var(--color-border)] p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">❌ &nbsp;Supprimer des plugins un par un</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Souvent, un plugin en remplace un autre. Et certains sont devenus tellement imbriqués dans le thème qu'on ne peut plus les supprimer sans casser quelque chose.</p>
              </div>
              <div class="rounded-xl border border-[var(--color-border)] p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">❌ &nbsp;Payer une agence pour "optimiser" votre WordPress</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">300 à 800€ de prestation pour gagner 10–15 points de score. Temporairement. La prochaine mise à jour d'un plugin régressera les performances. C'est une course sans fin.</p>
              </div>
            </div>
          </section>

          <!-- Section 5 -->
          <section id="vraie-solution" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              5. La vraie solution : changer de stack
            </h2>

            <p class="mb-4 text-[var(--color-text)]">
              La vraie solution pour avoir un site rapide et le rester, c'est de construire sur une architecture <strong>statique</strong> plutôt que dynamique.
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              Un site statique ne génère rien à la volée. Les pages sont pré-compilées en fichiers HTML/CSS/JS ultra-légers. Quand quelqu'un visite votre site, le serveur sert simplement un fichier — comme si vous envoyiez une image. Pas de PHP, pas de SQL, pas de plugins à charger.
            </p>

            <div class="mb-6 overflow-x-auto rounded-xl border border-[var(--color-border)] not-prose">
              <table class="w-full border-collapse text-sm text-[var(--color-text)]">
                <thead>
                  <tr class="bg-[var(--color-bg-alt)]">
                    <th class="border-b border-[var(--color-border)] p-3 text-left font-bold">Indicateur</th>
                    <th class="border-b border-[var(--color-border)] p-3 text-left font-bold">WordPress moyen</th>
                    <th class="border-b border-[var(--color-border)] p-3 text-left font-bold text-[var(--color-accent)]">Astro statique ✦</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td class="border-b border-[var(--color-border)] p-3 font-medium">Score Lighthouse mobile</td>
                    <td class="border-b border-[var(--color-border)] p-3">45–70</td>
                    <td class="border-b border-[var(--color-border)] p-3 text-[var(--color-accent)] font-semibold">95–100</td>
                  </tr>
                  <tr class="bg-[var(--color-bg-alt)]/50">
                    <td class="border-b border-[var(--color-border)] p-3 font-medium">Time to First Byte</td>
                    <td class="border-b border-[var(--color-border)] p-3">400–1 200 ms</td>
                    <td class="border-b border-[var(--color-border)] p-3 text-[var(--color-accent)] font-semibold">20–80 ms</td>
                  </tr>
                  <tr>
                    <td class="border-b border-[var(--color-border)] p-3 font-medium">Poids de la page</td>
                    <td class="border-b border-[var(--color-border)] p-3">3–8 Mo</td>
                    <td class="border-b border-[var(--color-border)] p-3 text-[var(--color-accent)] font-semibold">200–600 Ko</td>
                  </tr>
                  <tr class="bg-[var(--color-bg-alt)]/50">
                    <td class="p-3 font-medium">Maintenance requise</td>
                    <td class="p-3">Mensuelle (plugins, mises à jour)</td>
                    <td class="p-3 text-[var(--color-accent)] font-semibold">Quasi nulle</td>
                  </tr>
                </tbody>
              </table>
            </div>

            <p class="text-[var(--color-text)]">
              Le coût d'une refonte d'un site WordPress vers Astro ? <a href="/journal/combien-coute-un-site-web" class="text-[var(--color-accent)] hover:underline font-medium">À partir de 490€</a>. Souvent inférieur au coût d'un an de maintenance WordPress — et sans la frustration de performances qui régressent.
            </p>
          </section>

          <!-- FAQ -->
          <section id="faq" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              6. FAQ
            </h2>

            <div class="space-y-4">
              <div class="rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6">
                <h3 class="mb-2 text-base font-semibold text-[var(--color-text)]">Mon WordPress a un score de 75 sur mobile, c'est acceptable ?</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">75 est « passable ». Google recommande 90+. À 75, vous perdez probablement 20–30 % de vos visiteurs mobiles. À 95+, vous convertissez nettement mieux et Google vous favorise dans ses résultats.</p>
              </div>
              <div class="rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6">
                <h3 class="mb-2 text-base font-semibold text-[var(--color-text)]">Je peux garder WordPress et juste améliorer le score ?</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Oui, c'est possible avec du travail. Mais les optimisations régressent à chaque mise à jour de plugin ou de thème. C'est un entretien constant. Sauf si votre site a des besoins spécifiques à WordPress (WooCommerce étendu, multisites, accès abonnés), la migration vers une stack statique est toujours plus rentable sur la durée.</p>
              </div>
              <div class="rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6">
                <h3 class="mb-2 text-base font-semibold text-[var(--color-text)]">Un site statique peut-il avoir un blog, un formulaire, des animations ?</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Absolument. Ce journal tourne sur Astro et comporte un blog, un formulaire de contact et des animations CSS. Les fonctionnalités dynamiques (formulaire, contact, newsletter) sont assurées par des services légers dédiés, sans alourdir le site.</p>
              </div>
              <div class="rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6">
                <h3 class="mb-2 text-base font-semibold text-[var(--color-text)]">Combien coûte une refonte vers Astro ?</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Site Vitrine à partir de 490€, avec options à la carte. Projet Sur Mesure sur devis. C'est souvent inférieur à une année de maintenance WordPress (hébergement + mises à jour + sécurité). Et le résultat sera plus rapide, plus sécurisé et plus facile à maintenir. Voir le <a href="/journal/combien-coute-un-site-web" class="text-[var(--color-accent)] hover:underline font-medium">comparatif détaillé des prix</a>.</p>
              </div>
              <div class="rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6">
                <h3 class="mb-2 text-base font-semibold text-[var(--color-text)]">La vitesse du site impacte-t-elle vraiment le SEO ?</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Oui, directement. Depuis 2021, Google intègre les Core Web Vitals (LCP, FID, CLS) dans son algorithme de ranking. Un site lent est doublement pénalisé : il perd des visiteurs à l'arrivée, et Google le classe moins bien que ses concurrents rapides. Pour les artisans, cela se traduit par un impact direct sur le <a href="/journal/seo-local-artisans" class="text-[var(--color-accent)] hover:underline font-medium">SEO local</a>.</p>
              </div>
            </div>
          </section>

          <!-- Conclusion -->
          <section class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Conclusion
            </h2>

            <p class="mb-4 text-[var(--color-text)]">
              Un site lent, c'est un commercial qui part en rendez-vous et rentre sans signer. La promesse est là, mais l'exécution laisse filer les clients.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              La bonne nouvelle : ce problème se résout. Et la solution n'est pas forcément plus chère qu'une année de maintenance WordPress.
            </p>
            <p class="text-[var(--color-text)]">
              Pour tester votre site maintenant, rendez-vous sur <strong>pagespeed.web.dev</strong>, entrez votre URL et regardez le score mobile. S'il est en dessous de 80, il vaut la peine d'agir.
            </p>
          </section>

          <!-- Pour aller plus loin -->
          <div class="mt-12 mb-4 not-prose">
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-4">Pour aller plus loin</p>
            <div class="grid gap-4 sm:grid-cols-2">
              <a href="/journal/combien-coute-un-site-web" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-[var(--color-accent)]/10 px-2 py-0.5 text-xs font-semibold text-[var(--color-accent)] mb-3">Business</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">Combien coûte un site web en 2026 ? (comparatif honnête)</p>
              </a>
              <a href="/journal/seo-local-artisans" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-[var(--color-accent)]/10 px-2 py-0.5 text-xs font-semibold text-[var(--color-accent)] mb-3">SEO</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">SEO local : comment apparaître en première position sur Google</p>
              </a>
            </div>
          </div>

          <!-- Bio auteur -->
          <div class="my-10 flex items-center gap-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-6 not-prose">
            <img
              src="/images/marc-muller.webp"
              alt="Marc Muller — développeur web freelance"
              class="w-16 h-16 rounded-full object-cover shrink-0 border-2 border-white shadow-sm"
            />
            <div>
              <p class="font-bold text-[var(--color-text)] mb-1">Marc Muller</p>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Développeur web freelance. Je crée des sites ultra-rapides pour artisans et commerçants du Grand Est,
                livrés en 5–10 jours, sans WordPress ni maintenance lourde.
              </p>
            </div>
          </div>

          <!-- CTA -->
          <section class="rounded-xl bg-[var(--color-accent)] p-8 text-center text-white not-prose">
            <h2 class="mb-4 text-2xl font-bold">Votre site est-il trop lent ?</h2>
            <p class="mb-3 text-lg opacity-95">Testez-le sur PageSpeed Insights. S'il score moins de 80 sur mobile, je peux vous créer un site 2× plus rapide pour le même budget.</p>
            <p class="mb-8 opacity-80 text-sm">Score Lighthouse 95–100 garanti. Site Vitrine dès 490€.</p>
            <a
              href="/offre"
              class="inline-block rounded-xl bg-white px-8 py-3 font-semibold text-[var(--color-accent)] transition-all hover:bg-neutral-100 hover:shadow-lg"
            >
              Voir les formules — dès 490€
            </a>
            <p class="mt-4">
              <a href="/contact" class="text-sm text-white/90 underline underline-offset-4 hover:text-white transition-colors">
                Une question ? Parlons de votre projet →
              </a>
            </p>
          </section>
        </div>
      </article>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Pourquoi votre site WordPress est lent — et ce que ça vous coûte vraiment",
      "description": "Un site lent perd 53 % de ses visiteurs mobiles. Voici pourquoi WordPress ralentit inévitablement avec le temps, ce que ça vous coûte en clients, et quelles solutions marchent vraiment.",
      "image": "https://marcm.fr/og-default.png",
      "datePublished": "2026-01-15",
      "dateModified": "2026-01-15",
      "author": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr/qui-suis-je" },
      "publisher": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": "https://marcm.fr/journal/pourquoi-votre-site-est-lent" },
      "articleSection": "Performance",
      "inLanguage": "fr-FR"
    }
  </script>
</BaseLayout>
