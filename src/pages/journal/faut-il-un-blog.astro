---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Faut-il un blog pour son site vitrine ? (Réponse honnête)';
const description = 'Le blog est souvent vendu comme une solution miracle pour le SEO. La réalité est plus nuancée. Voici quand un blog vaut vraiment la peine — et quand c\'est une perte de temps.';

const publishDate = '2026-01-05';
const readTime = 6;
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  ogImage="/og-default.png"
  lang="fr"
  frPath="/journal/faut-il-un-blog"
  enPath="/en/blog/do-you-need-a-blog"
>
  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/journal" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Retour au journal
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-[var(--color-accent)]/30 bg-[var(--color-accent)]/10 px-3 py-1 text-xs font-semibold text-[var(--color-accent)]">
          Stratégie
        </span>
        <span class="text-sm text-neutral-400">5 janvier 2026</span>
        <span class="text-sm text-neutral-400">•</span>
        <span class="text-sm text-neutral-400">{readTime} min de lecture</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        {title}
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">
        <div class="prose max-w-none">

          <!-- Table des matières -->
          <nav class="mb-12 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6 not-prose">
            <p class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">Au programme</p>
            <ol class="space-y-2 text-sm">
              <li><a href="#promesse-blog" class="text-[var(--color-accent)] hover:underline font-medium">1. La promesse du blog — et ce qu'elle cache</a></li>
              <li><a href="#blog-bonne-idee" class="text-[var(--color-accent)] hover:underline font-medium">2. Quand un blog est une excellente idée</a></li>
              <li><a href="#blog-mauvaise-idee" class="text-[var(--color-accent)] hover:underline font-medium">3. Quand un blog est une perte de temps</a></li>
              <li><a href="#alternatives" class="text-[var(--color-accent)] hover:underline font-medium">4. Les alternatives au blog</a></li>
              <li><a href="#recommandation" class="text-[var(--color-accent)] hover:underline font-medium">5. Ma recommandation selon votre profil</a></li>
            </ol>
          </nav>

          <!-- Intro -->
          <section class="mb-12">
            <p class="mb-4 text-lg text-[var(--color-text)]">
              « Vous devriez créer un blog, ça fait du SEO. »
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Vous avez probablement entendu ça. Peut-être d'un ami, d'une agence, ou d'un article lu en 2019.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              C'est vrai — et c'est faux. Ça dépend entièrement de qui vous êtes, de ce que vous faites, et surtout de combien de temps vous êtes prêt à y consacrer.
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              Voici une réponse honnête, sans vendeur de rêves.
            </p>
          </section>

          <!-- Section 1 -->
          <section id="promesse-blog" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              1. La promesse du blog — et ce qu'elle cache
            </h2>

            <p class="mb-4 text-[var(--color-text)]">
              La logique est simple : plus de contenu = plus de pages indexées = plus de trafic organique.
            </p>
            <p class="mb-6 text-[var(--color-text)]">
              C'est vrai dans l'absolu. Mais il manque plusieurs conditions rarement mentionnées :
            </p>

            <ul class="mb-6 text-[var(--color-text)]">
              <li><strong>Le contenu doit être de qualité</strong> — un article bâclé de 400 mots n'indexe pas, ou mal</li>
              <li><strong>Il faut de la régularité</strong> — un blog avec 2 articles puis rien pendant 8 mois est contre-productif</li>
              <li><strong>Les résultats sont lents</strong> — il faut 6 à 12 mois avant de voir du trafic SEO sur un article</li>
              <li><strong>La concurrence est forte</strong> — si d'autres sites sur votre thématique blogguent depuis 5 ans, vous partez de loin</li>
            </ul>

            <p class="rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 text-[var(--color-text)] text-sm">
              Un blog mal tenu fait parfois plus de mal que de bien : il signale à Google que votre site est peu actif, et peut diluer votre autorité si les articles ne sont pas liés à votre activité principale.
            </p>
          </section>

          <!-- Section 2 -->
          <section id="blog-bonne-idee" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              2. Quand un blog est une excellente idée
            </h2>

            <div class="space-y-4 mb-6 not-prose">

              <div class="rounded-xl border border-[var(--color-border)] p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">✓ &nbsp;Vous êtes consultant, coach ou expert</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Votre valeur perçue dépend de votre expertise visible. Des articles de fond — stratégie, analyses, cas concrets — construisent votre autorité et convainquent des prospects haut de gamme avant même qu'ils vous contactent.</p>
              </div>

              <div class="rounded-xl border border-[var(--color-border)] p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">✓ &nbsp;Vous travaillez sur un sujet de niche à fort volume de recherche</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Exemple : vous êtes spécialiste de la restauration de volets anciens en Alsace. Les gens cherchent « comment restaurer un volet en bois ancien ». Un article bien écrit peut vous apporter du trafic qualifié pendant des années.</p>
              </div>

              <div class="rounded-xl border border-[var(--color-border)] p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">✓ &nbsp;Vous avez vraiment le temps et l'envie d'écrire régulièrement</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Si vous pouvez publier 1 article de qualité par mois (minimum 800 mots, utile, bien structuré) pendant au moins un an, ça peut faire une vraie différence. Si ce n'est pas réaliste, ne commencez pas.</p>
              </div>

              <div class="rounded-xl border border-[var(--color-border)] p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">✓ &nbsp;Votre activité couvre une large zone géographique</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Si vous intervenez dans plusieurs villes ou régions, un blog vous permet de créer du contenu ciblé par zone (« rénovation salle de bain Épinal », « menuisier sur mesure Metz ») sans alourdir votre navigation principale.</p>
              </div>

            </div>
          </section>

          <!-- Section 3 -->
          <section id="blog-mauvaise-idee" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              3. Quand un blog est une perte de temps
            </h2>

            <div class="space-y-4 mb-6 not-prose">

              <div class="rounded-xl border border-red-100 bg-red-50/50 p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">✗ &nbsp;Vous êtes artisan de proximité dans une petite ville</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Un électricien à Épinal n'a pas besoin d'un blog pour capter ses clients locaux. Il a besoin d'une fiche Google Business optimisée, d'un site rapide avec les bons mots-clés locaux, et d'avis clients. Pas de contenu rédactionnel.</p>
              </div>

              <div class="rounded-xl border border-red-100 bg-red-50/50 p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">✗ &nbsp;Vous ne pouvez pas tenir un rythme de publication</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Un blog avec 3 articles en 2 ans est pire que pas de blog du tout. Il donne l'impression d'un site abandonné — aux visiteurs comme à Google.</p>
              </div>

              <div class="rounded-xl border border-red-100 bg-red-50/50 p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">✗ &nbsp;Votre thématique est déjà saturée</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Vous voulez écrire sur « comment choisir un artisan » ou « les tendances de la cuisine 2026 » ? Ces sujets sont occupés par des dizaines de gros médias depuis des années. Vous n'apparaîtrez pas en première page, jamais.</p>
              </div>

              <div class="rounded-xl border border-red-100 bg-red-50/50 p-5">
                <p class="font-semibold text-[var(--color-text)] mb-2">✗ &nbsp;Votre temps est mieux investi ailleurs</p>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">Le temps que vous passez à rédiger un article, vous pourriez l'investir dans des avis Google, des publications sur votre fiche GBP, ou dans la prospection directe. Pour beaucoup d'artisans, le ROI est bien meilleur sur ces canaux.</p>
              </div>

            </div>
          </section>

          <!-- Section 4 -->
          <section id="alternatives" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              4. Les alternatives au blog
            </h2>

            <p class="mb-6 text-[var(--color-text)]">
              Si l'objectif est le SEO et la visibilité, il existe des leviers souvent plus efficaces pour un artisan :
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Pages de services spécifiques</h3>
            <p class="mb-6 text-[var(--color-text)]">
              Plutôt qu'un blog généraliste, créez des pages dédiées à chaque service : « Rénovation salle de bain Nancy », « Installation climatisation Metz ». Ces pages ciblent des requêtes précises avec forte intention d'achat. Elles indexent bien, attirent les bons clients, et ne demandent aucune mise à jour régulière.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Pages de villes</h3>
            <p class="mb-6 text-[var(--color-text)]">
              Si vous intervenez dans plusieurs communes, une page par ville (avec contenu spécifique, pas du copier-coller) vous positionne localement sans effort éditorial mensuel. C'est une décision structurelle, pas un engagement continu.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">FAQ intégrée au site</h3>
            <p class="mb-6 text-[var(--color-text)]">
              Une section FAQ bien rédigée répond aux questions fréquentes de vos clients ET capte des requêtes longue traîne sur Google. Elle se met à jour ponctuellement, pas chaque mois.
            </p>

            <h3 class="mb-3 text-lg font-semibold text-[var(--color-text)]">Publications Google Business Profile</h3>
            <p class="mb-4 text-[var(--color-text)]">
              Google valorise les fiches actives. Une publication mensuelle courte (photo d'une réalisation + description) suffit à maintenir votre fiche vivante. C'est 10 minutes par mois, pas 3 heures d'écriture.
            </p>

            <p class="mb-4 text-[var(--color-text)] text-sm">
              → Ces alternatives sont détaillées dans le guide complet : <a href="/journal/seo-local-artisans" class="text-[var(--color-accent)] hover:underline font-medium">SEO local pour artisans — comment apparaître en première position sur Google</a>.
            </p>
          </section>

          <!-- Section 5 -->
          <section id="recommandation" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              5. Ma recommandation selon votre profil
            </h2>

            <div class="space-y-5 not-prose">

              <div class="rounded-xl border border-[var(--color-border)] overflow-hidden">
                <div class="bg-[var(--color-bg-alt)] px-5 py-3 border-b border-[var(--color-border)]">
                  <p class="font-bold text-[var(--color-text)] text-sm">Artisan ou commerçant de proximité</p>
                </div>
                <div class="px-5 py-4">
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                    <strong class="text-[var(--color-text)]">Pas de blog.</strong> Priorité à la fiche Google Business optimisée, aux pages de services et aux avis clients. Investissez votre temps ici plutôt que dans la rédaction.
                  </p>
                </div>
              </div>

              <div class="rounded-xl border border-[var(--color-border)] overflow-hidden">
                <div class="bg-[var(--color-bg-alt)] px-5 py-3 border-b border-[var(--color-border)]">
                  <p class="font-bold text-[var(--color-text)] text-sm">Artisan qui intervient dans 3+ villes / une région</p>
                </div>
                <div class="px-5 py-4">
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                    <strong class="text-[var(--color-text)]">Pages de villes plutôt que blog.</strong> Créez une page par zone géographique clé avec contenu spécifique. Pas de blog.
                  </p>
                </div>
              </div>

              <div class="rounded-xl border border-[var(--color-border)] overflow-hidden">
                <div class="bg-[var(--color-bg-alt)] px-5 py-3 border-b border-[var(--color-border)]">
                  <p class="font-bold text-[var(--color-text)] text-sm">Consultant / coach / formateur</p>
                </div>
                <div class="px-5 py-4">
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                    <strong class="text-[var(--color-text)]">Blog fortement recommandé</strong> — si vous pouvez publier 1 article de fond par mois. Votre expertise visible est votre principal argument commercial.
                  </p>
                </div>
              </div>

              <div class="rounded-xl border border-[var(--color-border)] overflow-hidden">
                <div class="bg-[var(--color-bg-alt)] px-5 py-3 border-b border-[var(--color-border)]">
                  <p class="font-bold text-[var(--color-text)] text-sm">E-commerce, SaaS, marque</p>
                </div>
                <div class="px-5 py-4">
                  <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                    <strong class="text-[var(--color-text)]">Blog indispensable</strong> — mais professionalisé. Calendrier éditorial, SEO technique, stratégie de mots-clés. Pas du blogging amateur.
                  </p>
                </div>
              </div>

            </div>
          </section>

          <!-- Conclusion -->
          <section class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Conclusion
            </h2>

            <p class="mb-4 text-[var(--color-text)]">
              Un blog peut être un actif SEO extraordinaire — ou un boulet qui pèse sur votre site et votre moral.
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              La question à se poser honnêtement : <em>« Suis-je prêt à publier un article de qualité chaque mois pendant les 12 prochains mois ? »</em>
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Si la réponse est oui, et que votre activité s'y prête, foncez. Si la réponse est hésitante, investissez ce temps dans les leviers qui génèrent des résultats plus rapidement : SEO local, avis Google, pages de services.
            </p>
            <p class="text-[var(--color-text)]">
              Et si vous décidez de vous lancer dans un blog, faites-le sur une base technique solide — un site rapide, avec les bonnes métadonnées et une structure claire. C'est la fondation qui fait que vos efforts éditoriaux portent leurs fruits.
            </p>
          </section>

          <!-- Pour aller plus loin -->
          <div class="mt-12 mb-4 not-prose">
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-4">Pour aller plus loin</p>
            <div class="grid gap-4 sm:grid-cols-2">
              <a href="/journal/seo-local-artisans" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-[var(--color-accent)]/10 px-2 py-0.5 text-xs font-semibold text-[var(--color-accent)] mb-3">SEO</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">SEO local : comment apparaître en première position sur Google</p>
              </a>
              <a href="/journal/5-erreurs-site-web-artisan" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-[var(--color-accent)]/10 px-2 py-0.5 text-xs font-semibold text-[var(--color-accent)] mb-3">Conseils</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">Les 5 erreurs qui font fuir les clients de votre site web</p>
              </a>
            </div>
          </div>

          <!-- Bio auteur -->
          <div class="my-10 flex items-center gap-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-6 not-prose">
            <img
              src="/images/marc-muller.webp"
              alt="Marc Muller — développeur web freelance"
              class="w-16 h-16 rounded-full object-cover shrink-0 border-2 border-white shadow-sm"
            />
            <div>
              <p class="font-bold text-[var(--color-text)] mb-1">Marc Muller</p>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Développeur web freelance. Je crée des sites ultra-rapides pour artisans et commerçants du Grand Est,
                livrés en 5–10 jours, sans WordPress ni maintenance lourde.
              </p>
            </div>
          </div>

          <!-- CTA -->
          <section class="rounded-xl bg-[var(--color-accent)] p-8 text-center text-white not-prose">
            <h2 class="mb-4 text-2xl font-bold">Pas besoin de blog pour être visible sur Google</h2>
            <p class="mb-3 text-lg opacity-95">Un site bien construit, rapide, avec le bon SEO local et les bonnes pages de services fait souvent bien plus pour votre visibilité qu'un blog.</p>
            <p class="mb-8 opacity-80 text-sm">Je vous montre concrètement ce qui marche pour votre activité.</p>
            <a
              href="/offre"
              class="inline-block rounded-xl bg-white px-8 py-3 font-semibold text-[var(--color-accent)] transition-all hover:bg-neutral-100 hover:shadow-lg"
            >
              Voir les formules — dès 490€
            </a>
            <p class="mt-4">
              <a href="/contact" class="text-sm text-white/90 underline underline-offset-4 hover:text-white transition-colors">
                Une question ? Parlons de votre projet →
              </a>
            </p>
          </section>
        </div>
      </article>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "Faut-il un blog pour son site vitrine ? (Réponse honnête)",
      "description": "Le blog est souvent vendu comme une solution miracle pour le SEO. La réalité est plus nuancée. Voici quand un blog vaut vraiment la peine — et quand c'est une perte de temps.",
      "image": "https://marcm.fr/og-default.png",
      "datePublished": "2026-01-05",
      "dateModified": "2026-01-05",
      "author": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr/qui-suis-je" },
      "publisher": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": "https://marcm.fr/journal/faut-il-un-blog" },
      "articleSection": "Stratégie",
      "inLanguage": "fr-FR"
    }
  </script>
</BaseLayout>
