---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

const phoneIcon = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 00.948.684l1.498 7.487a1 1 0 00.502.756l2.048 1.029a11.042 11.042 0 005.516 5.516l1.029 2.048a1 1 0 00.756.502l7.487 1.498a1 1 0 00.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>`;
const mapIcon = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`;
const clockIcon = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`;
const mailIcon = `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>`;
---

<BaseLayout
  title="Contact - Marc Muller"
  description="Parlons de votre projet. Formulaire, email, téléphone. Je réponds en max 48h."
>
  <SchemaOrg type="localBusiness" />
  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <!-- Dot grid overlay -->
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-4xl text-center z-10">
      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Parlons de votre projet
      </h1>
      <p class="text-lg text-gray-300 md:text-xl">
        Formulaire, email, téléphone — comme vous voulez. Je réponds en max 48h.
      </p>
    </div>
  </section>

  <!-- CONTENT SECTION -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-3">
        <!-- FORMULAIRE -->
        <div class="md:col-span-2">
          <h2 class="mb-8 text-2xl font-bold text-[var(--color-text)]">Laissez-moi un message</h2>

          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-6"
          >
            <!-- Web3Forms Access Key -->
            <input
              type="hidden"
              name="access_key"
              value="dccda1f5-4e63-4b9f-9c66-f5ce76f0dfdd"
            />

            <!-- Honeypot (anti-spam) -->
            <input
              type="text"
              name="botcheck"
              style="display: none;"
            />

            <!-- Redirect after submit -->
            <input
              type="hidden"
              name="redirect"
              value="https://marcmuller.fr/merci"
            />

            <!-- Prénom -->
            <div>
              <label for="first_name" class="block text-sm font-medium text-[var(--color-text)] mb-2">
                Prénom *
              </label>
              <input
                type="text"
                id="first_name"
                name="first_name"
                required
                class="w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all"
                placeholder="Votre prénom"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-sm font-medium text-[var(--color-text)] mb-2">
                Email *
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all"
                placeholder="votre@email.com"
              />
            </div>

            <!-- Téléphone -->
            <div>
              <label for="phone" class="block text-sm font-medium text-[var(--color-text)] mb-2">
                Téléphone (optionnel)
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all"
                placeholder="+33 6 XX XX XX XX"
              />
            </div>

            <!-- Activité / Secteur -->
            <div>
              <label for="activity" class="block text-sm font-medium text-[var(--color-text)] mb-2">
                Activité / Secteur *
              </label>
              <input
                type="text"
                id="activity"
                name="activity"
                required
                class="w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all"
                placeholder="Ex: Restaurant, Plomberie, Gîte..."
              />
            </div>

            <!-- Formule -->
            <div>
              <label for="formule" class="block text-sm font-medium text-[var(--color-text)] mb-2">
                Formule envisagée
              </label>
              <select
                id="formule"
                name="formule"
                class="w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all"
              >
                <option value="">-- Choisissez --</option>
                <option value="Essentiel">Essentiel (490€ HT)</option>
                <option value="Multi-pages">Multi-pages (990€ HT)</option>
                <option value="Sur mesure">Sur mesure (1 490€ HT)</option>
                <option value="Pas sûr">Pas encore sûr</option>
              </select>
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-sm font-medium text-[var(--color-text)] mb-2">
                Message *
              </label>
              <textarea
                id="message"
                name="message"
                required
                minlength="20"
                rows="5"
                class="w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all resize-none"
                placeholder="Parlez-moi de votre projet, vos objectifs, vos questions..."
              ></textarea>
              <p class="mt-1 text-xs text-[var(--color-text-muted)]">Minimum 20 caractères</p>
            </div>

            <!-- RGPD -->
            <div class="flex items-start gap-3 pt-4">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 h-5 w-5 rounded border-[var(--color-border)] text-[var(--color-accent)] focus:ring-[var(--color-accent)] cursor-pointer"
              />
              <label for="privacy" class="text-sm text-[var(--color-text-muted)] cursor-pointer">
                J'accepte que mes données soient utilisées pour me recontacter au sujet de mon projet. *
              </label>
            </div>

            <!-- Submit Button -->
            <button
              type="submit"
              class="w-full rounded-xl bg-[var(--color-accent)] px-6 py-3 text-base font-medium text-white transition-all hover:bg-[var(--color-accent-hover)] mt-6"
            >
              Envoyer le message
            </button>
          </form>
        </div>

        <!-- INFOS CONTACT -->
        <div class="space-y-6">
          <!-- Email -->
          <div class="rounded-xl bg-white border border-[var(--color-border)] p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-10 h-10 rounded-lg bg-[var(--color-accent-light)] flex items-center justify-center text-[var(--color-accent)]" set:html={mailIcon} />
              <h3 class="font-bold text-[var(--color-text)]">Email</h3>
            </div>
            <a
              href="mailto:marc@muller.im"
              class="text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] block font-medium"
            >
              marc@muller.im
            </a>
          </div>

          <!-- Localisation -->
          <div class="rounded-xl bg-white border border-[var(--color-border)] p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-10 h-10 rounded-lg bg-[var(--color-accent-light)] flex items-center justify-center text-[var(--color-accent)]" set:html={mapIcon} />
              <h3 class="font-bold text-[var(--color-text)]">Localisation</h3>
            </div>
            <p class="text-[var(--color-text-muted)] text-sm">
              Strasbourg, Grand Est<br />
              (Disponible pour RDV local ou Zoom)
            </p>
          </div>

          <!-- Horaires -->
          <div class="rounded-xl bg-white border border-[var(--color-border)] p-6">
            <div class="flex items-center gap-3 mb-3">
              <span class="w-10 h-10 rounded-lg bg-[var(--color-accent-light)] flex items-center justify-center text-[var(--color-accent)]" set:html={clockIcon} />
              <h3 class="font-bold text-[var(--color-text)]">Horaires</h3>
            </div>
            <p class="text-[var(--color-text-muted)] text-sm">
              Lundi - Vendredi<br />
              9h - 18h<br />
              <span class="text-xs">(Réponse rapide garantie)</span>
            </p>
          </div>

          <!-- Réassurance -->
          <div class="rounded-xl bg-white border-l-4 border-l-[var(--color-accent)] border border-[var(--color-border)] p-6">
            <p class="text-sm text-[var(--color-text)] font-semibold mb-2">
              Pas de spam
            </p>
            <p class="text-sm text-[var(--color-text-muted)]">
              Pas d'appels à 6h du matin. Pas de newsletter non consentie. Juste une discussion honnête sur votre projet. Réponse en max 48h.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Calendly CTA -->
  <section class="w-full bg-gradient-to-b from-[#1A1A1A] to-[#111111] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-white">Vous préférez en parler directement ?</h2>
      <p class="mb-8 text-gray-300">
        Réservez 30 minutes pour discuter de votre projet en détail.
      </p>
      <a
        href="https://calendly.com/marc-muller"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-block px-8 py-3 bg-[var(--color-accent)] text-white font-medium rounded-xl hover:bg-[var(--color-accent-hover)] transition-all shadow-lg hover:shadow-xl"
        style="box-shadow: 0 10px 25px rgba(232, 108, 71, 0.3);"
      >
        Réserver un créneau sur Calendly
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  input[type="checkbox"] {
    accent-color: var(--color-accent);
  }

  select {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%236B6B6B' stroke-width='2'%3e%3cpath d='M6 9l6 6 6-6'%3e%3c/path%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 0 center;
    background-size: 1.5em 1.5em;
    padding-right: 2rem;
  }
</style>
