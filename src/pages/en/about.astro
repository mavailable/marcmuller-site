---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';
---

<BaseLayout
  title="About Marc M — Freelance Web Developer"
  description="Marc Muller — freelance web developer based in Grand Est, France. I build fast, custom websites for craftspeople, small businesses and entrepreneurs. No templates."
  lang="en"
  frPath="/qui-suis-je"
  enPath="/en/about"
>
  <SchemaOrg type="person" />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-20 md:px-8 md:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-[var(--color-accent)] opacity-[0.06] blur-[120px]"></div>

    <div class="relative mx-auto max-w-4xl text-center z-10">
      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Who is Marc M?
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto">
        I translate your craft into a website.
      </p>
    </div>
  </section>

  <!-- ABOUT CONTENT -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-16 md:grid-cols-2 items-start">

        <!-- Text -->
        <div class="space-y-6 text-[var(--color-text-muted)] leading-relaxed text-base">
          <p>
            I'm <strong class="text-[var(--color-text)]">Marc Muller</strong>, freelance web developer based in Montigny-lès-Metz (Grand Est, France). I specialise in creating custom websites for craftspeople, small businesses and local entrepreneurs.
          </p>
          <p>
            My approach is simple: I listen carefully to what you do, how you work, and who your clients are — then I build a website that actually reflects that. No generic templates. No bloated page builders. Just clean, fast code tailored to you.
          </p>
          <p>
            I use <strong class="text-[var(--color-text)]">Astro</strong> — a modern web framework that produces ultra-fast static sites that Google loves. The result: a site that loads in under a second, scores 100/100 on Lighthouse, and is built to last.
          </p>
          <p>
            I work mainly with businesses in the Grand Est region (Strasbourg, Metz, Nancy, Colmar, Mulhouse) but I'm fully comfortable working remotely with clients anywhere in France or Europe.
          </p>
        </div>

        <!-- Values / Approach -->
        <div class="space-y-6">
          <h2 class="text-2xl font-bold text-[var(--color-text)]">My approach</h2>
          <div class="space-y-4">
            {[
              { title: "Custom, not copy-paste", desc: "Every site is built from scratch. I don't reuse the same template for every client — your business is unique, your website should be too." },
              { title: "Speed is not optional", desc: "A slow site loses visitors. I'm obsessed with performance: every project targets 100/100 on Lighthouse. It's good for users and great for SEO." },
              { title: "SEO from day one", desc: "Visibility is built into the structure, not bolted on later. Technical SEO, Schema.org structured data, and GEO (AI search optimisation) are included in every project." },
              { title: "Honest timelines", desc: "I deliver in 7 days on average. I don't over-promise, and I keep you informed at every step." },
            ].map(({ title, desc }) => (
              <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5">
                <h3 class="mb-2 font-bold text-[var(--color-text)]">{title}</h3>
                <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- TECH STACK -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-16 md:px-8">
    <div class="mx-auto max-w-5xl">
      <h2 class="mb-10 text-center text-2xl font-bold text-[var(--color-text)]">Tech stack</h2>
      <div class="grid gap-4 grid-cols-2 md:grid-cols-4">
        {[
          { name: "Astro", role: "Framework", desc: "Ultra-fast static sites" },
          { name: "Tailwind", role: "Styling", desc: "Consistent, clean design" },
          { name: "Cloudflare", role: "Hosting", desc: "Global CDN, 99.9% uptime" },
          { name: "TypeScript", role: "Language", desc: "Reliable, maintainable code" },
        ].map(({ name, role, desc }) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <div class="mb-2 text-xl font-extrabold text-[var(--color-accent)]">{name}</div>
            <div class="text-xs font-semibold uppercase tracking-wider text-neutral-400 mb-1">{role}</div>
            <p class="text-xs text-[var(--color-text-muted)]">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-[#0D0D0D] px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-6 text-3xl md:text-4xl font-bold text-white">
        Want to work together?
      </h2>
      <p class="mb-10 text-lg text-neutral-400">
        I'd love to hear about your project. Free consultation, no obligation.
      </p>
      <a href="/en/contact" class="inline-flex items-center gap-2 rounded-xl px-10 py-4 text-lg font-semibold text-white transition-all duration-300 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.3);">
        Let's talk
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </section>
</BaseLayout>
