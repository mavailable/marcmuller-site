---
import BaseLayout from '../../layouts/BaseLayout.astro';

const checkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
---

<BaseLayout
  title="Designers & Creatives: offer websites to your clients — without coding"
  description="Web development subcontracting for freelance designers and creatives. One-page site €200, multi-page €300, delivered in 24–72h. Or training to become autonomous at €800."
  ogImage="/og-graphistes.png"
  noindex={true}
  lang="en"
  frPath="/graphistes"
  enPath="/en/designers"
>

  <!-- HERO -->
  <section class="w-full relative px-6 py-20 md:px-8 md:py-32 overflow-hidden" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-20 -left-32 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: #E86C47;"></div>
    <div class="absolute bottom-10 -right-32 w-80 h-80 rounded-full opacity-8 blur-3xl" style="background: #E86C47;"></div>

    <div class="mx-auto max-w-4xl text-center relative z-10">
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]/40">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white/90">For designers & creative freelancers</span>
      </div>

      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl lg:text-6xl">
        Your clients want a website.<br class="hidden md:block" />
        <span class="bg-gradient-to-r from-[#E86C47] to-[#F5C8B3] bg-clip-text text-transparent">What if it was your best opportunity?</span>
      </h1>

      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto mb-10">
        I code and deploy your clients' sites for you. Or I train you to do it yourself. Either way, you keep the client, the margin, and full creative control.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/en/contact" class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-accent)] px-8 py-4 font-semibold text-white transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-lg hover:-translate-y-0.5">
          I'm interested — let's talk
        </a>
        <a href="#offers" class="inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 py-4 font-semibold text-white/85 transition-all hover:bg-white/10">
          See the offers
        </a>
      </div>
    </div>
  </section>

  <!-- TWO PATHS -->
  <section id="offers" class="w-full bg-[var(--color-bg-alt)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="mb-4 text-center text-3xl font-bold text-[var(--color-text)]">Two ways to work together</h2>
      <p class="mb-12 text-center text-[var(--color-text-muted)] text-lg">Choose what fits your situation best.</p>

      <div class="grid gap-8 md:grid-cols-2">

        <!-- PATH 1: Subcontracting -->
        <div class="rounded-2xl border-2 border-[var(--color-accent)] bg-white p-8 shadow-xl relative">
          <div class="absolute -top-4 left-8">
            <span class="bg-[var(--color-accent)] text-white text-xs font-bold px-4 py-1.5 rounded-full">Most popular</span>
          </div>
          <h3 class="mb-2 text-xl font-bold text-[var(--color-text)]">Subcontracting</h3>
          <p class="mb-6 text-[var(--color-text-muted)] text-sm">You handle the design. I handle the code and deployment.</p>
          <div class="space-y-3 mb-8">
            {[
              "One-page site — €200 (you bill €400–600)",
              "Multi-page site — €300 (you bill €600–1,000)",
              "Delivered in 24–72h",
              "Astro + Tailwind (100/100 Lighthouse)",
              "Domain + 1-year hosting included",
              "White-label — your name, your brand",
            ].map(item => (
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex-shrink-0 text-emerald-500" set:html={checkIcon} />
                <span class="text-sm text-[var(--color-text-muted)]">{item}</span>
              </div>
            ))}
          </div>
          <a href="/en/contact" class="block w-full rounded-xl bg-[var(--color-accent)] px-6 py-3 text-center font-semibold text-white transition-all hover:bg-[var(--color-accent-hover)]">
            Start subcontracting
          </a>
        </div>

        <!-- PATH 2: Training -->
        <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm hover:shadow-lg transition-all">
          <h3 class="mb-2 text-xl font-bold text-[var(--color-text)]">Training</h3>
          <p class="mb-6 text-[var(--color-text-muted)] text-sm">I teach you Astro so you can code sites yourself.</p>
          <div class="mb-4 text-3xl font-extrabold text-[var(--color-accent)]">€800</div>
          <div class="space-y-3 mb-8">
            {[
              "2-day intensive training (remote)",
              "Astro + Tailwind: setup, components, deploy",
              "Complete starter template included",
              "1 month of Q&A support after training",
              "Build your first real client site during training",
            ].map(item => (
              <div class="flex items-start gap-3">
                <span class="mt-0.5 flex-shrink-0 text-emerald-500" set:html={checkIcon} />
                <span class="text-sm text-[var(--color-text-muted)]">{item}</span>
              </div>
            ))}
          </div>
          <a href="/en/contact" class="block w-full rounded-xl border-2 border-[var(--color-accent)] px-6 py-3 text-center font-semibold text-[var(--color-accent)] transition-all hover:bg-[var(--color-accent)] hover:text-white">
            Book a training session
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY -->
  <section class="w-full bg-white px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-12 text-center text-3xl font-bold text-[var(--color-text)]">Why work with me?</h2>
      <div class="grid gap-6 md:grid-cols-3">
        {[
          { title: "You keep the client", desc: "White-label by default. The client never knows I exist. Your brand, your relationship." },
          { title: "Real margins", desc: "I charge €200–300. You charge €400–1,000. You keep the difference — no negotiation needed." },
          { title: "No WordPress nightmares", desc: "I work with Astro. Zero plugins, zero maintenance issues. Sites that stay fast and clean." },
        ].map(({ title, desc }) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-6">
            <h3 class="mb-2 font-bold text-[var(--color-text)]">{title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-6 text-3xl font-bold text-white">Ready to team up?</h2>
      <p class="mb-10 text-neutral-400">Send me a message — let's figure out how to work together.</p>
      <a href="/en/contact" class="inline-flex items-center gap-2 rounded-xl px-10 py-4 text-lg font-semibold text-white" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.3);">
        Let's talk
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </section>

</BaseLayout>
