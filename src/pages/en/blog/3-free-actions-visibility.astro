---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = '3 free actions to boost your visibility this week';
const description = 'No ad budget or website needed to get started. Here are 3 concrete, free actions you can take today — that can change your local visibility.';

const publishDate = '2026-05-15';
const readTime = 5;
---

<BaseLayout title={title} description={description} ogType="article" ogImage="/og-default.png" lang="en" frPath="/journal/3-actions-gratuites-visibilite" enPath="/en/blog/3-free-actions-visibility">
  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="relative mx-auto max-w-3xl z-10">
      <a href="/en/blog" class="inline-flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18" /></svg>
        Back to blog
      </a>

      <div class="flex flex-wrap items-center gap-3 mb-6">
        <span class="inline-block rounded-full border border-violet-400/40 bg-violet-400/15 px-3 py-1 text-xs font-semibold text-violet-300">
          Strategy
        </span>
        <span class="text-sm text-neutral-400">May 15, 2026</span>
        <span class="text-sm text-neutral-400">&bull;</span>
        <span class="text-sm text-neutral-400">{readTime} min read</span>
      </div>

      <h1 class="mb-6 text-3xl font-bold leading-tight text-white md:text-5xl">
        {title}
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl leading-relaxed">
        {description}
      </p>
    </div>
  </section>

  <!-- ARTICLE BODY -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <article class="rounded-xl bg-white border border-[var(--color-border)] p-8 md:p-12 shadow-sm">
        <div class="prose max-w-none">

          <!-- Table of contents -->
          <nav class="mb-12 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-6 not-prose">
            <p class="mb-4 text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)]">In this article</p>
            <ol class="space-y-2 text-sm">
              <li><a href="#action-1" class="text-[var(--color-accent)] hover:underline font-medium">1. Create (or complete) your Google Business listing</a></li>
              <li><a href="#action-2" class="text-[var(--color-accent)] hover:underline font-medium">2. Ask for 5 Google reviews today</a></li>
              <li><a href="#action-3" class="text-[var(--color-accent)] hover:underline font-medium">3. Post a before/after on your social media</a></li>
              <li><a href="#bonus" class="text-[var(--color-accent)] hover:underline font-medium">Bonus: 10 more minutes</a></li>
              <li><a href="#why-it-works" class="text-[var(--color-accent)] hover:underline font-medium">Why it works</a></li>
              <li><a href="#faq" class="text-[var(--color-accent)] hover:underline font-medium">Frequently asked questions</a></li>
            </ol>
          </nav>

          <!-- Intro -->
          <section class="mb-12">
            <p class="mb-4 text-lg text-[var(--color-text)]">
              You don't have a website. No marketing budget. No time to "go digital."
            </p>
            <p class="mb-4 text-[var(--color-text)]">
              Good news: these 3 actions cost nothing, take less than 2 hours total, and can generate calls as early as this week.
            </p>
            <p class="text-[var(--color-text)]">
              No theory. Just three things to do, in order, with the estimated time for each.
            </p>
          </section>

          <!-- Action 1 -->
          <section id="action-1" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              1. Create (or complete) your Google Business listing
            </h2>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <div class="flex items-center gap-3 mb-0">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">30</span>
                <span class="text-sm font-semibold text-[var(--color-text)]">minutes — that's all it takes</span>
              </div>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Go to <strong>business.google.com</strong>. Create your listing if it doesn't exist, or claim it if Google generated one automatically.
            </p>

            <p class="mb-3 text-[var(--color-text)]">
              Fill in <strong>everything</strong>:
            </p>
            <ul class="mb-6 text-[var(--color-text)]">
              <li>Your exact business name</li>
              <li>Full address, phone number, opening hours</li>
              <li>The most specific category possible — not "Craftsman" but "Plumber," "Electrician," "Hairdresser"</li>
              <li>At least <strong>5 photos</strong>: your face, your work, your vehicle or tools</li>
              <li>A 750-character description with your trade + city naturally included</li>
            </ul>

            <p class="mb-4 text-[var(--color-text)]">
              <strong>Result:</strong> you show up on Google Maps when someone searches "[your trade] + [your city]." 46% of Google searches have local intent — nearly half. If you don't have a listing, you're invisible to those people.
            </p>

            <div class="mb-4 rounded-xl bg-[var(--color-accent)]/5 border border-[var(--color-accent)]/20 px-6 py-4 not-prose">
              <p class="text-sm text-[var(--color-text)] leading-relaxed italic">
                "An electrician in a small town told me he got 3 calls in the week after creating his listing — and he didn't even have a website."
              </p>
            </div>
          </section>

          <!-- Action 2 -->
          <section id="action-2" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              2. Ask for 5 Google reviews today
            </h2>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <div class="flex items-center gap-3 mb-0">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">15</span>
                <span class="text-sm font-semibold text-[var(--color-text)]">minutes — 5 texts, done</span>
              </div>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Open your Google Business Profile. Copy the direct link for leaving a review (under "Share review form").
            </p>

            <p class="mb-3 text-[var(--color-text)]">
              Send this text to your <strong>5 most recent happy clients</strong>:
            </p>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <p class="text-sm text-[var(--color-text)] leading-relaxed italic">
                "Hi [First name], it's [Your name]. Thanks again for your trust! If you have 2 minutes, a quick Google review would really help me out: [link]. Thank you!"
              </p>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Why 5? Because 5 recent reviews change everything. Google favors businesses with recent activity. A listing with 5 fresh reviews from this week ranks above one with 20 reviews from a year ago. 88% of consumers trust online reviews as much as a personal recommendation.
            </p>

            <p class="text-[var(--color-text)]">
              Want to go deeper on reviews? Check out <a href="/en/blog/local-seo-craftspeople#reviews" class="text-[var(--color-accent)] hover:underline font-medium">the full guide in our local SEO article</a>.
            </p>
          </section>

          <!-- Action 3 -->
          <section id="action-3" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              3. Post a before/after on your social media
            </h2>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <div class="flex items-center gap-3 mb-0">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">20</span>
                <span class="text-sm font-semibold text-[var(--color-text)]">minutes — one photo, one caption, published</span>
              </div>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              Grab your phone. Find a recent photo of a project, a finished piece, a dish, a haircut — whatever you do every day. If you don't have one, go take one now.
            </p>

            <p class="mb-3 text-[var(--color-text)]">
              Post on Facebook, Instagram, or both. Here's a caption template:
            </p>

            <div class="mb-6 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)] p-5 not-prose">
              <p class="text-sm text-[var(--color-text)] leading-relaxed italic">
                "[Trade] in [City] — [short project description]. Before / After. Need a quote? Call me at [number]."
              </p>
            </div>

            <p class="mb-4 text-[var(--color-text)]">
              No hashtag storm. No marketing jargon. Show your work, period.
            </p>

            <p class="mb-4 text-[var(--color-text)]">
              Why it works: your existing network sees the post, shares it, talks about it. A hairdresser gained 4 new clients in one month with just one before/after post per week. Organic reach on local content is still strong — Facebook and Instagram favor posts from nearby businesses.
            </p>

            <p class="text-[var(--color-text)]">
              The most common mistake: not posting at all for fear of "doing it wrong." An imperfect post is infinitely better than no post. Your clients want to see your work, not a polished ad.
            </p>
          </section>

          <!-- Bonus -->
          <section id="bonus" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Bonus: if you have 10 more minutes
            </h2>

            <div class="rounded-xl bg-[var(--color-accent)]/5 border border-[var(--color-accent)]/20 p-6 not-prose">
              <ul class="space-y-3 text-sm text-[var(--color-text)]">
                <li class="flex items-start gap-3">
                  <span class="text-[var(--color-accent)] font-bold shrink-0">+3 min</span>
                  <span>Reply to every existing Google review — even a simple "Thanks [First name]!" shows you're active</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--color-accent)] font-bold shrink-0">+2 min</span>
                  <span>Add your phone number to your Facebook bio</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-[var(--color-accent)] font-bold shrink-0">+5 min</span>
                  <span>Update your WhatsApp Business profile with your trade + city (e.g., "Plumber in Denver — Repairs & Installation")</span>
                </li>
              </ul>
            </div>
          </section>

          <!-- Why it works -->
          <section id="why-it-works" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Why it works
            </h2>

            <p class="mb-6 text-[var(--color-text)]">
              These 3 actions cover the 3 pillars of local visibility:
            </p>

            <div class="space-y-4 mb-6 not-prose">
              <div class="flex items-start gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] px-5 py-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">1</span>
                <div>
                  <p class="font-bold text-[var(--color-text)] mb-1">Google Business = getting found</p>
                  <p class="text-sm text-[var(--color-text-muted)]">You exist on Google Maps. People searching for your trade in your city can find you.</p>
                </div>
              </div>
              <div class="flex items-start gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] px-5 py-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">2</span>
                <div>
                  <p class="font-bold text-[var(--color-text)] mb-1">Reviews = getting chosen</p>
                  <p class="text-sm text-[var(--color-text-muted)]">Between two results, the client calls the one with recent, positive reviews. Trust is built right there.</p>
                </div>
              </div>
              <div class="flex items-start gap-4 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] px-5 py-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">3</span>
                <div>
                  <p class="font-bold text-[var(--color-text)] mb-1">Social media = getting recommended</p>
                  <p class="text-sm text-[var(--color-text-muted)]">Digital word-of-mouth. Your contacts share, comment, tag. The circle grows.</p>
                </div>
              </div>
            </div>

            <p class="text-[var(--color-text)]">
              Together, these three levers create a loop: people find you, trust you, talk about you. Total: 65 minutes of work. Zero dollars spent.
            </p>
          </section>

          <!-- FAQ -->
          <section id="faq" class="mb-12">
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">
              Frequently asked questions
            </h2>

            <div class="space-y-4 not-prose">
              {[
                {
                  q: "I'm already doing all this and it's not working",
                  a: "Check three things: Is your Google Business listing 100% complete (photos, description, specific category)? Do you have 10 or more recent reviews? Are you posting at least once a month on social media? If any answer is no, that's your starting point."
                },
                {
                  q: "Is social media enough without a website?",
                  a: "To get started, yes. Google listing + social media + reviews is enough to get calls. But long-term, a website gives you full control. Facebook can change its rules tomorrow — your website is yours. It's the logical next step, not the first one."
                },
                {
                  q: "How long before I see results?",
                  a: "Google Business Profile: a few days to a few weeks to show up on Maps. Reviews: immediate impact on trust — a client who sees 5 recent stars calls more easily. Social media: variable, but every post is a seed planted. A baker saw his orders increase by 20% in 3 months with one post per week."
                },
              ].map((item) => (
                <details class="group rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] overflow-hidden">
                  <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-semibold text-[var(--color-text)] text-sm list-none hover:text-[var(--color-accent)] transition-colors">
                    {item.q}
                    <svg class="w-4 h-4 shrink-0 ml-3 transition-transform group-open:rotate-180 text-[var(--color-text-muted)]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <p class="px-6 pb-5 pt-1 text-sm text-[var(--color-text-muted)] leading-relaxed border-t border-[var(--color-border)]">{item.a}</p>
                </details>
              ))}
            </div>
          </section>

          <!-- Related articles -->
          <div class="mt-12 mb-4 not-prose">
            <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-text-muted)] mb-4">Related articles</p>
            <div class="grid gap-4 sm:grid-cols-2">
              <a href="/en/blog/local-seo-craftspeople" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-emerald-100 px-2 py-0.5 text-xs font-semibold text-emerald-700 mb-3">SEO</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">Local SEO: how to rank first on Google</p>
              </a>
              <a href="/en/blog/5-website-mistakes-craftspeople" class="group block rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-5 hover:border-[var(--color-accent)]/40 transition-all hover:shadow-sm">
                <span class="inline-block rounded-full bg-sky-100 px-2 py-0.5 text-xs font-semibold text-sky-700 mb-3">Tips</span>
                <p class="font-semibold text-[var(--color-text)] text-sm leading-snug group-hover:text-[var(--color-accent)] transition-colors">5 mistakes that drive clients away from your website</p>
              </a>
            </div>
          </div>

          <!-- Author bio -->
          <div class="my-10 flex items-center gap-5 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-6 not-prose">
            <img
              src="/images/marc-muller.webp"
              alt="Marc Muller — freelance web developer"
              class="w-16 h-16 rounded-full object-cover shrink-0 border-2 border-white shadow-sm"
            />
            <div>
              <p class="font-bold text-[var(--color-text)] mb-1">Marc Muller</p>
              <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                Freelance web developer. I build ultra-fast websites for craftspeople and small businesses in eastern France,
                delivered in 5-10 days, with no WordPress and no heavy maintenance.
              </p>
            </div>
          </div>

          <!-- CTA -->
          <section class="rounded-xl bg-[var(--color-accent)] p-8 text-center text-white not-prose">
            <h2 class="mb-4 text-2xl font-bold">Ready for the next step?</h2>
            <p class="mb-3 text-lg opacity-95">These 3 actions lay the groundwork. A professional website turns them into a client-generating machine. I can build yours in 7 days.</p>
            <p class="mb-8 opacity-80 text-sm">Showcase website from 490. Delivered in 7 days.</p>
            <a
              href="/en/pricing"
              class="inline-block rounded-xl bg-white px-8 py-3 font-semibold text-[var(--color-accent)] transition-all hover:bg-neutral-100 hover:shadow-lg"
            >
              See pricing plans
            </a>
            <p class="mt-4">
              <a href="/en/contact" class="text-sm text-white/90 underline underline-offset-4 hover:text-white transition-colors">
                Have a question? Let's talk about your project
              </a>
            </p>
          </section>
        </div>
      </article>
    </div>
  </section>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": "3 free actions to boost your visibility this week",
      "description": "No ad budget or website needed to get started. Here are 3 concrete, free actions you can take today — that can change your local visibility.",
      "image": "https://marcm.fr/og-default.png",
      "datePublished": "2026-05-15",
      "dateModified": "2026-05-15",
      "author": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr/en/about" },
      "publisher": { "@type": "Person", "name": "Marc Muller", "url": "https://marcm.fr" },
      "mainEntityOfPage": { "@type": "WebPage", "@id": "https://marcm.fr/en/blog/3-free-actions-visibility" },
      "articleSection": "Strategy",
      "inLanguage": "en-US"
    }
  </script>
</BaseLayout>
