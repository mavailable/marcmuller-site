<BaseLayout
  title="Blog — Marc M | Web Design Tips & Insights"
  description="Tips, insights and opinions on web design, local SEO, and building sites that actually work for tradespeople and small businesses. Written by Marc Muller."
  lang="en"
  frPath="/journal"
  enPath="/en/blog"
>
  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative mx-auto max-w-4xl text-center z-10">
      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Blog
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto">
        Thoughts on web, local SEO, and building sites that actually work.
      </p>
    </div>
  </section>

  <!-- ARTICLES -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">
      <div class="grid gap-6">
        {articles.map((article) => (
          <a
            href={article.href}
            class="group block rounded-2xl border border-[var(--color-border)] bg-white p-8 hover:shadow-lg hover:-translate-y-1 transition-all duration-300"
          >
            <div class="mb-3 flex flex-wrap items-center gap-3">
              <span class="rounded-full bg-[var(--color-accent-light)] px-3 py-0.5 text-xs font-semibold text-[var(--color-accent)]">{article.tag}</span>
              <span class="text-xs text-[var(--color-text-muted)]">{article.date}</span>
              <span class="text-xs text-[var(--color-text-muted)]">·</span>
              <span class="text-xs text-[var(--color-text-muted)]">{article.readTime}</span>
            </div>
            <h2 class="mb-3 text-xl font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
              {article.title}
            </h2>
            <p class="text-[var(--color-text-muted)] leading-relaxed">
              {article.excerpt}
            </p>
            <div class="mt-4 inline-flex items-center gap-2 text-sm font-semibold text-[var(--color-accent)]">
              Read the article
              <svg class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
