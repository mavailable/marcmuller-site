---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { business } from '../../data/business';

const { sitesRealises, sitesTotal } = business;
const progressPercent = Math.round((sitesRealises / sitesTotal) * 100);
const spotsLeft = sitesTotal - sitesRealises;
---

<BaseLayout
  title="100 Free Websites for Craftspeople — Marc M"
  description="Marc M is building 100 free professional websites for craftspeople with no online presence. Design, hosting and domain included for the first year."
  lang="en"
  frPath="/100-sites-artisans"
  enPath="/en/100-artisan-websites"
>
  <!-- HERO -->
  <section class="relative w-full min-h-[60vh] flex items-center bg-[#0D0D0D] px-6 py-20 md:px-8 md:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-[20%] left-[10%] w-[500px] h-[500px] rounded-full bg-[var(--color-accent)] opacity-[0.08] blur-[150px]"></div>

    <div class="relative mx-auto max-w-4xl text-center z-10">
      <div class="mb-6 inline-flex items-center gap-2.5 rounded-full px-5 py-2 text-sm font-semibold" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.3); color: #E86C47;">
        <span class="relative flex h-2 w-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style="background: #E86C47;"></span>
          <span class="relative inline-flex h-2 w-2 rounded-full" style="background: #E86C47;"></span>
        </span>
        Challenge in progress — {spotsLeft} spots left
      </div>

      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-6xl">
        100 Websites.<br>
        <span style="background: linear-gradient(135deg, #E86C47, #FF8A65); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">100 Craftspeople. Free.</span>
      </h1>
      <p class="mb-8 text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto">
        I'm building 100 free professional websites for craftspeople and tradespeople with no online presence. No catch. No hidden fees.
      </p>

      <!-- Progress counter -->
      <div class="mx-auto mb-10 max-w-xs">
        <div class="flex items-baseline justify-center gap-1 mb-2">
          <span class="text-6xl font-extrabold" style="color: #E86C47;">{sitesRealises}</span>
          <span class="text-2xl font-bold text-white/50">/{sitesTotal}</span>
        </div>
        <p class="text-xs text-white/50 uppercase tracking-widest mb-3">sites built</p>
        <div class="w-full bg-white/10 rounded-full h-2">
          <div class="h-2 rounded-full" style={`width: ${progressPercent === 0 ? 0.5 : progressPercent}%; background: linear-gradient(90deg, #E86C47, #FF8A65);`}></div>
        </div>
      </div>

      <a
        href="#apply"
        class="inline-flex items-center gap-2 rounded-xl px-10 py-4 text-lg font-semibold text-white transition-all duration-300 hover:-translate-y-0.5"
        style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.3);"
      >
        Apply for a free website
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <h2 class="mb-4 text-center text-3xl font-bold text-[var(--color-text)]">What's included</h2>
      <p class="mb-12 text-center text-[var(--color-text-muted)] text-lg">Everything you need to get online. For free.</p>
      <div class="grid gap-6 md:grid-cols-3">
        {[
          { icon: "🎨", title: "Custom design", desc: "A site that looks like your business, not a generic template." },
          { icon: "🔍", title: "SEO included", desc: "Built to rank on Google from day one. Local SEO, structured data, fast loading." },
          { icon: "🌐", title: "Domain + hosting (1 year)", desc: "Your .fr or .com domain and Cloudflare hosting included for the first year." },
          { icon: "📱", title: "Mobile-first", desc: "Perfect on phones and tablets. Most of your clients browse on mobile." },
          { icon: "✉️", title: "Contact form", desc: "So clients can reach you directly from your site." },
          { icon: "⚡", title: "100/100 performance", desc: "Sites that load in under a second. No bloated plugins, no slow WordPress." },
        ].map(({ icon, title, desc }) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md hover:-translate-y-0.5 transition-all duration-300">
            <div class="mb-3 text-3xl">{icon}</div>
            <h3 class="mb-2 font-bold text-[var(--color-text)]">{title}</h3>
            <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO IS THIS FOR -->
  <section class="w-full bg-white px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-4xl">
      <h2 class="mb-4 text-center text-3xl font-bold text-[var(--color-text)]">Who can apply?</h2>
      <p class="mb-12 text-center text-[var(--color-text-muted)] text-lg">This initiative is for craftspeople and tradespeople with no online presence.</p>
      <div class="grid gap-4 md:grid-cols-2">
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-6">
          <h3 class="mb-4 font-bold text-emerald-700">✅ You qualify if you are:</h3>
          <ul class="space-y-2 text-sm text-emerald-700">
            {["A craftsperson (plumber, electrician, carpenter, painter…)", "A tradesperson (hairdresser, florist, baker…)", "A local service provider (cleaner, gardener…)", "A micro-enterprise or sole trader", "You have no website or a very outdated one"].map(item => (
              <li class="flex items-start gap-2"><span class="mt-0.5 flex-shrink-0">•</span>{item}</li>
            ))}
          </ul>
        </div>
        <div class="rounded-xl border border-neutral-200 bg-neutral-50 p-6">
          <h3 class="mb-4 font-bold text-neutral-600">ℹ️ Good to know:</h3>
          <ul class="space-y-2 text-sm text-neutral-600">
            {["After year 1, hosting renewal at €120/year (optional)", "I select candidates based on fit and availability", "I commit to 100 sites — first come, first served", "Remote collaboration is absolutely fine"].map(item => (
              <li class="flex items-start gap-2"><span class="mt-0.5 flex-shrink-0">•</span>{item}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- APPLY FORM -->
  <section id="apply" class="w-full bg-[var(--color-bg-alt)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-2xl">
      <h2 class="mb-4 text-center text-3xl font-bold text-[var(--color-text)]">Apply now</h2>
      <p class="mb-12 text-center text-[var(--color-text-muted)]">Tell me about your business. I'll get back to you within 48 hours.</p>

      <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
        <input type="hidden" name="access_key" value="dccda1f5-4e63-4b9f-9c66-f5ce76f0dfdd" />
        <input type="hidden" name="subject" value="100 Websites application — marcm.fr/en" />
        <input type="hidden" name="redirect" value="https://marcm.fr/en/thank-you" />
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

        <div class="grid gap-6 md:grid-cols-2">
          <div>
            <label for="name" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">Full name *</label>
            <input type="text" id="name" name="name" required placeholder="John Smith"
              class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] placeholder-neutral-400 focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20" />
          </div>
          <div>
            <label for="email" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">Email *</label>
            <input type="email" id="email" name="email" required placeholder="john@yourbusiness.com"
              class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] placeholder-neutral-400 focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20" />
          </div>
        </div>

        <div>
          <label for="trade" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">Your trade / business *</label>
          <input type="text" id="trade" name="trade" required placeholder="Electrician, baker, hairdresser…"
            class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] placeholder-neutral-400 focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20" />
        </div>

        <div>
          <label for="message" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">Tell me more</label>
          <textarea id="message" name="message" rows="4" placeholder="Where are you based? What do you do? Why do you need a website?"
            class="w-full rounded-xl border border-[var(--color-border)] bg-white px-4 py-3 text-[var(--color-text)] placeholder-neutral-400 focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20 resize-none"></textarea>
        </div>

        <button type="submit" class="group w-full inline-flex items-center justify-center gap-2 rounded-xl px-8 py-4 text-base font-semibold text-white transition-all duration-300 hover:-translate-y-0.5" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.3);" data-umami-event="en-100websites-apply">
          Apply for my free website
          <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
