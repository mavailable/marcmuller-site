---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';
---

<BaseLayout
  title="Web Design Strasbourg — Marc M | Custom Websites"
  description="Custom website creation in Strasbourg and Alsace. Fast, SEO-optimised sites for craftspeople, SMEs and local businesses. From €490. Free quote."
  lang="en"
  frPath="/creation-site-web-strasbourg"
  enPath="/en/web-design-strasbourg"
>
  <SchemaOrg type="localBusiness" />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-20 md:px-8 md:py-28 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-[20%] right-[10%] w-[400px] h-[400px] rounded-full bg-[var(--color-accent)] opacity-[0.08] blur-[120px]"></div>

    <div class="relative mx-auto max-w-4xl z-10">
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white">Strasbourg · Alsace · Grand Est</span>
      </div>

      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Web Design in Strasbourg
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl">
        Custom websites for businesses in Strasbourg and across Alsace. Custom, fast, SEO-optimised — and built to last.
      </p>

      <div class="mt-10 flex flex-col gap-4 sm:flex-row">
        <a href="/en/contact" class="inline-flex items-center justify-center gap-2 rounded-xl bg-[var(--color-accent)] px-8 py-4 font-semibold text-white transition-all duration-300 hover:bg-[var(--color-accent-hover)] hover:shadow-lg hover:-translate-y-0.5">
          Get a free quote
        </a>
        <a href="/en/portfolio" class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 py-4 font-semibold text-white/85 transition-all duration-300 hover:bg-white/10">
          View my work
        </a>
      </div>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-16 md:grid-cols-2 items-start">
        <div class="space-y-6 text-[var(--color-text-muted)] leading-relaxed">
          <h2 class="text-2xl font-bold text-[var(--color-text)]">Strasbourg web design for real businesses</h2>
          <p>I create custom websites for craftspeople, SMEs and local businesses in Strasbourg, the Eurométropole and across Alsace. Strasbourg is a crossroads city — French, German, and international. Your website needs to reflect the calibre of your work and speak to your clients.</p>
          <p>Whether you're a craftsperson in Hautepierre, a professional in Neudorf, a business on the Krutenau — you need a site that's as professional as you are. I build it without templates and without shortcuts.</p>
          <p>Built on Astro for performance. 100/100 Lighthouse. Under 1 second load time. Structured data for AI search (GEO). Everything to maximise your visibility.</p>
        </div>
        <div class="space-y-4">
          <h2 class="text-2xl font-bold text-[var(--color-text)]">What you get</h2>
          {[
            { title: "Bespoke design", desc: "Crafted for your business, your brand, your clients." },
            { title: "Strasbourg local SEO", desc: "Appear in searches from people looking for you in Strasbourg." },
            { title: "Bilingual-ready", desc: "French and German content possible — ideal for the Strasbourg market." },
            { title: "7-day delivery", desc: "Fast, reliable, on time." },
            { title: "Hosting + domain included", desc: "Cloudflare CDN hosting and domain for 12 months." },
          ].map(({ title, desc }) => (
            <div class="flex items-start gap-3 rounded-xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] p-4">
              <svg class="h-5 w-5 mt-0.5 flex-shrink-0 text-[var(--color-accent)]" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              <div>
                <div class="font-semibold text-[var(--color-text)]">{title}</div>
                <div class="text-sm text-[var(--color-text-muted)]">{desc}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-6 text-3xl font-bold text-white">Let's build something great</h2>
      <a href="/en/contact" class="inline-flex items-center gap-2 rounded-xl px-10 py-4 text-lg font-semibold text-white" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.3);">
        Get a free quote
      </a>
    </div>
  </section>
</BaseLayout>
