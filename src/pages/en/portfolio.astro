---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

interface Project {
  id: string;
  name: string;
  tagline: string;
  description: string;
  sector: string;
  sectorColor: string;
  type: string;
  url: string;
  gradient: string;
  image: string;
  features: string[];
  stack: string[];
  highlights: { label: string; value: string }[];
}

const projects: Project[] = [
  {
    id: 'paccord-piano',
    name: "P'Accord Piano",
    tagline: "Piano tuner with a premium digital presence",
    description: "Independent piano tuner based in Chartres, serving Eure-et-Loir. Full redesign with a geo-located pricing calculator, direct booking, and a premium dark aesthetic — built for a craftsman holding the prestigious Brevet des Métiers d'Art diploma.",
    sector: "Crafts",
    sectorColor: "border-yellow-400/30 bg-yellow-400/10 text-yellow-400",
    type: "Portfolio site",
    url: "https://master.site-paccord-piano.pages.dev/",
    gradient: "linear-gradient(135deg, #1A1A1A, #2C2008)",
    image: "/images/projects/paccord-piano.webp",
    features: ["Pricing calculator", "Geo-location", "Online booking", "Second-hand pianos", "FAQ", "Local SEO"],
    stack: ["Astro", "Tailwind", "Cloudflare"],
    highlights: [
      { label: "Lighthouse", value: "100" },
      { label: "Delivered in", value: "7 days" },
      { label: "Hosting cost", value: "€0/month" },
    ],
  },
  {
    id: 'mm-securite',
    name: "MM Sécurité",
    tagline: "Security & CCTV specialist for businesses and homes",
    description: "Independent alarm and CCTV technician based in Metz. A site built for local SEO with detailed service pages, highlighted ERP compliance, 50+ businesses protected, and a 48h quote request pipeline.",
    sector: "Security",
    sectorColor: "border-blue-400/30 bg-blue-400/10 text-blue-400",
    type: "Business site",
    url: "https://mm-securite.fr",
    gradient: "linear-gradient(135deg, #1A3A5C, #2D5A7B)",
    image: "/images/projects/mm-securite.webp",
    features: ["Advanced local SEO", "48h quote request", "ERP compliance", "Service pages", "Blog", "FAQ"],
    stack: ["Astro", "Tailwind", "Cloudflare"],
    highlights: [
      { label: "Lighthouse", value: "100" },
      { label: "Businesses protected", value: "50+" },
      { label: "Hosting cost", value: "€0/month" },
    ],
  },
  {
    id: 'roma-laudarium',
    name: "Roma Laudarium",
    tagline: "Storyteller with a poetic digital identity",
    description: "Writer, storyteller and stage director. The site showcases her show for young audiences, her poetic world, and allows venue programmers and schools to book her directly.",
    sector: "Arts",
    sectorColor: "border-violet-400/30 bg-violet-400/10 text-violet-400",
    type: "Portfolio site",
    url: "https://roma-laudarium.pages.dev/",
    gradient: "linear-gradient(135deg, #1E1040, #3D2080)",
    image: "/images/projects/roma-laudarium.webp",
    features: ["Show presentation", "Artistic world", "Programmer contact", "Poetic design", "Local SEO", "GDPR compliant"],
    stack: ["Astro", "Tailwind", "Cloudflare"],
    highlights: [
      { label: "Lighthouse", value: "100" },
      { label: "Delivered in", value: "5 days" },
      { label: "Hosting cost", value: "€0/month" },
    ],
  },
  {
    id: 'dmultiservices',
    name: "D Multiservices",
    tagline: "Multi-trade craftsman, every service under one roof",
    description: "Multi-trade craftsman in the Pyrenees with 30 years of experience in joinery, kitchen fitting, timber decking, and floor coverings. The site generates local quote requests through targeted local SEO in two departments.",
    sector: "Trades",
    sectorColor: "border-emerald-400/30 bg-emerald-400/10 text-emerald-400",
    type: "Business site",
    url: "https://dmultiservices.fr/",
    gradient: "linear-gradient(135deg, #1A1A2E, #2D2D3F)",
    image: "/images/projects/dmultiservices-og.webp",
    features: ["Online quotes", "Local SEO", "Work gallery", "Direct call", "WhatsApp", "FAQ"],
    stack: ["Astro", "Tailwind", "Cloudflare"],
    highlights: [
      { label: "Lighthouse", value: "100" },
      { label: "Delivered in", value: "7 days" },
      { label: "Hosting cost", value: "€0/month" },
    ],
  },
];
---

<BaseLayout
  title="Portfolio — Marc M | Custom Website Projects"
  description="Websites built for real craftspeople and small businesses: piano tuner, security firm, storyteller, multi-trade. Fast, custom, SEO-optimised."
  lang="en"
  frPath="/realisations"
  enPath="/en/portfolio"
>
  <SchemaOrg type="localBusiness" />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-10 md:px-8 md:py-14 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative mx-auto max-w-5xl z-10">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <h1 class="text-3xl font-bold text-white md:text-4xl">My work</h1>
          <p class="mt-2 text-neutral-400 text-sm max-w-lg">Custom sites, Astro + Tailwind. Fast, well-ranked, built to convert.</p>
        </div>
        <div class="flex items-center gap-5 md:gap-6">
          <div class="text-center">
            <p class="text-xl font-bold text-white">{projects.length}</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">Projects</p>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div class="text-center">
            <p class="text-xl font-bold text-white">100</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">Lighthouse</p>
          </div>
          <div class="w-px h-8 bg-white/10"></div>
          <div class="text-center">
            <p class="text-xl font-bold text-[var(--color-accent)]">€0</p>
            <p class="text-[10px] uppercase tracking-wider text-neutral-500">/month</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROJECTS -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-8 md:px-8 md:py-12">
    <div class="mx-auto max-w-5xl">
      <div class="space-y-12">
        {projects.map((project, index) => (
          <article class="group overflow-hidden rounded-2xl border border-[var(--color-border)] bg-white shadow-sm transition-all hover:shadow-xl">
            <div class={`grid ${index % 2 === 0 ? 'lg:grid-cols-[1.1fr_1fr]' : 'lg:grid-cols-[1fr_1.1fr]'}`}>

              {/* Screenshot area */}
              <div
                class={`relative overflow-hidden ${index % 2 !== 0 ? 'lg:order-2' : ''} flex flex-col items-center justify-center p-6 lg:p-8`}
                style={`background: ${project.gradient};`}
              >
                <div class="relative w-full rounded-lg overflow-hidden shadow-2xl ring-1 ring-black/10">
                  <img
                    src={project.image}
                    alt={`Screenshot of ${project.name}`}
                    class="w-full h-auto block"
                    loading="lazy"
                    width="600"
                    height="400"
                  />
                </div>
                <div class="flex flex-wrap justify-center gap-2 mt-5">
                  {project.highlights.map((h) => (
                    <span class="rounded-full bg-black/25 px-3 py-1 text-[11px] font-medium text-white backdrop-blur-sm">
                      {h.label}: <span class="font-bold">{h.value}</span>
                    </span>
                  ))}
                </div>
              </div>

              {/* Content side */}
              <div class={`flex flex-col justify-center p-8 lg:p-10 ${index % 2 !== 0 ? 'lg:order-1' : ''}`}>
                <div class="mb-4 flex flex-wrap items-center gap-2">
                  <span class={`inline-block rounded-full border px-3 py-1 text-xs font-semibold ${project.sectorColor}`}>
                    {project.sector}
                  </span>
                  <span class="text-xs text-[var(--color-text-muted)]">{project.type}</span>
                </div>

                <h2 class="mb-3 text-2xl font-bold text-[var(--color-text)] lg:text-3xl">
                  {project.name}
                </h2>

                <p class="mb-6 text-[var(--color-text-muted)] leading-relaxed">
                  {project.description}
                </p>

                <div class="mb-6 flex flex-wrap gap-2">
                  {project.features.map((f) => (
                    <span class="rounded-md bg-[var(--color-bg-alt)] px-2.5 py-1 text-xs font-medium text-[var(--color-text)]">
                      {f}
                    </span>
                  ))}
                </div>

                <div class="mb-8 flex items-center gap-3">
                  <span class="text-xs uppercase tracking-wider text-[var(--color-text-light)]">Stack:</span>
                  {project.stack.map((s) => (
                    <span class="text-xs font-semibold text-[var(--color-accent)]">{s}</span>
                  ))}
                </div>

                <div class="flex flex-wrap gap-3">
                  <a
                    href={project.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-accent)] px-5 py-2.5 text-sm font-medium text-white transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-lg"
                    style="box-shadow: 0 4px 15px rgba(232, 108, 71, 0.2);"
                    data-umami-event={`portfolio-visit-${project.id}`}
                  >
                    View the site
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                  <a
                    href={`https://pagespeed.web.dev/analysis?url=${encodeURIComponent(project.url)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-2.5 text-sm font-medium text-[var(--color-text-muted)] transition-all hover:border-[var(--color-accent)] hover:text-[var(--color-accent)]"
                  >
                    Lighthouse score
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" /></svg>
                  </a>
                </div>
              </div>

            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- TECH SECTION -->
  <section class="w-full border-t border-[var(--color-border)] bg-white px-6 py-16 md:px-8 md:py-20">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-[var(--color-text)]">The stack behind every project</h2>
      <p class="mb-10 text-[var(--color-text-muted)]">No WordPress, no templates. Custom code, optimised, deployed on the edge.</p>
      <div class="flex flex-wrap items-center justify-center gap-6">
        {[
          { name: "Astro", label: "Framework" },
          { name: "Tailwind", label: "CSS" },
          { name: "Cloudflare", label: "Hosting" },
          { name: "Stripe", label: "Payments" },
          { name: "Web3Forms", label: "Forms" },
        ].map((tech) => (
          <div class="flex items-center gap-2 rounded-xl border border-[var(--color-border)] px-5 py-3">
            <span class="text-lg font-bold text-[var(--color-accent)]">{tech.name}</span>
            <span class="text-xs text-[var(--color-text-muted)]">{tech.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="w-full bg-gradient-to-b from-[#1A1A1A] to-[#111111] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-white">Your business could be next</h2>
      <p class="mb-8 text-neutral-300">
        Essentials from €490, Multi-page from €1,290, Bespoke from €1,990. Delivered in 7 days.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/en/contact"
          class="inline-block rounded-xl bg-[var(--color-accent)] px-8 py-3 font-medium text-white transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-xl"
          style="box-shadow: 0 10px 25px rgba(232, 108, 71, 0.3);"
        >
          Tell me about your project
        </a>
        <a
          href="/en/services"
          class="inline-flex items-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 py-3 font-medium text-white/85 transition-all hover:bg-white/10"
        >
          See pricing
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
