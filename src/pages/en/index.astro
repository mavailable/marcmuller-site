---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const { sitesRealises, sitesTotal } = business;
const progressPercent = Math.round((sitesRealises / sitesTotal) * 100);

const faqItems = [
  {
    question: "How much does a website cost?",
    answer: "From €490 for a one-page site. Multi-page from €1,290, custom from €1,990. Hosting, domain name and maintenance included for the first year."
  },
  {
    question: "How long does it take to build a website?",
    answer: "On average 7 working days for an Essential site, 10 to 14 days for a Multi-page. Every project starts with a free discovery call."
  },
  {
    question: "Do you work with WordPress?",
    answer: "No, I use Astro, a modern framework that's much faster and more secure. The result: a site that loads in under a second and that Google loves."
  },
  {
    question: "Is SEO included?",
    answer: "Yes. Every site is optimised from the start: semantic markup, performance, structured data, and local SEO. Technical SEO is included in all packages."
  },
  {
    question: "Do you only work in Grand Est?",
    answer: "I'm based in Metz but I work with clients across France. Everything is done remotely: discovery call, emails and video meetings."
  }
];
---

<BaseLayout
  title="Marc M — Custom Websites for Craftspeople & Small Businesses"
  description="Custom, fast and SEO-optimised websites for craftspeople, small businesses and entrepreneurs. Based in Grand Est, France. Delivered in 7 days from €490."
  lang="en"
  frPath="/"
  enPath="/en/"
>
  <SchemaOrg type="person" />
  <SchemaOrg type="localBusiness" />
  <SchemaOrg type="faqPage" data={faqItems} />

  <!-- HERO -->
  <section class="relative w-full min-h-screen flex items-center overflow-hidden bg-[#0D0D0D]">
    <!-- Animated gradient blobs -->
    <div class="absolute top-[20%] left-[15%] w-[500px] h-[500px] rounded-full bg-[var(--color-accent)] opacity-[0.08] blur-[150px] hero-blob-1"></div>
    <div class="absolute bottom-[10%] right-[10%] w-[400px] h-[400px] rounded-full bg-[#4F46E5] opacity-[0.05] blur-[130px] hero-blob-2"></div>
    <div class="absolute top-[60%] left-[50%] w-[300px] h-[300px] rounded-full bg-[var(--color-accent)] opacity-[0.04] blur-[100px] hero-blob-3"></div>

    <!-- Noise texture overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

    <!-- Dot grid pattern -->
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="relative mx-auto max-w-7xl px-6 py-20 md:px-8 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        <!-- Left: Text content -->
        <div class="hero-content">
          <!-- Badge -->
          <div class="hero-badge mb-8 inline-flex items-center gap-3 rounded-full border border-emerald-400/20 bg-emerald-400/[0.06] px-5 py-2.5 text-sm backdrop-blur-md hero-fade hero-fade-1">
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
            </span>
            <span style="color: rgba(255,255,255,0.8);">Available for new projects</span>
          </div>

          <h1 class="mb-8 text-[2.75rem] md:text-6xl lg:text-[4.25rem] font-bold leading-[1.08] tracking-[-0.03em] text-white hero-fade hero-fade-2">
            You do great work.
            <span class="hero-accent-text">Let the world know.</span>
          </h1>

          <p class="mb-10 text-lg md:text-xl leading-relaxed text-neutral-400 max-w-xl hero-fade hero-fade-3">
            Your next client is searching for you on Google right now. Custom websites for craftspeople and small businesses — fast, well-ranked, that convert.
          </p>

          <div class="flex flex-col gap-4 sm:flex-row hero-fade hero-fade-4">
            <a href="/en/contact" class="hero-cta-primary group inline-flex items-center justify-center rounded-xl bg-accent px-8 py-4 text-base font-semibold text-white shadow-[0_4px_20px_rgba(232,108,71,0.25)] transition-all duration-300 hover:bg-accent-hover hover:shadow-[0_8px_30px_rgba(232,108,71,0.35)] hover:-translate-y-0.5" data-umami-event="en-hero-cta-click">
              Tell me about your project
              <svg class="ml-2 h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
            <a href="/en/portfolio" class="hero-cta-ghost group inline-flex items-center justify-center rounded-xl border border-white/20 bg-white/5 px-8 py-4 text-base font-semibold text-white/85 transition-all duration-300 backdrop-blur-sm hover:bg-white/10 hover:border-white/30 hover:text-white">
              See my work
              <svg class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
          </div>

          <!-- Trust indicators -->
          <div class="mt-14 flex flex-wrap items-center gap-3 hero-fade hero-fade-5">
            <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
              <svg class="h-4 w-4 shrink-0" fill="#34D399" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              <span style="color: rgba(255,255,255,0.75);">Delivered in 7 days</span>
            </div>
            <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
              <svg class="h-4 w-4 shrink-0" fill="#34D399" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              <span style="color: rgba(255,255,255,0.75);">From €490</span>
            </div>
            <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
              <svg class="h-4 w-4 shrink-0" fill="#34D399" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              <span style="color: rgba(255,255,255,0.75);">Free quote</span>
            </div>
          </div>
        </div>

        <!-- Right: Browser mockup with floating elements -->
        <div class="relative hidden lg:block hero-fade hero-fade-3">
          <!-- Main browser window -->
          <div class="relative hero-float">
            <div class="rounded-2xl border border-white/[0.08] bg-white/[0.03] backdrop-blur-xl overflow-hidden shadow-2xl shadow-black/40">
              <!-- Browser chrome -->
              <div class="flex items-center gap-2 px-4 py-3 bg-white/[0.04] border-b border-white/[0.06]">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 rounded-full bg-[#FF5F57]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#FFBD2E]"></div>
                  <div class="w-3 h-3 rounded-full bg-[#28CA41]"></div>
                </div>
                <div class="flex-1 ml-3">
                  <div class="mx-auto max-w-xs rounded-md bg-white/10 px-3 py-1 text-xs text-neutral-500 text-center">
                    your-site.com
                  </div>
                </div>
              </div>
              <!-- Fake site content -->
              <div class="p-6 space-y-4">
                <div class="flex gap-4 items-center mb-6">
                  <div class="w-8 h-8 rounded-lg bg-[var(--color-accent)]/20 flex items-center justify-center">
                    <div class="w-4 h-4 rounded bg-[var(--color-accent)]"></div>
                  </div>
                  <div class="flex gap-4">
                    <div class="h-2 w-12 rounded-full bg-white/10"></div>
                    <div class="h-2 w-10 rounded-full bg-white/10"></div>
                    <div class="h-2 w-14 rounded-full bg-white/10"></div>
                  </div>
                </div>
                <div class="space-y-2">
                  <div class="h-3 w-3/4 rounded-full bg-white/[0.08]"></div>
                  <div class="h-3 w-1/2 rounded-full bg-white/[0.06]"></div>
                </div>
                <div class="h-32 rounded-xl bg-gradient-to-br from-[var(--color-accent)]/10 to-[#4F46E5]/10 border border-white/[0.05]"></div>
                <div class="grid grid-cols-3 gap-3">
                  <div class="h-20 rounded-lg bg-white/[0.04] border border-white/[0.05]"></div>
                  <div class="h-20 rounded-lg bg-white/[0.04] border border-white/[0.05]"></div>
                  <div class="h-20 rounded-lg bg-white/[0.04] border border-white/[0.05]"></div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating performance card -->
          <div class="absolute -left-8 top-[20%] hero-float-delayed">
            <div class="rounded-xl border border-white/[0.08] bg-[#161616]/90 backdrop-blur-xl p-4 shadow-xl shadow-black/30">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-emerald-500/10">
                  <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </div>
                <div>
                  <div class="text-xs text-neutral-400">Performance</div>
                  <div class="text-lg font-bold text-emerald-400">100/100</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Floating SEO card -->
          <div class="absolute -right-4 bottom-[15%] hero-float-delayed-2">
            <div class="rounded-xl border border-white/[0.08] bg-[#161616]/90 backdrop-blur-xl p-4 shadow-xl shadow-black/30">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-accent)]/10">
                  <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11l5-5m0 0l5 5m-5-5v12"></path></svg>
                </div>
                <div>
                  <div class="text-xs text-neutral-400">SEO Score</div>
                  <div class="text-lg font-bold text-[var(--color-accent)]">98/100</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-neutral-500 hero-fade hero-fade-5">
      <span class="text-xs tracking-widest uppercase">Scroll</span>
      <div class="w-5 h-8 rounded-full border border-white/20 flex justify-center pt-1.5">
        <div class="w-1 h-2 rounded-full bg-white/40 animate-bounce"></div>
      </div>
    </div>
  </section>

  <!-- 100 WEBSITES CHALLENGE -->
  <section class="w-full relative overflow-hidden" style="background: linear-gradient(135deg, #1A1A1A 0%, #111111 100%);">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[200px] rounded-full blur-[120px]" style="background: rgba(232, 108, 71, 0.12);"></div>

    <div class="relative mx-auto max-w-6xl px-6 py-12 md:px-8 md:py-16">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">
        <div class="flex-1 text-center md:text-left">
          <div class="mb-4 inline-flex items-center gap-2.5 rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.25); color: #E86C47;">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style="background: #E86C47;"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full" style="background: #E86C47;"></span>
            </span>
            Challenge in progress
          </div>
          <h2 class="mb-3 text-2xl md:text-3xl font-bold text-white leading-tight">
            100 Websites for 100 Craftspeople.
            <span class="block text-base md:text-lg font-normal mt-1" style="color: rgba(255,255,255,0.7);">Free. Real. No strings attached.</span>
          </h2>
          <p class="text-sm md:text-base leading-relaxed max-w-xl mx-auto md:mx-0" style="color: rgba(255,255,255,0.75);">
            I'm building 100 free professional websites for craftspeople with no online presence. Design, hosting and domain included for the first year.
          </p>
        </div>

        <div class="flex flex-col items-center gap-5 flex-shrink-0">
          <div class="text-center">
            <div class="flex items-baseline gap-1 justify-center">
              <span class="text-5xl font-extrabold" style="color: #E86C47;">{sitesRealises}</span>
              <span class="text-xl font-bold text-white/70">/{sitesTotal}</span>
            </div>
            <p class="mt-1 text-xs text-white/70 uppercase tracking-widest">sites built</p>
            <div class="mt-3 w-48 bg-white/10 rounded-full h-1.5">
              <div class="h-1.5 rounded-full transition-all duration-1000" style={`width: ${progressPercent === 0 ? 0.5 : progressPercent}%; background: linear-gradient(90deg, #E86C47, #FF8A65);`}></div>
            </div>
          </div>

          <a
            href="/en/100-artisan-websites"
            class="group inline-flex items-center justify-center gap-2 rounded-xl px-7 py-3.5 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.3);"
          >
            Apply now
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a href="/en/100-artisan-websites" class="text-xs hover:underline" style="color: rgba(255,255,255,0.6);">
            Learn more about the initiative →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PAIN POINTS -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">Sound familiar?</h2>
      <p class="text-center text-[var(--color-text-muted)] mb-16 text-lg">You're not alone. Most small businesses face one of these.</p>
      <div class="mt-8 grid gap-8 md:grid-cols-3">
        <div class="rounded-xl bg-white p-8 border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-accent-light)]">
            <svg class="w-7 h-7 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-[var(--color-text)]">Your WordPress site is slow and costly</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            Constant plugin updates, caching plugins that don't cut it, rising hosting bills. Your site takes 3 seconds to load and your visitors leave.
          </p>
        </div>

        <div class="rounded-xl bg-white p-8 border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-accent-light)]">
            <svg class="w-7 h-7 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-[var(--color-text)]">You have no website and you're losing clients</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            Your competitors are visible online. You're invisible. Potential clients go elsewhere. You're leaving money on the table.
          </p>
        </div>

        <div class="rounded-xl bg-white p-8 border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
          <div class="mb-4 flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-accent-light)]">
            <svg class="w-7 h-7 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path>
            </svg>
          </div>
          <h3 class="mb-3 text-lg font-bold text-[var(--color-text)]">Your site looks generic and doesn't feel like you</h3>
          <p class="text-[var(--color-text-muted)] leading-relaxed">
            Generic template, default colours, nothing personal. Visitors don't get a real sense of who you are. No connection, no trust.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF -->
  <section class="w-full bg-white px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">It works</h2>
      <p class="text-center text-[var(--color-text-muted)] mb-16 text-lg">Numbers, not promises.</p>
      <div class="grid gap-12 md:grid-cols-3">
        <div class="text-center">
          <div class="mb-3 text-6xl font-bold text-[var(--color-accent)]"><span class="count-up" data-target="12">0</span><span class="text-3xl">+</span></div>
          <p class="text-[var(--color-text-muted)]">Projects delivered and live</p>
        </div>
        <div class="text-center">
          <div class="mb-3 text-4xl font-bold text-[var(--color-accent)]">7<span class="text-2xl">d</span></div>
          <p class="text-[var(--color-text-muted)]">Average delivery time from brief to launch</p>
        </div>
        <div class="text-center">
          <div class="mb-3 text-6xl font-bold text-[var(--color-accent)]">100<span class="text-3xl">%</span></div>
          <p class="text-[var(--color-text-muted)]">Client satisfaction rate</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES OVERVIEW -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">What I build</h2>
      <p class="text-center text-[var(--color-text-muted)] mb-16 text-lg">Custom websites. No templates. No page builders.</p>
      <div class="grid gap-8 md:grid-cols-3">
        {business.offers.map((offer) => (
          <div class="rounded-xl bg-white p-8 border border-[var(--color-border)] hover:shadow-lg hover:-translate-y-1 transition-all duration-300">
            <div class="mb-4 text-3xl font-extrabold text-[var(--color-accent)]">€{offer.price.toLocaleString()}</div>
            <h3 class="mb-3 text-xl font-bold text-[var(--color-text)]">{offer.name}</h3>
            <p class="text-[var(--color-text-muted)] leading-relaxed text-sm">{offer.description}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <a href="/en/services" class="inline-flex items-center gap-2 rounded-xl bg-[var(--color-accent)] px-8 py-4 text-base font-semibold text-white transition-all duration-300 hover:bg-[var(--color-accent-hover)] hover:shadow-lg hover:-translate-y-0.5">
          View all services
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-3xl">
      <h2 class="text-center text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">Frequently asked questions</h2>
      <p class="text-center text-[var(--color-text-muted)] mb-12 text-lg">Everything you need to know before getting started.</p>
      <div class="space-y-4">
        {faqItems.map((item) => (
          <details class="group rounded-xl border border-[var(--color-border)] bg-white">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-5 text-left font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors">
              {item.question}
              <svg class="h-5 w-5 shrink-0 text-[var(--color-text-muted)] transition-transform duration-200 group-open:rotate-180" aria-hidden="true" role="presentation" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </summary>
            <div class="px-6 pb-5 text-[var(--color-text-muted)] leading-relaxed">{item.answer}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA SECTION -->
  <section class="w-full bg-[#0D0D0D] px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-3xl text-center">
      <h2 class="mb-6 text-3xl md:text-5xl font-bold text-white leading-tight">
