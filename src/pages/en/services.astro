---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const whatsappMessage = encodeURIComponent("Hi Marc, I'd like to discuss a website project.");

const checkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;

const faqItems = [
  {
    question: "Is €490 a template?",
    answer: "No. Every site is built from scratch, tailored to you. No WordPress, no templates. The price reflects the efficiency of my process — a unique site ready in 7 days."
  },
  {
    question: "Can I pay in instalments?",
    answer: "Yes. Showcase Site: 2× €245. Bespoke Project: 50% upfront, the rest on delivery. We'll work it out."
  },
  {
    question: "What happens after the first year?",
    answer: "Your site keeps running, for free. Hosting is free forever. Only the domain name (~€10/year) needs renewing. If you want ongoing support (changes, content, help), plans start at €39/month."
  },
  {
    question: "What is GEO optimisation?",
    answer: "GEO = Generative Engine Optimization. On top of classic SEO (Google), I optimise your site to appear in AI responses — ChatGPT, Perplexity, Claude. It's tomorrow's SEO, included today."
  },
  {
    question: "Do you work with WordPress?",
    answer: "No, I work with Astro. It's faster (better Google ranking), more secure (no plugins = no vulnerabilities), and lighter. Result: a site that loads in under 1 second."
  },
  {
    question: "How does it work in practice?",
    answer: "You order online, fill in a guided questionnaire (business, texts, photos), we do a 15-minute call to align, and I deliver in 7 days. One round of revisions is included."
  },
  {
    question: "What if I need something more complex?",
    answer: "Multi-page sites, blogs, online booking, business-specific features — let's talk. I provide a free quote within 48 hours, no strings attached."
  }
];
---

<BaseLayout
  title="Services & Pricing — Marc M | Custom Website Design"
  description="Custom professional website for €490, order online. Delivered in 7 days. Lighthouse 100. Google & AI optimised. Complex projects on request."
  lang="en"
  frPath="/offre"
  enPath="/en/services"
>
  <SchemaOrg type="localBusiness" />
  <SchemaOrg type="faqPage" data={faqItems} />

  <!-- HERO -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="mx-auto max-w-4xl text-center relative z-10">
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white">Order online — delivered in 7 days</span>
      </div>

      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        A professional site that brings you clients
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto">
        Custom design. Google & AI optimised. Lighthouse score 100. You order, I deliver.
      </p>
    </div>
  </section>

  <!-- SHOWCASE SITE — THE PRODUCT -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-12 md:px-8 md:py-16">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-10 lg:grid-cols-2 items-start">

        <!-- PRODUCT CARD -->
        <div class="relative rounded-2xl p-8 lg:p-10 flex flex-col" style="background-color: #111; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(232, 108, 71, 0.3);">
          <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl" style="background: linear-gradient(90deg, #E86C47, #F5C8B3);"></div>

          <div class="mb-2">
            <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-wider text-neutral-300" style="letter-spacing: 0.15em;">Showcase Site</span>
          </div>
          <h2 class="text-2xl font-bold text-white mb-2">Your professional website</h2>
          <p class="text-sm text-neutral-400 mb-6 leading-relaxed">Built from scratch, tailored to you. Not a template.</p>

          <div class="mb-8">
            <div class="flex items-baseline gap-1">
              <span class="text-5xl font-extrabold text-white">€490</span>
              <span class="text-sm text-neutral-400 ml-2">excl. VAT · or 2× €245</span>
            </div>
          </div>

          <div class="space-y-3 flex-grow mb-8">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Unique design</strong> built around your brand — no templates</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Found on Google & AI</strong> — SEO & GEO optimised</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Built to convert</strong> — call, WhatsApp, contact form</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Lighthouse 100/100</strong> — faster than 99% of websites</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Ready in 7 days</strong> — one round of revisions included</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>It's your site</strong> — you own everything, zero lock-in</span>
            </div>
          </div>

          <div>
            <a href="/en/contact" class="block w-full py-4 px-6 text-center rounded-xl text-base font-semibold text-white transition-all duration-200" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.4);">
              Order my site — €490
            </a>
            <p class="text-center text-xs text-neutral-500 mt-3">Hosting & domain included for the first year</p>
          </div>
        </div>

        <!-- HOW IT WORKS -->
        <div class="flex flex-col gap-6">
          <h3 class="text-lg font-bold text-[var(--color-text)]">How it works</h3>

          <div class="space-y-5">
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white text-sm" style="background: linear-gradient(135deg, #E86C47, #D4572F);">1</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">Order online</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">Secure payment. Fill in a guided questionnaire: business, texts, photos, preferences.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white text-sm" style="background: linear-gradient(135deg, #E86C47, #D4572F);">2</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">Quick alignment call</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">15-minute call to scope the project. If your needs go beyond the Showcase Site, I'll guide you — no extra charge.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white text-sm" style="background: linear-gradient(135deg, #E86C47, #D4572F);">3</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">I build your site</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">Design, development, content, SEO — everything custom-built in 7 days.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex-shrink-0 w-10 h-10 rounded-xl flex items-center justify-center font-bold text-white text-sm" style="background: linear-gradient(135deg, #E86C47, #D4572F);">4</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">Your site goes live</p>
                <p class="text-sm text-[var(--color-text-muted)] mt-0.5">One round of revisions, then launch. You get full access to everything.</p>
              </div>
            </div>
          </div>

          <!-- SOCIAL PROOF -->
          <div class="mt-4 flex items-center gap-4 px-5 py-4 rounded-xl bg-[var(--color-bg-alt)] border border-[var(--color-border)]">
            <div class="text-3xl font-extrabold" style="color: #E86C47;">{business.sitesRealises}</div>
            <div>
              <p class="text-sm font-semibold text-[var(--color-text)]">sites delivered</p>
              <p class="text-xs text-[var(--color-text-muted)]">All scoring Lighthouse 100 — <a href="/en/portfolio" class="underline hover:text-[var(--color-accent)]">see portfolio</a></p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ADD-ONS -->
  <section class="w-full px-6 py-12 md:px-8 md:py-16" style="background: linear-gradient(180deg, #FAFAFA 0%, #FFFFFF 100%);">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-3" style="letter-spacing: 0.2em;">Add-ons</p>
        <h2 class="text-3xl font-bold text-[var(--color-text)]">Add what you need</h2>
        <p class="mt-3 text-[var(--color-text-muted)]">Available with the Showcase Site or any Bespoke Project.</p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Extra page</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">A dedicated page (About, Pricing, Gallery...)</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+€120</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Google Business Profile</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Creation & optimisation of your Google Maps listing</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+€90</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 4V2m0 2a2 2 0 100 4m0-4a2 2 0 110 4m10-4V2m0 2a2 2 0 100 4m0-4a2 2 0 110 4M5 20a7 7 0 0114 0M12 14a3 3 0 100-6 3 3 0 000 6z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">Social media pack</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">Optimised visuals for Facebook, LinkedIn & Google Business</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+€150</p>
        </div>

        <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 hover:shadow-md transition-shadow">
          <div class="w-10 h-10 mb-4 rounded-lg flex items-center justify-center" style="background: rgba(232, 108, 71, 0.1);">
            <svg class="w-5 h-5 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
          </div>
          <p class="font-semibold text-[var(--color-text)] text-sm">SEO Blog</p>
          <p class="text-xs text-[var(--color-text-muted)] mt-1">5 optimised articles + CMS to write your own</p>
          <p class="mt-3 text-lg font-bold" style="color: #E86C47;">+€390</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BESPOKE PROJECT -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-5" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="mx-auto max-w-5xl relative z-10">
      <div class="grid gap-10 lg:grid-cols-2 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-4" style="letter-spacing: 0.2em;">On request</p>
          <h2 class="text-3xl font-bold text-white mb-4">Need more than a showcase site?</h2>
          <p class="text-neutral-300 mb-6 leading-relaxed">
            Multi-page sites, blogs, online booking, price calculators, business-specific features — I build exactly what you need. Free quote within 48 hours.
          </p>

          <div class="space-y-4 mb-8">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Custom architecture</strong> — as many pages as needed</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Business features</strong> — booking, payments, catalogue, calculators</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Blog + CMS</strong> — write and manage content yourself</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>SEO strategy</strong> — location pages, service pages, targeted content</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 w-5 h-5 mt-0.5" set:html={checkIcon} />
              <span class="text-sm text-neutral-200"><strong>Analytics</strong> — visitor tracking and conversion monitoring</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-3">
            <a href="/en/contact" class="inline-flex items-center justify-center gap-2 rounded-xl border-2 border-[var(--color-accent)] px-8 py-3 text-sm font-semibold text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-all duration-200">
              Discuss my project
            </a>
            <a href={`https://wa.me/${business.whatsapp}?text=${whatsappMessage}`} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-xl px-8 py-3 text-sm font-semibold text-white transition-all duration-200" style="background:#25D366;">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              WhatsApp
            </a>
          </div>
        </div>

        <!-- PROJECT EXAMPLES -->
        <div class="space-y-4">
          <p class="text-xs font-bold uppercase tracking-wider text-neutral-500 mb-2" style="letter-spacing: 0.15em;">Example projects delivered</p>

          <div class="rounded-xl p-5 border border-neutral-800" style="background: rgba(255,255,255,0.03);">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-white">Multi-page site + gallery</span>
              <span class="text-xs text-neutral-500">10 days</span>
            </div>
            <p class="text-xs text-neutral-400">Carpenter — 6 pages, category gallery, quote form, local SEO</p>
          </div>

          <div class="rounded-xl p-5 border border-neutral-800" style="background: rgba(255,255,255,0.03);">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-white">Site + blog + CMS</span>
              <span class="text-xs text-neutral-500">10 days</span>
            </div>
            <p class="text-xs text-neutral-400">Animal therapist — 16 pages, blog, pricing, CMS for content management</p>
          </div>

          <div class="rounded-xl p-5 border border-neutral-800" style="background: rgba(255,255,255,0.03);">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-white">Site + price calculator</span>
              <span class="text-xs text-neutral-500">10 days</span>
            </div>
            <p class="text-xs text-neutral-400">Piano tuner — 8 pages, postcode-based pricing tool, used piano catalogue</p>
          </div>

          <div class="rounded-xl p-5 border border-neutral-800" style="background: rgba(255,255,255,0.03);">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-white">Site + SEO blog + local pages</span>
              <span class="text-xs text-neutral-500">3 weeks</span>
            </div>
            <p class="text-xs text-neutral-400">Security technician — 20+ pages, 11 articles, city & service landing pages</p>
          </div>

          <a href="/en/portfolio" class="inline-flex items-center gap-1 text-sm font-medium text-[var(--color-accent)] hover:underline mt-2">
            View all projects
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- SUPPORT -->
  <section class="w-full bg-white px-6 py-12 md:px-8 md:py-16">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-3" style="letter-spacing: 0.2em;">After delivery</p>
        <h2 class="text-3xl font-bold text-[var(--color-text)]">Ongoing support</h2>
        <p class="mt-3 text-[var(--color-text-muted)]">The first year is included. After that, you choose.</p>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        <!-- Self-managed -->
        <div class="rounded-xl border border-[var(--color-border)] p-6">
          <h3 class="text-base font-bold text-[var(--color-text)] mb-1">Self-managed</h3>
          <div class="flex items-baseline gap-1 mb-3">
            <span class="text-2xl font-extrabold text-[var(--color-text)]">€0</span>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] mb-4">Your site runs on its own. Hosting stays free. Only the domain needs renewing (~€10/year).</p>
          <ul class="space-y-2">
            <li class="flex items-start gap-2">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4 mt-0.5" set:html={checkIcon} />
              <span class="text-xs text-[var(--color-text-muted)]">Free hosting forever</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4 mt-0.5" set:html={checkIcon} />
              <span class="text-xs text-[var(--color-text-muted)]">Source code provided</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-emerald-500 flex-shrink-0 w-4 h-4 mt-0.5" set:html={checkIcon} />
              <span class="text-xs text-[var(--color-text-muted)]">Zero commitment</span>
            </li>
          </ul>
        </div>

        <!-- Support -->
        <div class="rounded-xl border-2 border-[var(--color-accent)] p-6 relative">
