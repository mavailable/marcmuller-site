---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';

const checkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
const xIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>`;

const faqItems = [
  {
    question: "Is €490 a template?",
    answer: "No. Every site is built from scratch, tailored to you. The price reflects the efficiency of my process, not a lack of quality."
  },
  {
    question: "Can I pay in instalments?",
    answer: "Yes. Essentials: 50/50. Multi-page and Bespoke: 2 or 3 payments, 50% upfront and the rest on delivery. We'll work it out."
  },
  {
    question: "What's included in 1-year hosting?",
    answer: "Hosting on Cloudflare (global CDN, ultra-fast), .com or .fr domain name, SSL certificate, technical maintenance and updates for 12 months. After a year, renewal at €120/year."
  },
  {
    question: "What is GEO optimisation?",
    answer: "GEO = Generative Engine Optimization. On top of classic SEO (Google), I optimise your site to be referenced in AI responses — ChatGPT, Perplexity, Claude. It's tomorrow's SEO, included today."
  },
  {
    question: "Do you work with WordPress?",
    answer: "No, I work with Astro. It's faster (better Google ranking), more secure (no plugins = no vulnerabilities), and lighter. Result: a site that loads in under 1 second and Google loves it."
  },
  {
    question: "Which package should I choose?",
    answer: "Essentials if you're starting out or one page is enough (freelancer, local craftsperson). Multi-page if you need to showcase several services, a gallery, or reviews (most popular). Bespoke if you have specific needs: booking, e-commerce, complex blog. Not sure? Let's talk on the phone."
  }
];
---

<BaseLayout
  title="Services & Pricing — Marc M | Custom Website Design"
  description="3 clear packages: Essentials €490, Multi-page €1,290, Bespoke from €1,990. All inclusive: 1-year hosting, domain, SEO & GEO, maintenance."
  lang="en"
  frPath="/offre"
  enPath="/en/services"
>
  <SchemaOrg type="localBusiness" />
  <SchemaOrg type="faqPage" data={faqItems} />

  <!-- HERO -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="mx-auto max-w-4xl text-center relative z-10">
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white">3 packages, 0 surprises</span>
      </div>

      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        A professional site, at the right price
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto">
        Every package includes 1-year hosting, domain name, maintenance and SEO & GEO optimisation.
      </p>
    </div>
  </section>

  <!-- PRICING CARDS -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-8 md:grid-cols-3">

        <!-- ESSENTIALS -->
        <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm hover:shadow-lg transition-all duration-300">
          <div class="mb-6">
            <h2 class="text-xl font-bold text-[var(--color-text)] mb-1">Essentials</h2>
            <div class="text-4xl font-extrabold text-[var(--color-accent)]">€490</div>
            <p class="text-sm text-[var(--color-text-muted)] mt-1">1–3 page showcase site</p>
          </div>
          <ul class="space-y-3 mb-8">
            {["Custom design", "Responsive (mobile-first)", "Contact form", "Basic SEO", "1-year hosting included", "Domain included", "SSL certificate", "Delivered in 7 days"].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex-shrink-0 text-emerald-500" set:html={checkIcon} />
                <span class="text-sm text-[var(--color-text-muted)]">{item}</span>
              </li>
            ))}
            {["Blog", "Multi-page structure", "Advanced analytics"].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex-shrink-0 text-neutral-300" set:html={xIcon} />
                <span class="text-sm text-neutral-400">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/en/contact" class="block w-full rounded-xl border-2 border-[var(--color-accent)] px-6 py-3 text-center font-semibold text-[var(--color-accent)] transition-all duration-300 hover:bg-[var(--color-accent)] hover:text-white">
            Get started
          </a>
        </div>

        <!-- MULTI-PAGE (POPULAR) -->
        <div class="rounded-2xl border-2 border-[var(--color-accent)] bg-white p-8 shadow-xl relative">
          <div class="absolute -top-4 left-1/2 -translate-x-1/2">
            <span class="bg-[var(--color-accent)] text-white text-xs font-bold px-4 py-1.5 rounded-full uppercase tracking-wider">Most popular</span>
          </div>
          <div class="mb-6">
            <h2 class="text-xl font-bold text-[var(--color-text)] mb-1">Multi-page</h2>
            <div class="text-4xl font-extrabold text-[var(--color-accent)]">€1,290</div>
            <p class="text-sm text-[var(--color-text-muted)] mt-1">4–8 page website</p>
          </div>
          <ul class="space-y-3 mb-8">
            {["Everything in Essentials", "Multi-page structure", "Integrated blog", "Structured data (Schema.org)", "GEO optimisation (AI search)", "Advanced contact form", "Google Analytics + Search Console", "Performance audit included"].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex-shrink-0 text-emerald-500" set:html={checkIcon} />
                <span class="text-sm text-[var(--color-text-muted)]">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/en/contact" class="block w-full rounded-xl bg-[var(--color-accent)] px-6 py-3 text-center font-semibold text-white transition-all duration-300 hover:bg-[var(--color-accent-hover)] hover:shadow-lg">
            Get started
          </a>
        </div>

        <!-- BESPOKE -->
        <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm hover:shadow-lg transition-all duration-300">
          <div class="mb-6">
            <h2 class="text-xl font-bold text-[var(--color-text)] mb-1">Bespoke</h2>
            <div class="text-4xl font-extrabold text-[var(--color-accent)]">€1,990+</div>
            <p class="text-sm text-[var(--color-text-muted)] mt-1">Custom architecture</p>
          </div>
          <ul class="space-y-3 mb-8">
            {["Everything in Multi-page", "Custom functionality", "Booking / payment system", "E-commerce integration", "Advanced API integrations", "Dedicated onboarding session", "Priority support", "Full technical handover"].map(item => (
              <li class="flex items-start gap-3">
                <span class="mt-0.5 flex-shrink-0 text-emerald-500" set:html={checkIcon} />
                <span class="text-sm text-[var(--color-text-muted)]">{item}</span>
              </li>
            ))}
          </ul>
          <a href="/en/contact" class="block w-full rounded-xl border-2 border-[var(--color-accent)] px-6 py-3 text-center font-semibold text-[var(--color-accent)] transition-all duration-300 hover:bg-[var(--color-accent)] hover:text-white">
            Request a quote
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- MAINTENANCE -->
  <section class="w-full bg-white px-6 py-16 md:px-8">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="mb-4 text-2xl font-bold text-[var(--color-text)]">Maintenance & support</h2>
      <p class="text-[var(--color-text-muted)] mb-8 text-lg">Need ongoing help after delivery? I offer monthly maintenance plans.</p>
      <div class="inline-flex items-center gap-4 rounded-2xl border border-[var(--color-border)] bg-[var(--color-bg-alt)] px-8 py-6">
        <div>
          <div class="text-3xl font-extrabold text-[var(--color-accent)]">€100–150<span class="text-lg font-normal text-[var(--color-text-muted)]">/month</span></div>
          <p class="text-sm text-[var(--color-text-muted)] mt-1">Updates, monitoring, content changes, technical support</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold text-[var(--color-text)]">Frequently Asked Questions</h2>
      <div class="space-y-4" id="faq-accordion">
        {faqItems.map((item, i) => (
          <div class="rounded-xl border border-[var(--color-border)] bg-white overflow-hidden">
            <button
              class="w-full flex items-center justify-between px-6 py-5 text-left font-semibold text-[var(--color-text)] hover:text-[var(--color-accent)] transition-colors faq-btn"
              aria-expanded="false"
              data-faq={i}
            >
              <span>{item.question}</span>
              <svg class="w-5 h-5 flex-shrink-0 transition-transform duration-300 faq-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div class="faq-answer hidden px-6 pb-5 text-[var(--color-text-muted)] leading-relaxed">
              {item.answer}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  document.querySelectorAll('.faq-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const answer = btn.nextElementSibling as HTMLElement;
      const icon = btn.querySelector('.faq-icon') as HTMLElement;
      const isOpen = !answer.classList.contains('hidden');
      answer.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', String(!isOpen));
    });
  });
</script>
