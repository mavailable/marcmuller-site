---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Thank you! — Marc M"
  description="Your message has been sent. Marc will reply within 48 hours."
  lang="en"
  noindex={true}
  frPath="/merci"
  enPath="/en/thank-you"
>
  <section class="relative w-full min-h-screen flex items-center bg-[#0D0D0D] px-6 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-emerald-500 opacity-[0.05] blur-[120px]"></div>

    <div class="relative mx-auto max-w-2xl text-center z-10">
      <!-- Success icon -->
      <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full bg-emerald-500/10 border border-emerald-500/20">
        <svg class="h-10 w-10 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>

      <h1 class="mb-6 text-4xl font-bold text-white md:text-5xl">
        Message received!
      </h1>
      <p class="mb-4 text-lg text-neutral-300">
        Thank you for reaching out. I'll get back to you <strong class="text-white">within 48 hours</strong>.
      </p>
      <p class="mb-12 text-neutral-400">
        In the meantime, feel free to take a look at my portfolio or learn more about my services.
      </p>

      <div class="flex flex-col gap-4 sm:flex-row sm:justify-center">
        <a href="/en/portfolio" class="inline-flex items-center justify-center gap-2 rounded-xl bg-[var(--color-accent)] px-8 py-4 font-semibold text-white transition-all duration-300 hover:bg-[var(--color-accent-hover)] hover:shadow-lg">
          View portfolio
        </a>
        <a href="/en/" class="inline-flex items-center justify-center gap-2 rounded-xl border border-white/20 bg-white/5 px-8 py-4 font-semibold text-white/85 transition-all duration-300 hover:bg-white/10">
          Back to home
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
