---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SchemaOrg from '../../components/SchemaOrg.astro';
import { business } from '../../data/business';

const whatsappMessage = encodeURIComponent("Hello Marc, I'd like to discuss a website project.");
---

<BaseLayout
  title="Contact — Marc M"
  description="Let's talk about your project. Form, email, or phone. I reply within 48 hours."
  lang="en"
  frPath="/contact"
  enPath="/en/contact"
>
  <SchemaOrg type="localBusiness" />

  <!-- HERO -->
  <section class="relative w-full bg-[#0D0D0D] px-6 py-16 md:px-8 md:py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="relative mx-auto max-w-4xl text-center z-10">
      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl">
        Let's talk about your project
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl">
        Form, email, or phone — whichever you prefer. I reply within 48 hours.
      </p>
    </div>
  </section>

  <!-- CONTENT SECTION -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-3">
        <!-- FORM -->
        <div class="md:col-span-2">
          <h2 class="mb-8 text-2xl font-bold text-[var(--color-text)]">Send me a message</h2>

          <div aria-live="polite" aria-atomic="true" class="sr-only" id="form-status"></div>
          <form
            action="https://api.web3forms.com/submit"
            method="POST"
            class="space-y-6"
            id="contact-form"
          >
            <input type="hidden" name="access_key" value="dccda1f5-4e63-4b9f-9c66-f5ce76f0dfdd" />
            <input type="hidden" name="subject" value="New contact from marcm.fr/en" />
            <input type="hidden" name="redirect" value="https://marcm.fr/en/thank-you" />
            <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

            <div class="grid gap-6 md:grid-cols-2">
              <div>
                <label for="name" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">
                  Full name <span class="text-[var(--color-accent)]">*</span>
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="John Smith"
                  class="w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-text)] placeholder-neutral-400 transition-colors focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20"
                />
              </div>
              <div>
                <label for="email" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">
                  Email <span class="text-[var(--color-accent)]">*</span>
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="john@yourcompany.com"
                  class="w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-text)] placeholder-neutral-400 transition-colors focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20"
                />
              </div>
            </div>

            <div>
              <label for="phone" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">
                Phone (optional)
              </label>
              <input
                type="tel"
                id="phone"
                name="phone"
                placeholder="+44 7700 000000"
                class="w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-text)] placeholder-neutral-400 transition-colors focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20"
              />
            </div>

            <div>
              <label for="project" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">
                Tell me about your project <span class="text-[var(--color-accent)]">*</span>
              </label>
              <textarea
                id="project"
                name="message"
                required
                rows="5"
                placeholder="I'm a [carpenter / florist / consultant]… I'd like a website to [showcase my work / get more clients / sell online]…"
                class="w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-text)] placeholder-neutral-400 transition-colors focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20 resize-none"
              ></textarea>
            </div>

            <div>
              <label for="budget" class="mb-2 block text-sm font-semibold text-[var(--color-text)]">
                Budget range
              </label>
              <select
                id="budget"
                name="budget"
                class="w-full rounded-xl border border-[var(--color-border)] bg-[var(--color-bg)] px-4 py-3 text-[var(--color-text)] transition-colors focus:border-[var(--color-accent)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)]/20"
              >
                <option value="">Select a budget</option>
                <option value="490-800">€490 – €800 (Essentials)</option>
                <option value="800-1500">€800 – €1,500 (Multi-page)</option>
                <option value="1500+">€1,500+ (Bespoke)</option>
                <option value="unknown">I don't know yet</option>
              </select>
            </div>

            <!-- GDPR Consent -->
            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy"
                name="privacy"
                required
                class="mt-1 h-4 w-4 rounded border-[var(--color-border)] text-[var(--color-accent)] focus:ring-[var(--color-accent)]"
              />
              <label for="privacy" class="text-sm text-[var(--color-text-muted)] leading-relaxed">
                I consent to my data being processed under <a href="/en/privacy-policy" target="_blank" rel="noopener" class="underline hover:text-[var(--color-accent)]">Art. 6(1)(a) GDPR</a> so Marc M can contact me about my project. <span class="text-[var(--color-accent)]">*</span>
              </label>
            </div>

            <button
              type="submit"
              class="group inline-flex w-full items-center justify-center gap-2 rounded-xl bg-[var(--color-accent)] px-8 py-4 text-base font-semibold text-white shadow-md transition-all duration-300 hover:bg-[var(--color-accent-hover)] hover:shadow-lg hover:scale-[1.01] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
              data-umami-event="en-contact-form-submit"
            >
              Send my message
              <svg class="h-5 w-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </button>
          </form>
        </div>

        <!-- CONTACT INFO -->
        <div class="space-y-8">
          <div>
            <h2 class="mb-6 text-2xl font-bold text-[var(--color-text)]">Other ways to reach me</h2>
            <div class="space-y-4">
              <a href={`tel:${business.phone}`} class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors" data-umami-event="phone-click">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-accent-light)] text-[var(--color-accent)]">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 00.948.684l1.498 7.487a1 1 0 00.502.756l2.048 1.029a11.042 11.042 0 005.516 5.516l1.029 2.048a1 1 0 00.756.502l7.487 1.498a1 1 0 00.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                </span>
                {business.phone.replace(/(\+33)(\d)(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5 $6')}
              </a>
              <a href="mailto:marc@muller.im" class="flex items-center gap-3 text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors" data-umami-event="contact-email-click">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-accent-light)] text-[var(--color-accent)]">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                </span>
                marc@muller.im
              </a>
              <div class="flex items-center gap-3 text-[var(--color-text-muted)]">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-accent-light)] text-[var(--color-accent)]">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                </span>
                Montigny-lès-Metz, France
              </div>
              <div class="flex items-center gap-3 text-[var(--color-text-muted)]">
                <span class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-accent-light)] text-[var(--color-accent)]">
                  <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </span>
                Reply within 48 hours
              </div>
            </div>
          </div>

          <!-- WhatsApp CTA -->
          <a
            href={`https://wa.me/${business.whatsapp}?text=${whatsappMessage}`}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center gap-3 rounded-xl bg-[#25D366] px-6 py-4 font-semibold text-white transition-all duration-300 hover:bg-[#20B858] hover:shadow-lg"
            data-umami-event="whatsapp-click"
          >
            <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Chat on WhatsApp
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
