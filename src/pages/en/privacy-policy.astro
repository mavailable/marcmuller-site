---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { business } from '../../data/business';
---

<BaseLayout
  title="Privacy Policy — Marc M"
  description="Privacy policy for marcm.fr — how your personal data is collected and used."
  lang="en"
  noindex={true}
  frPath="/politique-confidentialite"
  enPath="/en/privacy-policy"
>
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-3xl prose prose-neutral max-w-none">
      <h1 class="text-3xl font-bold text-[var(--color-text)] mb-8">Privacy Policy</h1>

      <p class="text-[var(--color-text-muted)] mb-8">Last updated: January 2026</p>

      <div class="space-y-8 text-[var(--color-text-muted)] leading-relaxed">
        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">1. Data Controller</h2>
          <p>{business.legalName}<br />
          {business.address.street}, {business.address.zip} {business.address.city}<br />
          Email: {business.email}<br />
          Phone: {business.phone}</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">2. Data Collected</h2>
          <p>When you use the contact form, we collect: your name, email address, phone number (optional), and your message. This data is used solely to respond to your enquiry.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">3. Legal Basis</h2>
          <p>Data is processed on the basis of your consent (Article 6(1)(a) GDPR), given when you submit the contact form.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">4. Data Retention</h2>
          <p>Your data is retained for a maximum of 2 years from the date of last contact.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">5. Analytics</h2>
          <p>This site uses Umami Analytics, a privacy-friendly analytics tool that does not use cookies and does not collect personal data. No consent banner is required.</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">6. Your Rights</h2>
          <p>Under GDPR, you have the right to access, rectify, erase, and port your personal data, as well as the right to object to processing. To exercise these rights, contact: {business.email}</p>
        </div>

        <div>
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-3">7. Complaints</h2>
          <p>You have the right to lodge a complaint with the CNIL (France's data protection authority): <a href="https://www.cnil.fr" target="_blank" rel="noopener noreferrer" class="text-[var(--color-accent)] hover:underline">www.cnil.fr</a></p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
