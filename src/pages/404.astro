---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page non trouvée — MM Agency';
const description = 'La page que vous cherchez n\'existe pas ou a été déplacée.';
---

<style>
  .not-found-bg::before {
    content: '404';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 25vw;
    font-weight: 900;
    color: var(--color-accent);
    opacity: 0.1;
    pointer-events: none;
    white-space: nowrap;
    line-height: 1;
  }
</style>

<BaseLayout title={title} description={description}>
  <div class="relative mx-auto flex min-h-screen max-w-7xl flex-col items-center justify-center overflow-hidden px-6 py-20 md:px-8">
    <div class="not-found-bg relative z-10 text-center">
      <h1 class="mb-8 text-5xl font-bold text-[var(--color-text)] md:text-6xl">
        Oups, cette page n'existe pas
      </h1>

      <p class="mb-12 max-w-2xl text-lg text-[var(--color-text-muted)]">
        Pas de panique — voici quelques pages qui existent, elles :
      </p>

      <!-- Links Grid 2x2 -->
      <div class="mb-12 grid gap-6 sm:grid-cols-2">
        <a
          href="/"
          class="group relative rounded-lg border border-[var(--color-bg-alt)] p-8 transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-alt)]"
        >
          <div class="text-2xl font-bold text-[var(--color-accent)] mb-2">Accueil</div>
          <p class="text-sm text-[var(--color-text-muted)] group-hover:text-[var(--color-text)]">
            Retour à la page principale
          </p>
        </a>

        <a
          href="/realisations"
          class="group relative rounded-lg border border-[var(--color-bg-alt)] p-8 transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-alt)]"
        >
          <div class="text-2xl font-bold text-[var(--color-accent)] mb-2">Réalisations</div>
          <p class="text-sm text-[var(--color-text-muted)] group-hover:text-[var(--color-text)]">
            Découvrez mes projets web
          </p>
        </a>

        <a
          href="/offre"
          class="group relative rounded-lg border border-[var(--color-bg-alt)] p-8 transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-alt)]"
        >
          <div class="text-2xl font-bold text-[var(--color-accent)] mb-2">Offre</div>
          <p class="text-sm text-[var(--color-text-muted)] group-hover:text-[var(--color-text)]">
            Mes services et forfaits
          </p>
        </a>

        <a
          href="/contact"
          class="group relative rounded-lg border border-[var(--color-bg-alt)] p-8 transition-all hover:border-[var(--color-accent)] hover:bg-[var(--color-bg-alt)]"
        >
          <div class="text-2xl font-bold text-[var(--color-accent)] mb-2">Contact</div>
          <p class="text-sm text-[var(--color-text-muted)] group-hover:text-[var(--color-text)]">
            Me contacter pour un projet
          </p>
        </a>
      </div>

      <!-- Primary Button -->
      <a
        href="/"
        class="inline-block rounded-lg bg-[var(--color-accent)] px-8 py-4 font-medium text-white transition-all hover:shadow-lg hover:scale-105"
      >
        Retour à l'accueil
      </a>
    </div>
  </div>
</BaseLayout>
