---
import VilleTemplate from '@components/VilleTemplate.astro';

const title = "Création de site web sur mesure à Colmar | Marc M";
const description = "Créateur de sites web custom à Colmar. Sites rapides, bien référencés Google & IA, pour artisans, commerçants et indépendants alsaciens. À partir de 490€.";

const ville = "Colmar";
const intro = "Vous êtes artisan, commerçant ou indépendant à Colmar et vous cherchez un site web qui travaille pour vous ? Je suis Marc M., je crée des sites sur mesure pour les pros d'Alsace. Design unique, SEO local, livré en 7 jours. Pas de WordPress, pas de template.";

const sections = [
  {
    title: "Colmar : une ville touristique, des pros encore trop peu visibles",
    content: "Colmar attire plus de 3 millions de visiteurs par an. Pourtant, beaucoup de commerçants et artisans colmariens n'ont pas de site web — ou un site qui date.\n\nLe problème :\n- Les touristes cherchent sur Google avant de venir (« restaurant Colmar », « artisan Colmar »)\n- Les locaux aussi cherchent en ligne avant de pousser la porte\n- Sans site, vous n'existez pas pour ces recherches\n- Vos concurrents avec un site captent ces clients à votre place\n\nUn site moderne bien référencé, c'est votre vitrine 24h/24 — pour les Colmariens et les visiteurs."
  },
  {
    title: "Mon approche pour les pros de Colmar",
    content: "Je travaille à distance depuis Metz, avec des clients dans tout le Grand Est et toute la France.\n\nCe que je fais pour chaque site :\n- Design sur mesure qui reflète votre identité et l'esprit alsacien si vous le souhaitez\n- SEO local Colmar + Haut-Rhin (Google Maps, mots-clés géolocalisés)\n- Référencement IA (ChatGPT, Perplexity, Claude)\n- Mobile-first (la majorité des touristes cherchent sur leur téléphone)\n- Performance Lighthouse 100/100\n- Rédaction de tous vos textes incluse\n- Possibilité de site bilingue FR/DE ou FR/EN (zone frontalière + tourisme)\n\nÉchange de 15 minutes pour démarrer — par téléphone, visio ou écrit."
  },
  {
    title: "Exemples de sites pour Colmar et l'Alsace",
    content: "**Fleurs Forbach (Commerce)**\nSite vitrine pour un fleuriste : catalogue de compositions, commande pour livraison, horaires et localisation. Design floral élégant.\n\n**La Grange aux Fées (Tourisme/Gîte)**\nSite multi-pages pour 6 gîtes de charme en Moselle : carousel de chambres, galerie photos, avis clients, blog touristique. Palette cuivrée et chaleureuse.\n\n**Yoga Sarah (Bien-être)**\nSite vitrine pour une prof de yoga : planning des cours, tarifs, philosophie, réservation de séances. Design épuré et apaisant."
  }
];

const faq = [
  {
    question: "Vous n'êtes pas à Colmar, c'est un problème ?",
    answer: "Pas du tout. Tout se fait à distance — échange de cadrage par téléphone ou visio, allers-retours par email et WhatsApp. Le résultat est le même qu'avec un prestataire local, souvent plus rapide et moins cher."
  },
  {
    question: "Vous pouvez faire un site en alsacien ou en allemand ?",
    answer: "Oui. Je propose des sites bilingues FR/DE ou FR/EN, parfait pour les activités touristiques ou transfrontalières. Le contenu est traduit et adapté, pas juste passé dans Google Translate."
  },
  {
    question: "Mon activité est saisonnière (marché de Noël, tourisme été), c'est adapté ?",
    answer: "Oui. Votre site reste en ligne toute l'année (hébergement gratuit à vie). Vous pouvez mettre à jour vos horaires et actualités vous-même via l'espace d'édition. Pas besoin de couper le site hors saison."
  },
  {
    question: "Combien ça coûte par rapport à une agence colmarienne ?",
    answer: "Mon Site Vitrine est à 490€, livré en 7 jours. Une agence locale facture généralement 2000 à 5000€ pour un résultat similaire, en 4 à 8 semaines. Même qualité technique, interlocuteur unique, et votre site vous appartient (pas d'abonnement)."
  }
];

const pricingExpress = {
  title: "Site Vitrine",
  price: "490€",
  features: [
    "✓ Design sur mesure, pas un template",
    "✓ Référencé Google & IA",
    "✓ Formulaire, WhatsApp, appel",
    "✓ Lighthouse 100/100",
    "✓ Livré en 7 jours"
  ]
};

const pricingCustom = {
  title: "Projet Sur Mesure",
  price: "Sur devis",
  features: [
    "✓ Multi-pages, blog, CMS",
    "✓ Fonctionnalités métier",
    "✓ Stratégie SEO avancée",
    "✓ Optimisé IA (ChatGPT, Claude)",
    "✓ Devis gratuit sous 48h"
  ]
};

const geo = {
  lat: 48.0794,
  lon: 7.3558
};

const areaServed = ["Colmar", "Haut-Rhin", "Mulhouse", "Sélestat", "Ribeauvillé", "Kaysersberg", "Munster"];

const ctaTitle = "Prêt à lancer votre site web à Colmar ?";
const ctaText = "Écrivez-moi ou appelez. Échange gratuit de 15 minutes, sans engagement. On regarde ensemble ce qu'il vous faut.";
const ctaButton = "Commander mon site — 490€";
---

<VilleTemplate
  title={title}
  description={description}
  ville={ville}
  intro={intro}
  sections={sections}
  faq={faq}
  pricingExpress={pricingExpress}
  pricingCustom={pricingCustom}
  geo={geo}
  areaServed={areaServed}
  ctaTitle={ctaTitle}
  ctaText={ctaText}
  ctaButton={ctaButton}
  frPath="/creation-site-web-colmar"
/>
