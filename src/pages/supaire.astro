  <meta property="og:title" content="SITE INTERNET GRATUIT ET PAS MOCHE 🔥" />
  <meta property="og:description" content="100% COOL ★ Cliquez ici pour découvrir le meilleur site du monde !!!" />
  <meta property="og:image" content="https://marcm.fr/og-supaire.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="fr_FR" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="SITE INTERNET GRATUIT ET PAS MOCHE 🔥" />
  <meta name="twitter:description" content="100% COOL ★ Cliquez ici pour découvrir le meilleur site du monde !!!" />
  <meta name="twitter:image" content="https://marcm.fr/og-supaire.png" />

  <style>
    /* ============================================================
       FONTS
       ============================================================ */
    @font-face {
      font-family: 'Satoshi';
      src: url('/fonts/Satoshi-Variable.woff2') format('woff2');
      font-weight: 100 900;
      font-display: swap;
    }

    /* ============================================================
       RESET & BASE
       ============================================================ */
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { overflow-x: hidden; font-family: 'Comic Sans MS', 'Comic Sans', cursive; background: #000; }

    /* ============================================================
       PHASE 1 — FAKE LOADING / DIAL-UP
       ============================================================ */
    #phase1 {
      position: fixed; inset: 0; z-index: 10000;
      background: #000; display: flex; align-items: center; justify-content: center;
      flex-direction: column; transition: opacity 0.5s;
    }
    #phase1.hidden { opacity: 0; pointer-events: none; }

    .xp-dialog {
      background: #ECE9D8; border: 2px solid #0054E3;
      border-radius: 8px 8px 0 0; width: 380px; max-width: 90vw;
      box-shadow: 2px 2px 10px rgba(0,0,0,0.5); font-family: 'Tahoma', 'Segoe UI', sans-serif;
      font-size: 12px; display: none;
    }
    .xp-dialog.visible { display: block; }
    .xp-titlebar {
      background: linear-gradient(180deg, #0997FF 0%, #0054E3 100%);
      color: white; padding: 4px 8px; font-weight: bold; font-size: 12px;
      border-radius: 6px 6px 0 0; display: flex; justify-content: space-between; align-items: center;
    }
    .xp-close { background: #E04343; color: white; border: 1px solid #8B0000; border-radius: 3px;
      width: 20px; height: 20px; font-size: 10px; cursor: pointer; display: flex; align-items: center; justify-content: center; }
    .xp-body { padding: 16px; }
    .xp-progress-outer {
      background: #FFF; border: 1px solid #8B8B8B; height: 18px; border-radius: 2px; overflow: hidden; margin: 10px 0;
    }
    .xp-progress-inner {
      background: linear-gradient(90deg, #0997FF 0%, #52B4FF 50%, #0997FF 100%);
      height: 100%; width: 0%; transition: width 0.3s; border-radius: 2px;
      background-size: 30px 18px;
      animation: xpProgressStripe 0.5s linear infinite;
    }
    @keyframes xpProgressStripe {
      0% { background-position: 0 0; }
      100% { background-position: 30px 0; }
    }
    .xp-text { color: #000; margin-bottom: 8px; }

    /* Error popup */
    .xp-error {
      position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
      z-index: 10001; display: none;
    }
    .xp-error.visible { display: block; }
    .xp-error .xp-body { text-align: center; }
    .xp-btn {
      background: linear-gradient(180deg, #FFF 0%, #E3E3DB 100%);
      border: 1px solid #8B8B8B; border-radius: 3px; padding: 3px 20px;
      font-family: 'Tahoma', sans-serif; font-size: 12px; cursor: pointer;
      margin: 4px;
    }
    .xp-btn:active { background: #D4D0C8; }

    /* IE loading bar */
    #ie-bar {
      position: fixed; top: 0; left: 0; height: 4px; z-index: 10002;
      background: #0997FF; width: 0%; display: none; transition: width 0.2s;
    }

    /* ============================================================
       PHASE 2 — THE UGLY 2000s SITE
       ============================================================ */
    #phase2 {
      display: none; min-height: 100vh; position: relative;
      background: #000033;
      cursor: url("data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32'><text y='24' font-size='24'>%E2%9C%A8</text></svg>") 16 16, auto;
    }
    #phase2.visible { display: block; }

    /* Starfield */
    #starfield {
      position: fixed; inset: 0; z-index: 0; pointer-events: none;
      background: radial-gradient(ellipse at center, #000033 0%, #000011 100%);
    }
    .star {
      position: absolute; background: white; border-radius: 50%;
      animation: starTwinkle var(--dur) ease-in-out infinite alternate;
    }
    @keyframes starTwinkle {
      0% { opacity: 0.2; transform: scale(0.5); }
      100% { opacity: 1; transform: scale(1.2); }
    }

    /* URL bar */
    .url-bar {
      background: #C0C0C0; border-bottom: 2px solid #808080; padding: 4px 8px;
      font-family: 'Tahoma', sans-serif; font-size: 12px; display: flex; align-items: center; gap: 8px;
      position: relative; z-index: 10;
    }
    .url-bar input {
      flex: 1; padding: 2px 4px; border: 2px inset #C0C0C0; font-family: 'Tahoma', sans-serif; font-size: 12px;
      background: #FFF;
    }
    .rec-badge {
      background: red; color: white; font-weight: bold; font-size: 10px;
      padding: 2px 6px; border-radius: 2px; animation: blink 0.5s infinite;
    }

    /* Blink animation */
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    .blink { animation: blink 0.8s infinite; }

    /* Rainbow text */
    .rainbow {
      background: linear-gradient(90deg, #FF0000, #FF7F00, #FFFF00, #00FF00, #0000FF, #4B0082, #8B00FF, #FF0000);
      background-size: 400% 100%;
      -webkit-background-clip: text; -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: rainbowShift 2s linear infinite;
    }
    @keyframes rainbowShift {
      0% { background-position: 0% 50%; }
      100% { background-position: 400% 50%; }
    }

    /* Giant title */
    .giant-title {
      font-family: 'Comic Sans MS', cursive; font-size: clamp(24px, 6vw, 64px);
      font-weight: bold; text-align: center; padding: 20px;
      text-shadow: 3px 3px 0 #000, -1px -1px 0 #FF00FF, 2px 2px 6px rgba(255,255,0,0.8);
      position: relative; z-index: 10;
    }

    /* Content wrapper */
    .ugly-content {
      max-width: 900px; margin: 0 auto; padding: 20px; position: relative; z-index: 10;
    }

    /* Fire text */
    .fire-text {
      font-family: Impact, sans-serif; font-size: clamp(32px, 5vw, 60px);
      font-weight: bold; text-align: center; color: #FF4500;
      text-shadow: 0 0 10px #FF4500, 0 0 20px #FF0000, 0 0 40px #FF6600, 0 0 80px #FF4500;
      animation: fireFlicker 0.15s infinite alternate;
    }
    @keyframes fireFlicker {
      0% { text-shadow: 0 0 10px #FF4500, 0 0 20px #FF0000, 0 0 40px #FF6600, 0 -5px 60px #FF4500; }
      50% { text-shadow: 0 0 15px #FFFF00, 0 0 30px #FF4500, 0 0 50px #FF0000, 0 -8px 70px #FF6600; }
      100% { text-shadow: 0 0 8px #FF4500, 0 0 18px #FF0000, 0 0 35px #FF6600, 0 -3px 55px #FF4500; }
    }

    /* Marquee styling */
    .ugly-marquee {
      background: #FFFF00; color: #FF0000; font-weight: bold; font-size: 16px;
      padding: 4px 0; font-family: 'Comic Sans MS', cursive; position: relative; z-index: 10;
    }
    .ugly-marquee2 {
      background: #FF00FF; color: #00FFFF; font-weight: bold; font-size: 14px;
      padding: 4px 0; font-family: 'Comic Sans MS', cursive; position: relative; z-index: 10;
    }
    .ugly-marquee3 {
      background: #00FF00; color: #000; font-weight: bold; font-size: 13px;
      padding: 4px 0; font-family: 'Comic Sans MS', cursive; position: relative; z-index: 10;
    }

    /* Layout */
    .ugly-layout {
      display: flex; gap: 16px; flex-wrap: wrap; position: relative; z-index: 10;
    }
    .ugly-sidebar {
      width: 180px; flex-shrink: 0;
    }
    .ugly-main {
      flex: 1; min-width: 250px;
    }

    /* Sidebar menu */
    .menu-btn {
      display: block; width: 100%; margin: 6px 0; padding: 8px;
      font-family: 'Comic Sans MS', cursive; font-weight: bold; font-size: 14px;
      border: 3px outset #C0C0C0; background: #C0C0C0; cursor: pointer;
      text-align: center; color: #000;
    }
    .menu-btn:hover { border-style: inset; }
    .menu-btn.rainbow-btn {
      background: linear-gradient(45deg, #FF0000, #FF7F00, #FFFF00, #00FF00, #00FFFF, #0000FF, #FF00FF);
      color: #FFF; text-shadow: 1px 1px 2px #000;
    }

    /* Image placeholder */
    .img-placeholder {
      border: 3px dashed #FF00FF; background: #FFF; padding: 40px 20px;
      text-align: center; color: #808080; font-size: 14px; margin: 16px 0;
      position: relative;
    }
    .tape {
      position: absolute; width: 60px; height: 20px; background: rgba(255,255,200,0.7);
      transform: rotate(-25deg); border: 1px solid rgba(200,200,100,0.5);
      box-shadow: 1px 1px 3px rgba(0,0,0,0.2);
    }
    .tape-tl { top: -8px; left: -10px; }
    .tape-tr { top: -8px; right: -10px; transform: rotate(25deg); }
    .tape-bl { bottom: -8px; left: -10px; transform: rotate(25deg); }
    .tape-br { bottom: -8px; right: -10px; transform: rotate(-25deg); }

    /* Cat */
    .lolcat {
      font-size: 80px; text-align: center; margin: 10px 0;
      animation: catBounce 0.5s ease-in-out infinite alternate;
    }
    @keyframes catBounce {
      from { transform: rotate(-5deg); }
      to { transform: rotate(5deg); }
    }

    /* Cool badge */
    .cool-badge {
      display: inline-block; background: #FFD700; color: #FF0000;
      font-weight: bold; font-size: 20px; padding: 8px 16px;
      border: 3px solid #FF0000; transform: rotate(-5deg);
      text-shadow: 1px 1px 0 #FFA500; margin: 10px;
      animation: badgePulse 0.8s ease-in-out infinite alternate;
    }
    @keyframes badgePulse {
      from { transform: rotate(-5deg) scale(1); }
      to { transform: rotate(-5deg) scale(1.1); }
    }

    /* Go button */
    .go-btn {
      display: inline-block; background: linear-gradient(180deg, #FF0000, #CC0000);
      color: #FFFF00; font-family: Impact, sans-serif; font-size: 48px;
      padding: 16px 40px; border: 4px outset #FF6666; cursor: pointer;
      text-shadow: 2px 2px 4px #000; margin: 16px;
      animation: goBtnPulse 0.5s infinite alternate;
    }
    .go-btn:hover { border-style: inset; }
    @keyframes goBtnPulse {
      from { transform: scale(1); box-shadow: 0 0 10px #FF0000; }
      to { transform: scale(1.05); box-shadow: 0 0 30px #FFFF00, 0 0 60px #FF0000; }
    }

    /* Bling */
    .bling {
      font-size: 28px; color: #FFD700; font-weight: bold;
      text-shadow: 0 0 10px #FFD700, 0 0 20px #FFA500, 0 0 40px #FFD700;
      animation: blingAnim 0.3s infinite alternate;
    }
    @keyframes blingAnim {
      from { transform: scale(1); text-shadow: 0 0 10px #FFD700; }
      to { transform: scale(1.1); text-shadow: 0 0 30px #FFD700, 0 0 60px #FFA500; }
    }

    /* Sparkle text */
    .sparkle-text {
      color: #FF0000; font-weight: bold; font-size: 22px; font-family: 'Comic Sans MS', cursive;
      position: relative;
    }
    .sparkle-text::after {
      content: '';
      position: absolute; inset: -4px; pointer-events: none;
      background-image: radial-gradient(circle, #FFD700 1px, transparent 1px);
      background-size: 12px 12px;
      animation: sparkleShift 0.5s linear infinite;
      opacity: 0.6;
    }
    @keyframes sparkleShift {
      0% { background-position: 0 0; }
      100% { background-position: 12px 12px; }
    }

    /* Under construction */
    .under-construction {
      background: repeating-linear-gradient(45deg, #FFD700, #FFD700 20px, #000 20px, #000 40px);
      padding: 8px 16px; text-align: center; color: #FF0000; font-weight: bold;
      font-family: Impact, sans-serif; font-size: 18px; margin: 10px 0;
      border: 3px solid #FF0000;
    }
    .under-construction span {
      background: #000; padding: 2px 8px; display: inline-block;
    }

    /* Visitor counter */
    .visitor-counter {
      background: #000; color: #00FF00; font-family: 'Courier New', monospace;
      padding: 8px 16px; text-align: center; font-size: 14px; margin: 10px 0;
      border: 2px inset #808080;
    }

    /* Footer credits */
    .ugly-footer {
      text-align: center; padding: 20px; font-size: 11px; color: #808080;
      font-family: 'Tahoma', sans-serif; border-top: 2px solid #C0C0C0;
      background: #000022; position: relative; z-index: 10;
    }
    .ugly-footer a { color: #00FFFF; }

    /* Spinning email */
    .spin-email {
      display: inline-block; font-size: 24px;
      animation: spinEmail 2s linear infinite;
    }
    @keyframes spinEmail {
      from { transform: rotateY(0deg); }
      to { transform: rotateY(360deg); }
    }

    /* Popup */
    .fake-popup {
      position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
      z-index: 9999; display: none;
    }
    .fake-popup.visible { display: block; }

    /* Video frame */
    .video-frame {
      border: 4px solid #333; background: #000; border-radius: 4px;
      box-shadow: 0 0 20px rgba(0,0,0,0.5); margin: 16px auto; padding: 4px;
    }
    .video-controls {
      background: #333; padding: 4px 8px; display: flex; gap: 8px; align-items: center;
    }
    .video-controls span { color: #FFF; font-size: 18px; cursor: pointer; }
    .video-bar { flex: 1; height: 4px; background: #666; border-radius: 2px; }
    .video-bar-fill { width: 35%; height: 100%; background: #FF0000; border-radius: 2px; }

    /* Scroll hint */
    .scroll-hint {
      position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
      z-index: 9998; color: #FFF; font-family: 'Satoshi', sans-serif;
      font-size: 18px; font-weight: 700; letter-spacing: 0.05em;
      opacity: 0; transition: opacity 0.6s;
      background: linear-gradient(135deg, #E86C47 0%, #D45A37 100%);
      padding: 16px 32px; border-radius: 50px;
      cursor: pointer; text-transform: uppercase;
      box-shadow: 0 4px 24px rgba(232, 108, 71, 0.5), 0 0 60px rgba(232, 108, 71, 0.2);
      display: flex; align-items: center; gap: 10px;
    }
    .scroll-hint.visible { opacity: 1; animation: hintPulse 2s ease-in-out infinite; }
    .scroll-hint .arrow {
      display: inline-block; font-size: 22px;
      animation: arrowBounce 1s ease-in-out infinite;
    }
    @keyframes hintPulse {
      0%, 100% { transform: translateX(-50%) translateY(0); box-shadow: 0 4px 24px rgba(232, 108, 71, 0.5), 0 0 60px rgba(232, 108, 71, 0.2); }
      50% { transform: translateX(-50%) translateY(-6px); box-shadow: 0 8px 32px rgba(232, 108, 71, 0.7), 0 0 80px rgba(232, 108, 71, 0.3); }
    }
    @keyframes arrowBounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(5px); }
    }

    /* Mouse trail */
    .trail-particle {
      position: fixed; pointer-events: none; z-index: 9997;
      font-size: 16px; transition: opacity 0.5s, transform 0.5s;
    }

    /* ============================================================
       PHASE 3 — THE REVEAL
       ============================================================ */
    #phase3 {
      display: none; min-height: 100vh;
      background: #FAFAF8; color: #1A1A1A;
      font-family: 'Satoshi', sans-serif;
      align-items: center; justify-content: center; flex-direction: column;
      text-align: center; padding: 40px 20px;
    }
    #phase3.visible {
      display: flex;
    }

    .reveal-title {
      font-size: clamp(48px, 10vw, 96px); font-weight: 800;
      opacity: 0; transform: translateY(40px) scale(0.9);
      transition: opacity 1s ease, transform 1s cubic-bezier(0.16, 1, 0.3, 1);
      color: #1A1A1A; line-height: 1.1;
      letter-spacing: -0.03em;
    }
    .reveal-title.show { opacity: 1; transform: translateY(0) scale(1); }

    .reveal-subtitle {
      font-size: clamp(18px, 3vw, 28px); font-weight: 400;
      color: #555; margin-top: 24px;
      max-width: 600px;
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s ease 0.5s, transform 0.8s ease 0.5s;
    }
    .reveal-subtitle.show { opacity: 1; transform: translateY(0); }

    .reveal-price {
      font-size: clamp(28px, 5vw, 48px); font-weight: 800;
      color: #E86C47; margin-top: 32px;
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s ease 1s, transform 0.8s ease 1s;
    }
    .reveal-price.show { opacity: 1; transform: translateY(0); }

    .reveal-cta {
      display: inline-block; margin-top: 40px;
      padding: 20px 48px; background: #E86C47; color: #FFF;
      font-family: 'Satoshi', sans-serif; font-size: 20px; font-weight: 700;
      border: none; border-radius: 12px; text-decoration: none; cursor: pointer;
      opacity: 0; transform: translateY(30px);
      transition: opacity 0.8s ease 1.4s, transform 0.8s ease 1.4s, background 0.3s, box-shadow 0.3s;
      box-shadow: 0 4px 24px rgba(232, 108, 71, 0.3);
    }
    .reveal-cta.show { opacity: 1; transform: translateY(0); }
    .reveal-cta:hover { background: #D45A37; box-shadow: 0 6px 32px rgba(232, 108, 71, 0.5); }

    .reveal-replay {
      display: inline-block; margin-top: 24px;
      font-family: 'Satoshi', sans-serif; font-size: 14px; font-weight: 400;
      color: #999; text-decoration: none; cursor: pointer;
      opacity: 0; transform: translateY(20px);
      transition: opacity 0.8s ease 2s, transform 0.8s ease 2s, color 0.3s;
    }
    .reveal-replay.show { opacity: 1; transform: translateY(0); }
    .reveal-replay:hover { color: #E86C47; }

    /* Glitch transition */
    .glitch-out {
      animation: glitchOut 0.8s forwards;
    }
    @keyframes glitchOut {
      0% { filter: none; opacity: 1; }
      20% { filter: hue-rotate(90deg) blur(2px); transform: skewX(5deg); }
      40% { filter: hue-rotate(180deg) blur(4px); transform: skewX(-3deg) translateX(10px); }
      60% { filter: saturate(0) blur(6px); transform: skewX(2deg) translateX(-5px); opacity: 0.5; }
      80% { filter: blur(10px); opacity: 0.2; }
      100% { filter: blur(20px); opacity: 0; display: none; }
    }

    /* Mobile adjustments */
    @media (max-width: 640px) {
      .ugly-sidebar { width: 100%; }
      .ugly-layout { flex-direction: column; }
      .xp-dialog { width: 95vw; }
      .go-btn { font-size: 32px; padding: 12px 24px; }
    }
  </style>
</head>

<body>

  <!-- ============================================================
       PHASE 1 — FAKE LOADING
       ============================================================ -->
  <div id="phase1">
    <!-- IE Error popup -->
    <div id="ieError" class="xp-error">
      <div class="xp-dialog visible">
        <div class="xp-titlebar">
          <span>Internet Explorer</span>
          <div class="xp-close">X</div>
        </div>
        <div class="xp-body">
          <p class="xp-text" style="margin-bottom:12px;">&#9888; Internet Explorer a rencontre un probleme et doit fermer.<br><br>Si vous etiez en train de travailler, les informations que vous utilisiez sont perdues.</p>
          <button class="xp-btn" id="ieErrorOk">OK</button>
        </div>
      </div>
    </div>

    <!-- Toolbar popup -->
    <div id="toolbarPopup" class="xp-error">
      <div class="xp-dialog visible">
        <div class="xp-titlebar">
          <span>Installation recommandee</span>
          <div class="xp-close">X</div>
        </div>
        <div class="xp-body">
          <p class="xp-text" style="margin-bottom:12px;">Voulez-vous installer <b>17 barres d'outils</b> ?<br><small>(BonzaiBuddy, Ask Toolbar, Yahoo! Companion, CoolWebSearch...)</small></p>
          <button class="xp-btn" id="tbOui">Oui</button>
          <button class="xp-btn" id="tbNon">Non</button>
        </div>
      </div>
    </div>

    <!-- 404 flash -->
    <div id="flash404" style="display:none;position:fixed;inset:0;background:#FFF;z-index:10003;font-family:'Tahoma',sans-serif;padding:40px;">
      <h1 style="font-size:24px;">404 Not Found</h1>
      <p style="margin-top:10px;">The requested URL was not found on this server.</p>
      <hr style="margin:10px 0;">
      <p style="font-size:12px;color:#808080;">Apache/2.0.52 (Win32) Server at mon-supaire-site.com Port 80</p>
    </div>

    <!-- IE loading bar -->
    <div id="ie-bar"></div>
  </div>

  <!-- ============================================================
       PHASE 2 — THE UGLY 2000s SITE
       ============================================================ -->
  <div id="phase2">
    <div id="starfield"></div>

    <!-- URL bar -->
    <div class="url-bar">
      <span style="font-size:14px;">&#127760;</span>
      <input type="text" value="http://www.MON-SUPAIRE-SITE.COM/index.html" readonly />
      <span class="rec-badge">&#9679; REC</span>
    </div>

    <!-- Marquee 1 -->
    <marquee class="ugly-marquee" scrollamount="4">&#9733; BIENVENUE SUR LE MEILLEUR SITE DU MONDE &#9733; ENTREZ VOTRE EMAIL POUR GAGNER UN iPOD &#9733; SITE MIS A JOUR LE 14/02/2003 &#9733; NOUVEAU : LIVRE D'OR !!! &#9733;</marquee>

    <!-- Giant title -->
    <div class="giant-title">
      <span class="rainbow">SITE INTERNET GRATUIT ET PAS MOCHE</span>
    </div>

