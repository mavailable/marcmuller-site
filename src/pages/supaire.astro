  <script>
    // ---- Right-click disable ----
    document.addEventListener('contextmenu', (e) => {
      e.preventDefault();
      alert('Nice try \u{1F60E}');
    });

    // ---- Web Audio: Dial-up modem sound ----
    function playDialupSound() {
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const duration = 4;
        const sr = ctx.sampleRate;
        const buf = ctx.createBuffer(1, sr * duration, sr);
        const data = buf.getChannelData(0);

        for (let i = 0; i < data.length; i++) {
          const t = i / sr;
          let sample = 0;
          if (t < 0.5) {
            // Initial dial tones
            sample = Math.sin(2 * Math.PI * 350 * t) * 0.3 + Math.sin(2 * Math.PI * 440 * t) * 0.3;
          } else if (t < 1.2) {
            // Ring
            sample = Math.sin(2 * Math.PI * 480 * t) * 0.2 * (Math.sin(2 * Math.PI * 20 * t) > 0 ? 1 : 0);
          } else if (t < 2.5) {
            // Modem handshake screech
            const freq = 1200 + Math.sin(t * 50) * 800 + Math.sin(t * 200) * 400;
            sample = Math.sin(2 * Math.PI * freq * t) * 0.15;
            sample += (Math.random() - 0.5) * 0.08;
          } else if (t < 3.5) {
            // Data negotiation noise
            const freq = 2400 + Math.sin(t * 150) * 600;
            sample = Math.sin(2 * Math.PI * freq * t) * 0.1;
            sample += Math.sin(2 * Math.PI * (freq * 0.5) * t) * 0.05;
            sample += (Math.random() - 0.5) * 0.05;
          } else {
            // Final connection burst
            sample = (Math.random() - 0.5) * 0.04 * (1 - (t - 3.5) * 2);
          }
          data[i] = sample;
        }

        const src = ctx.createBufferSource();
        src.buffer = buf;
        const gain = ctx.createGain();
        gain.gain.value = 0.4;
        src.connect(gain);
        gain.connect(ctx.destination);
        src.start();
        return ctx;
      } catch(e) { return null; }
    }

    // ---- Web Audio: Chiptune melody ----
    let chiptuneCtx = null;
    let chiptuneOsc = null;

    function playChiptune() {
      try {
        chiptuneCtx = new (window.AudioContext || window.webkitAudioContext)();
        const melody = [
          262, 294, 330, 349, 392, 349, 330, 294,
          262, 330, 392, 523, 392, 330, 262, 294,
          330, 349, 392, 440, 392, 349, 330, 294,
          262, 0, 262, 0, 392, 0, 523, 0
        ];
        const noteLength = 0.18;
        const totalTime = melody.length * noteLength;

        function scheduleNotes(startTime) {
          melody.forEach((freq, i) => {
            if (freq === 0) return;
            const osc = chiptuneCtx.createOscillator();
            osc.type = 'square';
            osc.frequency.value = freq;
            const g = chiptuneCtx.createGain();
            g.gain.value = 0.06;
            g.gain.setValueAtTime(0.06, startTime + i * noteLength);
            g.gain.exponentialRampToValueAtTime(0.001, startTime + (i + 0.9) * noteLength);
            osc.connect(g);
            g.connect(chiptuneCtx.destination);
            osc.start(startTime + i * noteLength);
            osc.stop(startTime + (i + 1) * noteLength);
          });
        }

        // Loop the melody
        let time = chiptuneCtx.currentTime;
        for (let loop = 0; loop < 50; loop++) {
          scheduleNotes(time);
          time += totalTime;
        }
      } catch(e) {}
    }

    function stopChiptune() {
      if (chiptuneCtx) {
        chiptuneCtx.close();
        chiptuneCtx = null;
      }
    }

    // ---- PHASE 1 SEQUENCE ----
    const phase1 = document.getElementById('phase1');
    const phase2 = document.getElementById('phase2');
    const phase3 = document.getElementById('phase3');
    const ieBar = document.getElementById('ie-bar');
    const ieError = document.getElementById('ieError');
    const toolbarPopup = document.getElementById('toolbarPopup');
    const flash404 = document.getElementById('flash404');

    async function sleep(ms) {
      return new Promise(r => setTimeout(r, ms));
    }

    async function runPhase1() {
      // Start dial-up sound on first interaction or immediately
      let audioStarted = false;
      function startAudio() {
        if (!audioStarted) {
          audioStarted = true;
          playDialupSound();
        }
      }
      // Try to autoplay, fallback to click
      startAudio();
      document.addEventListener('click', startAudio, { once: true });

      await sleep(300);

      // Show IE loading bar
      ieBar.style.display = 'block';
      for (let i = 0; i <= 80; i += 10) {
        ieBar.style.width = i + '%';
        await sleep(40);
      }
      await sleep(200);

      // IE Error popup
      ieError.classList.add('visible');
      await sleep(1400);
      ieError.classList.remove('visible');
      await sleep(200);

      // Toolbar popup
      toolbarPopup.classList.add('visible');
      await sleep(1600);
      toolbarPopup.classList.remove('visible');

      ieBar.style.width = '95%';
      await sleep(200);

      // 404 flash
      flash404.style.display = 'block';
      await sleep(500);
      flash404.style.display = 'none';

      // Complete
      ieBar.style.width = '100%';
      await sleep(300);

      // Transition to Phase 2
      phase1.classList.add('hidden');
      await sleep(500);
      phase1.style.display = 'none';
      phase2.classList.add('visible');

      // Start chiptune
      playChiptune();

      // Generate starfield
      generateStarfield();

      // Start visitor counter
      startVisitorCounter();

      // Show iPhone popup after 3s
      setTimeout(() => {
        document.getElementById('iphonePopup').classList.add('visible');
      }, 3000);

      // Show scroll hint after 5s
      setTimeout(() => {
        document.getElementById('scrollHint').classList.add('visible');
      }, 5000);

      // Start mouse trail
      startMouseTrail();
    }

    // ---- STARFIELD ----
    function generateStarfield() {
      const sf = document.getElementById('starfield');
      for (let i = 0; i < 80; i++) {
        const star = document.createElement('div');
        star.className = 'star';
        const size = Math.random() * 3 + 1;
        star.style.cssText = `
          left: ${Math.random() * 100}%;
          top: ${Math.random() * 100}%;
          width: ${size}px; height: ${size}px;
          --dur: ${Math.random() * 2 + 1}s;
        `;
        sf.appendChild(star);
      }
    }

    // ---- VISITOR COUNTER ----
    function startVisitorCounter() {
      const el = document.getElementById('visitorCount');
      let count = 12847;
      setInterval(() => {
        count += Math.floor(Math.random() * 3);
        el.textContent = count.toLocaleString('fr-FR').replace(/\s/g, ',').padStart(11, '0');
      }, 2000);
    }

    // ---- MOUSE TRAIL ----
    function startMouseTrail() {
      const sparkles = ['\u2728', '\u2B50', '\u2764\uFE0F', '\u2734\uFE0F', '\u269B\uFE0F'];
      document.addEventListener('mousemove', (e) => {
        if (Math.random() > 0.7) return; // throttle
        const particle = document.createElement('div');
        particle.className = 'trail-particle';
        particle.textContent = sparkles[Math.floor(Math.random() * sparkles.length)];
        particle.style.left = e.clientX + 'px';
        particle.style.top = e.clientY + 'px';
        document.body.appendChild(particle);
        requestAnimationFrame(() => {
          particle.style.opacity = '0';
          particle.style.transform = `translateY(-30px) scale(0.5) rotate(${Math.random()*360}deg)`;
        });
        setTimeout(() => particle.remove(), 600);
      });
    }

    // ---- PHASE 3 TRANSITION ----
    let phase3Triggered = false;

    function triggerPhase3() {
      if (phase3Triggered) return;
      phase3Triggered = true;

      // Stop the music
      stopChiptune();

      // Glitch out phase 2
      phase2.classList.add('glitch-out');

      setTimeout(() => {
        phase2.style.display = 'none';
        phase3.classList.add('visible');
        document.body.style.background = '#FAFAF8';

        // Remove scroll hint
        const hint = document.getElementById('scrollHint');
        if (hint) hint.remove();

        // Remove any remaining popups/trails
        document.querySelectorAll('.trail-particle, .fake-popup').forEach(el => el.remove());

        // Trigger reveal animations
        requestAnimationFrame(() => {
          document.getElementById('revealTitle').classList.add('show');
          document.getElementById('revealSubtitle').classList.add('show');
          document.getElementById('revealPrice').classList.add('show');
          document.getElementById('revealCta').classList.add('show');
          document.getElementById('revealReplay').classList.add('show');
        });
      }, 900);
    }

    // Scroll trigger
    window.addEventListener('scroll', () => {
      if (!phase3Triggered && phase2.classList.contains('visible')) {
        const scrolled = window.scrollY;
        const docHeight = document.documentElement.scrollHeight - window.innerHeight;
        if (scrolled > docHeight * 0.85) {
          triggerPhase3();
        }
      }
    });

    // Scroll hint click trigger
    document.getElementById('scrollHint').addEventListener('click', () => {
      window.scrollTo({ top: document.documentElement.scrollHeight, behavior: 'smooth' });
      setTimeout(triggerPhase3, 800);
    });

    // ---- INIT ----
    runPhase1();
  </script>

