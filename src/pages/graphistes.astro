---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import ProjectCarousel from '../components/ProjectCarousel.astro';

const checkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
---

<BaseLayout
  title="Graphistes : proposez des sites web à vos clients — sans coder"
  description="Sous-traitance web pour graphistes freelance. Site one-page 200€, multi-page 300€, livré en 24-72h. Ou formation pour devenir autonome à 800€."
  ogImage="/og-graphistes.png"
  noindex={true}
  lang="fr"
  frPath="/graphistes"
  enPath="/en/designers"
>

  <!-- ═══════════════════════════════════════ -->
  <!-- HERO — ACCROCHE -->
  <!-- ═══════════════════════════════════════ -->
  <section class="w-full relative px-6 py-20 md:px-8 md:py-32 overflow-hidden" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>

    <!-- Blobs décoratifs -->
    <div class="absolute top-20 -left-32 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: #E86C47;"></div>
    <div class="absolute bottom-10 -right-32 w-80 h-80 rounded-full opacity-8 blur-3xl" style="background: #E86C47;"></div>

    <div class="mx-auto max-w-4xl text-center relative z-10">
      <div class="mb-6 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]/40">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white/90">Offre réservée aux graphistes & designers</span>
      </div>

      <h1 class="mb-6 text-4xl font-bold leading-tight text-white md:text-5xl lg:text-6xl hero-fade-1">
        Vos clients vous demandent un site web.<br class="hidden md:block" />
        <span class="bg-gradient-to-r from-[#E86C47] to-[#F5C8B3] bg-clip-text text-transparent">Et si c'était votre meilleure opportunité ?</span>
      </h1>

      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mx-auto mb-10 hero-fade-2">
        Je code et déploie les sites de vos clients pour vous. Ou je vous apprends à le faire. Dans les deux cas, vous gardez le client, la marge, et le contrôle créatif.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 hero-fade-3">
        <a href="#offres" class="inline-flex items-center justify-center gap-2 rounded-lg px-8 py-3.5 text-base font-semibold text-white transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.4);">
          Voir les offres
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" /></svg>
        </a>
        <a href="#formation" class="inline-flex items-center gap-2 rounded-lg px-8 py-3.5 text-base font-semibold border border-white/20 text-white hover:bg-white/10 transition-all duration-300">
          Je veux devenir autonome
        </a>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════ -->
  <!-- LE PROBLÈME -->
  <!-- ═══════════════════════════════════════ -->
  <section class="w-full bg-white px-6 py-20 md:px-8 md:py-28">
    <div class="mx-auto max-w-4xl">

      <div class="mb-16">
        <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color:#E86C47; letter-spacing:0.2em;">Le vrai problème</p>
        <h2 class="text-3xl md:text-4xl font-bold leading-tight" style="color:#1A1A1A; letter-spacing:-0.025em; max-width:32rem;">
          Tu fais du beau. Mais le site, c'est toujours là que ça coince.
        </h2>
      </div>

      <!-- Trois options en colonnes épurées -->
      <div class="grid md:grid-cols-3 gap-0" style="border:1px solid #EDEBE8; border-radius:16px; overflow:hidden;">

        {[
          {
            label: 'Option A',
            title: 'Sous-traiter à un dev',
            body: 'Cher et lent. Ta marge fond. Et si le dev disparaît, c\'est toi qui gères le SAV.',
            icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
          },
          {
            label: 'Option B',
            title: 'Un page builder',
            body: 'Résultat médiocre, site lent, ton client paie un abonnement à vie. Zéro contrôle réel.',
            icon: 'M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z',
          },
          {
            label: 'Option C',
            title: 'Dire non',
            body: 'Tu perds la mission. Parfois tu perds le client entier, qui va voir quelqu\'un qui fait "tout".',
            icon: 'M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636',
          },
        ].map((opt, i) => (
          <div class="p-7 md:p-8 flex flex-col gap-4 relative" style={i < 2 ? 'border-bottom:1px solid #EDEBE8;' : ''}>
            {i > 0 && <div class="hidden md:block absolute inset-y-0 left-0 w-px" style="background:#EDEBE8;"></div>}

            <div class="flex items-center justify-between">
              <span class="text-xs font-semibold uppercase tracking-widest" style="color:#CCC; letter-spacing:0.15em;">{opt.label}</span>
              <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0" style="background:#FEF2F2;">
                <svg class="w-4 h-4" style="color:#EF4444;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d={opt.icon}/>
                </svg>
              </div>
            </div>

            <div>
              <p class="font-bold mb-1.5" style="color:#1A1A1A;">{opt.title}</p>
              <p class="text-sm leading-relaxed" style="color:#888;">{opt.body}</p>
            </div>
          </div>
        ))}

      </div>

      <!-- Résultat — bandeau sombre -->
      <div class="mt-5 flex items-center gap-5 rounded-2xl px-7 py-5" style="background:#0F0F0F;">
        <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0" style="background:rgba(232,108,71,0.15);">
          <svg class="w-4 h-4" style="color:#E86C47;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/></svg>
        </div>
        <p class="text-sm leading-relaxed" style="color:rgba(255,255,255,0.55);">
          <strong style="color:white;">Résultat :</strong> tu laisses de l'argent sur la table à chaque projet. Ou tu livres un site dont tu n'es pas fier.
        </p>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════ -->
  <!-- LA SOLUTION — 2 OFFRES -->
  <!-- ═══════════════════════════════════════ -->
  <section id="offres" class="w-full px-6 py-20 md:px-8 md:py-28" style="background: linear-gradient(180deg, #F5F4F1 0%, #FAFAF8 100%);">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-3" style="letter-spacing: 0.2em;">La solution</p>
        <h2 class="text-3xl font-bold text-[var(--color-text)] md:text-4xl">
          Deux façons de ne plus jamais dire non
        </h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)] max-w-2xl mx-auto">
          Choisis ce qui te convient : je le fais pour toi, ou je t'apprends à le faire.
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">

        <!-- OFFRE 1 — SOUS-TRAITANCE -->
        <div class="relative rounded-2xl bg-white p-8 lg:p-10 flex flex-col" style="box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04);">
          <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl" style="background: linear-gradient(90deg, #E86C47, #F5C8B3);"></div>

          <div class="mb-6">
            <span class="inline-flex items-center gap-2 px-3 py-1 bg-[var(--color-accent)]/10 text-[var(--color-accent)] text-xs font-bold uppercase tracking-wider rounded-full">
              <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
              Le plus rapide
            </span>
          </div>

          <h3 class="text-2xl font-bold text-[var(--color-text)] mb-2">Je le fais pour toi</h3>
          <p class="text-[var(--color-text-muted)] mb-6">Tu gardes la relation client et la direction artistique. Je m'occupe du code et du déploiement.</p>

          <!-- Pricing -->
          <div class="mb-6 p-5 rounded-xl bg-[var(--color-bg)]">
            <div class="flex items-baseline justify-between mb-3">
              <div>
                <span class="text-sm font-medium text-[var(--color-text-muted)]">Site one-page</span>
              </div>
              <div class="flex items-baseline gap-1">
                <span class="text-3xl font-extrabold text-[var(--color-text)]">200</span>
                <span class="text-base font-bold text-[var(--color-text)]">€</span>
                <span class="text-sm text-[var(--color-text-muted)]">HT</span>
              </div>
            </div>
            <div class="h-px bg-[var(--color-border)] my-3"></div>
            <div class="flex items-baseline justify-between">
              <div>
                <span class="text-sm font-medium text-[var(--color-text-muted)]">Multi-pages + blog</span>
              </div>
              <div class="flex items-baseline gap-1">
                <span class="text-3xl font-extrabold text-[var(--color-text)]">300</span>
                <span class="text-base font-bold text-[var(--color-text)]">€</span>
                <span class="text-sm text-[var(--color-text-muted)]">HT</span>
              </div>
            </div>
          </div>

          <!-- Features -->
          <div class="space-y-3 flex-grow mb-8">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Livré en <strong>24 à 72h</strong> selon le contenu</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]"><strong>Score Lighthouse 95+</strong> garanti (performance, SEO, accessibilité)</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]"><strong>Zéro abonnement</strong> pour ton client — hébergement quasi-gratuit</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Responsive, SEO natif, formulaire de contact</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]">Code propre — pas enfermé dans une plateforme</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-[var(--color-text)]"><strong>Tu factures ce que tu veux</strong> — la marge est pour toi</span>
            </div>
          </div>

          <div class="mt-auto">
            <a href="mailto:marc@muller.im?subject=Sous-traitance%20web%20-%20graphiste" class="block w-full py-3.5 px-5 text-center rounded-lg text-sm font-semibold text-white transition-all duration-200" style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 15px rgba(232, 108, 71, 0.4);">
              Envoyer un premier brief
            </a>
            <p class="text-center text-xs text-[var(--color-text-muted)] mt-3">Réponse sous 24h · Aucun engagement</p>
          </div>
        </div>

        <!-- OFFRE 2 — FORMATION -->
        <div id="formation" class="relative rounded-2xl p-8 lg:p-10 flex flex-col" style="background-color: #111; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4), 0 0 0 1px rgba(232, 108, 71, 0.2);">
          <div class="absolute top-0 left-0 right-0 h-1 rounded-t-2xl" style="background: linear-gradient(90deg, #E86C47, #F5C8B3);"></div>

          <div class="mb-6">
            <span class="inline-flex items-center gap-2 px-3 py-1 bg-[var(--color-accent)] text-white text-xs font-bold uppercase tracking-wider rounded-full">
              <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              Meilleur investissement
            </span>
          </div>

          <h3 class="text-2xl font-bold text-white mb-2">Je te rends autonome</h3>
          <p class="text-neutral-300 mb-6">Tu apprends à produire toi-même des sites ultra-performants. À la fin, tu ne dépends plus de personne.</p>

          <!-- Pricing -->
          <div class="mb-6 p-5 rounded-xl" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08);">
            <div class="flex items-baseline justify-between">
              <div>
                <span class="text-sm font-medium text-neutral-300">Formation complète</span>
              </div>
              <div class="flex items-baseline gap-1">
                <span class="text-3xl font-extrabold text-white">800</span>
                <span class="text-base font-bold text-white">€</span>
                <span class="text-sm text-neutral-300">HT</span>
              </div>
            </div>
            <p class="text-xs text-neutral-400 mt-2">Accompagnement individuel, adapté à ton niveau</p>
          </div>

          <!-- Features -->
          <div class="space-y-3 flex-grow mb-8">
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Autonomie totale</strong> — plus jamais besoin de sous-traiter</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>Nouvelle source de revenus</strong> — ajoute "site web" à tes prestations</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-white"><strong>ROI immédiat</strong> — dès le 1er site, la formation est amortie</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-white">Pipeline professionnel — un vrai process, pas du bricolage</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-white">Pas besoin de savoir coder — juste être à l'aise sur un ordi</span>
            </div>
            <div class="flex items-start gap-3">
              <span class="text-[var(--color-accent)] flex-shrink-0 mt-0.5 w-5 h-5" set:html={checkIcon} />
              <span class="text-sm text-white">Support après formation inclus</span>
            </div>
          </div>

          <div class="mt-auto">
            <a href="mailto:marc@muller.im?subject=Formation%20web%20-%20graphiste" class="block w-full py-3.5 px-5 text-center rounded-lg text-sm font-semibold border-2 border-[var(--color-accent)] text-[var(--color-accent)] hover:bg-[var(--color-accent)] hover:text-white transition-all duration-200">
              En savoir plus sur la formation
            </a>
            <p class="text-center text-xs text-neutral-400 mt-3">On échange d'abord, aucun engagement</p>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════ -->
  <!-- PREUVES — CHIFFRES -->
  <!-- ═══════════════════════════════════════ -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-16 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="text-center mb-12">
        <p class="text-xs font-bold uppercase tracking-widest text-[var(--color-accent)] mb-3" style="letter-spacing: 0.2em;">Résultats</p>
        <h2 class="text-3xl font-bold text-[var(--color-text)] md:text-4xl">Des sites qui performent vraiment</h2>
        <p class="mt-4 text-lg text-[var(--color-text-muted)]">Pas des promesses. Des chiffres mesurables.</p>
      </div>

      <!-- Stats grid -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mb-12">
        <div class="text-center p-6 rounded-xl bg-white border border-[var(--color-border)]">
          <div class="text-4xl font-extrabold text-[var(--color-accent)] mb-1">95+</div>
          <div class="text-sm text-[var(--color-text-muted)]">Score Lighthouse</div>
        </div>
        <div class="text-center p-6 rounded-xl bg-white border border-[var(--color-border)]">
          <div class="text-4xl font-extrabold text-[var(--color-accent)] mb-1">&lt;1s</div>
          <div class="text-sm text-[var(--color-text-muted)]">Temps de chargement</div>
        </div>
        <div class="text-center p-6 rounded-xl bg-white border border-[var(--color-border)]">
          <div class="text-4xl font-extrabold text-[var(--color-accent)] mb-1">0€</div>
          <div class="text-sm text-[var(--color-text-muted)]">Abonnement mensuel</div>
        </div>
        <div class="text-center p-6 rounded-xl bg-white border border-[var(--color-border)]">
          <div class="text-4xl font-extrabold text-[var(--color-accent)] mb-1">72h</div>
          <div class="text-sm text-[var(--color-text-muted)]">Délai max de livraison</div>
        </div>
      </div>

      <!-- Comparaison avec alternatives -->
      <div class="overflow-x-auto rounded-2xl" style="box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04);">
        <table class="w-full text-sm" style="border-collapse: separate; border-spacing: 0;">
          <thead>
            <tr>
              <th class="px-6 py-4 text-left text-xs font-bold uppercase tracking-wider text-[var(--color-text-muted)] bg-white rounded-tl-2xl" style="width: 30%;"></th>
              <th class="px-4 py-4 text-center" style="background-color: #111;">
                <span class="block text-sm font-bold text-white">Avec moi</span>
              </th>
              <th class="px-4 py-4 text-center bg-white">
                <span class="block text-sm font-bold text-[var(--color-text-muted)]">Dev freelance</span>
              </th>
              <th class="px-4 py-4 text-center bg-white rounded-tr-2xl">
                <span class="block text-sm font-bold text-[var(--color-text-muted)]">Wix / Squarespace</span>
              </th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td class="px-6 py-3.5 font-medium text-[var(--color-text)] bg-white" style="border-top: 1px solid #f0f0f0;">Prix one-page</td>
              <td class="px-4 py-3.5 text-center font-bold" style="background-color: #111; border-top: 1px solid #222; color: #E86C47;">200€</td>
              <td class="px-4 py-3.5 text-center text-[var(--color-text-muted)] bg-white" style="border-top: 1px solid #f0f0f0;">800 — 2 000€</td>
              <td class="px-4 py-3.5 text-center text-[var(--color-text-muted)] bg-white" style="border-top: 1px solid #f0f0f0;">15€/mois à vie</td>
            </tr>
            <tr>
              <td class="px-6 py-3.5 font-medium text-[var(--color-text)]" style="background: #FAFAFA; border-top: 1px solid #f0f0f0;">Délai</td>
              <td class="px-4 py-3.5 text-center font-bold text-white" style="background-color: #111; border-top: 1px solid #222;">24 — 72h</td>
              <td class="px-4 py-3.5 text-center text-[var(--color-text-muted)]" style="background: #FAFAFA; border-top: 1px solid #f0f0f0;">2 — 4 semaines</td>
              <td class="px-4 py-3.5 text-center text-[var(--color-text-muted)]" style="background: #FAFAFA; border-top: 1px solid #f0f0f0;">Tu le fais toi-même</td>
            </tr>
            <tr>
              <td class="px-6 py-3.5 font-medium text-[var(--color-text)] bg-white" style="border-top: 1px solid #f0f0f0;">Performance</td>
              <td class="px-4 py-3.5 text-center font-bold text-white" style="background-color: #111; border-top: 1px solid #222;">Lighthouse 95+</td>
              <td class="px-4 py-3.5 text-center text-[var(--color-text-muted)] bg-white" style="border-top: 1px solid #f0f0f0;">Variable</td>
              <td class="px-4 py-3.5 text-center text-[var(--color-text-muted)] bg-white" style="border-top: 1px solid #f0f0f0;">50 — 70</td>
            </tr>
            <tr>
