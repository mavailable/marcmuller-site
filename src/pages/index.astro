<style>
  /* ── Blobs ── */
  .hero-blob {
    scale: 0;
    animation: blobIn 1.4s cubic-bezier(0.16, 1, 0.3, 1) var(--blob-delay, 0s) forwards;
  }
  @keyframes blobIn {
    0% { scale: 0; opacity: 0; }
    100% { scale: 1; opacity: var(--blob-opacity, 0.06); }
  }

  /* ── H1 reveal — clip mask from bottom ── */
  .hero-reveal {
    clip-path: inset(100% 0 0 0);
    animation: clipReveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) 0.1s forwards;
  }
  @keyframes clipReveal {
    0% { clip-path: inset(100% 0 0 0); }
    100% { clip-path: inset(0 0 0 0); }
  }

  /* ── Accent text ── */
  .hero-accent-text {
    background: linear-gradient(135deg, #E86C47 0%, #FF8A65 50%, #E86C47 100%);
    background-size: 200% auto;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: shimmer 5s ease-in-out 2s infinite;
  }
  @keyframes shimmer {
    0%, 100% { background-position: 0% center; }
    50% { background-position: 200% center; }
  }

  /* ── Generic fade ── */
  .hero-fade {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) var(--hero-delay, 0.4s) forwards;
  }
  @keyframes fadeUp {
    to { opacity: 1; transform: none; }
  }

  /* ── CTA — entrance + glow pulse ── */
  .hero-cta {
    opacity: 0;
    transform: translateY(16px);
    animation:
      fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) 0.45s forwards,
      ctaGlow 0.8s ease-in-out 1.3s both;
    box-shadow: 0 4px 24px rgba(232, 108, 71, 0.2);
  }
  .hero-cta:hover {
    box-shadow: 0 8px 32px rgba(232, 108, 71, 0.35);
  }
  @keyframes ctaGlow {
    0%, 100% { box-shadow: 0 4px 24px rgba(232, 108, 71, 0.2); }
    50% { box-shadow: 0 4px 48px rgba(232, 108, 71, 0.45), 0 0 80px rgba(232, 108, 71, 0.12); }
  }

  /* ── Desktop showcase — 3D coverflow ── */
  .hero-showcase {
    opacity: 0;
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.6s forwards;
  }

  .hero-card {
    opacity: 0;
    animation: cardIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) var(--card-delay, 0.6s) forwards;
    will-change: transform;
  }
  .hero-card:hover {
    z-index: 30 !important;
  }

  /* Center card — front, largest */
  .hero-card-center {
    transform: translateZ(0) scale(1);
  }
  @keyframes cardIn {
    0% { opacity: 0; transform: translateY(60px) scale(0.9); }
    100% { opacity: 1; transform: translateY(0) scale(1); }
  }

  /* Left card */
  .hero-card-left {
    left: 0;
    bottom: 10px;
    transform: translateX(0) rotateY(4deg) scale(0.92);
  }
  .hero-card-left.hero-card { /* specificity override for final state */
    animation-name: cardInLeft;
  }
  @keyframes cardInLeft {
    0% { opacity: 0; transform: translateX(-40px) translateY(50px) rotateY(8deg) scale(0.85); }
    100% { opacity: 1; transform: translateX(0) rotateY(4deg) scale(0.92); }
  }

  /* Right card */
  .hero-card-right {
    right: 0;
    bottom: 10px;
    transform: translateX(0) rotateY(-4deg) scale(0.92);
  }
  .hero-card-right.hero-card {
    animation-name: cardInRight;
  }
  @keyframes cardInRight {
    0% { opacity: 0; transform: translateX(40px) translateY(50px) rotateY(-8deg) scale(0.85); }
    100% { opacity: 1; transform: translateX(0) rotateY(-4deg) scale(0.92); }
  }

  /* Center card position */
  .hero-card-center {
    left: 50%;
    bottom: 0;
    margin-left: -210px; /* half of 420px width */
  }

  /* Hover lift */
  .hero-card:hover {
    transform: translateY(-8px) scale(1) rotateY(0deg) !important;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Subtle float — desktop only */
  @media (min-width: 768px) {
    .hero-card-center { animation: cardIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) var(--card-delay) forwards, floatCenter 6s ease-in-out 1.6s infinite; }
    .hero-card-left   { animation: cardInLeft 0.8s cubic-bezier(0.16, 1, 0.3, 1) var(--card-delay) forwards, floatSide 7s ease-in-out 1.8s infinite; }
    .hero-card-right  { animation: cardInRight 0.8s cubic-bezier(0.16, 1, 0.3, 1) var(--card-delay) forwards, floatSide 7s ease-in-out 2s infinite; }

    @keyframes floatCenter {
      0%, 100% { transform: translateY(0) scale(1); }
      50% { transform: translateY(-8px) scale(1); }
    }
    @keyframes floatSide {
      0%, 100% { transform: translateY(0) rotateY(var(--ry, 4deg)) scale(0.92); }
      50% { transform: translateY(-6px) rotateY(var(--ry, 4deg)) scale(0.92); }
    }
    .hero-card-left { --ry: 4deg; }
    .hero-card-right { --ry: -4deg; }
  }

  /* ── Mobile carousel ── */
  .mobile-track {
    will-change: transform;
  }
  .carousel-item.active {
    border-color: rgba(232, 108, 71, 0.4);
    box-shadow: 0 0 30px rgba(232, 108, 71, 0.15), 0 8px 30px rgba(0,0,0,0.5);
    transform: scale(1.03);
  }
  .carousel-item.active img {
    transform: scale(1.04);
  }
  .carousel-item.active .carousel-overlay {
    opacity: 1;
    pointer-events: auto;
  }

  /* ── Utilities ── */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fadeIn {
    animation: fadeIn 0.6s ease-out forwards;
    opacity: 0;
  }
</style>

<script>
  // Intersection Observer pour les animations au scroll
  const observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('animate-in');
      }
    });
  }, observerOptions);

  // Observer sur les éléments count-up
  document.querySelectorAll('.count-up').forEach((el) => {
    observer.observe(el);
  });

  // Animation des chiffres
  document.querySelectorAll('.count-up').forEach((element) => {
    const targetText = element.getAttribute('data-target');
    const target = parseInt(targetText);

    const originalObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting && !element.classList.contains('counted')) {
          element.classList.add('counted');
          animateCount(element, target, 1500);
          originalObserver.unobserve(element);
        }
      });
    }, observerOptions);

    originalObserver.observe(element);
  });

  function animateCount(element: HTMLElement, target: number, duration: number) {
    const startTime = Date.now();
    const startValue = 0;

    const animate = () => {
      const now = Date.now();
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);

      const current = Math.floor(startValue + (target - startValue) * progress);
      element.textContent = current.toString();

      if (progress < 1) {
        requestAnimationFrame(animate);
      } else {
        element.textContent = target.toString();
      }
    };

    animate();
  }

  // FAQ accordion tracking
  document.querySelectorAll('details').forEach((el) => {
    el.addEventListener('toggle', () => {
      if (el.open) {
        const question = el.querySelector('summary')?.textContent?.trim() || '';
        if (typeof umami !== 'undefined') {
          umami.track('faq-open', { question: question.slice(0, 80) });
        }
      }
    });
  });

  // ── Mobile carousel: JS-driven scroll + tap to pause ──
  const track = document.getElementById('mobile-track') as HTMLElement | null;
  const resumeBtn = document.getElementById('carousel-resume');
  const items = document.querySelectorAll<HTMLElement>('.carousel-item');

  if (track) {
    let offset = 0;
    let paused = false;
    let activeCard: HTMLElement | null = null;
    const speed = 0.7; // px per frame (~42px/s at 60fps)
    const halfWidth = track.scrollWidth / 2;

    function tick() {
      if (!paused) {
        offset -= speed;
        if (Math.abs(offset) >= halfWidth) offset = 0;
        track!.style.transform = `translateX(${offset}px)`;
      }
      requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);

    function pauseOn(card: HTMLElement) {
      if (activeCard) activeCard.classList.remove('active');
      paused = true;
      card.classList.add('active');
      activeCard = card;
      // Set the CTA link href
      const link = card.querySelector('.carousel-overlay a');
      if (link) link.setAttribute('href', card.dataset.url || '/realisations');
      // Show resume button
      resumeBtn?.classList.remove('hidden');
      resumeBtn?.classList.add('flex');
    }

    function resume() {
      if (activeCard) activeCard.classList.remove('active');
      activeCard = null;
      paused = false;
      resumeBtn?.classList.add('hidden');
      resumeBtn?.classList.remove('flex');
    }

    items.forEach(card => {
      card.addEventListener('click', (e) => {
        // Let the CTA link work normally
        if ((e.target as HTMLElement).closest('.carousel-overlay a')) return;
        if (card.classList.contains('active')) {
          resume();
        } else {
          pauseOn(card);
        }
      });
    });

    resumeBtn?.addEventListener('click', resume);
  }
</script>
