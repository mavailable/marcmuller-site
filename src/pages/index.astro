---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionTitle from '../components/SectionTitle.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';
import { getProjectsForCarousel } from '../data/projects';

const { sitesRealises, sitesTotal } = business;
const progressPercent = Math.round((sitesRealises / sitesTotal) * 100);

// Projets pour le hero carousel (2 colonnes, dupliqués pour scroll infini)
const heroProjects = getProjectsForCarousel('homepage').map(p => ({
  img: p.screenshot,
  name: p.title,
  sub: `${p.sector}`,
  id: p.id,
  score: true,
}));
const col1 = [...heroProjects, ...heroProjects]; // dupliqué pour scroll infini
const col2 = [...heroProjects.slice(3), ...heroProjects.slice(0, 3), ...heroProjects.slice(3), ...heroProjects.slice(0, 3)];

const faqItems = [
  {
    question: "Combien coûte un site web ?",
    answer: "À partir de 490 € pour un site one-page. Multi-pages dès 1 290 €, sur mesure dès 1 990 €. Hébergement, nom de domaine et maintenance inclus pendant 1 an."
  },
  {
    question: "Combien de temps pour créer un site ?",
    answer: "En moyenne 7 jours ouvrés pour un site Essentiel, 10 à 14 jours pour un Multi-pages. Chaque projet démarre par un appel découverte gratuit."
  },
  {
    question: "Vous travaillez avec WordPress ?",
    answer: "Non, j'utilise Astro, un framework moderne bien plus rapide et sécurisé. Résultat : un site qui charge en moins d'une seconde et qui plaît à Google."
  },
  {
    question: "Est-ce que le SEO est inclus ?",
    answer: "Oui. Chaque site est optimisé dès la conception : balisage sémantique, performance, données structurées, et référencement local. Le SEO technique est inclus dans toutes les formules."
  },
  {
    question: "Vous intervenez uniquement dans le Grand Est ?",
    answer: "Je suis basé à Metz mais je travaille avec des clients partout en France. Tout se fait à distance : appel découverte, échanges par email et visio."
  }
];
---

<BaseLayout
  title="Marc M — Sites web sur mesure pour artisans et petits commerces"
  description="Créateur de sites web performants et référencés pour artisans, petits commerces et entrepreneurs du Grand Est. Rapides, bien SEO, qui ramènent des clients."
  lang="fr"
  frPath="/"
  enPath="/en/"
>
  <SchemaOrg type="person" />
  <SchemaOrg type="localBusiness" />
  <SchemaOrg type="faqPage" data={faqItems} />
  <!-- HERO -->
  <section class="relative w-full min-h-screen flex items-center overflow-hidden bg-[#0D0D0D]">
    <!-- Animated gradient blobs -->
    <div class="absolute top-[20%] left-[15%] w-[500px] h-[500px] rounded-full bg-[var(--color-accent)] opacity-[0.08] blur-[150px] hero-blob-1"></div>
    <div class="absolute bottom-[10%] right-[10%] w-[400px] h-[400px] rounded-full bg-[#4F46E5] opacity-[0.05] blur-[130px] hero-blob-2"></div>
    <div class="absolute top-[60%] left-[50%] w-[300px] h-[300px] rounded-full bg-[var(--color-accent)] opacity-[0.04] blur-[100px] hero-blob-3"></div>

    <!-- Noise texture overlay -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

    <!-- Dot grid pattern -->
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px); background-size: 32px 32px;"></div>

    <div class="relative mx-auto max-w-7xl px-6 py-20 md:px-8 w-full">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-8 items-center">
        <!-- Left: Text content -->
        <div class="hero-content">
          <!-- Badge -->
          <div class="hero-badge mb-8 inline-flex items-center gap-3 rounded-full border border-emerald-400/20 bg-emerald-400/[0.06] px-5 py-2.5 text-sm backdrop-blur-md hero-fade hero-fade-1">
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-emerald-400 opacity-75"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-emerald-400"></span>
            </span>
            <span style="color: rgba(255,255,255,0.8);">Disponible pour nouveaux projets</span>
          </div>

          <h1 class="mb-8 text-[2.75rem] md:text-6xl lg:text-[4.25rem] font-bold leading-[1.08] tracking-[-0.03em] text-white hero-fade hero-fade-2">
            Vous faites un bon boulot.
            <span class="hero-accent-text">Faites-le savoir.</span>
          </h1>

          <p class="mb-10 text-lg md:text-xl leading-relaxed text-neutral-400 max-w-xl hero-fade hero-fade-3">
            Votre prochain client vous cherche sur Google en ce moment. Sites web sur mesure pour artisans et petits commerces — rapides, bien référencés, qui convertissent.
          </p>

          <div class="flex flex-col gap-4 sm:flex-row hero-fade hero-fade-4">
            <a href="/contact" class="hero-cta-primary group inline-flex items-center justify-center rounded-xl bg-accent px-8 py-4 text-base font-semibold text-white shadow-[0_4px_20px_rgba(232,108,71,0.25)] transition-all duration-300 hover:bg-accent-hover hover:shadow-[0_8px_30px_rgba(232,108,71,0.35)] hover:-translate-y-0.5" data-umami-event="hero-cta-click">
              Parlons de votre projet
              <svg class="ml-2 h-5 w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" role="presentation"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
            <a href="/realisations" class="hero-cta-ghost group inline-flex items-center justify-center rounded-xl border border-white/20 bg-white/5 px-8 py-4 text-base font-semibold text-white/85 transition-all duration-300 backdrop-blur-sm hover:bg-white/10 hover:border-white/30 hover:text-white">
              Voir mes réalisations
              <svg class="ml-2 h-4 w-4 transition-transform duration-300 group-hover:translate-x-1 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true" role="presentation"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
            </a>
          </div>

          <!-- Trust indicators -->
          <div class="mt-14 flex flex-wrap items-center gap-3 hero-fade hero-fade-5">
            <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
              <svg class="h-4 w-4 shrink-0" fill="#34D399" viewBox="0 0 20 20" aria-hidden="true" role="presentation"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              <span style="color: rgba(255,255,255,0.75);">Livrés en 7 jours</span>
            </div>
            <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
              <svg class="h-4 w-4 shrink-0" fill="#34D399" viewBox="0 0 20 20" aria-hidden="true" role="presentation"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              <span style="color: rgba(255,255,255,0.75);">À partir de 490€</span>
            </div>
            <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
              <svg class="h-4 w-4 shrink-0" fill="#34D399" viewBox="0 0 20 20" aria-hidden="true" role="presentation"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path></svg>
              <span style="color: rgba(255,255,255,0.75);">Devis gratuit</span>
            </div>
          </div>
        </div>

        <!-- Right: Défilé interactif de réalisations -->
        <div class="relative hidden lg:block hero-fade hero-fade-3" style="height: 580px; overflow: hidden;">

          <!-- Fade top -->
          <div class="pointer-events-none absolute inset-x-0 top-0 z-10 h-24" style="background: linear-gradient(to bottom, #0D0D0D 30%, transparent 100%);"></div>
          <!-- Fade bottom -->
          <div class="pointer-events-none absolute inset-x-0 bottom-0 z-10 h-32" style="background: linear-gradient(to top, #0D0D0D 40%, transparent 100%);"></div>

          <div class="flex gap-4 h-full">

            <!-- Colonne 1 — monte lentement -->
            <div class="flex flex-1 flex-col gap-4 hero-scroll-up-slow">
              {col1.map((p) => (
                <a href={`/realisations#${p.id}`} class="group/card shrink-0 block overflow-hidden rounded-2xl border border-white/[0.07] bg-white/[0.02] shadow-xl shadow-black/40 transition-all duration-300 hover:-translate-y-1 hover:border-white/20 hover:shadow-black/60">
                  <div class="relative overflow-hidden">
                    <img src={p.img} alt={p.name} width="280" height="155" class="h-[155px] w-full object-cover object-top transition-transform duration-500 group-hover/card:scale-[1.04]" loading="lazy" />
                    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);"></div>
                    {p.score && (
                      <div class="absolute left-3 top-3 flex items-center gap-1.5 rounded-full border border-emerald-500/25 bg-black/50 px-2.5 py-1 backdrop-blur-sm">
                        <div class="h-1.5 w-1.5 rounded-full bg-emerald-400"></div>
                        <span class="text-[10px] font-bold text-emerald-400">100</span>
                      </div>
                    )}
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover/card:opacity-100">
                      <span class="rounded-full bg-white/15 px-4 py-1.5 text-xs font-semibold text-white backdrop-blur-sm border border-white/20">
                        Voir le projet →
                      </span>
                    </div>
                    <div class="absolute inset-x-0 bottom-0 px-3 pb-3">
                      <p class="text-sm font-semibold text-white leading-tight truncate">{p.name}</p>
                      <p class="text-[11px] text-white/70 truncate">{p.sub}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>

            <!-- Colonne 2 — monte plus vite, décalée -->
            <div class="flex flex-1 flex-col gap-4 hero-scroll-up-fast" style="margin-top: 70px;">
              {col2.map((p) => (
                <a href={`/realisations#${p.id}`} class="group/card shrink-0 block overflow-hidden rounded-2xl border border-white/[0.07] bg-white/[0.02] shadow-xl shadow-black/40 transition-all duration-300 hover:-translate-y-1 hover:border-white/20 hover:shadow-black/60">
                  <div class="relative overflow-hidden">
                    <img src={p.img} alt={p.name} width="280" height="155" class="h-[155px] w-full object-cover object-top transition-transform duration-500 group-hover/card:scale-[1.04]" loading="lazy" />
                    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.82) 0%, rgba(0,0,0,0.1) 50%, transparent 100%);"></div>
                    {p.score && (
                      <div class="absolute left-3 top-3 flex items-center gap-1.5 rounded-full border border-emerald-500/25 bg-black/50 px-2.5 py-1 backdrop-blur-sm">
                        <div class="h-1.5 w-1.5 rounded-full bg-emerald-400"></div>
                        <span class="text-[10px] font-bold text-emerald-400">100</span>
                      </div>
                    )}
                    <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover/card:opacity-100">
                      <span class="rounded-full bg-white/15 px-4 py-1.5 text-xs font-semibold text-white backdrop-blur-sm border border-white/20">
                        Voir le projet →
                      </span>
                    </div>
                    <div class="absolute inset-x-0 bottom-0 px-3 pb-3">
                      <p class="text-sm font-semibold text-white leading-tight truncate">{p.name}</p>
                      <p class="text-[11px] text-white/70 truncate">{p.sub}</p>
                    </div>
                  </div>
                </a>
              ))}
            </div>

          </div>

          <!-- Badge flottant -->
          <a href="/realisations" class="absolute bottom-6 left-1/2 z-20 -translate-x-1/2 transition-transform hover:-translate-y-0.5 hover:-translate-x-1/2">
            <div class="flex items-center gap-2 rounded-full border border-white/10 bg-black/70 px-5 py-2.5 backdrop-blur-md shadow-lg">
              <span class="text-xs font-medium text-white/70">{sitesRealises} projets livrés</span>
              <span class="text-white/15">·</span>
              <div class="flex items-center gap-1.5">
                <div class="h-1.5 w-1.5 rounded-full bg-emerald-400"></div>
                <span class="text-xs font-semibold text-emerald-400">Lighthouse 100</span>
              </div>
              <svg class="h-3 w-3 text-white/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-neutral-500 hero-fade hero-fade-5">
      <span class="text-xs tracking-widest uppercase">Défiler</span>
      <div class="w-5 h-8 rounded-full border border-white/20 flex justify-center pt-1.5">
        <div class="w-1 h-2 rounded-full bg-white/40 animate-bounce"></div>
      </div>
    </div>
  </section>

  <!-- DÉFI DU MOMENT — 100 Vitrines -->
  <section class="w-full relative overflow-hidden" style="background: linear-gradient(135deg, #1A1A1A 0%, #111111 100%);">
    <!-- Accent glow -->
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[200px] rounded-full blur-[120px]" style="background: rgba(232, 108, 71, 0.12);"></div>

    <div class="relative mx-auto max-w-6xl px-6 py-12 md:px-8 md:py-16">
      <div class="flex flex-col md:flex-row items-center gap-8 md:gap-12">

        <!-- Left: Badge + Texte -->
        <div class="flex-1 text-center md:text-left">
          <div class="mb-4 inline-flex items-center gap-2.5 rounded-full px-4 py-1.5 text-xs font-semibold uppercase tracking-widest" style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.25); color: #E86C47;">
            <span class="relative flex h-2 w-2">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style="background: #E86C47;"></span>
              <span class="relative inline-flex h-2 w-2 rounded-full" style="background: #E86C47;"></span>
            </span>
            Défi en cours
          </div>
          <h2 class="mb-3 text-2xl md:text-3xl font-bold text-white leading-tight">
            100 Vitrines pour 100 Artisans.
            <span class="block text-base md:text-lg font-normal mt-1" style="color: rgba(255,255,255,0.7);">Gratuit. Vrai. Sans engagement.</span>
          </h2>
          <p class="text-sm md:text-base leading-relaxed max-w-xl mx-auto md:mx-0" style="color: rgba(255,255,255,0.75);">
            Je crée gratuitement 100 sites web professionnels pour des artisans sans présence en ligne. Création, hébergement et domaine offerts la première année.
          </p>
        </div>

        <!-- Right: Compteur + CTA -->
        <div class="flex flex-col items-center gap-5 flex-shrink-0">
          <!-- Progress -->
          <div class="text-center">
            <div class="flex items-baseline gap-1 justify-center">
              <span class="text-5xl font-extrabold" style="color: #E86C47;">{sitesRealises}</span>
              <span class="text-xl font-bold text-white/70">/{sitesTotal}</span>
            </div>
            <p class="mt-1 text-xs text-white/70 uppercase tracking-widest">sites réalisés</p>
            <div class="mt-3 w-48 bg-white/10 rounded-full h-1.5">
              <div class="h-1.5 rounded-full transition-all duration-1000" style={`width: ${progressPercent === 0 ? 0.5 : progressPercent}%; background: linear-gradient(90deg, #E86C47, #FF8A65);`}></div>
            </div>
          </div>

          <a
            href="/100-sites-artisans"
            class="group inline-flex items-center justify-center gap-2 rounded-xl px-7 py-3.5 text-sm font-semibold text-white transition-all duration-300 hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, #E86C47, #D4572F); box-shadow: 0 4px 20px rgba(232, 108, 71, 0.3);"
          >
            Je candidate
            <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
            </svg>
          </a>
          <a href="/100-sites-artisans" class="text-xs underline-offset-2 hover:underline" style="color: rgba(255,255,255,0.6); text-decoration: none;" onmouseover="this.style.textDecoration='underline'" onmouseout="this.style.textDecoration='none'">
            En savoir plus sur l'initiative →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- PROBLÈME — 2 colonnes : accroche + pain points -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-20 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-[1fr_1.2fr] md:gap-16 items-start">

        <!-- Colonne gauche — accroche sticky -->
        <div class="md:sticky md:top-28">
          <p class="text-[var(--color-accent)] font-semibold text-sm tracking-wide uppercase mb-4">Le constat</p>
          <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] leading-tight">
            Vous avez un <span class="text-[var(--color-accent)]">vrai métier</span>.
          </h2>
          <p class="mt-3 text-[var(--color-text-muted)] text-lg leading-relaxed">
            Votre site devrait travailler aussi dur que vous. Pourtant...
          </p>
          <div class="mt-8 hidden md:block">
            <p class="text-[var(--color-text-muted)]">
              Et si votre site devenait votre <span class="font-semibold text-[var(--color-text)]">meilleur commercial</span> ?
            </p>
            <a href="#methode" class="mt-3 inline-flex items-center gap-2 text-[var(--color-accent)] font-semibold text-sm hover:underline transition-colors">
              Voir comment on travaille
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
            </a>
          </div>
        </div>

        <!-- Colonne droite — pain points -->
        <div class="space-y-4">
          <div class="group rounded-2xl border-l-4 border-l-red-400 bg-white px-6 py-5 shadow-sm transition-all duration-300 hover:shadow-md">
            <h3 class="text-[17px] font-bold text-[var(--color-text)] group-hover:text-red-500 transition-colors">
              Votre site WordPress rame et vous coûte cher
            </h3>
            <p class="mt-1.5 text-[var(--color-text-muted)] leading-relaxed text-[15px]">
              Plugins à mettre à jour, cache qui ne suffit pas, hébergement qui grimpe. <span class="font-medium text-[var(--color-text)]">3 secondes de chargement = 53% de visiteurs perdus.</span>
            </p>
          </div>

          <div class="group rounded-2xl border-l-4 border-l-amber-400 bg-white px-6 py-5 shadow-sm transition-all duration-300 hover:shadow-md">
            <h3 class="text-[17px] font-bold text-[var(--color-text)] group-hover:text-amber-600 transition-colors">
              Vous n'avez pas de site et perdez des clients
            </h3>
            <p class="mt-1.5 text-[var(--color-text-muted)] leading-relaxed text-[15px]">
              Vos concurrents apparaissent sur Google. Pas vous. <span class="font-medium text-[var(--color-text)]">Chaque jour sans site, c'est du chiffre en moins.</span>
            </p>
          </div>

          <div class="group rounded-2xl border-l-4 border-l-[var(--color-accent)] bg-white px-6 py-5 shadow-sm transition-all duration-300 hover:shadow-md">
            <h3 class="text-[17px] font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
              Votre site est générique et ne vous ressemble pas
            </h3>
            <p class="mt-1.5 text-[var(--color-text-muted)] leading-relaxed text-[15px]">
              Template vu mille fois, couleurs par défaut, zéro personnalité. <span class="font-medium text-[var(--color-text)]">Les visiteurs repartent sans se souvenir de vous.</span>
            </p>
          </div>
        </div>

      </div>

      <!-- CTA mobile (visible uniquement en mobile) -->
      <div class="mt-10 text-center md:hidden">
        <p class="text-[var(--color-text-muted)]">
          Et si votre site devenait votre <span class="font-semibold text-[var(--color-text)]">meilleur commercial</span> ?
        </p>
        <a href="#methode" class="mt-3 inline-flex items-center gap-2 text-[var(--color-accent)] font-semibold text-sm hover:underline transition-colors">
          Voir comment on travaille
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- PREUVE SOCIALE -->
  <section class="w-full bg-white px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">Ça marche</h2><p class="text-center text-[var(--color-text-muted)] mb-16 text-lg">Des chiffres, pas des promesses.</p>
      <div class="grid gap-12 md:grid-cols-3">
        <div class="text-center">
          <div class="mb-3 text-6xl font-bold text-[var(--color-accent)]"><span class="count-up" data-target="12">0</span><span class="text-3xl">+</span></div>
          <p class="text-[var(--color-text-muted)]">Projets livrés et en production</p>
        </div>
        <div class="text-center">
          <div class="mb-3 text-4xl font-bold text-[var(--color-accent)]">7<span class="text-2xl">j</span></div>
          <p class="text-[var(--color-text-muted)]">Délai moyen du brief à la mise en ligne</p>
        </div>
        <div class="text-center">
