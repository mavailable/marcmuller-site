---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
import SectionTitle from '../components/SectionTitle.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';
import { getProjectsForCarousel } from '../data/projects';

const { sitesRealises } = business;

// Projets pour le hero
const heroProjects = getProjectsForCarousel('homepage').map(p => ({
  img: p.screenshot,
  name: p.title,
  sub: p.sector,
  id: p.id,
  url: p.url,
}));

const faqItems = [
  {
    question: "Combien coûte un site web ?",
    answer: "490€ pour un Site Vitrine professionnel, livré en 7 jours. Projets plus complexes (multi-pages, blog, fonctionnalités métier) sur devis. Hébergement et domaine offerts."
  },
  {
    question: "Combien de temps pour créer un site ?",
    answer: "7 jours ouvrés pour un Site Vitrine. 2 à 4 semaines pour un Projet Sur Mesure. Chaque projet inclut un appel de cadrage."
  },
  {
    question: "Vous travaillez avec WordPress ?",
    answer: "Non, j'utilise Astro, un framework moderne bien plus rapide et sécurisé. Résultat : un site qui charge en moins d'une seconde et qui plaît à Google."
  },
  {
    question: "Est-ce que le SEO est inclus ?",
    answer: "Oui. Chaque site est optimisé dès la conception : balisage sémantique, performance, données structurées, et référencement local. Le SEO technique est inclus dans toutes les formules."
  },
  {
    question: "Je ne sais pas quoi écrire sur mon site, c'est un problème ?",
    answer: "Pas du tout. Je rédige tous vos textes à partir d'un court échange de 15 minutes. Vous me parlez de votre métier, je m'occupe du reste : accroches, descriptions, page à propos, FAQ. Vous validez, c'est tout."
  },
  {
    question: "Puis-je modifier mon site moi-même après ?",
    answer: "Oui. Votre site inclut un espace d'édition simple où vous changez vos textes, photos et horaires — c'est aussi facile que poster sur Facebook. Pas besoin de toucher au code."
  },
  {
    question: "C'est pour qui exactement ?",
    answer: "Artisans, commerçants, thérapeutes, photographes, freelances, coachs, associations — toute activité qui a besoin d'un site professionnel sans se ruiner ni y passer des semaines."
  },
  {
    question: "Vous intervenez uniquement dans le Grand Est ?",
    answer: "Je suis basé à Metz mais je travaille avec des clients partout en France. Tout se fait à distance : appel découverte, échanges par email et visio."
  },
  {
    question: "Vous avez déjà un site ?",
    answer: "Oui, je gère la transition. Je reprends votre nom de domaine, je redirige l'ancien site vers le nouveau pour préserver votre référencement Google, et je récupère votre contenu existant (textes, photos). Vous ne perdez rien."
  },
  {
    question: "Un seul aller-retour de corrections, c'est suffisant ?",
    answer: "Un aller-retour = une liste complète de modifications, pas une seule correction. Vous me faites tous vos retours en une fois, je corrige tout. Dans les faits, mes clients valident généralement du premier coup parce que l'appel de cadrage en amont permet de bien cibler vos attentes."
  },
  {
    question: "Pas à l'aise avec la technique ?",
    answer: "Aucun souci. Vous me donnez 15 minutes au téléphone, je fais tout le reste. Rien à installer, rien à configurer, rien à gérer. Vous recevez un site fini, prêt à l'emploi."
  }
];
---

<BaseLayout
  title="Marc M — Site web professionnel à 490€, livré en 7 jours"
  description="Site web sur mesure à 490€. Design unique, référencé Google & IA, Lighthouse 100, livré en 7 jours. Achat en ligne. Projets complexes sur devis."
  lang="fr"
  frPath="/"
  enPath="/en/"
>
  <SchemaOrg type="person" />
  <SchemaOrg type="localBusiness" />
  <SchemaOrg type="faqPage" data={faqItems} />
  <!-- HERO -->
  <section class="relative w-full overflow-hidden bg-[#0D0D0D]">
    <!-- Blobs -->
    <div class="absolute top-[15%] left-[10%] w-[600px] h-[600px] rounded-full bg-[var(--color-accent)] blur-[180px] hero-blob" style="--blob-delay: 0s; --blob-opacity: 0.07;"></div>
    <div class="absolute bottom-[5%] right-[5%] w-[500px] h-[500px] rounded-full bg-[#4F46E5] blur-[160px] hero-blob" style="--blob-delay: 0.15s; --blob-opacity: 0.04;"></div>

    <!-- Noise -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E');"></div>

    <div class="relative mx-auto max-w-6xl px-6 pt-16 pb-10 md:pt-28 md:pb-20 lg:pt-36 lg:pb-24 w-full">

      <!-- ── Text — centered ── -->
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-[2.5rem] md:text-[3.75rem] lg:text-[4.5rem] font-bold leading-[1.06] tracking-[-0.035em] text-white hero-reveal">
          Votre site pro,<br>
          <span class="hero-accent-text">livré en 7 jours.</span>
        </h1>

        <p class="mt-5 md:mt-8 text-[15px] md:text-lg text-neutral-400 leading-relaxed max-w-md mx-auto hero-fade" style="--hero-delay: 0.35s;">
          Design sur mesure, visible sur Google et les IA. Je m'occupe de tout — design, textes, mise en ligne. <span class="text-white font-medium">490€.</span>
        </p>

        <div class="mt-6 md:mt-10 flex flex-row items-center justify-center gap-3 md:gap-4">
          <a href="/commander" class="hero-cta group inline-flex items-center justify-center rounded-xl bg-accent px-6 py-3.5 md:px-8 md:py-4 text-[15px] md:text-base font-semibold text-white transition-all duration-300 hover:-translate-y-0.5" data-umami-event="hero-cta-click">
            Commander — 490€
            <svg class="ml-2 h-4 w-4 md:h-5 md:w-5 transition-transform duration-300 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
          </a>
          <a href="/contact" class="hero-fade inline-flex items-center justify-center rounded-xl border border-white/15 bg-white/[0.03] px-6 py-3.5 md:px-8 md:py-4 text-[15px] md:text-base font-semibold text-white/80 transition-all duration-300 hover:bg-white/[0.07] hover:text-white" style="--hero-delay: 0.5s;">
            Discuter d'un projet
          </a>
        </div>
      </div>

      <!-- ── Showcase — Desktop: 3D coverflow · Mobile: scroll ── -->
      <div class="mt-10 md:mt-20">

        <!-- Desktop coverflow -->
        <div class="hidden md:block hero-showcase" style="perspective: 1400px;">
          <div class="relative mx-auto flex items-end justify-center" style="height: 340px; max-width: 900px;">
            {heroProjects.slice(0, 3).map((p, i) => (
              <a
                href={`/realisations#${p.id}`}
                class={`hero-card group/card absolute overflow-hidden rounded-2xl border border-white/[0.08] shadow-2xl shadow-black/50 transition-all duration-500 hover:shadow-black/70 ${i === 1 ? 'hero-card-center z-20' : i === 0 ? 'hero-card-left z-10' : 'hero-card-right z-10'}`}
                style={`--card-delay: ${i === 1 ? '0.5' : i === 0 ? '0.65' : '0.8'}s;`}
                data-umami-event="hero-project-click"
                data-umami-event-project={p.id}
              >
                <div class="relative overflow-hidden">
                  <img
                    src={p.img}
                    alt={p.name}
                    width={i === 1 ? 420 : 340}
                    height={i === 1 ? 235 : 190}
                    class={`w-full object-cover object-top transition-transform duration-700 group-hover/card:scale-[1.03] ${i === 1 ? 'h-[235px]' : 'h-[190px]'}`}
                    style={`width: ${i === 1 ? '420px' : '340px'};`}
                    loading="eager"
                  />
                  <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);"></div>
                  <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover/card:opacity-100" style="background: rgba(0,0,0,0.3);">
                    <span class="rounded-full bg-white/15 px-5 py-2 text-sm font-medium text-white backdrop-blur-sm border border-white/20">
                      Voir le site →
                    </span>
                  </div>
                  <div class="absolute inset-x-0 bottom-0 px-4 pb-3">
                    <p class="text-sm font-semibold text-white truncate">{p.name}</p>
                    <p class="text-xs text-white/50 truncate">{p.sub}</p>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>

        <!-- Mobile carousel — tap to pause + CTA overlay -->
        <div class="md:hidden min-w-0" id="mobile-carousel">
          <div class="relative overflow-hidden rounded-2xl">
            <div class="pointer-events-none absolute left-0 top-0 bottom-0 w-6 z-10" style="background: linear-gradient(to right, #0D0D0D, transparent);"></div>
            <div class="pointer-events-none absolute right-0 top-0 bottom-0 w-6 z-10" style="background: linear-gradient(to left, #0D0D0D, transparent);"></div>
            <div class="mobile-track flex gap-3" id="mobile-track" style="width: max-content;">
              {[...heroProjects, ...heroProjects].map((p, i) => (
                <div
                  class="carousel-item shrink-0 w-[260px] overflow-hidden rounded-xl border border-white/[0.08] shadow-xl shadow-black/40 transition-all duration-300 cursor-pointer relative"
                  data-url={`/realisations#${p.id}`}
                  data-name={p.name}
                >
                  <div class="relative overflow-hidden">
                    <img src={p.img} alt={p.name} width="260" height="146" class="h-[146px] w-full object-cover object-top transition-transform duration-300" loading="eager" />
                    <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 55%);"></div>
                    <div class="absolute inset-x-0 bottom-0 px-3 pb-2.5">
                      <p class="text-sm font-semibold text-white truncate">{p.name}</p>
                      <p class="text-[11px] text-white/50 truncate">{p.sub}</p>
                    </div>
                    <!-- CTA overlay — shown when paused on this card -->
                    <div class="carousel-overlay absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-200 pointer-events-none" style="background: rgba(0,0,0,0.45); backdrop-filter: blur(2px);">
                      <a class="pointer-events-auto rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-[#0D0D0D] shadow-lg transition-transform hover:scale-105">
                        Voir le site →
                      </a>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <!-- Resume button — shown when paused -->
          <button id="carousel-resume" class="mt-3 mx-auto hidden items-center gap-2 rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-xs text-white/60 transition-all active:scale-95" type="button">
            <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 20 20"><path d="M6.3 2.841A1.5 1.5 0 004 4.11v11.78a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"/></svg>
            Reprendre le défilement
          </button>
        </div>
      </div>

      <!-- Subtle link -->
      <div class="mt-8 md:mt-10 text-center hero-fade" style="--hero-delay: 1s;">
        <a href="/realisations" class="inline-flex items-center gap-2 text-sm text-neutral-500 transition-colors hover:text-white/70">
          {sitesRealises} projets livrés — voir les réalisations
          <svg class="h-3.5 w-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>

    </div>
  </section>


  <!-- PROBLÈME — 2 colonnes : accroche + pain points -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-20 md:px-8 md:py-24">
    <div class="mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-[1fr_1.2fr] md:gap-16 items-start">

        <!-- Colonne gauche — accroche sticky -->
        <div class="md:sticky md:top-28">
          <p class="text-[var(--color-accent)] font-semibold text-sm tracking-wide uppercase mb-4">Le constat</p>
          <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] leading-tight">
            Vous avez un <span class="text-[var(--color-accent)]">vrai métier</span>.
          </h2>
          <p class="mt-3 text-[var(--color-text-muted)] text-lg leading-relaxed">
            Votre site devrait travailler aussi dur que vous. Pourtant...
          </p>
          <div class="mt-8 hidden md:block">
            <p class="text-[var(--color-text-muted)]">
              Et si votre site devenait votre <span class="font-semibold text-[var(--color-text)]">meilleur commercial</span> ?
            </p>
            <a href="#methode" class="mt-3 inline-flex items-center gap-2 text-[var(--color-accent)] font-semibold text-sm hover:underline transition-colors">
              Voir comment on travaille
              <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
            </a>
          </div>
        </div>

        <!-- Colonne droite — pain points -->
        <div class="space-y-4">
          <div class="group rounded-2xl border-l-4 border-l-red-400 bg-white px-6 py-5 shadow-sm transition-all duration-300 hover:shadow-md">
            <h3 class="text-[17px] font-bold text-[var(--color-text)] group-hover:text-red-500 transition-colors">
              Votre site WordPress rame et vous coûte cher
            </h3>
            <p class="mt-1.5 text-[var(--color-text-muted)] leading-relaxed text-[15px]">
              Plugins à mettre à jour, cache qui ne suffit pas, hébergement qui grimpe. <span class="font-medium text-[var(--color-text)]">3 secondes de chargement = 53% de visiteurs perdus.</span>
            </p>
          </div>

          <div class="group rounded-2xl border-l-4 border-l-amber-400 bg-white px-6 py-5 shadow-sm transition-all duration-300 hover:shadow-md">
            <h3 class="text-[17px] font-bold text-[var(--color-text)] group-hover:text-amber-600 transition-colors">
              Vous n'avez pas de site et perdez des clients
            </h3>
            <p class="mt-1.5 text-[var(--color-text-muted)] leading-relaxed text-[15px]">
              Vos concurrents apparaissent sur Google. Pas vous. <span class="font-medium text-[var(--color-text)]">Chaque jour sans site, c'est du chiffre en moins.</span>
            </p>
          </div>

          <div class="group rounded-2xl border-l-4 border-l-[var(--color-accent)] bg-white px-6 py-5 shadow-sm transition-all duration-300 hover:shadow-md">
            <h3 class="text-[17px] font-bold text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors">
              Votre site est générique et ne vous ressemble pas
            </h3>
            <p class="mt-1.5 text-[var(--color-text-muted)] leading-relaxed text-[15px]">
              Template vu mille fois, couleurs par défaut, zéro personnalité. <span class="font-medium text-[var(--color-text)]">Les visiteurs repartent sans se souvenir de vous.</span>
            </p>
          </div>
        </div>

      </div>

      <!-- CTA mobile (visible uniquement en mobile) -->
      <div class="mt-10 text-center md:hidden">
        <p class="text-[var(--color-text-muted)]">
          Et si votre site devenait votre <span class="font-semibold text-[var(--color-text)]">meilleur commercial</span> ?
        </p>
        <a href="#methode" class="mt-3 inline-flex items-center gap-2 text-[var(--color-accent)] font-semibold text-sm hover:underline transition-colors">
          Voir comment on travaille
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- PREUVE SOCIALE -->
  <section class="w-full bg-white px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <h2 class="text-center text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-4">Ça marche</h2><p class="text-center text-[var(--color-text-muted)] mb-16 text-lg">Des chiffres, pas des promesses.</p>
      <div class="grid gap-12 md:grid-cols-3">
        <div class="text-center">
          <div class="mb-3 text-6xl font-bold text-[var(--color-accent)]"><span class="count-up" data-target={sitesRealises}>0</span><span class="text-3xl">+</span></div>
          <p class="text-[var(--color-text-muted)]">Projets livrés et en production</p>
        </div>
        <div class="text-center">
          <div class="mb-3 text-4xl font-bold text-[var(--color-accent)]">7<span class="text-2xl">j</span></div>
          <p class="text-[var(--color-text-muted)]">Délai moyen du brief à la mise en ligne</p>
        </div>
        <div class="text-center">
          <div class="mb-3 text-6xl font-bold text-[var(--color-accent)]">100<span class="text-3xl">%</span></div>
          <p class="text-[var(--color-text-muted)]">Taux de satisfaction clients</p>
        </div>
      </div>
    </div>
  </section>

  <!-- AVIS CLIENTS -->
  <section class="w-full bg-[var(--color-bg-alt)] px-6 py-24 md:px-8 md:py-32">
    <div class="mx-auto max-w-5xl">
      <div class="mb-12 text-center">
        <p class="mb-2 text-sm font-semibold uppercase tracking-widest text-[var(--color-accent)]">Avis Google</p>
        <h2 class="text-3xl font-bold text-[var(--color-text)] md:text-4xl">Ils me font confiance</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <!-- Avis 1 — David MERLY -->
        <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm flex flex-col">
          <div class="mb-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">D</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">David Merly</p>
                <p class="text-xs text-[var(--color-text-muted)]">Local Guide · Mars 2026</p>
              </div>
            </div>
            <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          </div>
          <div class="mb-3 flex gap-0.5">
            {[...Array(5)].map(() => <svg class="h-4 w-4 text-yellow-400" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>)}
          </div>
          <p class="text-[var(--color-text-muted)] leading-relaxed flex-1">"Si vous avez envie d'un site web Marc est la personne qu'il vous faut sans hésitation 👍 Réactif, inventif, il sait exactement où il va pour que votre site soit parfait et surtout il est attentif à l'attente du client 👌 Je le recommande à 1000%. Un très grand MERCI, grâce à vous j'ai une meilleure visibilité pour mon entreprise."</p>
        </div>
        <!-- Avis 2 — Jennifer De Groeve -->
        <div class="rounded-2xl border border-[var(--color-border)] bg-white p-8 shadow-sm">
          <div class="mb-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-[var(--color-accent)] text-sm font-bold text-white">J</div>
              <div>
                <p class="font-semibold text-[var(--color-text)]">Jennifer De Groeve</p>
                <p class="text-xs text-[var(--color-text-muted)]">Mars 2026</p>
              </div>
            </div>
            <svg class="h-5 w-5" viewBox="0 0 24 24" aria-hidden="true"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
          </div>
          <div class="mb-3 flex gap-0.5">
