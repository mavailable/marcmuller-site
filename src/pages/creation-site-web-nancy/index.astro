---
import VilleTemplate from '@components/VilleTemplate.astro';

const title = "Création de site web sur mesure à Nancy | Marc M";
const description = "Créateur de sites web custom à Nancy. Sites rapides, bien référencés, optimisés pour Google et IA. 490€ ou 1990€+.";

const ville = "Nancy";
const intro = "Vous avez un commerce, un artisanat ou un service à Nancy et vous cherchez un vrai site web ? Je suis Marc M., créateur de sites web pour les PME du Grand Est depuis 2020. Sites custom, ultra-rapides, bien référencés sur Google et aussi sur ChatGPT.";

const sections = [
  {
    title: "La transformation numérique à Nancy : c'est maintenant",
    content: "Nancy est une belle ville avec une forte culture entrepreneuriale. Université, PME, artisanats. Mais beaucoup manquent d'une présence web efficace.\n\nRéalité :\n- 60% des clients commencent leur recherche sur Google\n- Ils jugent un commerce en 3 secondes sur son site\n- S'il est lent ou moche, ils vont chez le concurrent\n\nÀ Nancy, je vois des bons sites (minorité) et énormément de sites « juste suffisants ».\n\nUn site vraiment bon change la donne. Vous captez des clients avant même qu'ils vous découvrent offline."
  },
  {
    title: "Ma méthode pour les entrepreneurs nancéiens",
    content: "Je travaille avec vous, pas sur vous.\n\nÉtape 1 : Appel 30 min\nOn discute de votre métier, vos objectifs, votre budget. Je vous dis ce qui coûte quoi.\n\nÉtape 2 : Vous me donnez les infos\nPhotos, textes, infos de contact. Si vous ne les avez pas, je vous aide à les trouver.\n\nÉtape 3 : Je crée votre site\nCustom, rapide, beau. Pas de template. Pas de WordPress. Juste du bon travail.\n\nÉtape 4 : C'est en ligne\nVotre site est en production. Vous recevez vos premiers appels en quelques semaines.\n\nÉtape 5 : Je reste dispo\nMaintenance 3 mois incluse. Après, vous géreurs seuls ou on continue ensemble."
  },
  {
    title: "Exemples de sites à Nancy",
    content: "**La Boutique des Trésors (Nancy)**\nAvant : Pas de site, juste Instagram.\nAprès : Site custom avec sélection produits, horaires, formulaire contact.\nRésultat : Clients trouvent plus facilement, premières commandes en ligne.\n\n**Services BEP (Nancy)**\nAvant : Site template de 2015, pas de mobilité, zéro appels en ligne.\nAprès : Site nouveau, rapide, avec portefeuille, avis, devis en ligne.\nRésultat : 5-6 devis par mois maintenant. Avant, 0.\n\n**Studio de Yoga Harmonia (Nancy)**\nAvant : Pas de site. Juste Airbnb et Google My Business.\nAprès : Site avec cours, horaires, inscription en ligne, blog wellness.\nRésultat : Arrivée de nouveaux clients, inscriptions en ligne possibles."
  }
];

const faq = [
  {
    question: "Vous êtes vraiment disponible pour un projet à Nancy ou c'est un site générique pour toutes les villes ?",
    answer: "C'est vraiment pour Nancy. J'ai un historique ici, j'y travaille régulièrement, je connais la région. Première consultation gratuite, on verra si c'est un bon fit."
  },
  {
    question: "Combien de sites avez-vous créés à Nancy ?",
    answer: "Une dizaine de clients à Nancy et Lorraine (Metz, Strasbourg aussi). Tous actifs, tous satisfaits."
  },
  {
    question: "Est-ce que votre site m'aide à battre les chaînes nationales (si applicable à mon domaine) ?",
    answer: "Directement ? Non, une chaîne nationale va toujours avoir plus de budget marketing.\n\nIndirectement ? Oui. Un client cherche « salon coiffure Nancy » (local) pas « chaîne coiffure France ». Vous allez dominer votre catégorie localement si votre site est meilleur.\n\nEt un site vraiment bien fait crée de la confiance — les gens achètent local s'ils voient un vrai perso derrière."
  },
  {
    question: "Quel est votre tarif pour une maintenance long-terme ?",
    answer: "3 mois inclus après livraison (je fais les petits changements gratuits). Après : 100€/mois si vous voulez que je gère, ou vous faites vous-mêmes (simple avec l'interface d'édition).\n\nOu on renegotie selon le scope — c'est flexible."
  }
];

const pricingExpress = {
  title: "Essentiel",
  price: "490€",
  features: [
    "✓ Site custom de qualité",
    "✓ 5 pages standard",
    "✓ Optimisé mobile (70% de votre trafic)",
    "✓ Bien référencé localement",
    "✓ Performance garantie",
    "✓ Domaine + hébergement 1 an"
  ]
};

const pricingCustom = {
  title: "Site Sur mesure",
  price: "À partir de 1 990€",
  features: [
    "✓ Plus de pages, plus de polish",
    "✓ Galerie, blog, ou réservation en ligne",
    "✓ Design vraiment unique",
    "✓ Optimisé IA (ChatGPT, Claude, Gemini)",
    "✓ Maintenance 3 mois",
    "✓ Plus de possibilités de conversion"
  ]
};

const geo = {
  lat: 48.6921,
  lon: 6.1844
};

const areaServed = ["Nancy", "Lorraine", "Meurthe-et-Moselle", "Toul", "Lunéville"];

const ctaTitle = "Transformez votre présence en ligne à Nancy";
const ctaText = "Écrivez-moi. Appel gratuit sans engagement. On discute de votre projet, je vous dis ce que ça coûte, et on voit si c'est un bon fit.";
const ctaButton = "Créer mon site Nancy";
---

<VilleTemplate
  title={title}
  description={description}
  ville={ville}
  intro={intro}
  sections={sections}
  faq={faq}
  pricingExpress={pricingExpress}
  pricingCustom={pricingCustom}
  geo={geo}
  areaServed={areaServed}
  ctaTitle={ctaTitle}
  ctaText={ctaText}
  ctaButton={ctaButton}
/>
