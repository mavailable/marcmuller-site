---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business } from '../data/business';

const title = 'Mentions légales — Marc M';
const description = 'Informations légales et éditeur du site Marc M.';
---

<BaseLayout title={title} description={description} lang="fr" frPath="/mentions-legales" enPath="/en/legal-notice">
  <main class="mx-auto max-w-3xl px-6 py-20 md:px-8">
    <h1 class="mb-12 text-4xl font-bold text-[var(--color-text)]">
      Mentions légales
    </h1>

    <!-- Éditeur du site -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Éditeur du site
      </h2>
      <p class="mb-2 text-[var(--color-text)]">
        <strong>Marc M</strong>
      </p>
      <p class="mb-2 text-[var(--color-text)]">
        Création de sites web sur mesure
      </p>
      <p class="mb-2 text-[var(--color-text)]">
        SIRET : {business.siret}
      </p>
      <p class="mb-2 text-[var(--color-text)]">
        Téléphone : <a href={`tel:${business.phone}`} class="text-[var(--color-accent)] hover:underline">{business.phone}</a>
      </p>
      <p class="mb-2 text-[var(--color-text)]">
        Email : <a href={`mailto:${business.email}`} class="text-[var(--color-accent)] hover:underline">{business.email}</a>
      </p>
      <p class="text-[var(--color-text)]">
        13 Rue des Peupliers<br />
        57950 Montigny-lès-Metz, Grand Est — France
      </p>
    </section>

    <!-- Directeur de la publication -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Directeur de la publication
      </h2>
      <p class="mb-2 text-[var(--color-text)]">
        <strong>Marc Muller</strong>
      </p>
      <p class="text-[var(--color-text)]">
        Email : <a href="mailto:marc@muller.im" class="text-[var(--color-accent)] hover:underline">marc@muller.im</a>
      </p>
    </section>

    <!-- Hébergement -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Hébergeur
      </h2>
      <p class="mb-2 text-[var(--color-text)]">
        <strong>Cloudflare Pages</strong>
      </p>
      <p class="mb-2 text-[var(--color-text)]">
        Cloudflare Inc.
      </p>
      <p class="text-[var(--color-text)]">
        101 Townsend Street<br />
        San Francisco, CA 94107<br />
        États-Unis
      </p>
    </section>

    <!-- Propriété intellectuelle -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Propriété intellectuelle
      </h2>
      <p class="mb-4 text-[var(--color-text)]">
        L'ensemble du contenu de ce site (textes, images, logos, design) est protégé par le droit d'auteur et les droits de propriété intellectuelle. Toute reproduction, représentation, modification ou exploitation sans autorisation préalable écrite de Marc M est strictement interdite.
      </p>
      <p class="text-[var(--color-text)]">
        Les droits d'auteur sont la propriété exclusive de Marc Muller / Marc M.
      </p>
    </section>

    <!-- Données personnelles -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Données personnelles
      </h2>
      <p class="mb-4 text-[var(--color-text)]">
        Ce site ne collecte aucun cookie de tracking ou d'analytics invasif. Les données personnelles soumises via les formulaires de contact sont traitées conformément à la <a href="/politique-confidentialite" class="text-[var(--color-accent)] hover:underline">politique de confidentialité</a>.
      </p>
      <p class="text-[var(--color-text)]">
        Aucune donnée personnelle n'est vendue ou communiquée à des tiers.
      </p>
    </section>

    <!-- Responsabilité -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Limitation de responsabilité
      </h2>
      <p class="mb-4 text-[var(--color-text)]">
        Marc M décline toute responsabilité en cas de dommages directs ou indirects résultant de l'accès, de l'utilisation ou de l'impossibilité d'utiliser ce site, y compris :
      </p>
      <ul class="mb-4 list-inside list-disc space-y-2 text-[var(--color-text)]">
        <li>Perte de données</li>
        <li>Interruption de service</li>
        <li>Erreurs ou inexactitudes du contenu</li>
        <li>Dommages causés par des virus ou malveillances</li>
      </ul>
      <p class="text-[var(--color-text)]">
        L'accès au site se fait sous votre responsabilité entière.
      </p>
    </section>

    <!-- Loi applicable -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Loi applicable et juridiction
      </h2>
      <p class="text-[var(--color-text)]">
        Ce site et l'ensemble de ses mentions légales sont régis par la loi française. Tout litige sera soumis aux tribunaux compétents de Metz (Moselle, France).
      </p>
    </section>

    <!-- Accès au site -->
    <section class="mb-12">
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Accès au site
      </h2>
      <p class="text-[var(--color-text)]">
        Marc M s'efforce de maintenir ce site en ligne et opérationnel. Cependant, nous ne garantissons pas une disponibilité continue ou sans interruption. Les interruptions pour maintenance, mises à jour ou raisons techniques peuvent survenir sans notification préalable.
      </p>
    </section>

    <!-- Contact -->
    <section>
      <h2 class="mb-4 text-2xl font-semibold text-[var(--color-text)]">
        Pour toute question
      </h2>
      <p class="text-[var(--color-text)]">
        Vous pouvez me contacter à : <a href="mailto:marc@muller.im" class="text-[var(--color-accent)] hover:underline">marc@muller.im</a>
      </p>
    </section>

    <hr class="my-12 border-[var(--color-bg-alt)]" />
    <p class="text-sm text-[var(--color-text-muted)]">
      Dernière mise à jour : 15 mars 2026
    </p>
  </main>
</BaseLayout>
