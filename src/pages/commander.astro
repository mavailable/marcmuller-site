---
import BaseLayout from '../layouts/BaseLayout.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';

const siteVitrine = business.offers[0];
const basePrice = siteVitrine.price!;

const categories = [
  { id: 'all', label: 'Tout' },
  { id: 'visibility', label: 'Être trouvé' },
  { id: 'convert', label: 'Convertir' },
  { id: 'design', label: 'Design' },
];

const addonsData = [
  // Être trouvé
  { name: 'Fiche Google Business', price: 90, desc: 'Votre entreprise sur Google Maps — 46% des recherches Google sont locales', cat: 'visibility', badge: 'Populaire',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>' },
  { name: 'Pack réseaux sociaux', price: 150, desc: 'Visuels professionnels aux bonnes dimensions pour Facebook, LinkedIn et Google Business', cat: 'visibility', badge: '',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>' },
  { name: 'Blog SEO', price: 390, desc: '5 articles optimisés pour Google + espace simple pour écrire vos prochains articles', cat: 'visibility', badge: '',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg>' },
  { name: 'Rédaction de contenu', price: 190, desc: 'Je rédige tous les textes de votre site — vous n\'avez rien à écrire', cat: 'visibility', badge: '',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>' },
  // Convertir
  { name: 'Page supplémentaire', price: 120, desc: 'Page dédiée : À propos, tarifs, galerie, témoignages...', cat: 'convert', badge: '',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4v16m8-8H4"/></svg>' },
  { name: 'Prise de RDV en ligne', price: 180, desc: 'Vos clients réservent un créneau directement sur votre site (Cal.com, Doctolib ou autre)', cat: 'convert', badge: 'Recommandé',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>' },
  { name: 'Paiement en ligne', price: 250, desc: 'Vos clients commandent et paient en ligne via Stripe — devis, acomptes ou paiement complet', cat: 'convert', badge: '',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>' },
  // Design
  { name: 'Galerie photos', price: 90, desc: 'Galerie avant/après ou par catégorie avec lightbox plein écran', cat: 'design', badge: '',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>' },
  { name: 'Animations au scroll', price: 90, desc: 'Entrées animées des sections pour un site moderne et vivant', cat: 'design', badge: '',
    icon: '<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>' },
];

const checkIcon = `<svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>`;
---

<BaseLayout
  title="Commander votre site — Marc M"
  description="Commandez votre site professionnel en ligne. Site Vitrine à 490€ HT, options à la carte, livré en 7 jours."
  lang="fr"
  frPath="/commander"
>
  <SchemaOrg type="localBusiness" />

  <!-- SLIM HEADER — pas de hero, on va droit au but -->
  <section class="w-full bg-[#0D0D0D] px-6 py-8 md:py-10">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-2xl md:text-3xl font-bold text-white">Votre commande</h1>
      <p class="text-sm text-neutral-400 mt-2">Site Vitrine sur mesure — livré en 7 jours</p>
    </div>
  </section>

  <!-- STEP INDICATOR — toujours visible, collé sous le header -->
  <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-[var(--color-border)] px-6 py-3">
    <div class="mx-auto max-w-3xl">
      <div class="steps-indicator flex items-center justify-between" role="navigation" aria-label="Progression">
        {[
          { num: 1, label: 'Site' },
          { num: 2, label: 'Options' },
          { num: 3, label: 'Infos' },
          { num: 4, label: 'Récap' },
        ].map((step, i) => (
          <div class="flex items-center flex-1 last:flex-initial">
            <button type="button" class={`step-dot flex items-center gap-2 ${i === 0 ? 'active' : ''}`} data-step-dot={step.num} data-goto-step={step.num}>
              <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold transition-all duration-300 border-2 flex-shrink-0">
                <span class="step-num">{step.num}</span>
                <svg class="step-check w-4 h-4 hidden" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
              </div>
              <span class="text-xs font-medium">{step.label}</span>
            </button>
            {i < 3 && (
              <div class="step-line flex-1 h-0.5 mx-2 transition-all duration-300"></div>
            )}
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- STEPS CONTENT -->
  <section class="w-full bg-[var(--color-bg)] px-6 py-8 md:py-12">
    <div class="mx-auto max-w-3xl">

      <form id="order-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="dccda1f5-4e63-4b9f-9c66-f5ce76f0dfdd" />
        <input type="text" name="botcheck" style="display: none;" />
        <input type="hidden" name="redirect" value="https://marcm.fr/merci" />
        <input type="hidden" name="subject" value="Nouvelle commande Site Vitrine" />
        <input type="hidden" name="from_name" value="Commande marcm.fr" />
        <input type="hidden" name="commande_total" id="hidden-total" value="490" />
        <input type="hidden" name="commande_options" id="hidden-options" value="" />

        <!-- ========== STEP 1 — Compact product + payment ========== -->
        <div class="step-panel active" data-step="1">
          <!-- Product card — compact -->
          <div class="rounded-2xl overflow-hidden" style="background-color: #111; box-shadow: 0 15px 40px -10px rgba(0, 0, 0, 0.3);">
            <div class="h-1" style="background: linear-gradient(90deg, #E86C47, #F5C8B3);"></div>
            <div class="p-6 md:p-8">
              <div class="flex items-start justify-between gap-4 mb-5">
                <div>
                  <span class="text-xs font-bold uppercase tracking-wider text-neutral-400">Site Vitrine</span>
                  <h2 class="text-xl font-bold text-white mt-1">Votre site professionnel</h2>
                </div>
                <div class="text-right flex-shrink-0">
                  <div class="text-3xl font-extrabold text-white">490<span class="text-lg">€</span></div>
                  <span class="text-xs text-neutral-400">HT — ou 3× 165€</span>
                </div>
              </div>

              <!-- Features — compact 2 cols -->
              <div class="grid grid-cols-2 gap-x-4 gap-y-2 mb-6">
                {['Design unique', 'SEO & GEO', 'Lighthouse 100', 'Livré en 7j', 'Hébergement offert', 'Domaine inclus'].map((feat) => (
                  <div class="flex items-center gap-2">
                    <svg class="w-3.5 h-3.5 text-emerald-400 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                    <span class="text-xs text-neutral-300">{feat}</span>
                  </div>
                ))}
              </div>

              <input type="hidden" name="paiement" value="À définir" />
            </div>
          </div>

          <!-- Trust bar -->
          <div class="mt-4 flex flex-wrap items-center justify-center gap-4 text-xs text-[var(--color-text-muted)]">
            <span class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> {business.sitesRealises} sites livrés</span>
            <span class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> Lighthouse 100</span>
            <span class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5 text-emerald-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> Propriétaire de votre site</span>
          </div>

          <div class="flex justify-end mt-6">
            <button type="button" class="btn-next inline-flex items-center gap-2 px-8 py-3.5 bg-[var(--color-accent)] text-white font-semibold rounded-xl hover:bg-[var(--color-accent-hover)] transition-all shadow-md" data-goto="2">
              Choisir mes options
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- ========== STEP 2 — Options ========== -->
        <div class="step-panel" data-step="2">
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-1">Options à la carte</h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-5">Facultatif — choisissez ce qui vous sera utile.</p>

          <!-- Category filter tabs -->
          <div class="flex gap-2 mb-6 overflow-x-auto pb-1 -mx-1 px-1" role="tablist">
            {categories.map((cat, i) => (
              <button
                type="button"
                role="tab"
                class={`cat-tab whitespace-nowrap rounded-full px-4 py-2 text-xs font-semibold transition-all ${i === 0 ? 'active' : ''}`}
                data-cat={cat.id}
                aria-selected={i === 0 ? 'true' : 'false'}
              >
                {cat.label}
              </button>
            ))}
            <span class="cat-count ml-auto self-center text-xs text-[var(--color-text-muted)] flex-shrink-0" id="addon-count">0 sélectionnée(s)</span>
          </div>

          <!-- Addon cards -->
          <div class="grid gap-3 sm:grid-cols-2" id="addons-grid">
            {addonsData.map((addon, i) => (
              <label
                class="addon-card group relative flex gap-3 rounded-xl border border-[var(--color-border)] bg-white p-4 cursor-pointer transition-all hover:border-[var(--color-accent)]/50 hover:shadow-sm"
                data-addon-price={addon.price}
                data-addon-name={addon.name}
                data-addon-cat={addon.cat}
              >
                <input type="checkbox" name={`addon_${i}`} value={`${addon.name} (+${addon.price}€)`} class="sr-only addon-checkbox" />

                <!-- Icon -->
                <div class="addon-icon w-9 h-9 rounded-lg flex items-center justify-center flex-shrink-0 transition-all" style="background: rgba(232, 108, 71, 0.08);">
                  <span class="text-[var(--color-accent)]" set:html={addon.icon} />
                </div>

                <!-- Content -->
                <div class="flex-grow min-w-0">
                  <div class="flex items-start justify-between gap-2">
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="text-sm font-semibold text-[var(--color-text)] leading-tight">{addon.name}</span>
                      {addon.badge && (
                        <span class={`inline-block text-[10px] font-bold uppercase tracking-wide px-1.5 py-0.5 rounded-full ${addon.badge === 'Populaire' ? 'bg-amber-100 text-amber-700' : 'bg-emerald-100 text-emerald-700'}`}>{addon.badge}</span>
                      )}
                    </div>
                    <span class="text-sm font-bold text-[var(--color-accent)] flex-shrink-0">+{addon.price}€</span>
                  </div>
                  <p class="text-xs text-[var(--color-text-muted)] mt-1 leading-relaxed">{addon.desc}</p>
                </div>
              </label>
            ))}
          </div>

          <!-- Total en direct + CTA -->
          <div class="mt-6 rounded-xl border border-[var(--color-border)] bg-white p-5">
            <div class="flex items-center justify-between mb-4">
              <div>
                <span class="text-sm text-[var(--color-text-muted)]">Total estimé</span>
                <div class="text-2xl font-extrabold text-[var(--color-text)]" id="inline-total">490€ <span class="text-sm font-normal text-[var(--color-text-muted)]">HT</span></div>
              </div>
              <div class="text-right">
                <span class="text-xs text-[var(--color-text-muted)]" id="inline-addon-summary">Aucune option</span>
              </div>
            </div>
            <button type="button" class="btn-next w-full inline-flex items-center justify-center gap-2 px-8 py-4 bg-[var(--color-accent)] text-white font-semibold rounded-xl hover:bg-[var(--color-accent-hover)] transition-all shadow-md text-base" data-goto="3">
              Continuer
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </button>
            <p class="text-xs text-center text-[var(--color-text-muted)] mt-3">Pas besoin d'options ? Continuez directement.</p>
          </div>
        </div>

        <!-- ========== STEP 3 — Infos ========== -->
        <div class="step-panel" data-step="3">
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-1">Vos informations</h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-6">Pour préparer votre site. * = obligatoire.</p>

          <!-- Required — 2-col layout for short fields -->
          <div class="grid gap-4 sm:grid-cols-2">
            <div>
              <label for="fullname" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">Nom complet *</label>
              <input type="text" id="fullname" name="fullname" required class="field-input w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="Prénom Nom" />
            </div>
            <div>
              <label for="order-email" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">Email *</label>
              <input type="email" id="order-email" name="email" required class="field-input w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="votre@email.com" />
            </div>
            <div>
              <label for="order-phone" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">Téléphone *</label>
              <input type="tel" id="order-phone" name="phone" required class="field-input w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="06 XX XX XX XX" />
            </div>
            <div>
              <label for="company" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">Entreprise / activité *</label>
              <input type="text" id="company" name="company" required class="field-input w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="Boulangerie Martin..." />
            </div>
          </div>

          <div class="mt-4 grid gap-4 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <label for="activity-desc" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">Décrivez votre activité *</label>
              <textarea id="activity-desc" name="activity_description" required rows="2" class="field-input w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all resize-none" placeholder="Que faites-vous ? Pour qui ? Depuis quand ?"></textarea>
            </div>
            <div class="sm:col-span-2">
              <label for="city" class="block text-sm font-medium text-[var(--color-text)] mb-1.5">Ville / zone d'intervention *</label>
              <input type="text" id="city" name="city" required class="field-input w-full rounded-lg bg-white px-4 py-3 text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="Metz et alentours" />
            </div>
          </div>

          <!-- Optional — collapsible -->
          <details class="mt-6 group">
            <summary class="flex items-center gap-2 cursor-pointer text-sm font-semibold text-[var(--color-text)] select-none">
              <svg class="w-4 h-4 text-[var(--color-text-muted)] transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              Informations complémentaires <span class="text-xs font-normal text-[var(--color-text-muted)]">(facultatif)</span>
            </summary>
            <div class="mt-4 grid gap-4 sm:grid-cols-2">
              <div>
                <label for="current-site" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Site web actuel</label>
                <input type="url" id="current-site" name="current_website" class="field-input w-full rounded-lg bg-white px-4 py-2.5 text-sm text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="https://..." />
              </div>
              <div>
                <label for="google-business" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Fiche Google Business</label>
                <input type="url" id="google-business" name="google_business" class="field-input w-full rounded-lg bg-white px-4 py-2.5 text-sm text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="https://g.page/..." />
              </div>
              <div>
                <label for="social-media" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Réseaux sociaux</label>
                <input type="text" id="social-media" name="social_media" class="field-input w-full rounded-lg bg-white px-4 py-2.5 text-sm text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="Liens Facebook, Instagram..." />
              </div>
              <div>
                <label for="colors" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Couleurs préférées</label>
                <input type="text" id="colors" name="preferred_colors" class="field-input w-full rounded-lg bg-white px-4 py-2.5 text-sm text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="Bleu marine, or..." />
              </div>
              <div class="sm:col-span-2">
                <label for="inspiration" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Sites qui vous inspirent</label>
                <input type="text" id="inspiration" name="inspiration_sites" class="field-input w-full rounded-lg bg-white px-4 py-2.5 text-sm text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all" placeholder="URLs de sites que vous aimez" />
              </div>
              <div class="sm:col-span-2">
                <label for="order-message" class="block text-xs font-medium text-[var(--color-text-muted)] mb-1.5">Message / demandes particulières</label>
                <textarea id="order-message" name="message" rows="2" class="field-input w-full rounded-lg bg-white px-4 py-2.5 text-sm text-[var(--color-text)] placeholder-[var(--color-text-muted)] border border-[var(--color-border)] focus:outline-none focus:ring-2 focus:ring-[var(--color-accent)] focus:border-transparent transition-all resize-none" placeholder="Tout ce qui vous semble important..."></textarea>
              </div>
            </div>
          </details>

          <!-- RGPD -->
          <div class="flex items-start gap-3 mt-6">
            <input type="checkbox" id="order-privacy" name="privacy" required class="mt-1 h-4 w-4 rounded border-[var(--color-border)] text-[var(--color-accent)] focus:ring-[var(--color-accent)] cursor-pointer" />
            <label for="order-privacy" class="text-xs text-[var(--color-text-muted)] cursor-pointer leading-relaxed">
              J'accepte que mes données soient traitées pour la réalisation de mon projet (art. 6.1.a RGPD). <a href="/politique-confidentialite" class="text-[var(--color-accent)] hover:underline" target="_blank" rel="noopener">Politique de confidentialité</a> *
            </label>
          </div>

          <!-- CTA Voir le récap -->
          <div class="mt-8">
            <button type="button" class="btn-next w-full inline-flex items-center justify-center gap-2 px-8 py-4 bg-[var(--color-accent)] text-white font-semibold rounded-xl hover:bg-[var(--color-accent-hover)] transition-all shadow-md text-base" data-goto="4">
              Voir le récapitulatif
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </button>
          </div>
        </div>

        <!-- ========== STEP 4 — Récap complet ========== -->
        <div class="step-panel" data-step="4">
          <h2 class="text-xl font-bold text-[var(--color-text)] mb-2">Récapitulatif de votre commande</h2>
          <p class="text-sm text-[var(--color-text-muted)] mb-6">Vérifiez que tout est correct avant d'envoyer.</p>

          <!-- 1. Commande -->
          <div class="rounded-xl border border-[var(--color-border)] bg-white overflow-hidden mb-4">
            <div class="px-5 py-3 bg-[var(--color-bg-alt)] border-b border-[var(--color-border)] flex items-center justify-between">
              <span class="text-xs font-bold uppercase tracking-wider text-[var(--color-text-muted)]">Votre commande</span>
              <button type="button" class="text-xs text-[var(--color-accent)] hover:underline font-medium" data-goto="2">Modifier les options</button>
            </div>
            <div class="px-5 py-4 border-b border-[var(--color-border)] flex justify-between items-center">
              <div>
                <span class="font-semibold text-[var(--color-text)] text-sm">Site Vitrine</span>
                <span class="text-xs text-[var(--color-text-muted)] block">Design sur mesure, livré en 7 jours</span>
              </div>
              <span class="font-bold text-[var(--color-text)]">490€</span>
            </div>
            <div id="recap-addons"></div>
            <div class="px-5 py-4 bg-[var(--color-bg-alt)] flex justify-between items-center">
              <span class="font-bold text-[var(--color-text)]">Total HT</span>
              <span class="text-xl font-extrabold text-[var(--color-accent)]" id="recap-total">490€</span>
            </div>
          </div>

          <!-- 2. Vos informations -->
          <div class="rounded-xl border border-[var(--color-border)] bg-white overflow-hidden mb-4">
            <div class="px-5 py-3 bg-[var(--color-bg-alt)] border-b border-[var(--color-border)] flex items-center justify-between">
              <span class="text-xs font-bold uppercase tracking-wider text-[var(--color-text-muted)]">Vos informations</span>
              <button type="button" class="text-xs text-[var(--color-accent)] hover:underline font-medium" data-goto="3">Modifier</button>
            </div>
            <div class="px-5 py-4 text-sm text-[var(--color-text)] space-y-1" id="recap-info"></div>
          </div>

          <!-- 3. Ce qui va se passer -->
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 mb-6">
            <p class="text-xs font-bold uppercase tracking-wider text-[var(--color-text-muted)] mb-3">Prochaines étapes</p>
            <div class="space-y-3">
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-xs font-bold text-[var(--color-accent)]">1</span>
                </div>
                <p class="text-sm text-[var(--color-text)]">Je vous recontacte <strong>sous 24h</strong> pour confirmer votre commande</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-xs font-bold text-[var(--color-accent)]">2</span>
                </div>
                <p class="text-sm text-[var(--color-text)]">On planifie un <strong>appel de 15 min</strong> pour cadrer le projet</p>
              </div>
              <div class="flex items-start gap-3">
                <div class="w-6 h-6 rounded-full bg-[var(--color-accent)]/10 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <span class="text-xs font-bold text-[var(--color-accent)]">3</span>
                </div>
                <p class="text-sm text-[var(--color-text)]">Je construis votre site en <strong>7 jours</strong></p>
              </div>
            </div>
          </div>

          <!-- Submit -->
          <button type="submit" class="w-full rounded-xl bg-[var(--color-accent)] px-8 py-4 text-base font-bold text-white transition-all hover:bg-[var(--color-accent-hover)] hover:-translate-y-0.5" style="box-shadow: 0 8px 25px rgba(232, 108, 71, 0.3);" data-umami-event="order-submit" id="btn-submit">
            Confirmer ma commande
          </button>
          <p class="text-center text-xs text-[var(--color-text-muted)] mt-3 leading-relaxed">
            Pas de paiement immédiat — je vous recontacte d'abord.<br />
            Une question ? Appelez-moi au <a href="tel:+33688776648" class="text-[var(--color-accent)] hover:underline font-medium">06 88 77 66 48</a>
          </p>
        </div>

      </form>
    </div>
  </section>

  <!-- FLOATING TOTAL BAR — visible steps 2-4 -->
  <div id="floating-total" class="fixed bottom-0 inset-x-0 z-40 translate-y-full transition-transform duration-300">
    <div class="bg-white/95 backdrop-blur-md border-t border-[var(--color-border)] shadow-[0_-4px_20px_rgba(0,0,0,0.08)] px-6 py-3">
      <div class="mx-auto max-w-3xl flex items-center justify-between">
        <div>
          <span class="text-xs text-[var(--color-text-muted)]">Total</span>
          <div class="text-xl font-extrabold text-[var(--color-text)]" id="floating-total-amount">490€ <span class="text-xs font-normal text-[var(--color-text-muted)]">HT</span></div>
        </div>
        <div class="flex gap-2">
          <button type="button" id="btn-float-back" class="inline-flex items-center gap-1.5 px-4 py-2.5 text-sm text-[var(--color-text-muted)] font-medium rounded-lg border border-[var(--color-border)] hover:bg-[var(--color-bg-alt)] transition-all">
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
            Retour
          </button>
          <button type="button" id="btn-float-next" class="inline-flex items-center gap-1.5 px-5 py-2.5 text-sm bg-[var(--color-accent)] text-white font-semibold rounded-lg hover:bg-[var(--color-accent-hover)] transition-all">
            Continuer
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  /* Step indicator */
  .step-dot { cursor: default; }
  .step-dot.clickable { cursor: pointer; }
  .step-dot .w-8 {
    background: transparent;
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }
  .step-dot.active .w-8 {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .step-dot.done .w-8 {
    background: var(--color-accent);
    border-color: var(--color-accent);
    color: #fff;
  }
  .step-dot.done .step-num { display: none; }
  .step-dot.done .step-check { display: block; }
  .step-dot span:not(.step-num):not(.step-check) {
    color: var(--color-text-muted);
  }
  .step-dot.active span:not(.step-num):not(.step-check),
  .step-dot.done span:not(.step-num):not(.step-check) {
    color: var(--color-text);
    font-weight: 600;
  }
  .step-line { background: var(--color-border); }
  .step-line.active { background: var(--color-accent); }

  /* Step panels */
  .step-panel {
    display: none;
    opacity: 0;
    transform: translateX(20px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .step-panel.active { display: block; }
  .step-panel.visible { opacity: 1; transform: translateX(0); }
  .step-panel.slide-back { transform: translateX(-20px); }


  /* Category tabs */
  .cat-tab {
    background: var(--color-bg-alt);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }
  .cat-tab:hover { color: var(--color-text); border-color: var(--color-text-muted); }
  .cat-tab.active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }

  /* Addon cards */
  .addon-card { position: relative; }
  .addon-card.selected {
    border-color: var(--color-accent);
    background: var(--color-accent-light);
    box-shadow: 0 0 0 2px var(--color-accent), 0 4px 12px rgba(232, 108, 71, 0.15);
  }
  .addon-card.selected .addon-icon { background: rgba(232, 108, 71, 0.2); }
  .addon-card.selected .addon-icon span { color: var(--color-accent-hover); }
  .addon-card.hidden-by-filter { display: none; }

  /* Checkbox */
  input[type="checkbox"] { accent-color: var(--color-accent); }

  /* Field validation */
  .field-error { border-color: #EF4444 !important; }
  .error-msg { color: #EF4444; font-size: 0.75rem; margin-top: 0.25rem; }

  /* Recap rows */
  .recap-addon-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.6rem 1.25rem; border-bottom: 1px solid var(--color-border);
    font-size: 0.875rem;
  }
  .recap-addon-row:last-child { border-bottom: none; }

  /* Floating total entrance */
  #floating-total.show { transform: translateY(0); }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const BASE_PRICE = 490;
    let currentStep = 1;
    let maxStepReached = 1;

    const panels = document.querySelectorAll<HTMLElement>('.step-panel');
    const dots = document.querySelectorAll<HTMLElement>('.step-dot');
    const lines = document.querySelectorAll<HTMLElement>('.step-line');
    const form = document.getElementById('order-form') as HTMLFormElement;
    const floatingTotal = document.getElementById('floating-total') as HTMLElement;
    const floatingAmount = document.getElementById('floating-total-amount') as HTMLElement;
    const btnFloatBack = document.getElementById('btn-float-back') as HTMLElement;
    const btnFloatNext = document.getElementById('btn-float-next') as HTMLElement;

    // ---- Navigation ----
    function goToStep(step: number, direction: 'forward' | 'back' = 'forward') {
      panels.forEach(p => p.classList.remove('active', 'visible', 'slide-back'));

      dots.forEach((dot, i) => {
        const s = i + 1;
        dot.classList.remove('active', 'done', 'clickable');
        if (s < step) { dot.classList.add('done', 'clickable'); }
        if (s === step) dot.classList.add('active');
        if (s <= maxStepReached && s !== step) dot.classList.add('clickable');
      });

      lines.forEach((line, i) => line.classList.toggle('active', i + 1 < step));

      const target = document.querySelector<HTMLElement>(`[data-step="${step}"]`);
      if (target) {
        target.classList.add('active');
        if (direction === 'back') target.classList.add('slide-back');
        void target.offsetWidth;
        target.classList.add('visible');
        if (direction === 'back') target.classList.remove('slide-back');
      }

      currentStep = step;
      if (step > maxStepReached) maxStepReached = step;

      // Scroll to top — force le retour en haut sur mobile
      window.scrollTo({ top: 0, behavior: 'smooth' });

      // Floating total visibility
      floatingTotal.classList.toggle('show', step >= 2 && step <= 3);

      // Update floating buttons text
      if (step === 3) {
        btnFloatNext.textContent = 'Voir le récap';
      } else {
        btnFloatNext.innerHTML = 'Continuer <svg class="w-3.5 h-3.5 inline ml-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>';
      }

      if (step === 4) populateRecap();
    }

    // Init step 1
    requestAnimationFrame(() => {
      const first = document.querySelector<HTMLElement>('[data-step="1"]');
      if (first) first.classList.add('visible');
    });

    // ---- All navigation buttons ----
    document.querySelectorAll<HTMLElement>('[data-goto]').forEach(btn => {
      btn.addEventListener('click', () => {
        const goto = parseInt(btn.dataset.goto || '1', 10);
        if (goto === 4 && currentStep === 3 && !validateStep3()) return;
        goToStep(goto, goto < currentStep ? 'back' : 'forward');
      });
    });

    // Step dots clickable (only completed steps)
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const stepNum = parseInt(dot.dataset.stepDot || '0', 10);
        if (stepNum <= maxStepReached && stepNum !== currentStep) {
          if (stepNum === 4 && !validateStep3()) return;
          goToStep(stepNum, stepNum < currentStep ? 'back' : 'forward');
        }
      });
    });

    // Floating bar buttons
    btnFloatBack.addEventListener('click', () => {
      if (currentStep > 1) goToStep(currentStep - 1, 'back');
    });
    btnFloatNext.addEventListener('click', () => {
      if (currentStep === 3 && !validateStep3()) return;
      if (currentStep < 4) goToStep(currentStep + 1, 'forward');
    });

    // ---- Category filter ----
    const catTabs = document.querySelectorAll<HTMLElement>('.cat-tab');
    const addonCards = document.querySelectorAll<HTMLElement>('.addon-card');
    const addonCount = document.getElementById('addon-count');

    catTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        catTabs.forEach(t => { t.classList.remove('active'); t.setAttribute('aria-selected', 'false'); });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const cat = tab.dataset.cat;
        addonCards.forEach(card => {
          if (cat === 'all' || card.dataset.addonCat === cat) {
            card.classList.remove('hidden-by-filter');
          } else {
            card.classList.add('hidden-by-filter');
          }
        });
      });
    });

    // ---- Addon toggle ----
    function updateAddonCount() {
      let count = 0;
      addonCards.forEach(card => {
        const cb = card.querySelector('.addon-checkbox') as HTMLInputElement;
        if (cb.checked) count++;
      });
      if (addonCount) addonCount.textContent = count === 0 ? '0 sélectionnée(s)' : `${count} sélectionnée(s)`;
    }

    addonCards.forEach(card => {
      card.addEventListener('click', () => {
        const cb = card.querySelector('.addon-checkbox') as HTMLInputElement;
        cb.checked = !cb.checked;
        card.classList.toggle('selected', cb.checked);
        updateTotal();
        updateAddonCount();
      });
    });

    // ---- Totals ----
    function getAddonsTotal(): number {
      let sum = 0;
      addonCards.forEach(card => {
        const cb = card.querySelector('.addon-checkbox') as HTMLInputElement;
        if (cb.checked) sum += parseInt(card.dataset.addonPrice || '0', 10);
      });
      return sum;
    }

    function updateTotal() {
      const total = BASE_PRICE + getAddonsTotal();
      const formatted = `${total}€ <span class="text-xs font-normal text-[var(--color-text-muted)]">HT</span>`;
      if (floatingAmount) floatingAmount.innerHTML = formatted;

      // Inline total (step 2)
      const inlineTotal = document.getElementById('inline-total');
      if (inlineTotal) inlineTotal.innerHTML = `${total}€ <span class="text-sm font-normal text-[var(--color-text-muted)]">HT</span>`;

      const inlineSummary = document.getElementById('inline-addon-summary');
      if (inlineSummary) {
        let count = 0;
        let addonsSum = 0;
        addonCards.forEach(card => {
          const cb = card.querySelector('.addon-checkbox') as HTMLInputElement;
          if (cb.checked) { count++; addonsSum += parseInt(card.dataset.addonPrice || '0', 10); }
        });
        inlineSummary.textContent = count === 0 ? 'Aucune option' : `${count} option${count > 1 ? 's' : ''} (+${addonsSum}€)`;
      }

      const ht = document.getElementById('hidden-total') as HTMLInputElement;
      if (ht) ht.value = String(total);
      updateHiddenOptions();
    }

    function updateHiddenOptions() {
      const names: string[] = [];
      addonCards.forEach(card => {
        const cb = card.querySelector('.addon-checkbox') as HTMLInputElement;
        if (cb.checked) names.push(`${card.dataset.addonName} (+${card.dataset.addonPrice}€)`);
      });
      const el = document.getElementById('hidden-options') as HTMLInputElement;
      if (el) el.value = names.length ? names.join(', ') : 'Aucune option';
    }

    // ---- Validation ----
    function validateStep3(): boolean {
      let valid = true;
      document.querySelectorAll('.field-error').forEach(el => el.classList.remove('field-error'));
      document.querySelectorAll('.error-msg').forEach(el => el.remove());

      const required = [
        { id: 'fullname', label: 'Nom' },
        { id: 'order-email', label: 'Email' },
        { id: 'order-phone', label: 'Téléphone' },
        { id: 'company', label: 'Entreprise' },
        { id: 'activity-desc', label: 'Description' },
        { id: 'city', label: 'Ville' },
      ];

      required.forEach(f => {
        const el = document.getElementById(f.id) as HTMLInputElement | HTMLTextAreaElement;
        if (el && !el.value.trim()) {
          el.classList.add('field-error');
          const msg = document.createElement('p');
          msg.className = 'error-msg';
          msg.textContent = `${f.label} est requis.`;
          el.parentElement?.appendChild(msg);
          valid = false;
        }
      });

      const emailEl = document.getElementById('order-email') as HTMLInputElement;
      if (emailEl?.value.trim() && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value.trim())) {
        emailEl.classList.add('field-error');
        const msg = document.createElement('p');
        msg.className = 'error-msg';
        msg.textContent = 'Email invalide.';
        emailEl.parentElement?.appendChild(msg);
        valid = false;
      }

      const privacy = document.getElementById('order-privacy') as HTMLInputElement;
      if (privacy && !privacy.checked) {
        const msg = document.createElement('p');
        msg.className = 'error-msg';
        msg.textContent = 'Acceptez la politique de confidentialité.';
        privacy.parentElement?.parentElement?.appendChild(msg);
        valid = false;
      }

      if (!valid) {
        const firstError = document.querySelector('.field-error') as HTMLElement;
        firstError?.focus();
      }

      return valid;
    }

    // ---- Recap ----
    function populateRecap() {
      const total = BASE_PRICE + getAddonsTotal();
      const recapAddons = document.getElementById('recap-addons');
      if (recapAddons) {
        recapAddons.innerHTML = '';
        addonCards.forEach(card => {
          const cb = card.querySelector('.addon-checkbox') as HTMLInputElement;
          if (cb.checked) {
            const row = document.createElement('div');
            row.className = 'recap-addon-row';
            row.innerHTML = `<span class="text-[var(--color-text)]">${card.dataset.addonName}</span><span class="font-bold text-[var(--color-text)]">+${card.dataset.addonPrice}€</span>`;
            recapAddons.appendChild(row);
          }
        });
      }

      const recapTotal = document.getElementById('recap-total');
      if (recapTotal) recapTotal.textContent = `${total}€`;

      const recapInfo = document.getElementById('recap-info');
      if (recapInfo) {
        const v = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLTextAreaElement)?.value?.trim() || '';
        let html = `
          <div class="flex justify-between py-1.5 border-b border-[var(--color-border)]">
            <span class="text-[var(--color-text-muted)]">Nom</span>
            <span class="font-medium">${v('fullname')}</span>
          </div>
          <div class="flex justify-between py-1.5 border-b border-[var(--color-border)]">
            <span class="text-[var(--color-text-muted)]">Entreprise</span>
            <span class="font-medium">${v('company')}</span>
          </div>
          <div class="flex justify-between py-1.5 border-b border-[var(--color-border)]">
            <span class="text-[var(--color-text-muted)]">Ville</span>
            <span class="font-medium">${v('city')}</span>
          </div>
          <div class="flex justify-between py-1.5 border-b border-[var(--color-border)]">
            <span class="text-[var(--color-text-muted)]">Email</span>
            <span class="font-medium">${v('order-email')}</span>
          </div>
          <div class="flex justify-between py-1.5">
            <span class="text-[var(--color-text-muted)]">Téléphone</span>
            <span class="font-medium">${v('order-phone')}</span>
          </div>`;
        if (v('activity-desc')) {
          html += `<div class="pt-3 mt-2 border-t border-[var(--color-border)]">
            <span class="text-xs text-[var(--color-text-muted)]">Activité</span>
            <p class="text-sm mt-0.5">${v('activity-desc')}</p>
          </div>`;
        }
        recapInfo.innerHTML = html;
      }
    }

    // Form submit guard
    form?.addEventListener('submit', (e) => {
      if (!validateStep3()) { e.preventDefault(); goToStep(3, 'back'); }
    });
  });
</script>
