<BaseLayout
  title={title}
  description={description}
  noindex={true}
  lang="fr"
  frPath="/audit/paccord-piano-full"
>

  <!-- ═══════ HERO ═══════ -->
  <section class="relative w-full px-6 py-16 md:px-8 md:py-24 overflow-hidden" style="background-color:#0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image:radial-gradient(circle,white 1px,transparent 1px);background-size:40px 40px;"></div>
    <div class="absolute top-20 -left-32 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background:#E86C47;"></div>
    <div class="mx-auto max-w-4xl relative z-10">
      <div class="mb-4 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]/40">
        <span class="w-2 h-2 rounded-full bg-[#E86C47]"></span>
        <span class="text-sm font-semibold text-white/90">Rapport confidentiel — Edition complete</span>
      </div>
      <h1 class="mb-4 text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl">
        Audit UX + Technique — <span class="bg-gradient-to-r from-[#E86C47] to-[#F5C8B3] bg-clip-text text-transparent">P'accord Piano</span>
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mb-8">
        20 personas avec parcours complets + audit technique de <strong class="text-white">paccord-piano.fr</strong> — Simon Pacor, accordeur-reparateur, Chartres (28).
      </p>
      <div class="flex flex-wrap gap-3">
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">20 personas</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">6 canaux</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">5 pages scrapees</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">29 mars 2026</span>
      </div>
    </div>
  </section>

  <!-- ═══════ TAB BAR ═══════ -->
  <nav class="sticky top-16 md:top-20 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-2 h-12 text-sm overflow-x-auto">
      <button data-tab="0" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-[var(--color-accent)] bg-[var(--color-accent)]/10">Synthese</button>
      <button data-tab="1" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Technique</button>
      <button data-tab="2" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Visiteurs <span class="ml-1 text-xs text-neutral-400">20</span></button>
      <button data-tab="3" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Ameliorations <span class="ml-1 text-xs text-neutral-400">{nbAmelios}</span></button>
    </div>
  </nav>

  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-webkit-overflow-scrolling:touch;scrollbar-width:none;">

    <!-- ════ PANEL 1 — SYNTHESE ════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

      <!-- KPIs -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
            <p class="text-3xl md:text-4xl font-bold text-red-600">{tauxConv}%</p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Taux de conversion</p>
            <p class="mt-2 text-xs text-[var(--color-text-muted)]">{convertis} conv · {hesitants} hes · {quittent} partis</p>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
            <p class="text-3xl md:text-4xl font-bold text-amber-600">{avgExp}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Experience</p>
            <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden"><div class="h-full bg-amber-500" style={`width:${Number(avgExp)*10}%`}></div></div>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
            <p class="text-3xl md:text-4xl font-bold text-blue-600">{avgConf}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Confiance</p>
            <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden"><div class="h-full bg-blue-500" style={`width:${Number(avgConf)*10}%`}></div></div>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
            <p class="text-3xl md:text-4xl font-bold text-orange-600">{avgClarte}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Clarte</p>
            <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden"><div class="h-full bg-orange-500" style={`width:${Number(avgClarte)*10}%`}></div></div>
          </div>
        </div>
      </div>

      <!-- Paradoxe -->
      <div class="w-full px-6 py-8 md:px-8 bg-white">
        <div class="mx-auto max-w-5xl">
          <div class="rounded-xl border-l-4 border-l-[var(--color-accent)] bg-[var(--color-accent)]/5 p-6 md:p-8">
            <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">Paradoxe principal</h2>
            <p class="text-[var(--color-text)] leading-relaxed">
              P'accord Piano a un <strong>outil de conversion excellent</strong> (le calculateur de prix par code postal) entoure d'un <strong>desert de reassurance</strong>. Le calculateur repond a "combien ?" en 10 secondes. Mais personne ne repond a "pourquoi vous ?". Les visiteurs obtiennent le prix puis quittent faute de preuves. Le bouche-a-oreille compense (67% de conversion) mais <strong>le site seul ne convertit aucun visiteur en phase de comparaison (0/7)</strong>.
            </p>
          </div>
        </div>
      </div>

      <!-- Canal -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-2">Conversion par canal</h2>
          <p class="text-[var(--color-text-muted)] mb-8">Bouche-a-oreille seul canal efficace (67%). Google Search, IA et Facebook : 0%.</p>
          <div class="grid md:grid-cols-2 gap-4">
            {canalStats.map((c) => {
              const pct = Math.round((c.conv / c.total) * 100);
              return (
                <div class="rounded-xl border border-[var(--color-border)] bg-white p-5">
                  <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-[var(--color-text)] text-sm">{c.canal}</h3>
                    <span class={`text-base font-bold ${pct > 50 ? 'text-emerald-600' : pct > 0 ? 'text-amber-600' : 'text-red-600'}`}>{pct}%</span>
                  </div>
                  <div class="h-3 rounded-full bg-neutral-100 overflow-hidden mb-3">
                    <div class="h-full flex">
                      <div class="bg-emerald-500" style={`width:${(c.conv/c.total)*100}%`}></div>
                      <div class="bg-amber-400" style={`width:${(c.hesitant/c.total)*100}%`}></div>
                      <div class="bg-red-400" style={`width:${(c.quitte/c.total)*100}%`}></div>
                    </div>
