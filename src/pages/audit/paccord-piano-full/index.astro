    </section>

  </div>

  <style is:inline>
    #panels { -ms-overflow-style:none; }
    #panels::-webkit-scrollbar { display:none; }
  </style>

  <script is:inline>
    const panels = document.getElementById('panels');
    const tabs = document.querySelectorAll('.tab-btn');
    const sections = panels.querySelectorAll('.tab-panel');
    function activateTab(i) {
      tabs.forEach((b, j) => {
        if (j === i) { b.classList.remove('text-neutral-500','hover:text-neutral-700'); b.classList.add('text-[var(--color-accent)]','bg-[var(--color-accent)]/10'); }
        else { b.classList.remove('text-[var(--color-accent)]','bg-[var(--color-accent)]/10'); b.classList.add('text-neutral-500','hover:text-neutral-700'); }
      });
    }
    tabs.forEach((btn, i) => btn.addEventListener('click', () => { sections[i].scrollIntoView({behavior:'smooth',inline:'start',block:'nearest'}); activateTab(i); }));
    let t;
    panels.addEventListener('scroll', () => { clearTimeout(t); t = setTimeout(() => activateTab(Math.round(panels.scrollLeft / panels.offsetWidth)), 50); }, {passive:true});
  </script>

</BaseLayout>
