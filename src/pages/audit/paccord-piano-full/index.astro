// ── Technique ──
const ps = {
  m: { perf: 68, access: 92, bp: 100, seo: 100 },
  d: { perf: 90, access: 91, bp: 100, seo: 100 },
};
const cwvData = {
  mobile:  [['lcp','LCP affichage principal','6.6s'],['cls','CLS stabilite visuelle','0.137'],['tbt','TBT reactivite','60ms'],['fcp','FCP premier affichage','2.5s']],
  desktop: [['lcp','LCP affichage principal','1.5s'],['cls','CLS stabilite visuelle','0.128'],['tbt','TBT reactivite','0ms'], ['fcp','FCP premier affichage','0.7s']],
};
const observatory = { grade: 'C-', score: 45, passed: 6, total: 10 };
const obsTests = [
  { name: 'Content Security Policy (CSP)',  pass: false, impact: '-25 pts' },
  { name: 'X-Frame-Options',                pass: false, impact: '-20 pts' },
  { name: 'X-Content-Type-Options',         pass: false, impact: '-5 pts'  },
