  { name: 'CORS non implemente (OK)',       pass: true,  impact: '+0'      },
];
const schemaChecks = [
  'JSON-LD present', '@type LocalBusiness', 'name / url / description',
  'address + geo', 'telephone', 'openingHours', 'image / logo',
  'sameAs (reseaux sociaux)', 'aggregateRating', 'Service / priceRange',
];
const ogChecks = [
  { label: 'og:title',       ok: false },
  { label: 'og:description', ok: false },
  { label: 'og:image',       ok: false },
  { label: 'og:url',         ok: false },
  { label: 'og:type',        ok: false },
  { label: 'twitter:card',   ok: false },
  { label: 'canonical',      ok: true  },
  { label: 'viewport',       ok: true  },
];

// ── Helpers ──
function sc(v: number)  { return v >= 90 ? '#22c55e' : v >= 50 ? '#f59e0b' : '#ef4444'; }
function stc(v: number) { return v >= 90 ? 'text-green-600' : v >= 50 ? 'text-amber-600' : 'text-red-600'; }
function sev(s: string) { return s === 'critique' ? 'bg-red-100 text-red-800' : s === 'haute' ? 'bg-orange-100 text-orange-800' : 'bg-blue-100 text-blue-800'; }
function dBorder(d: string) { return d === 'Convertit' ? 'border-green-200 bg-green-50/30' : d === 'Hesite' ? 'border-amber-200 bg-amber-50/30' : 'border-neutral-200 bg-neutral-50/30'; }
function dBadge(d: string)  { return d === 'Convertit' ? 'bg-emerald-100 text-emerald-800' : d === 'Hesite' ? 'bg-amber-100 text-amber-800' : 'bg-neutral-100 text-neutral-700'; }
function dtBorder(d: string){ return d === 'Convertit' ? 'border-green-200' : d === 'Hesite' ? 'border-amber-200' : 'border-neutral-200'; }
function cwvBg(k: string, v: string) {
  const n = parseFloat(v);
  const good = k === 'lcp' ? n < 2.5 : k === 'cls' ? n < 0.1 : k === 'fcp' ? n < 1.8 : n < 200;
  const mid  = k === 'lcp' ? n < 4   : k === 'cls' ? n < 0.25: k === 'fcp' ? n < 3   : n < 600;
  return good ? 'bg-green-50 text-green-800' : mid ? 'bg-amber-50 text-amber-800' : 'bg-red-50 text-red-800';
}
function cwvLbl(k: string, v: string) {
  const n = parseFloat(v);
  const good = k === 'lcp' ? n < 2.5 : k === 'cls' ? n < 0.1 : k === 'fcp' ? n < 1.8 : n < 200;
  const mid  = k === 'lcp' ? n < 4   : k === 'cls' ? n < 0.25: k === 'fcp' ? n < 3   : n < 600;
  return good ? 'Bon' : mid ? 'A ameliorer' : 'Mauvais';
}
const obsClr = observatory.grade.startsWith('A') ? { border:'border-green-200', bg:'bg-green-50', text:'text-green-700' }
             : observatory.grade.startsWith('B') ? { border:'border-amber-200',  bg:'bg-amber-50',  text:'text-amber-700'  }
             :                                     { border:'border-red-200',     bg:'bg-red-50',    text:'text-red-700'    };
const nbAmelios = ameliorations.haute.length + ameliorations.moyenne.length + ameliorations.discuter.length;
