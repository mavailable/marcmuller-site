const amelioDiscuter = [
  { emoji: '🎯', title: 'Ciblage pub Instagram / Facebook', detail: 'Les personas hors-cible arrivent par des pubs mal ciblees. Ajuster les audiences ou creer une offre particuliers.' },
  { emoji: '📋', title: 'Clarifier l\'engagement 48 mois', detail: 'Mentionne sans contrepartie visible, cree un frein psychologique. A detailler dans la communication.' },
  { emoji: '🌡️', title: 'Camera thermique COVID', detail: 'Service obsolete toujours en ligne. A retirer ou repositionner.' },
  { emoji: '📍', title: 'Geolocalisation via Geotek', detail: 'Le renvoi vers un partenaire externe desoriente. Clarifier le role de chacun.' },
];

// ─── HELPERS ───
function scoreColor(s: number) {
  if (s >= 90) return '#22c55e';
  if (s >= 50) return '#f59e0b';
  return '#ef4444';
}

function scoreTextColor(s: number) {
  if (s >= 90) return 'text-green-600';
  if (s >= 50) return 'text-amber-600';
  return 'text-red-600';
}

function decisionColor(d: string) {
  if (d === 'Convertit') return 'bg-emerald-100 text-emerald-800';
  if (d === 'Hesite') return 'bg-amber-100 text-amber-800';
  return 'bg-red-100 text-red-800';
}

function decisionBorder(d: string) {
  if (d === 'Convertit') return 'border-green-200 bg-green-50/40';
  if (d === 'Hesite') return 'border-amber-200 bg-amber-50/40';
  return 'border-neutral-200 bg-neutral-50/40';
}

function severityColor(s: string) {
  if (s === 'critique') return 'bg-red-100 text-red-800';
  if (s === 'haute') return 'bg-orange-100 text-orange-800';
  return 'bg-blue-100 text-blue-800';
}

function cwvBg(status: string) {
  if (status === 'good') return 'bg-green-50';
  if (status === 'mid') return 'bg-amber-50';
  return 'bg-red-50';
}

function cwvText(status: string) {
  if (status === 'good') return 'text-green-700';
  if (status === 'mid') return 'text-amber-700';
  return 'text-red-700';
}

function cwvBadge(status: string) {
  if (status === 'good') return 'bg-green-100 text-green-800';
  if (status === 'mid') return 'bg-amber-100 text-amber-800';
  return 'bg-red-100 text-red-800';
}

function cwvLabel(status: string) {
  if (status === 'good') return 'Bon';
  if (status === 'mid') return 'Moyen';
  return 'Mauvais';
}

function scoreBar(val: number) {
  return `${val * 10}%`;
}

function gradeColor(g: string) {
  if (g.startsWith('A')) return { border: 'border-green-300', bg: 'bg-green-50', text: 'text-green-700' };
  if (g.startsWith('B')) return { border: 'border-amber-300', bg: 'bg-amber-50', text: 'text-amber-700' };
  return { border: 'border-red-300', bg: 'bg-red-50', text: 'text-red-700' };
}

const gc = gradeColor(observatory.grade);
---

<BaseLayout
  title={title}
  description={description}
  noindex={true}
  lang="fr"
  frPath="/audit/solutic57"
>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24 overflow-hidden" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-20 -left-32 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: #E86C47;"></div>

    <div class="mx-auto max-w-4xl relative z-10">
      <div class="mb-4 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]/40">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white/90">Rapport confidentiel</span>
      </div>

      <h1 class="mb-4 text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl">
        Audit UX + Technique — <span class="bg-gradient-to-r from-[#E86C47] to-[#F5C8B3] bg-clip-text text-transparent">SOLUTIC57</span>
      </h1>

      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mb-8">
        Analyse complete de <strong class="text-white">solutic57.fr</strong> — audit technique (PageSpeed, securite, SEO) + simulation de 20 visites personas avec feedback detaille.
      </p>

      <div class="flex flex-wrap gap-3">
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">20 personas testes</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">9 canaux d'arrivee</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">Audit Lighthouse + Observatory</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">29 mars 2026</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ TAB BAR ═══════════════════ -->
  <nav class="sticky top-16 md:top-20 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-2 h-12 text-sm overflow-x-auto">
      <button data-tab="0" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-primary-700 bg-primary-50">Synthese</button>
      <button data-tab="1" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Technique</button>
      <button data-tab="2" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Visiteurs <span class="ml-1 text-xs text-neutral-400">20</span>
      </button>
      <button data-tab="3" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Ameliorations <span class="ml-1 text-xs text-neutral-400">{amelioHaute.length + amelioMoyenne.length + amelioDiscuter.length}</span>
      </button>
    </div>
  </nav>

  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">

    <!-- ═══════════════════ PANEL 1 : SYNTHESE ═══════════════════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

      <!-- KPI Cards -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class={`text-3xl md:text-4xl font-bold ${tauxConv < 20 ? 'text-red-600' : tauxConv < 40 ? 'text-amber-600' : 'text-emerald-600'}`}>{tauxConv}%</p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Taux de conversion</p>
              <p class="mt-2 text-xs text-[var(--color-text-muted)]">{convertis} convertis · {hesitants} hesitants · {quitte} partis</p>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-amber-600">{avgExp}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Experience</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-amber-500" style={`width: ${scoreBar(Number(avgExp))}`}></div>
              </div>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-blue-600">{avgConf}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Confiance</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-blue-500" style={`width: ${scoreBar(Number(avgConf))}`}></div>
              </div>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-orange-600">{avgClarte}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Clarte</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-orange-500" style={`width: ${scoreBar(Number(avgClarte))}`}></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Paradoxe -->
      <div class="w-full px-6 py-8 md:px-8 bg-white">
        <div class="mx-auto max-w-5xl">
          <div class="rounded-xl border-l-4 border-l-[var(--color-accent)] bg-accent-50 p-6 md:p-8">
            <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">Paradoxe principal</h2>
            <p class="text-[var(--color-text)] leading-relaxed">
              Les <strong>30 avis Google 5/5</strong> font plus de travail commercial que l'integralite du site. Les 2 seules conversions viennent de visiteurs deja convaincus <em>avant</em> d'arriver (bouche-a-oreille + urgence post-vol). Le site ne convertit personne par lui-meme — il sert uniquement de <strong>filtre anti-decouragement</strong>, pas de machine a leads.
            </p>
          </div>
        </div>
      </div>

      <!-- Conversion par canal -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-2">Conversion par canal</h2>
          <p class="text-[var(--color-text-muted)] mb-8">Seuls le bouche-a-oreille et Google Maps convertissent (33%). Tous les autres canaux affichent 0% — le site ne confirme pas les attentes generees en amont.</p>
          <div class="grid md:grid-cols-2 gap-4">
            {canalStats.map((c) => {
              const pct = c.total > 0 ? Math.round((c.conv / c.total) * 100) : 0;
              return (
                <div class="rounded-xl border border-[var(--color-border)] bg-white p-5">
                  <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-[var(--color-text)]">{c.canal}</h3>
                    <span class={`text-lg font-bold ${pct > 50 ? 'text-emerald-600' : pct > 0 ? 'text-amber-600' : 'text-red-600'}`}>{pct}%</span>
                  </div>
                  <div class="h-3 rounded-full bg-neutral-100 overflow-hidden mb-3">
                    <div class="h-full rounded-full flex">
                      <div class="bg-emerald-500" style={`width: ${(c.conv / c.total) * 100}%`}></div>
                      <div class="bg-amber-400" style={`width: ${(c.hesitant / c.total) * 100}%`}></div>
                      <div class="bg-red-400" style={`width: ${(c.quitte / c.total) * 100}%`}></div>
                    </div>
                  </div>
                  <div class="flex gap-4 text-xs text-[var(--color-text-muted)]">
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> {c.conv} conv.</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-amber-400"></span> {c.hesitant} hes.</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-400"></span> {c.quitte} partis</span>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Conversion par maturite -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-white">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">Conversion par maturite</h2>
          <div class="grid md:grid-cols-3 gap-4">
            {maturiteStats.map((m) => (
              <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 text-center">
                <p class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-2">{m.level}</p>
                <p class={`text-4xl font-bold ${m.pct === '0%' ? 'text-red-600' : m.pct === '33%' ? 'text-amber-600' : 'text-emerald-600'}`}>{m.pct}</p>
                <p class="mt-1 text-sm text-[var(--color-text-muted)]">{m.conv}/{m.total} convertis</p>
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-xl bg-red-50 border border-red-200 p-5">
            <p class="text-sm text-red-800">
              <strong>Alerte :</strong> 0% de conversion en phase <strong>decouverte</strong> et <strong>comparaison</strong>. Seuls les visiteurs en phase <strong>decision</strong> (deja convaincus avant d'arriver) passent a l'action — et encore, seulement 33%.
            </p>
          </div>
        </div>
      </div>

    </section>

    <!-- ═══════════════════ PANEL 2 : TECHNIQUE ═══════════════════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

      <!-- PageSpeed Scores -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-2">Scores PageSpeed Lighthouse</h2>
          <p class="text-[var(--color-text-muted)] mb-8">Votre site est lent, surtout sur mobile. Les visiteurs attendent plus de 16 secondes avant de voir le contenu principal.</p>

          <div class="grid md:grid-cols-2 gap-6">
            {/* Mobile */}
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-6">
              <h3 class="font-semibold text-[var(--color-text)] mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                Mobile
              </h3>
              <div class="grid grid-cols-4 gap-4">
                {Object.entries(lighthouseScores.mobile).map(([key, val]) => (
                  <div class="text-center">
                    <div class="relative w-16 h-16 mx-auto mb-2">
                      <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e5e7eb" stroke-width="3" />
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke={scoreColor(val)} stroke-width="3" stroke-dasharray={`${val}, 100`} stroke-linecap="round" />
                      </svg>
                      <span class={`absolute inset-0 flex items-center justify-center text-lg font-bold ${scoreTextColor(val)}`}>{val}</span>
                    </div>
                    <p class="text-xs text-neutral-600 font-medium">{key === 'perf' ? 'Perf.' : key === 'access' ? 'Access.' : key === 'bp' ? 'Pratiques' : 'SEO'}</p>
                  </div>
                ))}
              </div>
            </div>

            {/* Desktop */}
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-6">
              <h3 class="font-semibold text-[var(--color-text)] mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                Desktop
              </h3>
              <div class="grid grid-cols-4 gap-4">
                {Object.entries(lighthouseScores.desktop).map(([key, val]) => (
                  <div class="text-center">
                    <div class="relative w-16 h-16 mx-auto mb-2">
                      <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e5e7eb" stroke-width="3" />
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke={scoreColor(val)} stroke-width="3" stroke-dasharray={`${val}, 100`} stroke-linecap="round" />
                      </svg>
                      <span class={`absolute inset-0 flex items-center justify-center text-lg font-bold ${scoreTextColor(val)}`}>{val}</span>
                    </div>
                    <p class="text-xs text-neutral-600 font-medium">{key === 'perf' ? 'Perf.' : key === 'access' ? 'Access.' : key === 'bp' ? 'Pratiques' : 'SEO'}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Core Web Vitals -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-white">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">Core Web Vitals</h2>
          <div class="grid md:grid-cols-2 gap-6">
            <div>
              <h3 class="text-sm font-semibold text-[var(--color-text-muted)] mb-3 uppercase tracking-wider">Mobile</h3>
              <div class="space-y-2">
                {Object.entries(cwv).map(([key, v]) => (
                  <div class={`flex items-center justify-between p-3 rounded-lg ${cwvBg(v.mobileStatus)}`}>
                    <div>
                      <span class="text-xs font-bold text-neutral-700">{key.toUpperCase()}</span>
                      <span class="text-xs text-neutral-500 ml-1">({key === 'lcp' ? 'Largest Contentful Paint' : key === 'fcp' ? 'First Contentful Paint' : key === 'cls' ? 'Cumulative Layout Shift' : key === 'tbt' ? 'Total Blocking Time' : 'Speed Index'})</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class={`text-sm font-bold ${cwvText(v.mobileStatus)}`}>{v.mobile}</span>
                      <span class={`text-[10px] px-1.5 py-0.5 rounded font-medium ${cwvBadge(v.mobileStatus)}`}>{cwvLabel(v.mobileStatus)}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
            <div>
              <h3 class="text-sm font-semibold text-[var(--color-text-muted)] mb-3 uppercase tracking-wider">Desktop</h3>
              <div class="space-y-2">
                {Object.entries(cwv).map(([key, v]) => (
                  <div class={`flex items-center justify-between p-3 rounded-lg ${cwvBg(v.desktopStatus)}`}>
                    <div>
                      <span class="text-xs font-bold text-neutral-700">{key.toUpperCase()}</span>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class={`text-sm font-bold ${cwvText(v.desktopStatus)}`}>{v.desktop}</span>
                      <span class={`text-[10px] px-1.5 py-0.5 rounded font-medium ${cwvBadge(v.desktopStatus)}`}>{cwvLabel(v.desktopStatus)}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Observatory -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">Securite HTTP</h2>
          <p class="text-[var(--color-text-muted)] mb-6">Votre site manque de protections de securite basiques. C'est comme laisser la porte d'entree ouverte.</p>

          <div class={`flex items-center gap-4 p-4 rounded-xl border ${gc.border} ${gc.bg} mb-6`}>
            <div class={`text-3xl font-black ${gc.text}`}>{observatory.grade}</div>
            <div>
              <p class="text-sm font-semibold text-neutral-900">Mozilla Observatory</p>
              <p class="text-xs text-neutral-500">{observatory.passed}/{observatory.total} tests passes — Score {observatory.score}/100</p>
            </div>
          </div>

          <h3 class="font-semibold text-[var(--color-text)] mb-3">Headers de securite manquants</h3>
          <div class="space-y-1.5">
            {missingHeaders.map((h) => (
              <div class="flex items-center gap-2 py-1.5">
                <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                <span class="text-sm text-neutral-400 line-through">{h}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Schema.org + OG + SEO -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-white">
        <div class="mx-auto max-w-5xl">
          <div class="grid md:grid-cols-3 gap-6">

            {/* Schema.org */}
            <div>
              <h3 class="font-semibold text-[var(--color-text)] mb-3">Schema.org</h3>
              <p class="text-xs text-[var(--color-text-muted)] mb-3">Google ne comprend pas bien ce que vous proposez</p>
              <div class="space-y-1">
                {schemaChecks.map((c) => (
                  <div class="flex items-center gap-2 py-1">
                    {c.ok ? (
                      <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    ) : (
                      <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    )}
                    <span class={`text-xs ${c.ok ? 'text-neutral-700' : 'text-neutral-400 line-through'}`}>{c.label}</span>
                  </div>
                ))}
              </div>
            </div>

            {/* Open Graph */}
            <div>
              <h3 class="font-semibold text-[var(--color-text)] mb-3">Open Graph</h3>
              <p class="text-xs text-[var(--color-text-muted)] mb-3">Quand quelqu'un partage votre site, aucune preview n'apparait</p>
              <div class="space-y-1">
                {ogChecks.map((c) => (
                  <div class="flex items-center gap-2 py-1">
                    {c.ok ? (
                      <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                    ) : (
