<BaseLayout
  title={title}
  description={description}
  noindex={true}
  lang="fr"
  frPath="/audit/zompa"
>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24 overflow-hidden" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-20 -left-32 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: #E86C47;"></div>
    <div class="absolute bottom-0 right-0 w-72 h-72 rounded-full opacity-5 blur-3xl" style="background: #818CF8;"></div>

    <div class="mx-auto max-w-4xl relative z-10">
      <div class="mb-4 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]/40">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white/90">Rapport confidentiel</span>
      </div>

      <h1 class="mb-4 text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl">
        Audit UX + Technique — <span class="bg-gradient-to-r from-[#E86C47] to-[#F5C8B3] bg-clip-text text-transparent">Zompa Design</span>
      </h1>

      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mb-8">
        Simulation de 20 visites personas + audit technique complet de <strong class="text-white">zompa.fr</strong> — graphiste specialisee escape games et experiences immersives.
      </p>

      <div class="flex flex-wrap gap-3">
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">20 personas testes</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">5 canaux d'arrivee</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">10 pages analysees</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">29 mars 2026</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ TAB BAR ═══════════════════ -->
  <nav class="sticky top-16 md:top-20 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-2 h-12 text-sm overflow-x-auto">
      <button data-tab="0" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-[var(--color-accent)] bg-[var(--color-accent)]/10">Synthese</button>
      <button data-tab="1" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Technique</button>
      <button data-tab="2" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Visiteurs <span class="ml-1 text-xs text-neutral-400">20</span>
      </button>
      <button data-tab="3" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Ameliorations <span class="ml-1 text-xs text-neutral-400">{ameliorations.haute.length + ameliorations.moyenne.length}</span>
      </button>
    </div>
  </nav>

  <!-- ═══════════════════ PANELS ═══════════════════ -->
  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">

    <!-- ══ PANEL 0 : SYNTHESE ══ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-10 space-y-10">

        <!-- KPI Cards -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="bg-white rounded-xl border border-neutral-200 p-5 text-center shadow-sm">
            <div class="text-3xl font-bold text-[var(--color-accent)]">{tauxConversion}%</div>
            <div class="text-sm text-neutral-500 mt-1">Taux de conversion</div>
            <div class="text-xs text-neutral-400">{convertis} / 20 personas</div>
          </div>
          <div class="bg-white rounded-xl border border-neutral-200 p-5 text-center shadow-sm">
            <div class="text-3xl font-bold text-neutral-800">{avgExp}</div>
            <div class="text-sm text-neutral-500 mt-1">Experience / 10</div>
          </div>
          <div class="bg-white rounded-xl border border-neutral-200 p-5 text-center shadow-sm">
            <div class="text-3xl font-bold text-neutral-800">{avgConf}</div>
            <div class="text-sm text-neutral-500 mt-1">Confiance / 10</div>
          </div>
          <div class="bg-white rounded-xl border border-neutral-200 p-5 text-center shadow-sm">
            <div class="text-3xl font-bold text-neutral-800">{avgClarte}</div>
            <div class="text-sm text-neutral-500 mt-1">Clarte / 10</div>
          </div>
        </div>

        <!-- Paradoxe principal -->
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-6">
          <div class="flex items-start gap-3">
            <span class="text-2xl">⚡</span>
            <div>
