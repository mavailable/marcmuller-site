function decisionColor(d: string) {
  if (d === 'Convertit') return 'bg-emerald-100 text-emerald-800 border-emerald-200';
  if (d === 'Hesite') return 'bg-amber-100 text-amber-800 border-amber-200';
  return 'bg-red-100 text-red-800 border-red-200';
}

function decisionBorder(d: string) {
  if (d === 'Convertit') return 'border-green-200 bg-green-50/40';
  if (d === 'Hesite') return 'border-amber-200 bg-amber-50/40';
  return 'border-neutral-200 bg-neutral-50/40';
}

function severityColor(s: string) {
  if (s === 'critique') return 'bg-red-100 text-red-800';
  if (s === 'haute') return 'bg-orange-100 text-orange-800';
  return 'bg-blue-100 text-blue-800';
}

function scoreColor(v: number) {
  if (v >= 90) return '#22c55e';
  if (v >= 50) return '#f59e0b';
  return '#ef4444';
}

function cwvColor(metric: string, val: string) {
  const n = parseFloat(val);
  if (metric === 'lcp') return n <= 2.5 ? '#22c55e' : n <= 4 ? '#f59e0b' : '#ef4444';
  if (metric === 'cls') return n <= 0.1 ? '#22c55e' : n <= 0.25 ? '#f59e0b' : '#ef4444';
  if (metric === 'tbt') { const ms = parseInt(val); return ms <= 200 ? '#22c55e' : ms <= 600 ? '#f59e0b' : '#ef4444'; }
  if (metric === 'fcp') return n <= 1.8 ? '#22c55e' : n <= 3 ? '#f59e0b' : '#ef4444';
  return '#f59e0b';
}
