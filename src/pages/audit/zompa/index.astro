// ─── DATA ───
const personas = [
  { id: 1, name: 'Mathieu', age: 38, situation: 'Gerant de salle escape game, Lyon', canal: 'Google Search', maturite: 'Comparaison', device: 'Desktop', decision: 'Hesite', exp: 6, conf: 7, clarte: 4, emoji: '🔍', contexte: 'Ouvre une 4e salle "Victorian detective", a eu de mauvaises experiences avec un graphiste generaliste', question: 'Peut-elle livrer 15 documents d\'ambiance victoriens d\'ici 4 mois pour quel budget ?', reponse: 'Partiellement', commentReponse: 'Le delai 2-3 mois est en FAQ (4 mois faisable), mais le budget est totalement absent.', impression: 'Hero fort, specialisation claire. Logos Netflix/WB/DC rassurent un gerant de salle. LCP 3.9s acceptable en desktop.', parcours: [['Accueil', 'Logos Netflix/WB/DC tres rassurants — il reconnait les clients haut de gamme'], ['Portfolio', 'Batman et Stranger Things = meme registre que son projet victorien'], ['Services', 'Aucun prix, frustration — "comment je compare avec les autres prestataires ?"'], ['FAQ', 'Delai 2-3 mois trouve mais enfui'], ['Contact', 'Formulaire sans telephone — frein pour un achat B2B']], impactTech: 'LCP 3.9s desktop acceptable. Securite C- invisible pour Mathieu mais absence de SIRET problematique pour un bon de commande.', positifs: ['Portfolio licences majeures (Netflix, WB, DC)', 'Specialisation escape game ultra-claire', 'Univers graphique coherent et professionnel', 'Delai 2-3 mois rassurant pour son echance a 4 mois'], frictions: ['Aucun prix ni fourchette', 'Pas de telephone pour un achat B2B significatif', 'Pas de verbatims clients malgre des references premium', 'SIRET absent'], raison: 'Portfolio trop convaincant pour partir mais absence de prix empeche la comparaison.', changement: 'Une fourchette tarifaire indicative et un numero de telephone feraient basculer vers la prise de contact.' },
  { id: 2, name: 'Sophie', age: 29, situation: 'Chargee de projet chez un editeur de jeux (Paris)', canal: 'LinkedIn', maturite: 'Decision', device: 'Mobile', decision: 'Hesite', exp: 4, conf: 6, clarte: 4, emoji: '📚', contexte: 'Veut lancer une gamme de jeux d\'enquete premium avant Noel, urgence apres avoir vu un post LinkedIn sur Stranger Things', question: 'Est-elle disponible dans les 2 prochains mois ?', reponse: 'Non', commentReponse: 'Delai 2-3 mois en FAQ mais disponibilite temps reel totalement absente.', impression: 'Arrive avec forte intention depuis LinkedIn. LCP 9.2s catastrophique sur mobile — CLS 0.197 provoque des decalages pendant le chargement.', parcours: [['Accueil (lent)', 'Logo Hachette visible — signal editeur pertinent'], ['Portfolio', 'Projets editeurs pertinents (Detective Box, Hachette)'], ['Contact', 'Cherche un telephone pour une conversation rapide — trouve uniquement un formulaire']], impactTech: 'LCP 9.2s mobile redibitoire — en deplacement entre deux reunions, une DA ne patiente pas 9 secondes. CLS 0.197 visible.', positifs: ['Hachette directement dans les logos', 'Specialisation documents d\'enquete — exactement son besoin', 'Reponse promis en 24h'], frictions: ['Chargement mobile catastrophique (9.2s LCP)', 'Aucune info sur la disponibilite actuelle', 'Pas de telephone pour son urgence', 'CLS mobile instabilise la navigation'], raison: 'Trop de frictions au moment de passer a l\'action. La lenteur mobile peut provoquer l\'abandon.', changement: 'Numero de telephone visible + badge "Disponible pour nouveaux projets — depart dans X semaines".' },
  { id: 3, name: 'Romain', age: 25, situation: 'Game designer freelance, Bordeaux', canal: 'Instagram', maturite: 'Decouverte', device: 'Mobile', decision: 'Quitte', exp: 3, conf: 5, clarte: 2, emoji: '🎲', contexte: 'Cree son 1er jeu d\'enquete en boite, budget < 2 000 EUR, ebloui par les visuels Batman sur Instagram', question: 'Combien ca coute pour 5-6 documents ?', reponse: 'Non', commentReponse: 'Absolument aucune information tarifaire sur le site.', impression: 'Coherence Instagram-site forte. LCP 9.2s mobile : attente. Portfolio impressionnant mais references Netflix/WB l\'intimident — "c\'est pas pour moi."', parcours: [['Portfolio', 'Qualite convaincante mais grosses references intimidantes'], ['Services', 'Aucun prix, frustration immmediate'], ['FAQ', 'Delais trouves mais pas de tarifs'], ['Quitte', 'Sans prix, impossible d\'evaluer si c\'est dans son budget']], impactTech: 'LCP 9.2s mobile depuis Instagram — tolérance a l\'attente tres faible sur mobile. CLS visible.', positifs: ['Coherence visuelle forte avec Instagram', 'Portfolio montre exactement les documents qu\'il cherche', 'Specialisation rassurante'], frictions: ['Aucun prix — raison principale de depart', 'Chargement lent depuis Instagram', 'References ultra-premium intimidantes pour un petit projet', 'Formulaire comme seul canal exploratoire'], raison: 'Absence totale de prix + references haut de gamme = part en supposant "c\'est hors de mon budget".', changement: 'Une ligne "documents d\'ambiance a partir de X EUR la piece" ou FAQ "vous travaillez avec des petits projets ?".' },
  { id: 4, name: 'Claire', age: 44, situation: 'Directrice agence evenementielle team-building, Nantes', canal: 'Bouche-a-oreille', maturite: 'Decision', device: 'Mobile', decision: 'Hesite', exp: 5, conf: 6, clarte: 5, emoji: '🎪', contexte: 'Escape game mobile barnum pour 200 personnes en septembre, recommandee par un confrere APEC', question: 'Elle a de l\'experience avec des barnums pour team-building entreprise ?', reponse: 'Partiellement', commentReponse: 'Barnums mentionnes dans les services, Koezio dans les logos — mais aucun cas client team-building corporate visible.', impression: 'Recommandation chaude compensant le LCP 9.2s mobile. Cherche "barnum team-building" — non visible en accueil.', parcours: [['Accueil', 'Koezio dans les logos — pertinent mais pas de reference corporate'], ['Services (Decors imprimes)', 'Barnums mentionnes — OK'], ['Portfolio', 'Pas de cas client team-building corporate'], ['Contact', 'Pas de telephone — frein decisif pour une directrice d\'agence']], impactTech: 'LCP 9.2s penible meme avec forte motivation. SIRET absent = probleme administratif pour un bon de commande agence.', positifs: ['Koezio dans les references', 'Barnums bien mentionnes dans les services', 'Recommandation compensant les lacunes'], frictions: ['Aucun cas client team-building/corporate visible', 'Pas de telephone pour valider rapidement', 'SIRET absent — obstacle B2B', 'Delai septembre non evalue'], raison: 'La recommandation est suffisamment forte pour ne pas partir, mais les lacunes ralentissent la decision.', changement: 'Cas client Koezio developpe avec photos barnum + SIRET en footer + numero de telephone.' },
  { id: 5, name: 'Nicolas', age: 52, situation: 'Directeur creatif agence com, Paris', canal: 'Reference directe', maturite: 'Decision', device: 'Desktop', decision: 'Convertit', exp: 7, conf: 8, clarte: 6, emoji: '🎬', contexte: 'A lu un article sur Batman Escape Paris, cherche une graphiste pour un projet sous licence entertainment', question: 'A-t-elle l\'experience pour des contraintes de charte de licence internationale ?', reponse: 'Partiellement', commentReponse: 'Batman (WB/DC) et Stranger Things (Netflix) prouvent l\'experience mais le site ne verbalise jamais ce savoir-faire.', impression: 'Desktop LCP 3.9s acceptable. WB/DC, Netflix, Ubisoft en page d\'accueil — parfait pour un directeur creatif. Premiere impression tres positive.', parcours: [['Accueil', 'Logos licences majeures — exactement ce qu\'il cherchait'], ['Portfolio Batman + Stranger Things', 'Passe du temps — qualite d\'execution convaincante'], ['A propos', 'Cherche "process licence/NDA" — ne trouve pas explicitement'], ['Contact', 'Formulaire OK pour un profil asynchrone']], impactTech: 'LCP desktop acceptable. Securite C- non visible en navigation normale. SIRET absent peut poser probleme pour le contrat agence.', positifs: ['References licences majeures exactement comme attendu', 'Univers graphique desktop coherent et premium', 'Specialisation revendiquee', 'Batman + Stranger Things impliquent des processus licence deja maitrise'], frictions: ['Page a-propos ne verbalise pas le process "licence internationale"', 'Pas de verbatims clients de licencies (WB, Netflix)', 'SIRET absent — probleme pour le contrat', 'Aucune mention de NDA/confidentialite'], raison: 'References Batman et Stranger Things sont des preuves suffisantes pour un profil qui lit entre les lignes.', changement: 'Un paragraphe "gestion de licences" dans a-propos + case studies avec contexte contractuel.' },
  { id: 6, name: 'Anais', age: 31, situation: 'Graphiste generaliste freelance, Toulouse', canal: 'Google Search', maturite: 'Comparaison', device: 'Mobile', decision: 'Quitte', exp: 6, conf: 7, clarte: 5, emoji: '🖌️', contexte: 'Cherche a se specialiser en escape game — visite de veille concurrentielle', question: 'Comment elle se positionne et quels sont ses tarifs ?', reponse: 'Partiellement', commentReponse: 'Positionnement limpide, tarifs totalement absents.', impression: 'Graphiste elle-meme, analyse le positionnement avec un oeil professionnel. Site lent sur mobile.', parcours: [['Services', 'Note la segmentation 5 offres — utile pour sa propre reflexion'], ['Portfolio', 'Impressed par Netflix/WB/Hachette — benchmark de marche'], ['FAQ', 'Cherche tarifs — "forfait personnalise" = mur'], ['Quitte', 'Bookmarke le site comme reference concurrentielle']], impactTech: 'LCP 9.2s mobile — elle note "site lourd" comme indicateur du niveau technique.', positifs: ['Positionnement tres clair et assume', 'Clients grands comptes = benchmark precieux', 'Identite visuelle forte et analysable'], frictions: ['Zero tarif impossible de se situer', 'Pas de temoignages sur la relation client', 'Absence de blog ou process detail'], raison: 'Repart avec portfolio comme reference mais sans info tarifaire. Visite d\'etude non commerciale.', changement: 'N/A — persona non-cliente' },
  { id: 7, name: 'Tom', age: 22, situation: 'Etudiant game design, Strasbourg', canal: 'Instagram', maturite: 'Decouverte', device: 'Mobile', decision: 'Quitte', exp: 4, conf: 7, clarte: 5, emoji: '🎓', contexte: 'Fan de @zompa_design depuis 6 mois, clique sur le lien du profil', question: 'Est-ce qu\'elle repond aux messages de petits crateurs ?', reponse: 'Non', commentReponse: 'Aucun signal d\'ouverture aux petits createurs/etudiants. Formulaire trop professionnel.', impression: 'LCP 9.2s mobile — commence a scroller Instagram dans un autre onglet pendant le chargement.', parcours: [['Portfolio', 'Plonge dedans pendant de longues minutes — visite de fan'], ['A propos', 'Cherche l\'histoire personnelle de Laurie'], ['Retourne sur Instagram', 'Pas de porte d\'entree adaptee a son profil']], impactTech: 'LCP 9.2s + CLS 0.197 — site qui "saute" pendant le chargement, impression de site pas fini.', positifs: ['Esthetique coherente avec Instagram', 'Portfolio inspirant pour ses propres projets', 'Positionement unique et distinctif'], frictions: ['Aucun pont entre le site et Instagram', 'Formulaire trop formel pour une demarche fan', 'Pas de contenu "behind the scenes"', 'Aucune raison de revenir ou de marquer le site'], raison: 'Repart impressionne sans avoir trouve de porte d\'entree adaptee. Ira sur Instagram pour un DM.', changement: 'Lien Instagram prooeminent + blog actif avec coulisses creatives.' },
  { id: 8, name: 'Isabelle', age: 46, situation: 'Responsable marketing grand parc de loisirs (50+ salles), Bruxelles', canal: 'LinkedIn', maturite: 'Comparaison', device: 'Desktop', decision: 'Hesite', exp: 6, conf: 6, clarte: 4, emoji: '🏢', contexte: 'Son agence graphique habituelle a ferme — urgence de trouver un remplacant pour Q3', question: 'Peut-elle gerer 3 salles en parallele sur l\'annee ?', reponse: 'Non', commentReponse: 'Aucune info sur la capacite de production, le rythme de travail, les partenaires.', impression: 'Desktop LCP 3.9s acceptable. Koezio dans le portfolio — signal grand parc pertinent.', parcours: [['Accueil', 'Grands clients rassurants, specialisation OK'], ['Portfolio', 'Koezio confirme — mais pas d\'info sur la volumetrie'], ['A propos', 'Cherche "equipe ? sous-traitants ?" — aucune reponse'], ['FAQ', 'Delai 2-3 mois x 3 salles = planning problematique'], ['Contact', 'Soumet formulaire avec demande d\'appel telephonique']], impactTech: 'LCP desktop acceptable. CLS 0.143 provoque micro-decalages. Securite C- risque si elle soumet des briefs confidentiels.', positifs: ['Koezio (parc de loisirs) — directement pertinent', 'Services couvrent ses 3 types de besoins', 'Identite visuelle professionnelle'], frictions: ['Aucune indication de capacite production', 'Pas de temoignages verbatims clients', 'Fourchettes tarifaires absentes', 'Formulaire sans option "partenariat long terme"'], raison: 'Tres interessee mais bloquee sur la question capacite/volume. Contacte mais avec d\'autres prestataires en parallele.', changement: 'Page a-propos mentionnant le reseau de partenaires/sous-traitants + Calendly pour un appel.' },
  { id: 9, name: 'Julien', age: 34, situation: 'Co-fondateur salle escape game, Lille', canal: 'Bouche-a-oreille', maturite: 'Decision', device: 'Mobile', decision: 'Convertit', exp: 6, conf: 8, clarte: 5, emoji: '🕵️', contexte: 'Renovation salle "polar 1930", ami a deja travaille avec Zompa — recommandation chaude', question: 'Le style correspond-il a mon theme polar annees 30 ?', reponse: 'Partiellement', commentReponse: 'Batman (Art Deco) approche le registre mais aucun projet "polar 1930" explicite — Julien doit inferer.', impression: 'Recommandation de confiance — le site doit confirmer, pas convaincre. LCP 9.2s teste sa patience mais il persiste.', parcours: [['Accueil', 'Validation immediate — "l\'ami avait raison, ca a de la gueule"'], ['Portfolio', 'Batman (annees 30 Art Deco) — le plus proche de son theme'], ['Services', '"Documents de jeu" = exactement son besoin'], ['Contact', 'Remplit le formulaire avec le brief polar 1930']], impactTech: 'LCP 9.2s penible pour quelqu\'un d\'enthousiaste. CLS risque de faire "rater" un visuel pertinent.', positifs: ['Recommandation neutralise 80% des objections', 'Polyvalence stylistique (Batman → proche polar)', 'Proximite geographique Roubaix/Lille — confiance supplementaire'], frictions: ['Portfolio non filtrable par style/epoque', 'Pas de prix — doit soumettre formulaire sans budget indicatif', 'Pas de telephone pour les personnes en phase de decision'], raison: 'Recommandation + portfolio + proximite geographique = contact envoye.', changement: 'Filtres portfolio par style/univers + fourchette tarifaire indicative.' },
  { id: 10, name: 'Marie', age: 39, situation: 'Directrice ecole primaire, Nantes', canal: 'Google Search', maturite: 'Decouverte', device: 'Tablette', decision: 'Quitte', exp: 4, conf: 5, clarte: 3, emoji: '🏫', contexte: 'Projet escape game pedagogique, budget APE 500 EUR', question: 'Elle travaille avec des ecoles et quel est le prix pour un petit projet ?', reponse: 'Non', commentReponse: 'Aucune mention du secteur educatif, des associations, ni des petits budgets.', impression: 'L\'univers sombre et entertainment la frappe immediatement. Premier doute : "est-ce que c\'est pour moi ?"', parcours: [['Accueil', 'Univers "grandeur et complexite" — se demande si ses 500 EUR sont la'], ['Services', 'Pas de mention "projet scolaire" ou "budget serre"'], ['Portfolio', 'Netflix et Hachette = hors de sa categorie'], ['FAQ', 'Pas de reponse sur les petits budgets'], ['Quitte', 'Suppose que c\'est trop cher, retourne vers une plateforme freelance']], impactTech: 'Sur tablette, chargement intermediate. La lenteur amplifie ses doutes.', positifs: ['Portfolio montre les "faux journaux" qu\'elle imagine pour son escape'], frictions: ['Positionnement grand compte = effet d\'exclusion fort', 'Aucune fourchette de prix', 'Formulaire pro intimide'], raison: 'Aucun signal qui lui dit qu\'elle est la bienvenue avec son profil et son budget.', changement: 'FAQ "vous travaillez aussi avec les ecoles et associations ?" + mention de la possibilite de petits projets.' },
  { id: 11, name: 'Alexandre', age: 41, situation: 'Producteur executif societe de production audiovisuelle, Paris', canal: 'Reference directe', maturite: 'Comparaison', device: 'Desktop', decision: 'Hesite', exp: 6, conf: 6, clarte: 4, emoji: '🎥', contexte: 'Developpement d\'une experience immersive pour une serie Netflix France — a vu le projet Stranger Things dans une newsletter', question: 'Elle a travaille sous NDA pour Netflix — elle peut faire pareil pour nous ?', reponse: 'Non', commentReponse: 'NDA/confidentialite jamais mentionnes meme si implies par le projet Stranger Things.', impression: 'Desktop acceptable. Portfolio Stranger Things convaincant visuellement. Cherche le process licence/NDA et ne le trouve pas.', parcours: [['Accueil', 'Logos Netflix, WB, Ubisoft — satisfaisant'], ['Portfolio Stranger Things', 'Visuels de qualite — mais pas de contexte contractuel'], ['Services', 'Rien sur les licences, la confidentialite, la gestion de droits'], ['A propos', 'Cherche experience ayants droit — contenu oriente creatif, pas juridique']], impactTech: 'Desktop acceptable. Site "solo" peut sembler sous-dimensionne pour un projet de licence de serie.', positifs: ['Projet Stranger Things = reference Netflix directe et rassurante', 'Qualite d\'execution convaincante', 'Identite graphique premium coherente'], frictions: ['NDA/confidentialite jamais mentionnes', 'Pas de description du process licence', 'Pas de temoignages de responsables licences (Netflix, WB)', 'Impression "trop solo" pour un projet de serie'], raison: 'Visuels convainquants mais question centrale non repondue. Continue d\'evaluer d\'autres prestataires.', changement: 'Section "gestion de licences" dans services/a-propos + mention NDA + case study Batman avec contexte WB.' },
  { id: 12, name: 'Celine', age: 36, situation: 'Gerante salle escape game, Strasbourg', canal: 'Google Search', maturite: 'Comparaison', device: 'Mobile', decision: 'Hesite', exp: 3, conf: 5, clarte: 3, emoji: '🚪', contexte: 'Cree sa 2e salle, veut de vrais props immersifs — sa 1ere salle avait des props achetes en ligne', question: 'Quel budget pour refaire les decors d\'une salle de 80 m² ?', reponse: 'Non', commentReponse: 'Aucune information tarifaire nulle part.', impression: 'LCP 9.2s mobile — dans sa salle, entre deux groupes. Quand ca s\'affiche, le visuel est beau mais references Netflix/WB perccues comme "hors budget".', parcours: [['Accueil (lent)', 'Scroll rapide, pertinent mais aucun signal de prix'], ['Services', 'Categories bien decrites mais zero tarif'], ['Portfolio', 'Qualite evidente mais Netflix/WB intimidants — "c\'est pas mon budget"'], ['Contact', 'Reticente a remplir un formulaire sans budget indicatif']], impactTech: 'LCP 9.2s dans un contexte d\'usage debout entre deux groupes = abandon tres probable.', positifs: ['Services correspondent exactement a son besoin', 'Specialisation escape game claire et rassurante'], frictions: ['LCP 9.2s en usage mobile en salle — abandon avant le contenu', 'Aucun prix', 'References luxe percues comme excluantes', 'Formulaire seul sans telephone'], raison: 'Lenteur + absence de prix + effet "haut de gamme" excluant. Retourne sur Google pour trouver un concurrent avec des tarifs.', changement: 'Performance mobile < 3s + fourchette tarifaire par type de projet.' },
  { id: 13, name: 'Pierre', age: 27, situation: 'Community manager marque jeux de societe, Lyon', canal: 'LinkedIn', maturite: 'Decouverte', device: 'Mobile', decision: 'Quitte', exp: 4, conf: 6, clarte: 5, emoji: '📱', contexte: 'Veille creative, pas de projet immmediat — liked un article LinkedIn sur l\'immersion visuelle', question: 'N/A — visite de curiosite', reponse: 'N/A', commentReponse: 'Pas de question specifique — visite de veille', impression: 'LCP 9.2s mobile depuis LinkedIn en pause dejeuner — attend, commence a scroller autre chose.', parcours: [['Accueil', 'Visuels frappants quand ca se charge enfin'], ['Portfolio', 'Ouvre 1-2 projets — inspection visuelle en mode scroll'], ['Retourne LinkedIn', 'Aucun mecanisme de retention : pas de newsletter, pas de CTA decouverte']], impactTech: 'LCP 9.2s redibitoire pour un visiteur sans intention d\'achat sur mobile.', positifs: ['Identite visuelle memorisable si la page se charge', 'References impressionnantes meme pour un CM en veille'], frictions: ['LCP 9.2s — abandon probable avant la premiere impression', 'Aucun mecanisme de retention (newsletter, Instagram en avant)', 'Pas de contenu "behind the scenes" pour un CM'], raison: 'Repart sans memoriser l\'URL. Peut liker le post LinkedIn mais ne reviendra pas.', changement: 'Lien Instagram prooeminent + performance mobile correcte = retention possible.' },
  { id: 14, name: 'Laura', age: 32, situation: 'Graphiste & game designer, Bordeaux', canal: 'Instagram', maturite: 'Comparaison', device: 'Mobile', decision: 'Hesite', exp: 5, conf: 6, clarte: 4, emoji: '✏️', contexte: 'Co-cree un jeu d\'enquete Kickstarter pour juin 2026, cherche a deleguer l\'illustration', question: 'Elle peut travailler avec une autre creative sur un projet Kickstarter ?', reponse: 'Non', commentReponse: 'Site 100% centre sur la relation client-prestataire, aucune mention de co-creation entre pairs.', impression: 'LCP 9.2s patient car venue d\'Instagram en mode exploration. Connexion esthetique immediate.', parcours: [['Accueil', 'Univers visuel dans son registre — connexion immediate'], ['A propos', 'Cherche "collaboration, co-creation, travail avec d\'autres creatifs" — rien'], ['Portfolio Hachette', 'Proche de son projet Kickstarter'], ['Contact', 'Hesite — peur d\'etre mal categorisee en envoyant un formulaire pro']], impactTech: 'LCP 9.2s patient (venue d\'Instagram, mode exploration). CLS peu important car elle inspecte visuellement.', positifs: ['Univers esthetique dans son registre', 'Portfolio Hachette (escape game book) proche de son projet', 'Specialisation jeu et narration graphique'], frictions: ['Aucune mention de collaboration entre creatifs — demande atypique', 'Budget Kickstarter serre + pas de fourchette basse', 'Formulaire pro intimidant pour une demarche pair-a-pair'], raison: 'Adéquation creative forte mais cas d\'usage non valide. Ira probablement sur Instagram pour un DM.', changement: 'FAQ "travaillez-vous avec d\'autres creatifs ?" + mention de l\'ouverture aux collaborations.' },
