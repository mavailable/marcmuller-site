      <p class="text-neutral-600 mb-8">Ce rapport est un point de depart. Marc M peut implementer ces ameliorations sur un site Astro performant, concu specifiquement pour convertir vos visiteurs en clients.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/commander" class="px-6 py-3 bg-[var(--color-accent)] text-white font-semibold rounded-xl hover:opacity-90 transition-opacity">
          Commander un site
        </a>
        <a href="/contact" class="px-6 py-3 border-2 border-neutral-300 text-neutral-700 font-semibold rounded-xl hover:border-neutral-400 transition-colors">
          En discuter d'abord
        </a>
      </div>
    </div>
  </section>

  <style is:inline>
    #panels { -ms-overflow-style: none; }
    #panels::-webkit-scrollbar { display: none; }
  </style>

  <script is:inline>
    const panels = document.getElementById('panels');
    const tabs = document.querySelectorAll('.tab-btn');
    const sections = panels.querySelectorAll('.tab-panel');

    function activateTab(index) {
      tabs.forEach((b, i) => {
        if (i === index) {
          b.classList.remove('text-neutral-500');
          b.classList.add('text-[var(--color-accent)]', 'bg-[var(--color-accent)]/10');
        } else {
          b.classList.remove('text-[var(--color-accent)]', 'bg-[var(--color-accent)]/10');
          b.classList.add('text-neutral-500');
        }
      });
    }

    tabs.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
        activateTab(i);
      });
    });

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && entry.intersectionRatio >= 0.5) {
          const idx = Array.from(sections).indexOf(entry.target);
          if (idx >= 0) activateTab(idx);
        }
      });
    }, { root: panels, threshold: 0.5 });

    sections.forEach(s => observer.observe(s));
  </script>

</BaseLayout>
