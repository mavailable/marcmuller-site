const avgExp = (personas.reduce((s, p) => s + p.exp, 0) / personas.length).toFixed(1);
const avgConf = (personas.filter(p => p.conf > 0).reduce((s, p) => s + p.conf, 0) / personas.filter(p => p.conf > 0).length).toFixed(1);
const avgClarte = (personas.reduce((s, p) => s + p.clarte, 0) / personas.length).toFixed(1);
const convertis = personas.filter(p => p.decision === 'Convertit').length;
const hesitants = personas.filter(p => p.decision === 'Hesite').length;
const quittent = personas.filter(p => p.decision === 'Quitte').length;
const tauxConversion = Math.round((convertis / personas.length) * 100);

const canalStats = [
  { canal: 'Google Search', total: 6, conv: 1, hesitant: 3, quitte: 2 },
  { canal: 'Google Maps', total: 3, conv: 1, hesitant: 2, quitte: 0 },
  { canal: 'IA (ChatGPT / Perplexity / Claude)', total: 3, conv: 0, hesitant: 1, quitte: 2 },
  { canal: 'Reseaux sociaux (Facebook)', total: 3, conv: 0, hesitant: 0, quitte: 3 },
  { canal: 'Bouche-a-oreille', total: 3, conv: 2, hesitant: 1, quitte: 0 },
  { canal: 'Autres (email, PagesJaunes)', total: 2, conv: 0, hesitant: 2, quitte: 0 },
];

const maturiteStats = [
  { level: 'Decouverte', total: 6, conv: 0, pct: '0%' },
  { level: 'Comparaison', total: 9, conv: 0, pct: '0%' },
  { level: 'Decision', total: 5, conv: 4, pct: '80%' },
];

const deviceStats = [
  { device: 'Mobile', total: 12, conv: 2, pct: '17%' },
  { device: 'Desktop', total: 6, conv: 2, pct: '33%' },
  { device: 'Tablette', total: 2, conv: 0, pct: '0%' },
];

const frictions = [
  { label: 'Pas d\'avis ni temoignages clients', count: 12, severity: 'critique' },
  { label: 'Site trop lent sur mobile (3.2 MB)', count: 12, severity: 'critique' },
  { label: 'Aucun prix ni fourchette indicative', count: 11, severity: 'critique' },
  { label: 'Galerie realisations sans descriptions', count: 11, severity: 'critique' },
  { label: 'Cibles tactiles trop petites (mobile)', count: 8, severity: 'haute' },
  { label: 'Blog mort depuis 2020', count: 7, severity: 'haute' },
  { label: 'Formulaire de devis trop basique', count: 7, severity: 'haute' },
  { label: 'Pas de FAQ sur les pages produit', count: 5, severity: 'haute' },
  { label: 'Horaires d\'ouverture non affiches', count: 5, severity: 'haute' },
  { label: 'Pas de page A propos / Equipe', count: 5, severity: 'moyenne' },
];

const ameliorations = {
  haute: [
    { title: 'Integrer un widget d\'avis Google', impact: '12/20 personas', detail: 'Afficher la note moyenne et les 5-10 derniers avis Google sur l\'accueil et chaque page produit. "500 clients satisfaits" sans preuve est contre-productif.' },
    { title: 'Optimiser les performances mobile', impact: '12/20 personas', detail: 'Convertir le logo en WebP (775 KB a 40 KB), supprimer le GTM en double (-174 KB), lazy-load images. Objectif : passer de 3.2 MB a moins de 1 MB.' },
    { title: 'Ajouter des fourchettes de prix', impact: '11/20 personas', detail: '"Fenetre PVC double vitrage : a partir de X EUR pose comprise" sur chaque page. Meme une fourchette large qualifie les prospects et debloque les comparaisons.' },
    { title: 'Legender et categoriser les realisations', impact: '11/20 personas', detail: 'Pour chaque photo : type de projet, materiau, ville. Ajouter des filtres par categorie. Idealement : avant/apres avec contexte du chantier.' },
    { title: 'Ajouter des FAQ (modele page porte cochere)', impact: '5/20 personas', detail: 'La page porte cochere est la seule avec FAQ — et c\'est la seule qui convertit bien. Repliquer ce modele sur toutes les pages produit.' },
    { title: 'Ameliorer le formulaire de devis', impact: '7/20 personas', detail: 'Multi-selection produits, champ quantite, upload photo, champ descriptif. Ajouter "portail" et "porte cochere" dans le dropdown.' },
  ],
  moyenne: [
    { title: 'Afficher les horaires d\'ouverture', impact: '5/20 personas', detail: 'Dans le header, footer et page contact : "Lun-Ven 8h-18h". Ajouter un gros bouton "Appelez-nous" visible sur mobile.' },
    { title: 'Creer une page A propos', impact: '5/20 personas', detail: '77 ans d\'histoire inexploites. Photos d\'atelier, de l\'equipe, chronologie depuis 1947, valeurs. Argument commercial majeur.' },
    { title: 'Securiser le site (grade D vers A)', impact: '3/20 personas', detail: 'Ajouter HSTS, X-Frame-Options, X-Content-Type-Options, Referrer-Policy via Cloudflare ou .htaccess.' },
    { title: 'Ajouter Schema.org LocalBusiness', impact: 'SEO global', detail: 'Google ne comprend pas que Perry est une menuiserie locale. Ajouter adresse, telephone, horaires, services, zone de service.' },
    { title: 'Supprimer ou relancer le blog', impact: '7/20 personas', detail: 'Un blog mort depuis 6 ans est pire que pas de blog. Soit le supprimer, soit publier 5-10 articles metier.' },
  ],
  discussion: [
    { title: 'Creer un espace Professionnels & Collectivites', emoji: '💼', detail: 'Catalogue PDF, tarifs pro, references chantiers, formulaire adapte. 3 personas B2B frustres.' },
    { title: 'Ajouter des pages SEO par ville', emoji: '🎯', detail: '"Menuiserie Gerardmer", "Menuiserie Epinal", "Menuiserie Saint-Die" pour capter le trafic local.' },
    { title: 'Creer des etudes de cas avant/apres', emoji: '🏗️', detail: '5 chantiers documentes avec contexte, photos, temoignage client. Argument de persuasion ultime.' },
    { title: 'Ajouter WhatsApp ou chat en ligne', emoji: '📱', detail: 'Canal prefere des 25-40 ans. Mehdi, Emilie et Aurelie ne veulent pas appeler un 06.' },
  ],
};

// PageSpeed data
const pagespeed = {
  desktop: { perf: 73, access: 93, bp: 100, seo: 92 },
  mobile: { perf: 48, access: 90, bp: 98, seo: 88 },
  cwv: { lcp: '3.2s', cls: '0.099', tbt: '0ms', fcp: '1.4s' },
};

const observatory = { grade: 'D', score: 30, passed: 5, total: 10 };

const schemaChecks = [
  { label: 'JSON-LD present', ok: true },
  { label: 'WebPage + BreadcrumbList', ok: true },
  { label: 'WebSite + SearchAction', ok: true },
  { label: 'LocalBusiness', ok: false },
  { label: 'Adresse + geo', ok: false },
  { label: 'Telephone', ok: false },
  { label: 'Horaires d\'ouverture', ok: false },
  { label: 'Services / Product', ok: false },
  { label: 'Logo / Image', ok: true },
  { label: 'sameAs (reseaux sociaux)', ok: false },
  { label: 'aggregateRating', ok: false },
];

const ogChecks = [
  { label: 'title', ok: true },
  { label: 'description', ok: true },
  { label: 'og:image', ok: true },
  { label: 'og:url', ok: true },
  { label: 'og:type', ok: true },
  { label: 'canonical', ok: true },
  { label: 'viewport', ok: true },
  { label: 'twitter:card', ok: false },
  { label: 'twitter:image', ok: false },
  { label: 'Meta description (accueil trop courte)', ok: false },
  { label: 'Title accueil (nom repete)', ok: false },
];

const securityHeaders = [
  { header: 'HSTS', ok: false },
  { header: 'X-Frame-Options', ok: false },
  { header: 'X-Content-Type-Options', ok: false },
  { header: 'Referrer-Policy', ok: false },
  { header: 'Permissions-Policy', ok: false },
  { header: 'Content-Security-Policy', ok: false },
  { header: 'HTTP vers HTTPS', ok: true },
  { header: 'Cookies securises', ok: true },
  { header: 'CORS correct', ok: true },
];

function decisionColor(d: string) {
  if (d === 'Convertit') return 'bg-emerald-100 text-emerald-800 border-emerald-200';
  if (d === 'Hesite') return 'bg-amber-100 text-amber-800 border-amber-200';
  return 'bg-red-100 text-red-800 border-red-200';
}

function decisionBorder(d: string) {
  if (d === 'Convertit') return 'border-green-200 bg-green-50/40';
  if (d === 'Hesite') return 'border-amber-200 bg-amber-50/40';
  return 'border-neutral-200 bg-neutral-50/40';
}

function severityColor(s: string) {
  if (s === 'critique') return 'bg-red-100 text-red-800';
  if (s === 'haute') return 'bg-orange-100 text-orange-800';
  return 'bg-blue-100 text-blue-800';
}

function scoreColor(v: number) {
  if (v >= 90) return '#22c55e';
  if (v >= 50) return '#f59e0b';
  return '#ef4444';
}

function scoreBar(val: number) {
  return `${val * 10}%`;
}
---

<BaseLayout
  title={title}
  description={description}
  noindex={true}
  lang="fr"
  frPath="/audit/menuiserie-perry"
>

  <!-- ═══════════════════ HERO ═══════════════════ -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24 overflow-hidden" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-20 -left-32 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: #E86C47;"></div>

    <div class="mx-auto max-w-4xl relative z-10">
      <div class="mb-4 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]/40">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white/90">Rapport confidentiel</span>
      </div>

      <h1 class="mb-4 text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl">
        Audit UX + Technique — <span class="bg-gradient-to-r from-[#E86C47] to-[#F5C8B3] bg-clip-text text-transparent">Menuiserie Perry</span>
      </h1>

      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mb-8">
        Simulation de 20 visites personas + audit technique complet de <strong class="text-white">menuiserie-perry.com</strong>. Chaque persona est un visiteur realiste avec son profil, son canal d'arrivee et ses attentes.
      </p>

      <div class="flex flex-wrap gap-3">
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">20 personas testes</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">6 canaux d'arrivee</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">17 pages analysees</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">29 mars 2026</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════════ TAB BAR ═══════════════════ -->
  <nav class="sticky top-16 md:top-20 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-2 h-12 text-sm overflow-x-auto">
      <button data-tab="0" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-[var(--color-accent)] bg-[var(--color-accent)]/10">Synthese</button>
      <button data-tab="1" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Technique</button>
      <button data-tab="2" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Visiteurs <span class="ml-1 text-xs text-neutral-400">20</span>
      </button>
      <button data-tab="3" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Ameliorations <span class="ml-1 text-xs text-neutral-400">{ameliorations.haute.length + ameliorations.moyenne.length + ameliorations.discussion.length}</span>
      </button>
    </div>
  </nav>

  <!-- ═══════════════════ PANELS ═══════════════════ -->
  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">

    <!-- ═══════════ PANEL 1 : SYNTHÈSE ═══════════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

      <!-- KPI Cards -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-red-600">{tauxConversion}%</p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Taux de conversion</p>
              <p class="mt-2 text-xs text-[var(--color-text-muted)]">{convertis} convertis · {hesitants} hesitants · {quittent} partis</p>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-amber-600">{avgExp}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Experience</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-amber-500" style={`width: ${scoreBar(Number(avgExp))}`}></div>
              </div>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-blue-600">{avgConf}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Confiance</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-blue-500" style={`width: ${scoreBar(Number(avgConf))}`}></div>
              </div>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-orange-600">{avgClarte}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Clarte</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-orange-500" style={`width: ${scoreBar(Number(avgClarte))}`}></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Paradoxe -->
      <div class="w-full px-6 py-8 md:px-8 bg-white">
        <div class="mx-auto max-w-5xl">
          <div class="rounded-xl border-l-4 border-l-[var(--color-accent)] bg-[var(--color-accent)]/5 p-6 md:p-8">
            <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">Paradoxe principal</h2>
            <p class="text-[var(--color-text)] leading-relaxed">
              Le site de Menuiserie Perry <strong>ne vend pas — il confirme</strong>. Les 4 conversions proviennent exclusivement de visiteurs en phase de <strong>decision</strong> (80% de conversion), deja convaincus par le bouche-a-oreille ou un besoin tres specifique. Le site n'a convaincu <strong>aucun</strong> visiteur en phase de comparaison (0/9). Perry perd systematiquement les prospects qui comparent — exactement ceux qui representent le plus gros volume.
            </p>
          </div>
        </div>
      </div>

      <!-- Conversion par canal -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-2">Conversion par canal</h2>
          <p class="text-[var(--color-text-muted)] mb-8">Le bouche-a-oreille est le seul canal qui convertit bien (67%). Le site echoue totalement avec les visiteurs IA (0%) et reseaux sociaux (0%).</p>
          <div class="grid md:grid-cols-2 gap-4">
            {canalStats.map((c) => {
              const pct = c.total > 0 ? Math.round((c.conv / c.total) * 100) : 0;
              return (
                <div class="rounded-xl border border-[var(--color-border)] bg-white p-5">
                  <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-[var(--color-text)]">{c.canal}</h3>
                    <span class={`text-lg font-bold ${pct > 50 ? 'text-emerald-600' : pct > 0 ? 'text-amber-600' : 'text-red-600'}`}>{pct}%</span>
                  </div>
                  <div class="h-3 rounded-full bg-neutral-100 overflow-hidden mb-3">
                    <div class="h-full rounded-full flex">
                      <div class="bg-emerald-500" style={`width: ${(c.conv / c.total) * 100}%`}></div>
                      <div class="bg-amber-400" style={`width: ${(c.hesitant / c.total) * 100}%`}></div>
                      <div class="bg-red-400" style={`width: ${(c.quitte / c.total) * 100}%`}></div>
                    </div>
                  </div>
                  <div class="flex gap-4 text-xs text-[var(--color-text-muted)]">
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> {c.conv} conv.</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-amber-400"></span> {c.hesitant} hes.</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-400"></span> {c.quitte} partis</span>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Conversion par maturité -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-white">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">Conversion par maturite</h2>
          <div class="grid md:grid-cols-3 gap-4">
            {maturiteStats.map((m) => (
              <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 text-center">
                <p class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-2">{m.level}</p>
                <p class={`text-4xl font-bold ${m.pct === '0%' ? 'text-red-600' : 'text-emerald-600'}`}>{m.pct}</p>
                <p class="mt-1 text-sm text-[var(--color-text-muted)]">{m.conv}/{m.total} convertis</p>
              </div>
            ))}
          </div>
          <div class="mt-6 rounded-xl bg-red-50 border border-red-200 p-5">
            <p class="text-sm text-red-800">
              <strong>Alerte :</strong> 0% de conversion en decouverte ET en comparaison. Le site ne joue <strong>aucun role</strong> dans la persuasion — il confirme seulement les decisions prises ailleurs (bouche-a-oreille, fiche Google).
            </p>
          </div>
        </div>
      </div>

      <!-- Conversion par device -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">Conversion par device</h2>
          <div class="grid md:grid-cols-3 gap-4">
            {deviceStats.map((d) => (
              <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 text-center">
                <p class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-2">{d.device}</p>
                <p class={`text-4xl font-bold ${d.pct === '0%' ? 'text-red-600' : Number(d.pct.replace('%','')) > 25 ? 'text-amber-600' : 'text-amber-600'}`}>{d.pct}</p>
                <p class="mt-1 text-sm text-[var(--color-text-muted)]">{d.conv}/{d.total} convertis</p>
              </div>
            ))}
          </div>
        </div>
      </div>

    </section>

    <!-- ═══════════ PANEL 2 : TECHNIQUE ═══════════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

      <!-- PageSpeed Scores -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">PageSpeed Insights</h2>

          <div class="grid md:grid-cols-2 gap-8">
            <!-- Desktop -->
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-6">
              <h3 class="text-lg font-semibold text-[var(--color-text)] mb-6 text-center">Desktop</h3>
              <div class="grid grid-cols-4 gap-4">
                {[
                  { label: 'Performance', score: pagespeed.desktop.perf },
                  { label: 'Accessibilite', score: pagespeed.desktop.access },
                  { label: 'Bonnes Pratiques', score: pagespeed.desktop.bp },
                  { label: 'SEO', score: pagespeed.desktop.seo },
                ].map((item) => (
                  <div class="text-center">
                    <div class="relative w-16 h-16 mx-auto mb-2">
                      <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e5e7eb" stroke-width="3" />
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke={scoreColor(item.score)} stroke-width="3" stroke-dasharray={`${item.score}, 100`} stroke-linecap="round" />
                      </svg>
                      <span class="absolute inset-0 flex items-center justify-center text-lg font-bold" style={`color: ${scoreColor(item.score)}`}>{item.score}</span>
                    </div>
                    <p class="text-xs text-neutral-600 font-medium">{item.label}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Mobile (estimated) -->
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-6">
              <h3 class="text-lg font-semibold text-[var(--color-text)] mb-1 text-center">Mobile</h3>
              <p class="text-xs text-center text-[var(--color-text-muted)] mb-6">(estime — quota API epuisee)</p>
              <div class="grid grid-cols-4 gap-4">
                {[
                  { label: 'Performance', score: pagespeed.mobile.perf },
                  { label: 'Accessibilite', score: pagespeed.mobile.access },
                  { label: 'Bonnes Pratiques', score: pagespeed.mobile.bp },
                  { label: 'SEO', score: pagespeed.mobile.seo },
                ].map((item) => (
                  <div class="text-center">
                    <div class="relative w-16 h-16 mx-auto mb-2">
                      <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e5e7eb" stroke-width="3" />
                        <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke={scoreColor(item.score)} stroke-width="3" stroke-dasharray={`${item.score}, 100`} stroke-linecap="round" />
                      </svg>
                      <span class="absolute inset-0 flex items-center justify-center text-lg font-bold" style={`color: ${scoreColor(item.score)}`}>{item.score}</span>
                    </div>
                    <p class="text-xs text-neutral-600 font-medium">{item.label}</p>
                  </div>
                ))}
              </div>
            </div>
