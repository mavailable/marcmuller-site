  { id: 9, name: 'Jean-Marc', age: 55, situation: 'Artisan plombier, Rupt-sur-Moselle', canal: 'Bouche-a-oreille', maturite: 'Decision', device: 'Mobile', decision: 'Convertit', exp: 5, conf: 8, clarte: 5, emoji: '🔧', contexte: 'Portail motorise, connait les Perry de reputation', question: 'Quels modeles de portails proposent-ils ?', reponse: 'Partiellement', commentReponse: 'PVC et alu motorises, mais aucun catalogue de modeles ou coloris.', impression: 'Il connait deja l\'entreprise. Le site confirme qu\'ils font des portails.', parcours: [['Portails', 'Options PVC/alu/motorisation — pas de catalogue visuel'], ['Realisations', 'Cherche des photos de portails sans succes'], ['Devis', 'Selectionne "Autres" car pas d\'option portail — agacant']], impactTech: 'Mobile 4G a Rupt, zone semi-rurale. Les 3.2 MB chargent lentement.', positifs: ['Confirme que Perry fait des portails', 'Numero direct', 'Meme commune'], frictions: ['Pas de catalogue modeles', 'Pas d\'option "portail" dans le formulaire', 'Realisations non categorisees'], raison: 'Deja decide par le bouche-a-oreille. Remplit le formulaire ET appellera demain.', changement: 'Un catalogue visuel de portails et "portail" dans le dropdown du formulaire.' },
