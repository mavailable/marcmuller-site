];

// ─── AMELIORATIONS ───
const ameliorations = {
  haute: [
    { title: 'Afficher les prix sur le menu et la boutique', impact: '18/20 personas', detail: 'Meme une fourchette ("Plats de 350 a 1 200 THB") debloquerait la majorite des hesitants. L\'absence de prix est le premier frein de conversion.', action: 'Ajouter les prix a cote de chaque plat dans la section Menu et sur chaque fiche produit de la boutique.' },
    { title: 'Optimiser drastiquement la performance', impact: '20/20 personas', detail: 'Le site met 19 secondes a s\'afficher sur mobile. Les visiteurs partent avant de voir le contenu. Migration hors Wix ou optimisation radicale necessaire.', action: 'Migrer vers un site statique (Astro, Next.js) ou optimiser le JS Wix : lazy loading, CDN images, suppression des 432 KiB de JS inutilise.' },
    { title: 'Integrer des temoignages clients', impact: '14/20 personas', detail: 'Les 4.9/5 etoiles de TripAdvisor (20 avis) sont un atout majeur non exploite. Les visiteurs doivent quitter le site pour les trouver.', action: 'Ajouter 4-5 verbatims TripAdvisor sur la page d\'accueil avec la note globale et un lien vers la fiche complete.' },
    { title: 'Afficher adresse + horaires + telephone en permanence', impact: '12/20 personas', detail: 'Les informations pratiques essentielles sont enfouies. Un visiteur devrait pouvoir trouver ou vous etes et quand vous etes ouvert en moins de 3 secondes.', action: 'Ajouter un bandeau fixe ou un footer visible sur toutes les pages avec adresse (lien Maps), horaires et telephone cliquable.' },
    { title: 'Supprimer les doublons de pages', impact: '10/20 personas', detail: 'Deux pages Contact, deux pages Boutique, deux pages Reservation creent de la confusion et donnent une impression d\'amateurisme.', action: 'Fusionner les doublons : une seule page Contact, une seule Boutique, une seule Reservation. Supprimer la page en construction.' },
  ],
  moyenne: [
    { title: 'Indiquer les options vegetariennes / allergenes', detail: 'Ajouter des pictogrammes sur le menu et une mention "Options vegetariennes sur demande".' },
    { title: 'Ajouter une FAQ', detail: 'Repondre aux questions recurrentes : prix, epicement, groupes, accessibilite, reservations jour meme.' },
    { title: 'Ajouter du Schema.org', detail: 'Restaurant, Menu, Product — pour les rich snippets Google et les recommandations IA.' },
    { title: 'Detailler les fiches produits fromages', detail: 'Type de lait, affinage, notes de degustation — un argument de vente inexploite.' },
  ],
  discussion: [
    { title: 'Migration hors Wix', emoji: '🔄', detail: 'Le rendu 100% JavaScript cause les problemes de performance, SEO et accessibilite IA. Un site statique chargerait en 1-2 secondes.' },
    { title: 'Version francaise du site', emoji: '🇫🇷', detail: 'Trois personas francophones auraient prefere naviguer en francais. Les proprietaires sont francais — c\'est coherent.' },
    { title: 'Menu degustation / experience couple', emoji: '💑', detail: 'Opportunite de vente additionnelle pour les occasions speciales (lune de miel, anniversaires).' },
  ],
};

// ─── HELPERS ───
function scoreColor(score: number) {
  if (score >= 90) return { ring: '#22c55e', text: 'text-green-600', bg: 'bg-green-50' };
  if (score >= 50) return { ring: '#f59e0b', text: 'text-amber-600', bg: 'bg-amber-50' };
  return { ring: '#ef4444', text: 'text-red-600', bg: 'bg-red-50' };
}

function decisionColor(d: string) {
  if (d === 'Convertit') return { border: 'border-green-200', bg: 'bg-green-50/40', badge: 'bg-green-600', text: 'text-green-800', badgeText: 'text-white' };
  if (d === 'Hesite') return { border: 'border-amber-200', bg: 'bg-amber-50/40', badge: 'bg-amber-500', text: 'text-amber-800', badgeText: 'text-white' };
  return { border: 'border-neutral-200', bg: 'bg-neutral-50/40', badge: 'bg-red-500', text: 'text-red-800', badgeText: 'text-white' };
}

function severityColor(s: string) {
  if (s === 'critique') return 'bg-red-100 text-red-800';
  if (s === 'haute') return 'bg-orange-100 text-orange-800';
  return 'bg-blue-100 text-blue-800';
}
---

<BaseLayout title={title} description={description} noindex={true} lang="fr" frPath="/audit/harmony-kohtao">

  <!-- ══════════ HERO ══════════ -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24 overflow-hidden" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="absolute top-20 -left-32 w-96 h-96 rounded-full opacity-10 blur-3xl" style="background: #E86C47;"></div>
    <div class="mx-auto max-w-4xl relative z-10">
      <div class="mb-4 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]/40">
        <span class="w-2 h-2 rounded-full" style="background-color: #E86C47;"></span>
        <span class="text-sm font-semibold text-white/90">Rapport confidentiel</span>
      </div>
      <h1 class="mb-4 text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl">
        Audit UX + Technique — <span class="bg-gradient-to-r from-[#E86C47] to-[#F5C8B3] bg-clip-text text-transparent">Harmony Koh Tao</span>
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mb-8">
        Audit complet de <strong class="text-white">harmonykohtao.com</strong> : performance, securite, SEO, et simulation de 20 visites personas realistes.
      </p>
      <div class="flex flex-wrap gap-3">
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">20 personas testes</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">6 canaux d'arrivee</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">8 audits techniques</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">29 mars 2026</span>
      </div>
    </div>
  </section>

  <!-- ══════════ TAB BAR ══════════ -->
  <nav class="sticky top-16 md:top-20 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-2 h-12 text-sm overflow-x-auto">
      <button data-tab="0" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-primary-700 bg-primary-50">Synthese</button>
      <button data-tab="1" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Technique</button>
      <button data-tab="2" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Visiteurs <span class="ml-1 text-xs text-neutral-400">20</span>
      </button>
      <button data-tab="3" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">
        Ameliorations <span class="ml-1 text-xs text-neutral-400">{ameliorations.haute.length + ameliorations.moyenne.length + ameliorations.discussion.length}</span>
      </button>
    </div>
  </nav>

  <!-- ══════════ PANELS ══════════ -->
  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">

    <!-- ════════ PANEL 1 : SYNTHESE ════════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

      <!-- KPI Cards -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class={`text-3xl md:text-4xl font-bold ${txConv < 30 ? 'text-red-600' : txConv < 60 ? 'text-amber-600' : 'text-emerald-600'}`}>{txConv}%</p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Taux de conversion</p>
              <p class="mt-2 text-xs text-[var(--color-text-muted)]">{convertis} convertis · {hesitants} hesitants · {quittent} partis</p>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-red-600">{avgExp}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Experience</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-red-500" style={`width: ${Number(avgExp) * 10}%`}></div>
              </div>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-amber-600">{avgConf}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Confiance</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-amber-500" style={`width: ${Number(avgConf) * 10}%`}></div>
              </div>
            </div>
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
              <p class="text-3xl md:text-4xl font-bold text-red-600">{avgClarte}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">Clarte</p>
              <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden">
                <div class="h-full rounded-full bg-red-500" style={`width: ${Number(avgClarte) * 10}%`}></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Paradoxe -->
      <div class="w-full px-6 py-8 md:px-8 bg-white">
        <div class="mx-auto max-w-5xl">
          <div class="rounded-xl border-l-4 border-l-[var(--color-accent)] bg-accent-50 p-6 md:p-8">
            <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">Paradoxe principal</h2>
            <p class="text-[var(--color-text)] leading-relaxed">
              Le site ne <strong>convainc pas</strong> — il se contente de ne pas <strong>dissuader</strong> ceux qui sont deja decides. Les visiteurs en <strong>Decision</strong> convertissent a <strong>67%</strong>, mais ceux en <strong>Comparaison</strong> seulement a <strong>12%</strong> et ceux en <strong>Decouverte</strong> a <strong>0%</strong>. Les <strong>10 hesitants</strong> sont un reservoir de conversion perdu par manque d'information (prix, temoignages, FAQ).
            </p>
          </div>
        </div>
      </div>

      <!-- Conversion par canal -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-2">Conversion par canal</h2>
          <p class="text-[var(--color-text-muted)] mb-8">Seuls le bouche-a-oreille et les referrals externes convertissent. Google Search et Instagram = 0%.</p>
          <div class="grid md:grid-cols-2 gap-4">
            {canalStats.map((c) => {
              const pct = c.total > 0 ? Math.round((c.conv / c.total) * 100) : 0;
              return (
                <div class="rounded-xl border border-[var(--color-border)] bg-white p-5">
                  <div class="flex items-center justify-between mb-3">
                    <h3 class="font-semibold text-[var(--color-text)] text-sm">{c.canal}</h3>
                    <span class={`text-lg font-bold ${pct > 50 ? 'text-emerald-600' : pct > 0 ? 'text-amber-600' : 'text-red-600'}`}>{pct}%</span>
                  </div>
                  <div class="h-3 rounded-full bg-neutral-100 overflow-hidden mb-3">
                    <div class="h-full rounded-full flex">
                      <div class="bg-emerald-500" style={`width: ${(c.conv / c.total) * 100}%`}></div>
                      <div class="bg-amber-400" style={`width: ${(c.hesitant / c.total) * 100}%`}></div>
                      <div class="bg-red-400" style={`width: ${(c.quitte / c.total) * 100}%`}></div>
                    </div>
                  </div>
                  <div class="flex gap-4 text-xs text-[var(--color-text-muted)]">
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> {c.conv} conv.</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-amber-400"></span> {c.hesitant} hes.</span>
                    <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-400"></span> {c.quitte} partis</span>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </div>

      <!-- Conversion par maturite -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-white">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">Conversion par maturite</h2>
          <div class="grid md:grid-cols-3 gap-4">
            {maturiteStats.map((m) => (
              <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 text-center">
                <p class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-2">{m.level}</p>
                <p class={`text-4xl font-bold ${m.pct === '0%' ? 'text-red-600' : m.pct === '12%' ? 'text-amber-600' : 'text-emerald-600'}`}>{m.pct}</p>
                <p class="mt-1 text-sm text-[var(--color-text-muted)]">{m.conv}/{m.total} convertis</p>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Conversion par device -->
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">Conversion par device</h2>
          <div class="grid md:grid-cols-3 gap-4">
            {deviceStats.map((d) => (
              <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 text-center">
                <p class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-2">{d.device}</p>
                <p class={`text-4xl font-bold ${d.pct === '0%' ? 'text-red-600' : 'text-amber-600'}`}>{d.pct}</p>
                <p class="mt-1 text-sm text-[var(--color-text-muted)]">{d.conv}/{d.total} convertis</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ════════ PANEL 2 : TECHNIQUE ════════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl space-y-12">

          <!-- PageSpeed Scores -->
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">PageSpeed Insights</h2>
            <div class="grid md:grid-cols-2 gap-6">
              {(['mobile', 'desktop'] as const).map((strategy) => {
                const data = pagespeed[strategy];
                const scores = [
                  { label: 'Performance', score: data.perf },
                  { label: 'Accessibilite', score: data.access },
                  { label: 'Bonnes Pratiques', score: data.bp },
                  { label: 'SEO', score: data.seo },
                ];
                return (
                  <div class="rounded-xl border border-[var(--color-border)] bg-white p-6">
                    <h3 class="font-bold text-[var(--color-text)] mb-4 text-center uppercase text-sm tracking-wider">{strategy === 'mobile' ? '📱 Mobile' : '💻 Desktop'}</h3>
                    <div class="grid grid-cols-4 gap-4 mb-6">
                      {scores.map((s) => {
                        const c = scoreColor(s.score);
                        return (
                          <div class="text-center">
                            <div class="relative w-16 h-16 mx-auto mb-2">
                              <svg class="w-16 h-16 -rotate-90" viewBox="0 0 36 36">
                                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e5e7eb" stroke-width="3" />
                                <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke={c.ring} stroke-width="3" stroke-dasharray={`${s.score}, 100`} stroke-linecap="round" />
                              </svg>
                              <span class={`absolute inset-0 flex items-center justify-center text-lg font-bold ${c.text}`}>{s.score}</span>
                            </div>
                            <p class="text-xs text-neutral-600 font-medium">{s.label}</p>
                          </div>
                        );
                      })}
                    </div>
                    <div class="space-y-2">
                      <div class={`flex items-center justify-between p-3 rounded-lg ${data.lcp.includes('19') || data.lcp.includes('17') ? 'bg-red-50' : 'bg-green-50'}`}>
                        <div><span class="text-xs font-bold text-neutral-700">LCP</span><span class="text-xs text-neutral-500 ml-1">(plus gros element)</span></div>
                        <div class="flex items-center gap-2"><span class="text-sm font-bold text-red-600">{data.lcp}</span><span class="text-[10px] px-1.5 py-0.5 rounded font-medium bg-red-100 text-red-700">Mauvais</span></div>
                      </div>
                      <div class={`flex items-center justify-between p-3 rounded-lg ${strategy === 'mobile' ? 'bg-red-50' : 'bg-green-50'}`}>
                        <div><span class="text-xs font-bold text-neutral-700">TBT</span><span class="text-xs text-neutral-500 ml-1">(temps de blocage)</span></div>
                        <div class="flex items-center gap-2">
                          <span class={`text-sm font-bold ${strategy === 'mobile' ? 'text-red-600' : 'text-green-600'}`}>{data.tbt}</span>
                          <span class={`text-[10px] px-1.5 py-0.5 rounded font-medium ${strategy === 'mobile' ? 'bg-red-100 text-red-700' : 'bg-green-100 text-green-700'}`}>{strategy === 'mobile' ? 'Mauvais' : 'Bon'}</span>
                        </div>
                      </div>
                      <div class="flex items-center justify-between p-3 rounded-lg bg-green-50">
                        <div><span class="text-xs font-bold text-neutral-700">CLS</span><span class="text-xs text-neutral-500 ml-1">(stabilite visuelle)</span></div>
                        <div class="flex items-center gap-2"><span class="text-sm font-bold text-green-600">{data.cls}</span><span class="text-[10px] px-1.5 py-0.5 rounded font-medium bg-green-100 text-green-700">Bon</span></div>
                      </div>
                    </div>
                  </div>
                );
              })}
            </div>
          </div>

          <!-- Observatory -->
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">Securite HTTP</h2>
            <div class="flex items-center gap-4 p-4 rounded-xl border border-red-200 bg-red-50 mb-6">
              <div class="text-3xl font-black text-red-600">{observatory.grade}</div>
              <div>
                <p class="text-sm font-semibold text-neutral-900">Mozilla Observatory</p>
                <p class="text-xs text-neutral-500">{observatory.passed}/{observatory.total} tests passes — Score {observatory.score}/100</p>
              </div>
            </div>
            <div class="grid md:grid-cols-2 gap-3">
              {securityHeaders.map((h) => (
                <div class="flex items-center gap-2 py-1.5">
                  {h.ok ? (
                    <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  ) : (
                    <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  )}
                  <span class={`text-sm ${h.ok ? 'text-neutral-700' : 'text-neutral-400 line-through'}`}>{h.header}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Schema.org -->
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-text)] mb-4">Schema.org (donnees structurees)</h2>
            <p class="text-sm text-red-600 font-medium mb-4">Aucune donnee structuree detectee — Google ne comprend pas que c'est un restaurant.</p>
            <div class="grid md:grid-cols-2 gap-1">
              {schemaChecks.map((c) => (
                <div class="flex items-center gap-2 py-1.5">
                  <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  <span class="text-sm text-neutral-400 line-through">{c.item}</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Open Graph -->
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-text)] mb-4">Open Graph (partage reseaux sociaux)</h2>
            <p class="text-sm text-amber-600 font-medium mb-4">Non verifiable — le site Wix rend les meta tags cote client. Les partages risquent d'afficher un apercu vide.</p>
            <div class="grid md:grid-cols-2 gap-1">
              {ogChecks.map((c) => (
                <div class="flex items-center gap-2 py-1.5">
                  <svg class="w-4 h-4 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01M12 3a9 9 0 100 18 9 9 0 000-18z" /></svg>
                  <span class="text-sm text-neutral-500">{c.item} — non verifiable</span>
                </div>
              ))}
            </div>
          </div>

          <!-- SEO Technique -->
          <div>
            <h2 class="text-2xl font-bold text-[var(--color-text)] mb-4">SEO technique</h2>
            <div class="grid md:grid-cols-2 gap-1">
              {seoChecks.map((c) => (
                <div class="flex items-center gap-2 py-1.5">
                  {c.ok ? (
                    <svg class="w-4 h-4 text-green-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  ) : (
                    <svg class="w-4 h-4 text-red-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
                  )}
                  <span class={`text-sm ${c.ok ? 'text-neutral-700' : 'text-neutral-400 line-through'}`}>{c.item}</span>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ════════ PANEL 3 : VISITEURS ════════ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">

