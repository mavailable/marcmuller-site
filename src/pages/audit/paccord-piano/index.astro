function decisionColor(d: string) {
  if (d === 'Convertit') return 'bg-emerald-100 text-emerald-800';
  if (d === 'Hesite') return 'bg-amber-100 text-amber-800';
  return 'bg-red-100 text-red-800';
}
function decisionBorder(d: string) {
  if (d === 'Convertit') return 'border-green-200 bg-green-50/40';
  if (d === 'Hesite') return 'border-amber-200 bg-amber-50/40';
  return 'border-neutral-200 bg-neutral-50/40';
}
function severityColor(s: string) {
  if (s === 'critique') return 'bg-red-100 text-red-800';
  if (s === 'haute') return 'bg-orange-100 text-orange-800';
  return 'bg-blue-100 text-blue-800';
}
function scoreColor(v: number) {
  if (v >= 90) return '#22c55e';
  if (v >= 50) return '#f59e0b';
  return '#ef4444';
}
function scoreTextColor(v: number) {
  if (v >= 90) return 'text-green-600';
  if (v >= 50) return 'text-amber-600';
  return 'text-red-600';
}
function scoreBar(val: number) {
  return `${val * 10}%`;
}
---

<BaseLayout
  title={title}
  description={description}
  noindex={true}
  lang="fr"
  frPath="/audit/paccord-piano"
>

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24 overflow-hidden" style="background-color: #0D0D0D;">
    <div class="absolute inset-0 opacity-10" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 40px 40px;"></div>
    <div class="mx-auto max-w-4xl relative z-10">
      <div class="mb-4 inline-flex items-center gap-2 px-4 py-2 rounded-full border border-[var(--color-accent)]/40">
        <span class="w-2 h-2 rounded-full" style="background-color: var(--color-accent);"></span>
        <span class="text-sm font-semibold text-white/90">Rapport confidentiel</span>
      </div>
      <h1 class="mb-4 text-3xl font-bold leading-tight text-white md:text-4xl lg:text-5xl">
        Audit UX + Technique — <span class="text-[var(--color-accent)]">P'accord Piano</span>
      </h1>
      <p class="text-lg text-neutral-300 md:text-xl max-w-2xl mb-8">
        Simulation de 20 visites personas sur <strong class="text-white">paccord-piano.fr</strong> + audit technique complet (PageSpeed, securite, SEO, Schema.org).
      </p>
      <div class="flex flex-wrap gap-3">
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">20 personas</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">6 canaux</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">8 audits techniques</span>
        <span class="px-4 py-2 rounded-lg bg-white/10 text-white text-sm font-medium">29 mars 2026</span>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TAB BAR ═══════════════ -->
  <nav class="sticky top-16 md:top-20 z-40 bg-white/95 backdrop-blur border-b border-neutral-200" id="tab-bar">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center gap-2 h-12 text-sm overflow-x-auto">
      <button data-tab="0" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-[var(--color-accent)] bg-[var(--color-accent)]/10">Synthese</button>
      <button data-tab="1" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Technique</button>
      <button data-tab="2" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Visiteurs <span class="ml-1 text-xs text-neutral-400">20</span></button>
      <button data-tab="3" class="tab-btn px-4 py-1.5 rounded-lg font-medium whitespace-nowrap transition-colors text-neutral-500 hover:text-neutral-700">Ameliorations <span class="ml-1 text-xs text-neutral-400">{ameliorations.haute.length + ameliorations.moyenne.length + ameliorations.discuter.length}</span></button>
    </div>
  </nav>

  <div id="panels" class="flex overflow-x-auto snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch; scrollbar-width: none;">

  <!-- ═══════════════ PANEL 1 : SYNTHESE ═══════════════ -->
  <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

    <!-- KPI cards -->
    <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
      <div class="mx-auto max-w-5xl">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
            <p class="text-3xl md:text-4xl font-bold text-red-600">20%</p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Taux de conversion</p>
            <p class="mt-2 text-xs text-[var(--color-text-muted)]">{convertis} convertis · {hesitants} hesitants · {quittent} partis</p>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
            <p class="text-3xl md:text-4xl font-bold text-amber-600">{avgExp}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Experience</p>
            <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden"><div class="h-full rounded-full bg-amber-500" style={`width: ${scoreBar(Number(avgExp))}`}></div></div>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
            <p class="text-3xl md:text-4xl font-bold text-blue-600">{avgConf}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Confiance</p>
            <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden"><div class="h-full rounded-full bg-blue-500" style={`width: ${scoreBar(Number(avgConf))}`}></div></div>
          </div>
          <div class="rounded-xl border border-[var(--color-border)] bg-white p-5 text-center">
            <p class="text-3xl md:text-4xl font-bold text-orange-600">{avgClarte}<span class="text-lg text-[var(--color-text-muted)]">/10</span></p>
            <p class="mt-1 text-sm text-[var(--color-text-muted)]">Clarte</p>
            <div class="mt-2 h-2 rounded-full bg-neutral-100 overflow-hidden"><div class="h-full rounded-full bg-orange-500" style={`width: ${scoreBar(Number(avgClarte))}`}></div></div>
          </div>
        </div>
      </div>
    </div>

    <!-- Paradoxe -->
    <div class="w-full px-6 py-8 md:px-8 bg-white">
      <div class="mx-auto max-w-5xl">
        <div class="rounded-xl border-l-4 border-l-[var(--color-accent)] bg-[var(--color-accent)]/5 p-6 md:p-8">
          <h2 class="text-lg font-bold text-[var(--color-text)] mb-2">Paradoxe principal</h2>
          <p class="text-[var(--color-text)] leading-relaxed">
            Le site a un <strong>outil de conversion excellent</strong> (le calculateur de prix par code postal) entoure d'un <strong>desert de reassurance</strong>. Le calculateur repond a "combien ?", mais personne ne repond a "pourquoi vous ?". <strong>0% de conversion en phase comparaison</strong> — les visiteurs obtiennent le prix en 10 secondes puis quittent faute de preuves que le service vaut ce prix.
          </p>
        </div>
      </div>
    </div>

    <!-- Conversion par canal -->
    <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-2xl font-bold text-[var(--color-text)] mb-2">Conversion par canal</h2>
        <p class="text-[var(--color-text-muted)] mb-8">Le bouche-a-oreille est le seul canal qui convertit (67%). Le site ne convertit pas en autonome.</p>
        <div class="grid md:grid-cols-2 gap-4">
          {canalStats.map((c) => {
            const pct = c.total > 0 ? Math.round((c.conv / c.total) * 100) : 0;
            return (
              <div class="rounded-xl border border-[var(--color-border)] bg-white p-5">
                <div class="flex items-center justify-between mb-3">
                  <h3 class="font-semibold text-[var(--color-text)] text-sm">{c.canal}</h3>
                  <span class={`text-lg font-bold ${pct > 50 ? 'text-emerald-600' : pct > 0 ? 'text-amber-600' : 'text-red-600'}`}>{pct}%</span>
                </div>
                <div class="h-3 rounded-full bg-neutral-100 overflow-hidden mb-3">
                  <div class="h-full rounded-full flex">
                    <div class="bg-emerald-500" style={`width: ${(c.conv / c.total) * 100}%`}></div>
                    <div class="bg-amber-400" style={`width: ${(c.hesitant / c.total) * 100}%`}></div>
                    <div class="bg-red-400" style={`width: ${(c.quitte / c.total) * 100}%`}></div>
                  </div>
                </div>
                <div class="flex gap-4 text-xs text-[var(--color-text-muted)]">
                  <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-emerald-500"></span> {c.conv}</span>
                  <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-amber-400"></span> {c.hesitant}</span>
                  <span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-400"></span> {c.quitte}</span>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>

    <!-- Conversion par maturite -->
    <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-white">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-2xl font-bold text-[var(--color-text)] mb-8">Conversion par maturite</h2>
        <div class="grid md:grid-cols-3 gap-4">
          {maturiteStats.map((m) => (
            <div class="rounded-xl border border-[var(--color-border)] bg-white p-6 text-center">
              <p class="text-sm font-semibold text-[var(--color-text-muted)] uppercase tracking-wider mb-2">{m.level}</p>
              <p class={`text-4xl font-bold ${m.pct === '0%' ? 'text-red-600' : Number(m.pct.replace('%','')) < 30 ? 'text-amber-600' : 'text-emerald-600'}`}>{m.pct}</p>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">{m.conv}/{m.total} convertis</p>
            </div>
          ))}
        </div>
        <div class="mt-6 rounded-xl bg-red-50 border border-red-200 p-5">
          <p class="text-sm text-red-800">
            <strong>Alerte :</strong> le site ne convertit <strong>aucun</strong> visiteur en phase de <strong>comparaison</strong> (0/7). Ces visiteurs sont interesses mais le site ne fournit pas assez d'elements pour les convaincre (pas de temoignages, pas de portfolio, pas de FAQ).
          </p>
        </div>
      </div>
    </div>

  </section>

  <!-- ═══════════════ PANEL 2 : TECHNIQUE ═══════════════ -->
  <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">

    <!-- PageSpeed -->
    <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
      <div class="mx-auto max-w-5xl">
        <h2 class="text-2xl font-bold text-[var(--color-text)] mb-2">Scores PageSpeed (Lighthouse)</h2>
        <p class="text-[var(--color-text-muted)] mb-8">Mesures sur le terrain. Le score de performance mobile (68) est le point faible principal.</p>

        <div class="grid md:grid-cols-2 gap-8">
          {[{ label: 'Mobile', scores: mobile }, { label: 'Desktop', scores: desktop }].map(({ label, scores }) => (
