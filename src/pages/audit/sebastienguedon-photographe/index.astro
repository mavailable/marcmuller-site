<BaseLayout title={title} description={description} noindex={true} lang="fr" frPath="/audit/sebastienguedon-photographe">

  <!-- HERO -->
  <section class="w-full relative px-6 py-16 md:px-8 md:py-24 overflow-hidden" style="background-color: #0D0D0D;">
