];

const missingHeaders = ['Content-Security-Policy', 'Strict-Transport-Security', 'X-Frame-Options', 'X-Content-Type-Options', 'Referrer-Policy', 'Permissions-Policy', 'X-XSS-Protection'];

// ─── FRICTIONS ───
const frictions = [
  { label: 'Absence de tarifs (seances et tableaux)', count: 18, severity: 'critique' },
