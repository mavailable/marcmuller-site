  { title: 'Afficher les prix des seances', impact: '18/20 personas', detail: 'Ajouter sur chaque page service une fourchette ("A partir de X€") ou une grille simple. Sans prix, impossible de comparer. Mathilde, Sarah, Leila, Nicolas quittent directement vers les concurrents transparents.' },
  { title: 'Afficher les prix en boutique', impact: '10/20 personas', detail: 'Les prix existent dans WooCommerce (tableaux a 90€) mais ne s\'affichent pas correctement sur les vignettes et fiches produit. Pierre, Celine, Amandine quittent vers Etsy sans avoir pu evaluer l\'offre.' },
  { title: 'Optimiser les performances mobiles', impact: '13/20 personas', detail: 'LCP ~8s mobile = taux de rebond immediat. Convertir les 85 images JPG/PNG en WebP, differer les 28 scripts bloquants, alleger les 31 CSS Elementor. La taille HTML de 333 KB est 6x la norme.' },
  { title: 'Ajouter des temoignages clients', impact: '12/20 personas', detail: 'Le widget Trustindex (Google Reviews) est deja installe — l\'afficher sur les pages services. 5-8 temoignages cibles par service (mariage, grossesse, famille, tableau) debloqueraient la confiance pour Leila, Sarah, Nathalie, Yasmine.' },
  { title: 'Numero de telephone cliquable en header mobile', impact: '10/20 personas', detail: 'Thomas, Margaux, Isabelle, Nathalie, Jerome sont bloques sans contact rapide. Un numero cliquable (tel: link) en header mobile est le correctif le plus simple pour les profils Decision.' },
];

const amelioMoyenne = [
  { title: 'Creer une FAQ (5-8 questions)', impact: '9 personas', detail: '"Comment se passe une seance ?", "Ou ca se deroule ?", "Combien de photos je recois ?", "Quel delai ?", "Exterieurs ou studio ?". Nathalie (primo-cliente locale parfaite) est bloqueee uniquement par cette barriere informationnelle.' },
  { title: 'Creer une page A propos / Biographie', impact: '7 personas', detail: 'Qui est Sebastien ? Son parcours, son approche, ses valeurs. Une photo de lui. Critical pour Nicolas (mariage fille, budget 2000-3000€) et Fabrice (B2B). Une page A propos humanise un prestataire de service.' },
  { title: 'Corriger les 4 fautes de la meta description', impact: '5 personas', detail: '"Rour vos scéances... en ïle de France" — 4 fautes visibles dans l\'extrait Google avant meme d\'ouvrir le site. Impact CTR organique + credibilite au premier contact.' },
  { title: 'Creer une galerie mariage dediee', impact: 'Nicolas + tous mariage', detail: 'Un portfolio mariage structure avec 5-6 reportages complets. Nicolas ne peut pas engager 2000-3000€ sur la foi de photos dispersees. Camille ne reviendra pas sans un style clair et memorisable.' },
];

const amelioDiscuter = [
  { emoji: '🔒', title: 'En-tetes de securite HTTP', detail: '0/7 en-tetes de securite. A configurer dans .htaccess IONOS (HSTS, X-Frame-Options, CSP, etc.). Correspond a un grade F Observatory.' },
  { emoji: '📊', title: 'Schema.org LocalBusiness + Photographer', detail: 'Ajouter le type Photographer avec adresse, telephone, horaires, aggregateRating depuis Trustindex. Impact direct sur le pack local Google Maps.' },
  { emoji: '🍪', title: 'Google Fonts en local (RGPD)', detail: 'Poppins charge via CDN Google = transfert vers USA sans consentement. Heberger en local (comme Glacial Indifference). Gain performance + conformite RGPD France.' },
  { emoji: '✉️', title: 'Lead magnet pour visiteurs decouverte', detail: 'Camille (mariage dans 18 mois) ne reviendra pas sans ancrage. Un guide "Choisir son photographe mariage en IDF" par email capturerait ces leads et alimenterait le tunnel sur 12-18 mois.' },
  { emoji: '🏷️', title: 'X-Powered-By: PHP/8.1.34 expose', detail: 'La version PHP est exposee dans les en-tetes HTTP = information pour un attaquant. Masquer via .htaccess : Header unset X-Powered-By.' },
];

// ─── HELPERS ───
function scoreColor(s: number) {
  if (s >= 90) return '#22c55e';
  if (s >= 50) return '#f59e0b';
  return '#ef4444';
}

function scoreTextColor(s: number) {
  if (s >= 90) return 'text-green-600';
  if (s >= 50) return 'text-amber-600';
  return 'text-red-600';
}

function decisionBorder(d: string) {
  if (d === 'Convertit') return 'border-green-200 bg-green-50/40';
  if (d === 'Hesite') return 'border-amber-200 bg-amber-50/40';
  return 'border-neutral-200 bg-neutral-50/40';
}

function severityColor(s: string) {
  if (s === 'critique') return 'bg-red-100 text-red-800';
  if (s === 'haute') return 'bg-orange-100 text-orange-800';
  return 'bg-blue-100 text-blue-800';
}

function cwvBg(status: string) {
  if (status === 'good') return 'bg-green-50';
  if (status === 'mid') return 'bg-amber-50';
  return 'bg-red-50';
}

function cwvText(status: string) {
  if (status === 'good') return 'text-green-700';
  if (status === 'mid') return 'text-amber-700';
  return 'text-red-700';
}

function cwvBadge(status: string) {
  if (status === 'good') return 'bg-green-100 text-green-800';
  if (status === 'mid') return 'bg-amber-100 text-amber-800';
  return 'bg-red-100 text-red-800';
}

function cwvLabel(status: string) {
  if (status === 'good') return 'Bon';
  if (status === 'mid') return 'Moyen';
  return 'Mauvais';
}

function scoreBar(val: number) {
  return `${val * 10}%`;
}

function gradeColor(g: string) {
  if (g.startsWith('A')) return { border: 'border-green-300', bg: 'bg-green-50', text: 'text-green-700' };
  if (g.startsWith('B')) return { border: 'border-amber-300', bg: 'bg-amber-50', text: 'text-amber-700' };
  return { border: 'border-red-300', bg: 'bg-red-50', text: 'text-red-700' };
}

const gc = gradeColor(observatory.grade);
