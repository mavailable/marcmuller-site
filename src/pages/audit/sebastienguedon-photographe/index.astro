  { id: 15, name: 'Nathalie', age: 55, role: 'Chef de projet reconversion, Clamart (5km)', canal: 'Google Maps', maturite: 'Comparaison', device: 'Tablette', decision: 'Hesite', exp: 4, conf: 5, clarte: 2, emoji: '🌸', situation: 'Premiere fois avec un photographe pro, veut offrir seance couple/famille pour depart en retraite', parcours: ['Seance Couple', 'Seance Famille', 'Cherche FAQ', 'Cherche prix', 'Contact incertain'], questionCle: 'Comment se passe une seance ? Ou ? C\'est combien ?', reponse: 'Non', premierImpression: 'Arrive de Google Maps. Tablette, chargement 3-4s. "C\'est professionnel, c\'est beau." Mais immediatement : "Comment ca se passe concretement ?"', positifs: ['Proximite geographique forte (Clamart/Chatenay = 5km)', 'Style photos couple exactement ce qu\'elle imagine', 'Design premium inspire confiance sur la qualite artistique', 'Presence Google Maps avec localisation precise'], frictions: ['Absence de FAQ = bloquant absolu pour primo-cliente', 'Absence de prix = inquietude budget', 'Pas de description deroulement seance (duree, lieu, nombre photos, delais)', 'Pas de telephone', 'Pas de A propos', 'Pas d\'avis clients'], raisonDecision: 'Tres interessee et geographiquement ideale mais barriere informationnelle trop haute. Repart probablement sans avoir contacte.', impactTech: 'Chargements accumules sur 5 minutes de navigation entre plusieurs pages = experience laborieuse.' },
  { id: 16, name: 'Pierre', age: 39, role: 'Journaliste freelance, Paris 6e', canal: 'IA (Perplexity)', maturite: 'Comparaison', device: 'Desktop', decision: 'Quitte', exp: 3, conf: 4, clarte: 2, emoji: '🖼️', situation: 'Cherche tableau photo urbain pour bureau home-office, budget 300-500€', parcours: ['Boutique', 'Fiche tableau Bruxelles', 'Deuxieme fiche', 'Etsy (30s)', 'Quitte'], questionCle: 'C\'est combien ce tableau en 60x90 ? Toile ou tirage alu ?', reponse: 'Non', premierImpression: 'Arrive directement sur la boutique depuis Perplexity. Tableaux urbains, design noir/dore. Style lui parle. Premier reflexe : chercher les prix. Ne voit rien. Scrole. Toujours rien.', positifs: ['Qualite photographique evidente, coherente avec sa recherche', 'Style urbain nuit/ambiance premium exactement ce qu\'il cherchait', 'Design coherent et distinctif (or, noir)'], frictions: ['Absence totale de prix = dealbreaker absolu boutique en ligne', 'Pas d\'info sur les supports (toile, alu, papier fine-art)', 'Pas de tableau dimensions/prix', 'Page /contact en 404', 'Pas d\'avis clients', 'Comparaison defavorable avec Etsy en 30 secondes'], raisonDecision: 'Achat e-commerce sans prix n\'a aucune raison d\'aboutir. Pierre est en comparaison active avec budget precis.', impactTech: 'Desktop LCP 5-8s = anormal mais tolerable. Sur 2e page produit, ouvre Etsy en parallele.' },
  { id: 17, name: 'Aurelie', age: 32, role: 'Kinesitherapeute, 8 mois grossesse, Montrouge (8km)', canal: 'Google Search', maturite: 'Decision', device: 'Mobile', decision: 'Hesite', exp: 5, conf: 5, clarte: 3, emoji: '🤰', situation: 'Urgence : 8 mois de grossesse, cherche seance avant terme dans 6 semaines', parcours: ['Seance Grossesse', 'Cherche contact', 'Tente /contact (404)', 'Cherche GBP Google'], questionCle: 'Disponibilites ce mois-ci ? C\'est en interieur ou exterieur ?', reponse: 'Non', premierImpression: 'Clique depuis Google mobile. Attend 5-6s. Voit une photo de grossesse lumineuse, lumiere doree. "Oh, c\'est beau." Emotionnellement accrochee malgre la lenteur.', positifs: ['Photos grossesse de qualite emotionnellement impactantes', 'Style coherent avec ses attentes (doux, naturel, lumineux)', 'Localisation 92 visible, proximite rassurante'], frictions: ['Zero info pratique : duree, lieu, nombre photos livrées', 'Absence prix (meme fourchette)', 'Page /contact en 404 alors qu\'elle est prete a reserver', 'Pas de temoignages femmes enceintes rassurées', 'Pas de FAQ', 'Pas de telephone cliquable'], raisonDecision: 'Veut vraiment reserver — photos l\'ont convaincue. Mais ne trouve pas comment contacter rapidement. Va chercher le GBP de Sebastien sur Google.', impactTech: 'LCP 5-8s mobile tolere par motivation. 3e navigation lente = patience epuisee.' },
  { id: 18, name: 'Sebastien DA', age: 48, role: 'Directeur artistique agence pub, Paris 9e', canal: 'LinkedIn', maturite: 'Decouverte', device: 'Desktop', decision: 'Quitte', exp: 5, conf: 6, clarte: 4, emoji: '🎭', situation: 'Cherche photographe commercial/editorial pour client mode — persona hors cible', parcours: ['Accueil', 'Boutique', 'Seance individuelle', 'Quitte (90s)'], questionCle: 'Faites-vous de la photographie commerciale / editorial mode ?', reponse: 'Non (reponse implicite correcte)', premierImpression: 'Directeur artistique = scan pro en 2 secondes. "C\'est correct pour du B2C grand public." Identifie Elementor. Question formee avant de cliquer : "Est-ce qu\'il fait du commercial ?"', positifs: ['Design "propre" meme pour oeil professionnel exigeant', 'Coherence visuelle portfolio notee positivement', 'Specialisation B2C claire — il comprend vite a qui s\'adresse le site'], frictions: ['Aucune mention photographie commerciale/editoriale', 'Pas de page A propos confirmant la specialisation', 'Pas de section Prestations Pro pour l\'orienter rapidement', 'Menu surchargé oblige a cliquer pour comprendre'], raisonDecision: 'Hors cible absolue. Sortie rapide saine et attendue.', impactTech: 'Quitte avant que la performance soit un probleme. Sortie motivee par le contenu, pas la technique.' },
