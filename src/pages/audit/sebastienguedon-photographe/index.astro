// ─── PERSONAS ───
const personas = [
  { id: 1, name: 'Mathilde', age: 31, role: 'Infirmiere, Boulogne-Billancourt', canal: 'Google Search', maturite: 'Comparaison', device: 'Mobile', decision: 'Quitte', exp: 4, conf: 4, clarte: 3, emoji: '💉', situation: 'Cherche photographe pour seance couple anniversaire rencontre, budget ~150-200€', parcours: ['Accueil', 'Seance Couple', 'Boutique', 'Formulaire'], questionCle: 'Combien coute une seance photo couple ?', reponse: 'Non', premierImpression: 'Page d\'accueil premium avec grand visuel photo et logo dore. Chargement 5-8s sur mobile. Style "premium dore" plait. Cherche immediatement menu "Tarifs". Absent.', positifs: ['Portfolio visuellement fort, photos couple de qualite', 'Design coherent premium, couleur or', 'Formulaire contact present dans la page service'], frictions: ['Aucun tarif = impossible de comparer avec ses 4 autres onglets', 'Pas d\'avis clients = pas de preuve sociale', 'Pas de page "A propos" = ne sait pas qui est Sebastien', 'Site lent 5-8s mobile', 'Fautes dans la meta description Google = premier contact rate'], raisonDecision: 'Sans prix, ne peut pas valider la compatibilite budgetaire. Le concurrent qui affiche "a partir de 150€" gagne.', impactTech: 'LCP 5-8s mobile frustrant pour une infirmiere qui consulte entre deux taches. Fautes meta Google = doute plante avant meme d\'ouvrir le site.' },
  { id: 2, name: 'Thomas', age: 38, role: 'Cadre commercial, Antony (3km)', canal: 'Google Maps', maturite: 'Decision', device: 'Mobile', decision: 'Hesite', exp: 5, conf: 6, clarte: 4, emoji: '📱', situation: 'Cherche photographe pour anniversaire mariage dans 3 semaines, Antony', parcours: ['Google Maps', 'Seance Couple', 'Seance Famille', 'Formulaire'], questionCle: 'Disponible dans 3 semaines pour seance famille/couple a Antony ?', reponse: 'Non', premierImpression: 'Arrive depuis Google Maps, deja partiellement convaincu. Chargement lent mais mode decision = patience. Cherche immediatement numero telephone ou bouton Contact.', positifs: ['Fiche Google Maps avait rassuré en amont', 'Page Seance Famille existe avec portfolio adapte', 'Formulaire integre dans les pages service'], frictions: ['Aucun telephone = impossible d\'appeler pour verifier disponibilites', 'Pas de calendrier ni mention delai de reponse', 'Page /contact en 404', 'Urgence 3 semaines vs processus formulaire trop long'], raisonDecision: 'Motivation forte mais impossibilite de contacter directement par telephone cree une tension reelle face a l\'urgence.', impactTech: 'LCP 5-8s. Recharge deux fois en pensant que sa connexion est mauvaise. Page /contact 404 = signal negatif.' },
  { id: 3, name: 'Celine', age: 28, role: 'Graphiste freelance, Paris 14e', canal: 'Instagram', maturite: 'Decouverte', device: 'Mobile', decision: 'Quitte', exp: 3, conf: 4, clarte: 2, emoji: '🎨', situation: 'Veut un tableau urbain pour son nouvel appart, arrive depuis un post Instagram', parcours: ['Boutique', 'Fiche produit tableau', 'Frustration', 'Etsy'], questionCle: 'C\'est combien ce tableau en 50x70 ? Livraison en combien de jours ?', reponse: 'Non', premierImpression: 'Graphiste = juge immediatement la qualite visuelle. Design or coherent avec l\'esthetique Instagram. Impressionnee. Cherche les prix immediatement.', positifs: ['Visuels tableaux de grande qualite', 'Theme urbain Paris/Bruxelles coherent et differenciateur', 'Design global coherent avec l\'esthetique Instagram'], frictions: ['Prix absents en boutique = dealbreaker e-commerce absolu', 'Formats et dimensions non listes', 'Delais livraison absents', 'Pas d\'avis produits, pas de politique retour', 'Chargement lent images produit'], raisonDecision: 'En e-commerce, absence de prix = erreur fondamentale. Repart vers Etsy ou Society6 ou tout est transparent.', impactTech: 'WooCommerce + images 2560px non optimisees = chargement pages produit tres lent. Signal de manque de pro technique pour une graphiste.' },
