                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 mb-0.5 flex-wrap">
                        <h4 class="font-semibold text-neutral-900 text-sm">{p.name}, {p.age} ans</h4>
                        <span class="text-[11px] text-blue-600 bg-blue-50 px-1.5 py-0.5 rounded">{p.canal}</span>
                        <span class="text-[11px] text-neutral-500 bg-neutral-100 px-1.5 py-0.5 rounded">{p.device}</span>
                      </div>
                      <p class="text-xs text-neutral-500 mb-2">{p.role}</p>
                      <div class="flex flex-wrap items-center gap-1">
                        {p.parcours.map((page, i) => (
                          <>
                            <span class="text-[10px] text-primary-700 bg-white border border-primary-100 px-1.5 py-0.5 rounded">{page}</span>
                            {i < p.parcours.length - 1 && <span class="text-neutral-300 text-[10px]">›</span>}
                          </>
                        ))}
                        <span class="text-[10px] bg-neutral-500 text-white px-1.5 py-0.5 rounded font-medium ml-0.5">Repart</span>
                      </div>
                    </div>
                    <svg class="w-5 h-5 text-neutral-400 shrink-0 mt-1 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="px-4 pb-4 pt-0 border-t border-neutral-200 bg-white/50">
                    <div class="grid gap-3 text-xs mt-3">
                      <div><p class="font-semibold text-neutral-700 mb-1">Premiere impression</p><p class="text-neutral-600">{p.premierImpression}</p></div>
                      <div><p class="font-semibold text-neutral-700 mb-1">Question cle</p><p class="text-neutral-600 italic">"{p.questionCle}"</p><p class="text-neutral-600 mt-1">Reponse du site : <strong>{p.reponse}</strong></p></div>
                      <div><p class="font-semibold text-neutral-700 mb-1">Impact technique</p><p class="text-neutral-600">{p.impactTech}</p></div>
                      <div class="flex gap-4">
                        <div class="flex-1"><p class="font-semibold text-green-700 mb-1">Points positifs</p><ul class="list-disc list-inside text-neutral-600 space-y-0.5">{p.positifs.map(pt => <li>{pt}</li>)}</ul></div>
                        <div class="flex-1"><p class="font-semibold text-red-700 mb-1">Frictions</p><ul class="list-disc list-inside text-neutral-600 space-y-0.5">{p.frictions.map(f => <li>{f}</li>)}</ul></div>
                      </div>
                      <div><p class="font-semibold text-neutral-700 mb-1">Ce qui aurait pu le retenir</p><p class="text-neutral-600">{p.raisonDecision}</p></div>
                      <div class="flex gap-6 pt-2 border-t border-neutral-200">
                        <div class="text-center"><span class="block text-lg font-bold text-red-500">{p.exp}</span><span class="text-[10px] text-neutral-500">Experience</span></div>
                        <div class="text-center"><span class="block text-lg font-bold text-red-500">{p.conf}</span><span class="text-[10px] text-neutral-500">Confiance</span></div>
                        <div class="text-center"><span class="block text-lg font-bold text-red-500">{p.clarte}</span><span class="text-[10px] text-neutral-500">Clarte</span></div>
                      </div>
                    </div>
                  </div>
                </details>
              ))}
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ═══ PANEL 4 : AMELIORATIONS ═══ -->
    <section class="tab-panel min-w-full w-full snap-start snap-always shrink-0">
      <div class="w-full px-6 py-12 md:px-8 md:py-16 bg-[var(--color-bg)]">
        <div class="mx-auto max-w-5xl">

          <!-- Frictions -->
          <div class="mb-10">
            <h2 class="text-2xl font-bold text-[var(--color-text)] mb-2">Points de friction identifies</h2>
            <p class="text-[var(--color-text-muted)] mb-6">Classes par nombre de personas impactes, sur 20 visites simulees.</p>
            <div class="space-y-3">
              {frictions.map((f) => (
                <div class="flex items-center gap-3 rounded-xl border border-[var(--color-border)] bg-white px-4 py-3">
                  <span class={`text-xs px-2 py-1 rounded font-semibold shrink-0 ${severityColor(f.severity)}`}>{f.severity}</span>
                  <p class="text-sm text-neutral-700 flex-1">{f.label}</p>
                  <span class="text-sm font-bold text-neutral-500 shrink-0">{f.count}/20</span>
                </div>
              ))}
            </div>
          </div>

          <!-- Le plus important -->
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">Le plus important</h2>
          <div class="space-y-4 mb-10">
            {amelioHaute.map((a) => (
              <div class="bg-white border-2 border-red-200 rounded-xl p-5 shadow-sm">
                <div class="flex items-start justify-between gap-3 mb-2">
                  <h4 class="font-semibold text-neutral-900">{a.title}</h4>
                  <span class="text-xs text-red-700 bg-red-50 border border-red-200 px-2 py-1 rounded shrink-0">{a.impact}</span>
                </div>
                <p class="text-sm text-neutral-600 mb-3">{a.detail}</p>
              </div>
            ))}
          </div>

          <!-- Utile aussi -->
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">Utile aussi</h2>
          <div class="grid md:grid-cols-2 gap-4 mb-10">
            {amelioMoyenne.map((a) => (
              <div class="bg-white border border-neutral-200 rounded-xl p-4">
                <div class="flex items-start justify-between gap-2 mb-1.5">
                  <h4 class="font-semibold text-neutral-900 text-sm">{a.title}</h4>
                  <span class="text-xs text-neutral-500 shrink-0">{a.impact}</span>
                </div>
                <p class="text-xs text-neutral-600">{a.detail}</p>
              </div>
            ))}
          </div>

          <!-- A discuter -->
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">A discuter ensemble</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {amelioDiscuter.map((a) => (
              <div class="bg-neutral-50 border border-neutral-200 rounded-xl p-4 flex gap-3">
                <span class="text-lg shrink-0">{a.emoji}</span>
                <div>
                  <h4 class="font-semibold text-neutral-900 text-sm mb-0.5">{a.title}</h4>
                  <p class="text-xs text-neutral-600">{a.detail}</p>
                </div>
              </div>
            ))}
          </div>

        </div>
      </div>

      <!-- Methodologie -->
      <div class="w-full px-6 py-12 md:px-8 bg-white">
        <div class="mx-auto max-w-5xl">
          <h2 class="text-2xl font-bold text-[var(--color-text)] mb-6">Methodologie</h2>
          <ol class="list-decimal list-inside space-y-2 text-sm text-neutral-600">
            <li>Scraping complet du site (21 pages identifiees via sitemap, contenu extrait)</li>
            <li>Audit technique : analyse HTML directe (Python), tentative API PageSpeed (quota epuise), en-tetes HTTP via curl</li>
            <li>Creation de 20 personas diversifies (7 canaux, 3 niveaux de maturite, 3 types de device)</li>
            <li>Simulation de 20 visites par 4 agents IA en parallele (lots de 5 personas)</li>
            <li>Agregation des resultats : taux de conversion, scores UX, frictions recurrentes, ameliorations priorisees</li>
          </ol>
        </div>
      </div>

      <!-- CTA -->
      <section class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
        <h2 class="font-heading text-2xl md:text-3xl font-bold text-neutral-900 mb-4">
          Pret a transformer ces insights en resultats ?
        </h2>
        <p class="text-neutral-600 mb-8 max-w-xl mx-auto">
          Ce rapport identifie des opportunites concretes. Je peux construire un site qui convertit vraiment vos visiteurs en clients.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/commander" class="inline-flex items-center gap-2 px-8 py-3.5 bg-[var(--color-accent)] text-white font-semibold rounded-xl hover:bg-[var(--color-accent-hover)] transition-all shadow-md">
            Commander un site
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
          </a>
          <a href="/contact" class="inline-flex items-center gap-2 px-8 py-3.5 border border-neutral-300 text-neutral-700 font-semibold rounded-xl hover:border-[var(--color-accent)] hover:text-[var(--color-accent)] transition-all">
            En discuter d'abord
          </a>
        </div>
      </section>

    </section>

  </div>

  <style is:inline>
    #panels { -ms-overflow-style: none; }
    #panels::-webkit-scrollbar { display: none; }
  </style>

  <script is:inline>
    const panels = document.getElementById('panels');
    const tabs = document.querySelectorAll('.tab-btn');
    const sections = panels ? panels.querySelectorAll('.tab-panel') : [];

    function activateTab(index) {
      tabs.forEach((b, i) => {
        if (i === index) {
          b.classList.remove('text-neutral-500');
          b.classList.add('text-primary-700', 'bg-primary-50');
        } else {
          b.classList.remove('text-primary-700', 'bg-primary-50');
          b.classList.add('text-neutral-500');
        }
      });
    }

    tabs.forEach((btn, i) => {
      btn.addEventListener('click', () => {
        if (sections[i]) sections[i].scrollIntoView({ behavior: 'smooth', inline: 'start', block: 'nearest' });
        activateTab(i);
      });
    });

    let scrollTimeout;
    if (panels) {
      panels.addEventListener('scroll', () => {
        clearTimeout(scrollTimeout);
        scrollTimeout = setTimeout(() => {
          const index = Math.round(panels.scrollLeft / panels.offsetWidth);
          activateTab(index);
        }, 50);
      }, { passive: true });
    }
  </script>

</BaseLayout>
