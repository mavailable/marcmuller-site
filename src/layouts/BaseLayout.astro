---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileCallButton from '../components/MobileCallButton.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  noHeader?: boolean;
  lang?: 'fr' | 'en';
  frPath?: string; // e.g. '/', '/realisations'
  enPath?: string; // e.g. '/en/', '/en/portfolio'
}

const {
  title,
  description,
  ogImage = '/og-default.png',
  ogType = 'website',
  noindex = false,
  noHeader = false,
  lang = 'fr',
  frPath,
  enPath,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).href;
const ogLocale = lang === 'en' ? 'en_US' : 'fr_FR';

const frURL = frPath ? new URL(frPath, Astro.site).href : null;
const enURL = enPath ? new URL(enPath, Astro.site).href : null;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content={business.owner} />
    <meta name="theme-color" content="#E86C47" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- OG Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={business.name} />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@marcmuller_dev" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Canonical URL & Favicon -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Font preload for faster First Contentful Paint -->
    <link rel="preload" as="font" href="/fonts/Satoshi-Variable.woff2" type="font/woff2" crossorigin />
    <link rel="preload" as="font" href="/fonts/Satoshi-VariableItalic.woff2" type="font/woff2" crossorigin />

    <!-- Hreflang alternate links -->
    {frURL && <link rel="alternate" hreflang="fr" href={frURL} />}
    {enURL && <link rel="alternate" hreflang="en" href={enURL} />}
    {frURL && <link rel="alternate" hreflang="x-default" href={frURL} />}

    <title>{title}</title>

    <!-- Schema.org WebSite (global) -->
    <SchemaOrg type="webSite" />

    <!-- Umami Analytics (self-hosted for CSP/SRI compliance) -->
    <script is:inline defer src="/scripts/umami.js" data-website-id="0e4930eb-681d-4c89-94f2-5abfcf564383" data-host-url="https://cloud.umami.is"></script>
  </head>
  <body>
    <a href="#main" class="skip-link">
      {lang === 'en' ? 'Skip to main content' : 'Aller au contenu principal'}
    </a>
    {!noHeader && <Header lang={lang} frPath={frPath} enPath={enPath} />}
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <MobileCallButton />
  </body>
</html>
