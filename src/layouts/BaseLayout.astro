---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
  noHeader?: boolean;
}

const { title, description, ogImage = '/og-default.png', noindex = false, noHeader = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang={business.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#E86C47" />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- OG Meta Tags -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content={business.name} />

    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />

    <!-- Canonical URL & Favicon -->
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/site.webmanifest" />

    <title>{title}</title>

    <!-- Schema.org WebSite (global) -->
    <SchemaOrg type="webSite" />

    <!-- Cloudflare Web Analytics (uncomment to enable) -->
    <!-- <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "YOUR_CF_TOKEN"}'></script> -->
  </head>
  <body>
    <a href="#main" class="skip-link">
      Aller au contenu principal
    </a>
    {!noHeader && <Header />}
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
