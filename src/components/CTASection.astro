---
interface Props {
  title: string;
  text: string;
  buttonText: string;
  buttonLink: string;
  variant?: 'default' | 'dark' | 'accent';
  reassurance?: string;
}

const {
  title,
  text,
  buttonText,
  buttonLink,
  variant = 'default',
  reassurance,
} = Astro.props;

const variantStyles = {
  default: {
    bg: 'bg-[var(--color-bg-alt)]',
    text: 'text-[var(--color-text)]',
    subtext: 'text-[var(--color-text-muted)]',
    button: 'bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-hover)]',
    pattern: 'opacity-5',
  },
  dark: {
    bg: 'bg-[var(--color-bg-dark)]',
    text: 'text-white',
    subtext: 'text-gray-400',
    button: 'bg-[var(--color-accent)] text-white hover:bg-[var(--color-accent-hover)]',
    pattern: 'opacity-10',
  },
  accent: {
    bg: 'bg-[var(--color-accent)]',
    text: 'text-white',
    subtext: 'text-white/80',
    button: 'bg-white text-[var(--color-accent)] hover:bg-gray-100',
    pattern: 'opacity-5',
  },
};

const styles = variantStyles[variant];
---

<section class={`relative w-full py-20 md:py-32 ${styles.bg} overflow-hidden`}>
  <!-- Subtle decorative pattern background -->
  <div class={`absolute inset-0 ${styles.pattern} pointer-events-none`}>
    <svg class="h-full w-full" viewBox="0 0 100 100" preserveAspectRatio="none">
      <defs>
        <pattern id="dots-pattern" x="0" y="0" width="20" height="20" patternUnits="userSpaceOnUse">
          <circle cx="10" cy="10" r="1.5" fill="currentColor" />
        </pattern>
      </defs>
      <rect width="100" height="100" fill="url(#dots-pattern)" />
    </svg>
  </div>

  <div class="relative mx-auto max-w-3xl px-6 text-center md:px-8">
    <h2 class={`mb-6 text-4xl font-bold md:text-5xl ${styles.text}`}>
      {title}
    </h2>
    <p class={`mb-10 text-lg md:text-xl ${styles.subtext}`}>
      {text}
    </p>
    <div class="flex flex-col items-center gap-3">
      <a
        href={buttonLink}
        class={`inline-flex items-center justify-center gap-2 rounded-lg px-10 py-4 font-semibold transition-all duration-300 shadow-lg hover:shadow-xl hover:scale-105 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white ${styles.button}`}
      >
        {buttonText}
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      {reassurance && (
        <p class={`text-xs font-medium ${variant === 'accent' ? 'text-white/80' : 'text-[var(--color-text-light)]'}`}>
          {reassurance}
        </p>
      )}
    </div>
  </div>
</section>
