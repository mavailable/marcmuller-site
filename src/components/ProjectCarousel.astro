---
/**
 * Carousel horizontal de projets, réutilisable sur toutes les pages.
 *
 * Usage :
 *   <ProjectCarousel carouselId="graphistes" />
 *   <ProjectCarousel carouselId="100-sites" title="Déjà en ligne" subtitle="Des exemples concrets." ctaHref="/realisations" ctaLabel="Tout voir" />
 */
import { getProjectsForCarousel } from '../data/projects';

interface Props {
  /** Identifiant du carousel (doit correspondre à un tag dans projects.ts) */
  carouselId: string;
  /** Surtitre affiché au-dessus du titre (ex: "Déjà en ligne") */
  label?: string;
  /** Titre de la section */
  title?: string;
  /** Lien CTA à droite du titre */
  ctaHref?: string;
  /** Texte du lien CTA */
  ctaLabel?: string;
}

const {
  carouselId,
  label = 'Déjà en ligne',
  title = 'Des exemples concrets.',
  ctaHref = '/realisations',
  ctaLabel = 'Tout voir',
} = Astro.props;

const items = getProjectsForCarousel(carouselId);
---

{items.length > 0 && (
  <section class="w-full py-14 md:py-16" style="background:#F7F5F2;">
    <div class="mx-auto max-w-5xl px-6 md:px-8">
      <div class="mb-8 flex items-baseline justify-between">
        <div>
          <p class="text-xs uppercase tracking-widest font-semibold mb-1.5" style="color:#E86C47;">{label}</p>
          <h2 class="text-xl font-bold" style="color:#1A1A1A; letter-spacing:-0.02em;">{title}</h2>
        </div>
        {ctaHref && (
          <a href={ctaHref} class="hidden sm:inline-flex items-center gap-1.5 text-xs font-medium transition-colors hover:text-[#E86C47]" style="color:#BBB;">
            {ctaLabel}
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        )}
      </div>
    </div>

    <div class="overflow-x-auto pb-4 gallery-scroll" style="cursor:grab;">
      <div class="flex gap-4 px-6 md:px-8" style="width:max-content;">
        {items.map(p => (
          <a href={p.url} target="_blank" rel="noopener noreferrer"
            class="group block rounded-2xl overflow-hidden flex-shrink-0 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl"
            style="width: calc((100vw - 3rem) / 1.1); max-width:340px; background:white; border:1px solid #E8E4E0; box-shadow:0 2px 8px rgba(0,0,0,0.06);"
          >
            <div class="relative overflow-hidden" style="aspect-ratio:16/9;">
              <div class="absolute inset-0" style={`background: linear-gradient(135deg, ${p.gradientFrom}, ${p.gradientTo});`}></div>
              <img src={p.screenshot} alt={`Site web ${p.title}`}
                width="340" height="191"
                class="absolute inset-0 w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-105"
                loading="lazy" />
              <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background:rgba(0,0,0,0.4);">
                <span class="flex items-center gap-2 rounded-lg px-4 py-2 text-xs font-semibold text-white" style="background:rgba(255,255,255,0.15); backdrop-filter:blur(4px); border:1px solid rgba(255,255,255,0.2);">
                  Voir le site
                  <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                </span>
              </div>
            </div>
            <div class="px-5 py-4">
              <p class="text-sm font-semibold mb-1" style="color:#1A1A1A;">{p.title}</p>
              <span class="inline-block rounded-full px-2.5 py-0.5 text-xs font-medium" style={`background: ${p.sectorColor.includes('border-') ? '#E86C4718' : p.sectorColor + '18'}; color: #E86C47;`}>{p.sector}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
