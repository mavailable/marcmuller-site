---
import BaseLayout from '@layouts/BaseLayout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

interface Section {
  title: string;
  content: string;
}

interface FAQ {
  question: string;
  answer: string;
}

export interface Props {
  title: string;
  description: string;
  ville: string;
  intro: string;
  sections: Section[];
  faq: FAQ[];
  pricingExpress?: { title: string; price: string; features: string[] };
  pricingCustom?: { title: string; price: string; features: string[] };
  geo: { lat: number; lon: number };
  areaServed: string[];
  ctaTitle: string;
  ctaText: string;
  ctaButton: string;
}

const {
  title,
  description,
  ville,
  intro,
  sections,
  faq,
  pricingExpress = {
    title: 'Essentiel',
    price: '490€',
    features: [
      '✓ 5 pages, design custom',
      '✓ Formulaire de contact',
      '✓ Optimisé Google local',
      '✓ Mobile-first',
      '✓ Performance garantie'
    ]
  },
  pricingCustom = {
    title: 'Site Sur mesure',
    price: 'À partir de 1 490€',
    features: [
      '✓ 7-10 pages custom',
      '✓ Galerie ou blog',
      '✓ Animations subtiles',
      '✓ Optimisé IA (ChatGPT, Claude)',
      '✓ Maintenance 3 mois incluse'
    ]
  },
  geo,
  areaServed,
  ctaTitle,
  ctaText,
  ctaButton
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteUrl = Astro.site?.toString().replace(/\/$/, '');

// LocalBusiness Schema JSON-LD
const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Marc Muller - Création de sites web",
  "description": `Création de sites web sur mesure à ${ville}. Sites custom, rapides, bien référencés.`,
  "url": siteUrl,
  "telephone": "",
  "email": "marc@muller.im",
  "founder": {
    "@type": "Person",
    "name": "Marc Muller",
    "jobTitle": "Créateur de sites web"
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": ville,
    "addressCountry": "FR"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": geo.lat,
    "longitude": geo.lon
  },
  "areaServed": areaServed.map(area => ({
    "@type": "City",
    "name": area
  })),
  "priceRange": "490€ - 1490€+",
  "currenciesAccepted": "EUR",
  "paymentAccepted": "Virement, Chèque",
  "image": `${siteUrl}/og-default.jpg`,
  "logo": `${siteUrl}/assets/logos/logo.webp`
};

// FAQPage Schema JSON-LD
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<BaseLayout title={title} description={description}>
  <Header />

  <main class="min-h-screen">
    <!-- Hero Section -->
    <section class="relative bg-gradient-to-b from-[var(--color-text)] via-[var(--color-bg-alt)] to-[var(--color-text)] py-16 md:py-24">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h1 class="text-4xl md:text-5xl font-bold text-[var(--color-accent)] mb-6 leading-tight">
          Création de site web sur mesure à {ville}
        </h1>
        <div class="prose prose-invert max-w-none text-[var(--color-text-muted)] text-lg leading-relaxed">
          <p>{intro}</p>
        </div>
      </div>
    </section>

    <!-- Dynamic Sections -->
    <section class="py-16 md:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        {sections.map((section, idx) => (
          <div key={idx} class={idx > 0 ? "mt-16 md:mt-20" : ""}>
            <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-6">
              {section.title}
            </h2>
            <div class="prose prose-lg max-w-none text-[var(--color-text-muted)] leading-relaxed">
              <p>{section.content}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Pricing Section -->
    <section class="py-16 md:py-20 bg-[var(--color-bg-alt)]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-accent)] mb-12 text-center">
          Les trois offres pour {ville}
        </h2>

        <div class="grid md:grid-cols-2 gap-8">
          <!-- Express Offer -->
          <div class="bg-white p-8 rounded-lg border-l-4 border-[var(--color-accent)]">
            <h3 class="text-2xl font-bold text-[var(--color-accent)] mb-2">
              {pricingExpress.title}
            </h3>
            <p class="text-3xl font-bold text-[var(--color-text)] mb-6">{pricingExpress.price}</p>
            <ul class="space-y-3 mb-6">
              {pricingExpress.features.map(feature => (
                <li key={feature} class="text-[var(--color-text)] text-sm">
                  {feature}
                </li>
              ))}
            </ul>
            <p class="text-sm text-[var(--color-text-muted)]">
              Délai : 5-7 jours
            </p>
          </div>

          <!-- Custom Offer -->
          <div class="bg-[var(--color-accent)] p-8 rounded-lg border-l-4 border-[var(--color-accent)]">
            <h3 class="text-2xl font-bold text-white mb-2">
              {pricingCustom.title}
            </h3>
            <p class="text-3xl font-bold text-white mb-6">{pricingCustom.price}</p>
            <ul class="space-y-3 mb-6">
              {pricingCustom.features.map(feature => (
                <li key={feature} class="text-white text-sm">
                  {feature}
                </li>
              ))}
            </ul>
            <p class="text-sm text-white opacity-90">
              Délai : 2-3 semaines
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-16 md:py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-text)] mb-12">
          Questions fréquentes
        </h2>

        <div class="space-y-4">
          {faq.map((item, idx) => (
            <details key={idx} class="group border border-[var(--color-accent)] rounded-lg p-6 cursor-pointer hover:bg-[var(--color-bg)] transition-colors">
              <summary class="flex justify-between items-center font-semibold text-[var(--color-text)] text-lg">
                {item.question}
                <span class="transform group-open:rotate-180 transition-transform">
                  <svg class="w-6 h-6 text-[var(--color-accent)]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
                  </svg>
                </span>
              </summary>
              <p class="mt-4 text-[var(--color-text-muted)] leading-relaxed">
                {item.answer}
              </p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-20 bg-gradient-to-b from-[var(--color-text)] to-[var(--color-bg-alt)]">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-[var(--color-accent)] mb-6">
          {ctaTitle}
        </h2>
        <p class="text-lg text-white mb-8 leading-relaxed">
          {ctaText}
        </p>
        <a
          href="/contact"
          class="inline-block bg-[var(--color-accent)] text-white px-8 py-4 rounded-lg font-bold text-lg hover:bg-[var(--color-accent-hover)] transition-colors"
        >
          {ctaButton}
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <!-- JSON-LD Schema Scripts -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</BaseLayout>
