---
// Header component with signature logo, navigation with underline animation,
// CTA button with micro-animation, smooth scroll background transition, and animated mobile menu

interface Props {
  lang?: 'fr' | 'en';
  frPath?: string;
  enPath?: string;
}

import { business } from '@data/business';

const { lang = 'fr', frPath, enPath } = Astro.props;

// Format phone for display: +33 6 88 77 66 48
const phoneRaw = business.phone;
const phoneDisplay = phoneRaw.replace(/(\+33)(\d)(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5 $6');

const nav = lang === 'en'
  ? [
      { href: '/en/portfolio', label: 'Portfolio', aria: 'View my work', event: 'nav-portfolio' },
      { href: '/en/services', label: 'Services', aria: 'Discover my services', event: 'nav-services' },
      { href: '/en/blog', label: 'Blog', aria: 'Read my blog', event: 'nav-blog' },
      { href: '/en/about', label: 'About', aria: 'About Marc', event: 'nav-about' },
    ]
  : [
      { href: '/realisations', label: 'Réalisations', aria: 'Voir mes réalisations', event: 'nav-realisations' },
      { href: '/offre', label: 'Offre', aria: 'Découvrir mon offre', event: 'nav-offre' },
      { href: '/journal', label: 'Journal', aria: 'Lire mon journal', event: 'nav-journal' },
      { href: '/qui-suis-je', label: 'Qui suis-je', aria: 'En savoir plus sur Marc', event: 'nav-qui-suis-je' },
    ];

const ctaLabel = lang === 'en' ? 'Order — €490' : 'Commander — 490€';
const ctaHref = lang === 'en' ? '/en/contact' : '/commander';
// Language switcher URLs
const switchToFR = frPath ?? '/';
const switchToEN = enPath ?? '/en/';
---

<header
  class="sticky top-0 z-50 w-full transition-all duration-300 header"
  data-scroll="false"
>
  <!-- Background blur effect on scroll -->
  <div
    class="absolute inset-0 bg-[var(--color-bg)] opacity-0 transition-opacity duration-300 backdrop-blur-md header-bg"
  ></div>

  <nav class="relative mx-auto flex max-w-7xl items-center justify-between px-6 py-4 md:px-8">
    <!-- Logo with signature style -->
    <a href={lang === 'en' ? '/en/' : '/'} class="group relative flex items-center gap-2">
      <span class="text-2xl font-bold text-[var(--color-text)]">Marc M</span>
      <span class="absolute bottom-0 left-0 h-1 w-0 bg-[var(--color-accent)] transition-all duration-300 group-hover:w-full"></span>
    </a>

    <!-- Desktop Navigation with underline animation -->
    <div class="hidden items-center gap-8 md:flex">
      {nav.map(({ href, label, aria, event }) => (
        <a
          href={href}
          class="relative text-sm font-medium text-[var(--color-text)] transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-[var(--color-accent)] after:transition-all after:duration-300 hover:text-[var(--color-accent)] hover:after:w-full"
          aria-label={aria}
          data-umami-event={event}
        >
          {label}
        </a>
      ))}
      <!-- Language Switcher -->
      <div class="flex items-center gap-1 rounded-full border border-neutral-700 bg-neutral-800/50 px-1 py-0.5 text-xs font-semibold">
        <a
          href={switchToFR}
          class={`rounded-full px-2 py-0.5 transition-all duration-200 ${lang === 'fr' ? 'bg-[var(--color-accent)] text-white' : 'text-neutral-400 hover:text-neutral-200'}`}
          aria-label="Version française"
          hreflang="fr"
          data-umami-event="lang-switch-fr"
        >FR</a>
        <a
          href={switchToEN}
          class={`rounded-full px-2 py-0.5 transition-all duration-200 ${lang === 'en' ? 'bg-[var(--color-accent)] text-white' : 'text-neutral-400 hover:text-neutral-200'}`}
          aria-label="English version"
          hreflang="en"
          data-umami-event="lang-switch-en"
        >EN</a>
      </div>
    </div>

    <!-- Phone + CTA (Desktop) -->
    <div class="hidden items-center gap-4 md:flex">
      <a
        href={`tel:${phoneRaw}`}
        class="flex items-center gap-1.5 text-sm text-neutral-400 transition-colors duration-300 hover:text-[var(--color-accent)]"
        aria-label={lang === 'en' ? 'Call Marc' : 'Appeler Marc'}
        data-umami-event="nav-phone-click"
      >
        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        <span>{phoneDisplay}</span>
      </a>
      <a
        href={ctaHref}
        class="rounded-lg bg-[var(--color-accent)] px-6 py-2.5 text-sm font-medium text-white transition-all duration-300 shadow-md hover:shadow-lg hover:scale-105 hover:bg-[var(--color-accent-hover)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
        aria-label={lang === 'en' ? 'Go to contact' : 'Accéder à la section contact'}
        data-umami-event="nav-cta-commander"
      >
        {ctaLabel}
      </a>
    </div>

    <!-- Mobile Hamburger Button -->
    <button
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg hover:bg-[var(--color-bg-alt)] transition-colors hamburger-btn focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      aria-label="Ouvrir le menu de navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        class="w-6 h-6 hamburger-icon transition-all duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        class="w-6 h-6 hamburger-close absolute hidden transition-all duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
        aria-hidden="true"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Navigation Panel — fullscreen dark overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-0 z-40 hidden flex-col md:hidden mobile-menu opacity-0 transition-opacity duration-300 ease-out"
    style="background: rgba(13, 13, 13, 0.97); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);"
  >
    <!-- Top bar — logo + close aligned with header -->
    <div class="flex items-center justify-between px-6 py-4">
      <a href={lang === 'en' ? '/en/' : '/'} class="text-2xl font-bold text-white">Marc M</a>
      <button
        class="mobile-close-btn flex items-center justify-center w-10 h-10 rounded-lg text-neutral-400 hover:text-white hover:bg-white/10 transition-colors"
        aria-label="Fermer le menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Navigation links — large, centered, spaced -->
    <div class="flex flex-1 flex-col justify-center px-8 -mt-12">
      <nav class="flex flex-col gap-2">
        {nav.map(({ href, label, event }, i) => (
          <a
            href={href}
            class="mobile-nav-link group flex items-center gap-4 rounded-xl px-4 py-4 text-2xl font-semibold text-white/90 transition-all duration-200 hover:bg-white/[0.06] hover:text-[var(--color-accent)] active:scale-[0.98]"
            style={`transition-delay: ${i * 50}ms;`}
            data-umami-event={event}
          >
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-accent)] opacity-0 group-hover:opacity-100 transition-opacity"></span>
            {label}
          </a>
        ))}
      </nav>

    </div>

    <!-- Bottom section — Phone + CTA + language -->
    <div class="px-8 pb-10 flex flex-col gap-3">
      <!-- Phone -->
      <a
        href={`tel:${phoneRaw}`}
        class="flex items-center justify-center gap-2 rounded-xl border border-white/10 bg-white/[0.04] px-6 py-3.5 text-base font-medium text-white/90 transition-all duration-200 hover:bg-white/[0.08] active:scale-[0.98]"
        data-umami-event="mobile-menu-phone"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
        </svg>
        {phoneDisplay}
      </a>
      <!-- CTA Contact -->
      <a
        href={ctaHref}
        class="flex items-center justify-center gap-2 rounded-xl bg-[var(--color-accent)] px-6 py-4 text-base font-semibold text-white transition-all duration-200 hover:bg-[var(--color-accent-hover)] active:scale-[0.98] shadow-lg shadow-[var(--color-accent)]/20"
        data-umami-event="nav-cta-commander"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path></svg>
        {ctaLabel}
      </a>

      <!-- Language switcher + copyright -->
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-1.5 rounded-full border border-white/10 bg-white/[0.04] px-1.5 py-1 text-sm font-semibold">
          <a
            href={switchToFR}
            class={`rounded-full px-3 py-1 transition-all duration-200 ${lang === 'fr' ? 'bg-[var(--color-accent)] text-white' : 'text-neutral-500 hover:text-neutral-300'}`}
            aria-label="Version française"
            data-umami-event="lang-switch-fr"
          >FR</a>
          <a
            href={switchToEN}
            class={`rounded-full px-3 py-1 transition-all duration-200 ${lang === 'en' ? 'bg-[var(--color-accent)] text-white' : 'text-neutral-500 hover:text-neutral-300'}`}
            aria-label="English version"
            data-umami-event="lang-switch-en"
          >EN</a>
        </div>
        <span class="text-xs text-neutral-600">marcm.fr</span>
      </div>
    </div>
  </div>
</header>

<script>
  const hamburgerBtn = document.querySelector('.hamburger-btn');
  const mobileMenu = document.querySelector('#mobile-menu') as HTMLElement | null;
  const hamburgerIcon = document.querySelector('.hamburger-icon');
  const hamburgerClose = document.querySelector('.hamburger-close');
  const mobileCloseBtn = document.querySelector('.mobile-close-btn');
  const header = document.querySelector('header');
  const headerBg = document.querySelector('.header-bg');

  function openMobileMenu() {
    if (!mobileMenu) return;
    mobileMenu.classList.remove('hidden');
    mobileMenu.classList.add('flex');
    // Trigger reflow then animate in
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        mobileMenu.classList.remove('opacity-0');
        mobileMenu.classList.add('opacity-100');
      });
    });
    hamburgerIcon?.classList.add('hidden');
    hamburgerClose?.classList.remove('hidden');
    hamburgerBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    if (!mobileMenu) return;
    mobileMenu.classList.remove('opacity-100');
    mobileMenu.classList.add('opacity-0');
    setTimeout(() => {
      mobileMenu.classList.add('hidden');
      mobileMenu.classList.remove('flex');
    }, 300);
    hamburgerIcon?.classList.remove('hidden');
    hamburgerClose?.classList.add('hidden');
    hamburgerBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  // Open via hamburger
  hamburgerBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    isHidden ? openMobileMenu() : closeMobileMenu();
  });

  // Close via X button inside menu
  mobileCloseBtn?.addEventListener('click', closeMobileMenu);

  // Close when a link is clicked
  document.querySelectorAll('#mobile-menu a').forEach((link) => {
    link.addEventListener('click', closeMobileMenu);
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !mobileMenu?.classList.contains('hidden')) {
      closeMobileMenu();
    }
  });

  // Sticky header with smooth backdrop blur on scroll
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 10;

    if (scrolled && header?.getAttribute('data-scroll') !== 'true') {
      headerBg?.classList.remove('opacity-0');
      headerBg?.classList.add('opacity-100');
      header?.setAttribute('data-scroll', 'true');
      header?.classList.add('shadow-md');
    } else if (!scrolled && header?.getAttribute('data-scroll') === 'true') {
      headerBg?.classList.add('opacity-0');
      headerBg?.classList.remove('opacity-100');
      header?.setAttribute('data-scroll', 'false');
      header?.classList.remove('shadow-md');
    }
  });
</script>
