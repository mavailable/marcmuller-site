---
// Header component with signature logo, navigation with underline animation,
// CTA button with micro-animation, smooth scroll background transition, and animated mobile menu
---

<header
  class="sticky top-0 z-50 w-full transition-all duration-300 header"
  data-scroll="false"
>
  <!-- Background blur effect on scroll -->
  <div
    class="absolute inset-0 bg-[var(--color-bg)] opacity-0 transition-opacity duration-300 backdrop-blur-md header-bg"
  ></div>

  <nav class="relative mx-auto flex max-w-7xl items-center justify-between px-6 py-4 md:px-8">
    <!-- Logo with signature style -->
    <a href="/" class="group relative flex items-center gap-2">
      <span class="text-2xl font-bold text-[var(--color-text)]">Marc M</span>
      <span class="absolute bottom-0 left-0 h-1 w-0 bg-[var(--color-accent)] transition-all duration-300 group-hover:w-full"></span>
    </a>

    <!-- Desktop Navigation with underline animation -->
    <div class="hidden items-center gap-8 md:flex">
      <a
        href="/realisations"
        class="relative text-sm font-medium text-[var(--color-text)] transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-[var(--color-accent)] after:transition-all after:duration-300 hover:text-[var(--color-accent)] hover:after:w-full"
        aria-label="Voir mes réalisations"
      >
        Réalisations
      </a>
      <a
        href="/offre"
        class="relative text-sm font-medium text-[var(--color-text)] transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-[var(--color-accent)] after:transition-all after:duration-300 hover:text-[var(--color-accent)] hover:after:w-full"
        aria-label="Découvrir mon offre"
      >
        Offre
      </a>
      <a
        href="/journal"
        class="relative text-sm font-medium text-[var(--color-text)] transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-[var(--color-accent)] after:transition-all after:duration-300 hover:text-[var(--color-accent)] hover:after:w-full"
        aria-label="Lire mon journal"
      >
        Journal
      </a>
      <a
        href="/qui-suis-je"
        class="relative text-sm font-medium text-[var(--color-text)] transition-colors duration-300 after:absolute after:bottom-0 after:left-0 after:h-0.5 after:w-0 after:bg-[var(--color-accent)] after:transition-all after:duration-300 hover:text-[var(--color-accent)] hover:after:w-full"
        aria-label="En savoir plus sur Marc"
      >
        Qui suis-je
      </a>
      <a
        href="/100-sites-artisans"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full px-3.5 py-1.5 text-xs font-semibold transition-all duration-300 hover:opacity-90"
        style="background: rgba(232, 108, 71, 0.12); border: 1px solid rgba(232, 108, 71, 0.3); color: #E86C47;"
        aria-label="Initiative 100 Vitrines pour les artisans"
      >
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style="background: #E86C47;"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full" style="background: #E86C47;"></span>
        </span>
        100 Vitrines
      </a>
    </div>

    <!-- CTA Button with micro-animation (Desktop) -->
    <a
      href="/contact"
      class="hidden rounded-lg bg-[var(--color-accent)] px-6 py-2.5 text-sm font-medium text-white transition-all duration-300 shadow-md hover:shadow-lg hover:scale-105 hover:bg-[var(--color-accent-hover)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] md:inline-block"
      aria-label="Accéder à la section contact"
    >
      Contact
    </a>

    <!-- Mobile Hamburger Button -->
    <button
      class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg hover:bg-[var(--color-bg-alt)] transition-colors hamburger-btn focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      aria-label="Ouvrir le menu de navigation"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <svg
        class="w-6 h-6 hamburger-icon transition-all duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg
        class="w-6 h-6 hamburger-close absolute hidden transition-all duration-300"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile Navigation Panel with slide-in animation -->
  <div
    id="mobile-menu"
    class="fixed inset-0 top-[65px] hidden w-full flex-col gap-6 bg-[var(--color-bg)] px-6 py-8 md:hidden mobile-menu transform transition-transform duration-300 ease-out translate-x-full"
  >
    <!-- Dark overlay behind mobile menu -->
    <div class="absolute inset-0 top-[65px] bg-black opacity-0 -z-10 mobile-menu-overlay"></div>

    <a
      href="/realisations"
      class="text-[var(--color-text)] font-medium transition-colors duration-300 hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] rounded-sm"
    >
      Réalisations
    </a>
    <a
      href="/offre"
      class="text-[var(--color-text)] font-medium transition-colors duration-300 hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] rounded-sm"
    >
      Offre
    </a>
    <a
      href="/journal"
      class="text-[var(--color-text)] font-medium transition-colors duration-300 hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] rounded-sm"
    >
      Journal
    </a>
    <a
      href="/qui-suis-je"
      class="text-[var(--color-text)] font-medium transition-colors duration-300 hover:text-[var(--color-accent)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)] rounded-sm"
    >
      Qui suis-je
    </a>
    <a
      href="/100-sites-artisans"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
      style="background: rgba(232, 108, 71, 0.1); border: 1px solid rgba(232, 108, 71, 0.25); color: #E86C47;"
    >
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style="background: #E86C47;"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full" style="background: #E86C47;"></span>
      </span>
      100 Vitrines — Sites gratuits pour artisans
    </a>
    <a
      href="/contact"
      class="mt-4 rounded-lg bg-[var(--color-accent)] px-6 py-2.5 text-center font-medium text-white transition-all duration-300 hover:bg-[var(--color-accent-hover)] hover:shadow-lg focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--color-accent)]"
    >
      Contact
    </a>
  </div>
</header>

<script>
  const hamburgerBtn = document.querySelector('.hamburger-btn');
  const mobileMenu = document.querySelector('#mobile-menu');
  const hamburgerIcon = document.querySelector('.hamburger-icon');
  const hamburgerClose = document.querySelector('.hamburger-close');
  const header = document.querySelector('header');
  const headerBg = document.querySelector('.header-bg');

  // Toggle mobile menu with slide-in animation
  hamburgerBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');

    if (isHidden) {
      mobileMenu?.classList.remove('hidden');
      mobileMenu?.classList.remove('translate-x-full');
      hamburgerIcon?.classList.add('hidden');
      hamburgerClose?.classList.remove('hidden');
      hamburgerBtn?.setAttribute('aria-expanded', 'true');
    } else {
      mobileMenu?.classList.add('translate-x-full');
      // Wait for animation before hiding
      setTimeout(() => {
        mobileMenu?.classList.add('hidden');
      }, 300);
      hamburgerIcon?.classList.remove('hidden');
      hamburgerClose?.classList.add('hidden');
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  // Close menu when a link is clicked
  const mobileLinks = document.querySelectorAll('.mobile-menu a');
  mobileLinks.forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('translate-x-full');
      setTimeout(() => {
        mobileMenu?.classList.add('hidden');
      }, 300);
      hamburgerIcon?.classList.remove('hidden');
      hamburgerClose?.classList.add('hidden');
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Sticky header with smooth backdrop blur on scroll
  window.addEventListener('scroll', () => {
    const scrolled = window.scrollY > 10;

    if (scrolled && header?.getAttribute('data-scroll') !== 'true') {
      headerBg?.classList.remove('opacity-0');
      headerBg?.classList.add('opacity-100');
      header?.setAttribute('data-scroll', 'true');
      header?.classList.add('shadow-md');
    } else if (!scrolled && header?.getAttribute('data-scroll') === 'true') {
      headerBg?.classList.add('opacity-0');
      headerBg?.classList.remove('opacity-100');
      header?.setAttribute('data-scroll', 'false');
      header?.classList.remove('shadow-md');
    }
  });
</script>
