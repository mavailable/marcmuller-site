---
// Footer component with signature accent line, tagline, mini CTA, and inline social icons
import { business } from '../data/business';

interface Props {
  lang?: 'fr' | 'en';
}

const { lang = 'fr' } = Astro.props;
const phoneDisplay = business.phone.replace(/(\+33)(\d)(\d{2})(\d{2})(\d{2})(\d{2})/, '$1 $2 $3 $4 $5 $6');

const nav = lang === 'en'
  ? [
      { href: '/en/portfolio', label: 'Portfolio', event: 'footer-nav-portfolio' },
      { href: '/en/services', label: 'Services', event: 'footer-nav-services' },
      { href: '/en/blog', label: 'Blog', event: 'footer-nav-blog' },
      { href: '/en/about', label: 'About', event: 'footer-nav-about' },
    ]
  : [
      { href: '/realisations', label: 'Réalisations', event: 'footer-nav-realisations' },
      { href: '/offre', label: 'Offre', event: 'footer-nav-offre' },
      { href: '/commander', label: 'Commander', event: 'footer-nav-commander' },
      { href: '/journal', label: 'Journal', event: 'footer-nav-journal' },
      { href: '/qui-suis-je', label: 'Qui suis-je', event: 'footer-nav-qui-suis-je' },
      { href: '/aide', label: 'Aide', event: 'footer-nav-aide' },
    ];

const legalLinks = lang === 'en'
  ? [
      { href: '/en/legal-notice', label: 'Legal Notice' },
      { href: '/en/privacy-policy', label: 'Privacy Policy' },
    ]
  : [
      { href: '/mentions-legales', label: 'Mentions légales' },
      { href: '/politique-confidentialite', label: 'Politique de confidentialité' },
    ];

const ctaText = lang === 'en'
  ? { question: 'Have a web project in mind?', cta: "Let's talk →", href: '/en/contact' }
  : { question: 'Un projet web en tête ?', cta: 'Parlons-en →', href: '/contact' };

const tagline1 = lang === 'en' ? 'I translate your craft into a website.' : 'Je traduis votre métier en site web.';
const tagline2 = lang === 'en'
  ? 'Custom websites for SMEs and craftspeople. No templates, true bespoke work.'
  : 'Sites web sur mesure pour PME et artisans. Pas de template, du vrai sur-mesure.';
const navTitle = lang === 'en' ? 'Navigation' : 'Navigation';
const followTitle = lang === 'en' ? 'Follow me' : 'Suivez-moi';
---

<footer class="relative border-t-[3px] border-[var(--color-accent)] bg-gradient-to-b from-[var(--color-bg-dark)] to-[var(--color-neutral-950)] text-white">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-8">
    <!-- Main Footer Content -->
    <div class="mb-12 grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand & Tagline -->
      <div class="lg:col-span-2">
        <h3 class="mb-2 text-lg font-bold">Marc M</h3>
        <p class="mb-6 text-sm text-neutral-300">
          {tagline1}
        </p>
        <p class="text-sm text-neutral-400">
          {tagline2}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-neutral-300">{navTitle}</h4>
        <div class="flex flex-wrap gap-3">
          {nav.map(({ href, label, event }, i) => (
            <>
              <a
                href={href}
                class="text-sm text-neutral-400 transition-colors duration-300 hover:text-[var(--color-accent)]"
                data-umami-event={event}
              >
                {label}
              </a>
              {i < nav.length - 1 && <span class="text-neutral-600">•</span>}
            </>
          ))}
        </div>
      </div>

      <!-- Social Icons -->
      <div>
        <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-neutral-300">{followTitle}</h4>
        <div class="flex gap-4">
          <!-- LinkedIn Icon -->
          <a
            href="https://www.linkedin.com/in/marcmuller"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Marc M LinkedIn profile"
            class="flex h-8 w-8 items-center justify-center rounded-full bg-neutral-800 text-neutral-300 transition-all duration-300 hover:bg-[var(--color-accent)] hover:text-white"
            data-umami-event="footer-social-linkedin"
          >
            <svg
              class="h-4 w-4"
              fill="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.249-.129.597-.129.946v5.441h-3.554s.05-8.814 0-9.737h3.554v1.38c.43-.664 1.202-1.609 2.923-1.609 2.135 0 3.74 1.395 3.74 4.393v5.573zM5.337 8.855c-1.144 0-1.915-.762-1.915-1.715 0-.951.77-1.715 1.916-1.715.574 0 1.091.19 1.446.545.356.356.545.872.545 1.17 0 .953-.771 1.715-1.992 1.715zm1.446-9.737H3.452V20.45h3.331V7.118z" />
            </svg>
          </a>

        </div>
      </div>
    </div>

    <!-- Mini CTA -->
    <div class="mb-12 rounded-lg bg-neutral-800/50 p-6 backdrop-blur-sm">
      <p class="text-center text-sm text-neutral-300">
        <strong>{ctaText.question}</strong> <a href={ctaText.href} class="text-[var(--color-accent)] hover:underline transition-colors" data-umami-event="footer-cta-click">{ctaText.cta}</a>
      </p>
      <p class="text-center text-xs text-neutral-500 mt-2">
        <a href={`tel:${business.phone}`} class="hover:text-neutral-300 transition-colors" data-umami-event="footer-phone-click">{phoneDisplay}</a>
        <span class="mx-2">·</span>
        <a href="mailto:marc@muller.im" class="hover:text-neutral-300 transition-colors" data-umami-event="footer-email-click">marc@muller.im</a>
      </p>
    </div>

    <!-- Copyright & Legal Links -->
    <div class="border-t border-neutral-700 pt-8">
      <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
        <p class="text-sm text-neutral-400" id="copyright">
          © 2026 Marc M
        </p>
        <div class="flex gap-6">
          {legalLinks.map(({ href, label }) => (
            <a
              href={href}
              class="text-sm text-neutral-400 transition-colors duration-300 hover:text-neutral-200"
            >
              {label}
            </a>
          ))}
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  // Update copyright year dynamically
  const copyrightElement = document.getElementById('copyright');
  if (copyrightElement) {
    const currentYear = new Date().getFullYear();
    copyrightElement.textContent = `© ${currentYear} Marc M`;
  }
</script>
