---
// Footer component with signature accent line, tagline, mini CTA, and inline social icons
---

<footer class="relative border-t-[3px] border-[var(--color-accent)] bg-gradient-to-b from-[var(--color-bg-dark)] to-[#0f0f0f] text-white">
  <div class="mx-auto max-w-7xl px-6 py-16 md:px-8">
    <!-- Main Footer Content -->
    <div class="mb-12 grid grid-cols-1 gap-12 md:grid-cols-2 lg:grid-cols-4">
      <!-- Brand & Tagline -->
      <div class="lg:col-span-2">
        <h3 class="mb-2 text-lg font-bold">MM Agency</h3>
        <p class="mb-6 text-sm text-gray-300">
          Je traduis votre métier en site web.
        </p>
        <p class="text-sm text-gray-400">
          Sites web sur mesure pour PME et artisans. Pas de template, du vrai sur-mesure.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-300">Navigation</h4>
        <div class="flex flex-wrap gap-3">
          <a
            href="/realisations"
            class="text-sm text-gray-400 transition-colors duration-300 hover:text-[var(--color-accent)]"
          >
            Réalisations
          </a>
          <span class="text-gray-600">•</span>
          <a
            href="/offre"
            class="text-sm text-gray-400 transition-colors duration-300 hover:text-[var(--color-accent)]"
          >
            Offre
          </a>
          <span class="text-gray-600">•</span>
          <a
            href="/journal"
            class="text-sm text-gray-400 transition-colors duration-300 hover:text-[var(--color-accent)]"
          >
            Journal
          </a>
          <span class="text-gray-600">•</span>
          <a
            href="/qui-suis-je"
            class="text-sm text-gray-400 transition-colors duration-300 hover:text-[var(--color-accent)]"
          >
            Qui suis-je
          </a>
        </div>
      </div>

      <!-- Social Icons -->
      <div>
        <h4 class="mb-4 text-sm font-semibold uppercase tracking-wider text-gray-300">Suivez-moi</h4>
        <div class="flex gap-4">
          <!-- LinkedIn Icon -->
          <a
            href="https://linkedin.com/in/marcmuller"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Profil LinkedIn de Marc Muller"
            class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-800 text-gray-300 transition-all duration-300 hover:bg-[var(--color-accent)] hover:text-white"
          >
            <svg
              class="h-4 w-4"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.249-.129.597-.129.946v5.441h-3.554s.05-8.814 0-9.737h3.554v1.38c.43-.664 1.202-1.609 2.923-1.609 2.135 0 3.74 1.395 3.74 4.393v5.573zM5.337 8.855c-1.144 0-1.915-.762-1.915-1.715 0-.951.77-1.715 1.916-1.715.574 0 1.091.19 1.446.545.356.356.545.872.545 1.17 0 .953-.771 1.715-1.992 1.715zm1.446-9.737H3.452V20.45h3.331V7.118z" />
            </svg>
          </a>

          <!-- GitHub Icon -->
          <a
            href="https://github.com/marcmuller"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Profil GitHub de Marc Muller"
            class="flex h-8 w-8 items-center justify-center rounded-full bg-gray-800 text-gray-300 transition-all duration-300 hover:bg-[var(--color-accent)] hover:text-white"
          >
            <svg
              class="h-4 w-4"
              fill="currentColor"
              viewBox="0 0 24 24"
            >
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v 3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Mini CTA -->
    <div class="mb-12 rounded-lg bg-gray-800/50 p-6 backdrop-blur-sm">
      <p class="mb-4 text-center text-sm text-gray-300">
        <strong>Un projet web en tête ?</strong> Écrivez-moi directement.
      </p>
      <div class="flex flex-col items-center justify-center gap-3 sm:flex-row">
        <a
          href="mailto:marc@muller.im"
          class="inline-flex items-center gap-2 rounded-lg bg-[var(--color-accent)] px-6 py-2.5 text-sm font-medium text-white transition-all duration-300 hover:bg-[var(--color-accent-hover)] hover:shadow-lg"
        >
          Écrire
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <span class="text-sm text-gray-400">marc@muller.im</span>
      </div>
    </div>

    <!-- Copyright & Legal Links -->
    <div class="border-t border-gray-700 pt-8">
      <div class="flex flex-col items-center justify-between gap-4 md:flex-row">
        <p class="text-sm text-gray-400" id="copyright">
          © 2026 Marc Muller — MM Agency
        </p>
        <div class="flex gap-6">
          <a
            href="/mentions-legales"
            class="text-sm text-gray-400 transition-colors duration-300 hover:text-gray-200"
          >
            Mentions légales
          </a>
          <a
            href="/politique-confidentialite"
            class="text-sm text-gray-400 transition-colors duration-300 hover:text-gray-200"
          >
            Politique de confidentialité
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>

<script>
  // Update copyright year dynamically
  const copyrightElement = document.getElementById('copyright');
  if (copyrightElement) {
    const currentYear = new Date().getFullYear();
    copyrightElement.textContent = `© ${currentYear} Marc Muller — MM Agency`;
  }
</script>
